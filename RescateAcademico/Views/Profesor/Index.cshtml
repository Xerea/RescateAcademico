@model RescateAcademico.Controllers.ProfesorDashboardViewModel
@{
    ViewData["Title"] = "Panel del Profesor";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-person-workspace ra-text-accent me-2"></i>Panel del Profesor</h1>
        <p class="text-secondary small mb-0">
            Bienvenido, <strong>@Model.ProfesorNombre</strong>.
            @(DateTime.Now.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-MX")))
        </p>
    </div>
    <div class="col-auto">
        <a asp-action="MisEstudiantes" class="ra-btn ra-btn-primary">
            <i class="bi bi-people"></i> Ver Todos
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-accent text-center">
            <div class="ra-stat-label">Total Estudiantes</div>
            <div class="ra-stat-value">@Model.TotalEstudiantes</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-success text-center">
            <div class="ra-stat-label">Riesgo Verde</div>
            <div class="ra-stat-value">@Model.EnRiesgoVerde</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-warning text-center">
            <div class="ra-stat-label">Riesgo Amarillo</div>
            <div class="ra-stat-value">@Model.EnRiesgoAmarillo</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-danger text-center">
            <div class="ra-stat-label">Riesgo Rojo</div>
            <div class="ra-stat-value">@Model.EnRiesgoRojo</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-info text-center">
            <div class="ra-stat-label">Promedio General</div>
            <div class="ra-stat-value">@Model.PromedioGeneral.ToString("F1")</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="ra-card h-100">
            <div class="ra-card-header">
                <i class="bi bi-grid-3x3-gap"></i> Mis Grupos
            </div>
            <div class="ra-card-body">
                <div class="row g-3">
                    @foreach (var g in Model.Grupos)
                    {
                        <div class="col-md-6">
                            <a asp-action="MisEstudiantes" asp-route-grupo="@g.Clave" class="text-decoration-none">
                                <div class="ra-card h-100" style="transition: var(--ra-transition);">
                                    <div class="ra-card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="fw-bold mb-0 ra-text-accent">@g.Clave</h5>
                                            <span class="ra-badge ra-badge-neutral">@g.Turno</span>
                                        </div>
                                        <p class="text-secondary small mb-2">@g.Carrera — @g.Semestre° Semestre</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-secondary small"><i class="bi bi-people me-1"></i>@g.TotalAlumnos estudiantes</span>
                                            @if (g.EnRiesgo > 0)
                                            {
                                                <span class="ra-badge ra-badge-danger"><i class="bi bi-exclamation-triangle me-1"></i>@g.EnRiesgo en riesgo</span>
                                            }
                                            else
                                            {
                                                <span class="ra-badge ra-badge-success"><i class="bi bi-check-circle me-1"></i>Sin riesgo</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ra-card h-100">
            <div class="ra-card-header">
                <i class="bi bi-lightning"></i> Acciones Rápidas
            </div>
            <div class="ra-card-body d-flex flex-column gap-2">
                <a asp-action="MisEstudiantes" class="ra-btn ra-btn-primary w-100">
                    <i class="bi bi-people"></i> Todos mis estudiantes
                </a>
                <a asp-action="MateriasReprobadas" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-x-circle"></i> Materias reprobadas
                </a>
                <a asp-controller="Intervenciones" asp-action="Index" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-clipboard-pulse"></i> Ver intervenciones
                </a>
                <a asp-controller="PlanesMejora" asp-action="Index" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-journal-check"></i> Planes de mejora
                </a>
            </div>
        </div>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-people"></i> Estudiantes Recientes</span>
        <a asp-action="MisEstudiantes" class="ra-btn ra-btn-sm ra-btn-ghost">Ver todos <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="ra-card-body p-0">
        <div class="table-responsive">
            <table class="table ra-table mb-0" id="tablaRecientes">
                <thead>
                    <tr>
                        <th>Boleta</th>
                        <th>Nombre</th>
                        <th>Grupo</th>
                        <th>Carrera</th>
                        <th>Promedio</th>
                        <th>Riesgo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Estudiantes)
                    {
                        <tr>
                            <td><strong>@a.Matricula</strong></td>
                            <td>@a.Nombre @a.Apellidos</td>
                            <td>@(a.Grupo?.Clave ?? "—")</td>
                            <td>@a.Carrera</td>
                            <td>
                                <span class="ra-badge @(a.PromedioGlobal >= 8 ? "ra-badge-success" : a.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                    @a.PromedioGlobal.ToString("F2")
                                </span>
                            </td>
                            <td>
                                @if (a.RiesgoAcademico == "Rojo")
                                {
                                    <span class="ra-badge ra-badge-danger">Rojo</span>
                                }
                                else if (a.RiesgoAcademico == "Amarillo")
                                {
                                    <span class="ra-badge ra-badge-warning">Amarillo</span>
                                }
                                else
                                {
                                    <span class="ra-badge ra-badge-success">Verde</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="HistorialAcademico" asp-route-boleta="@a.Matricula" class="ra-btn ra-btn-sm ra-btn-primary" title="Perfil">
                                        <i class="bi bi-graph-up"></i>
                                    </a>
                                    <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@a.Matricula" class="ra-btn ra-btn-sm ra-btn-accent" title="Intervención">
                                        <i class="bi bi-plus-circle"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaRecientes').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 10,
                ordering: false,
                searching: false,
                lengthChange: false,
                info: false
            });
        });
    </script>
}
