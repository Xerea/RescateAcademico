@model RescateAcademico.Controllers.ProfesorDashboardViewModel
@{
    ViewData["Title"] = "Panel del Profesor";
}

<h2><i class="bi bi-person-workspace"></i> Panel del Profesor</h2>
<p class="text-muted">Bienvenido, <strong>@Model.ProfesorNombre</strong>. Resumen de tus grupos asignados.</p>

<div class="row mb-4">
    <div class="col-md-2">
        <div class="card text-white bg-primary border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-people fs-2 mb-2 d-block"></i>
                <h3 class="mb-0">@Model.TotalEstudiantes</h3>
                <small>Total Estudiantes</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-success border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-check-circle fs-2 mb-2 d-block"></i>
                <h3 class="mb-0">@Model.EnRiesgoVerde</h3>
                <small>Riesgo Verde</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-dark bg-warning border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-exclamation-triangle fs-2 mb-2 d-block"></i>
                <h3 class="mb-0">@Model.EnRiesgoAmarillo</h3>
                <small>Riesgo Amarillo</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-danger border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-x-octagon fs-2 mb-2 d-block"></i>
                <h3 class="mb-0">@Model.EnRiesgoRojo</h3>
                <small>Riesgo Rojo</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-info border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-clipboard-pulse fs-2 mb-2 d-block"></i>
                <h3 class="mb-0">@Model.IntervencionesPendientes</h3>
                <small>Seguimientos</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-white bg-secondary border-0 shadow-sm">
            <div class="card-body text-center py-3">
                <i class="bi bi-journal-check fs-2 mb-2 d-block"></i>
                <h3 class="mb-0">@Model.PlanesActivos</h3>
                <small>Planes Activos</small>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header" style="background-color: #6c1d45; color: white;">
                <h5 class="mb-0"><i class="bi bi-grid-3x3-gap"></i> Mis Grupos</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (var g in Model.Grupos)
                    {
                        <div class="col-md-6 mb-3">
                            <a asp-action="MisEstudiantes" asp-route-grupo="@g.Clave" class="text-decoration-none">
                                <div class="card border-0 shadow-sm h-100 hover-shadow" style="transition: transform .2s;">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <h5 class="mb-0" style="color: #6c1d45;">@g.Clave</h5>
                                            <span class="badge bg-dark">@g.Turno</span>
                                        </div>
                                        <p class="text-muted mb-2">@g.Carrera - @g.Semestre° Semestre</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="text-muted"><i class="bi bi-people"></i> @g.TotalAlumnos estudiantes</small>
                                            @if (g.EnRiesgo > 0)
                                            {
                                                <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> @g.EnRiesgo en riesgo</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Sin riesgo</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header" style="background-color: #6c1d45; color: white;">
                <h5 class="mb-0"><i class="bi bi-traffic-light"></i> Semáforo de Riesgo</h5>
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <div style="max-width: 320px; width: 100%;">
                    <canvas id="semaforoChart"></canvas>
                </div>
                <div class="mt-3 d-flex gap-3 justify-content-center">
                    <span class="badge bg-success"><i class="bi bi-circle-fill"></i> Verde @Model.EnRiesgoVerde</span>
                    <span class="badge bg-warning text-dark"><i class="bi bi-circle-fill"></i> Amarillo @Model.EnRiesgoAmarillo</span>
                    <span class="badge bg-danger"><i class="bi bi-circle-fill"></i> Rojo @Model.EnRiesgoRojo</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header" style="background-color: #6c1d45; color: white;">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-people"></i> Estudiantes Recientes</h5>
            <a asp-action="MisEstudiantes" class="btn btn-light btn-sm">Ver todos</a>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Boleta</th>
                    <th>Nombre</th>
                    <th>Grupo</th>
                    <th>Carrera</th>
                    <th>Promedio</th>
                    <th>Riesgo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Estudiantes)
                {
                    <tr>
                        <td><strong>@a.Matricula</strong></td>
                        <td>@a.Nombre @a.Apellidos</td>
                        <td>@(a.Grupo?.Clave ?? "—")</td>
                        <td>@a.Carrera</td>
                        <td>@a.PromedioGlobal.ToString("F2")</td>
                        <td>
                            <span class="badge bg-@(a.RiesgoAcademico == "Rojo" ? "danger" : a.RiesgoAcademico == "Amarillo" ? "warning text-dark" : "success")">
                                @(a.RiesgoAcademico ?? "Verde")
                            </span>
                        </td>
                        <td>
                            <a asp-action="HistorialAcademico" asp-route-boleta="@a.Matricula" class="btn btn-sm btn-outline-info"><i class="bi bi-graph-up"></i> Perfil</a>
                            <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@a.Matricula" class="btn btn-sm btn-outline-warning"><i class="bi bi-plus-circle"></i> Intervención</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('semaforoChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Verde', 'Amarillo', 'Rojo'],
                datasets: [{
                    data: [@Model.EnRiesgoVerde, @Model.EnRiesgoAmarillo, @Model.EnRiesgoRojo],
                    backgroundColor: ['#198754', '#ffc107', '#dc3545'],
                    borderWidth: 3,
                    borderColor: '#ffffff',
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                cutout: '60%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 20,
                            usePointStyle: true,
                            font: { size: 14 }
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const label = context.label || '';
                                const value = context.parsed || 0;
                                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                const pct = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                return label + ': ' + value + ' (' + pct + '%)';
                            }
                        }
                    }
                }
            }
        });
    </script>
    <style>
        .hover-shadow:hover { transform: translateY(-3px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important; }
    </style>
}
