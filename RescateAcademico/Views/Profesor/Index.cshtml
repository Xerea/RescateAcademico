@model RescateAcademico.Controllers.ProfesorDashboardViewModel
@{
    ViewData["Title"] = "Mis Grupos";
    Layout = "_Layout";

    var total = Model.TotalEstudiantes;
    var pctVerde = total > 0 ? (Model.EnRiesgoVerde * 100.0 / total) : 0;
    var pctAmarillo = total > 0 ? (Model.EnRiesgoAmarillo * 100.0 / total) : 0;
    var pctRojo = total > 0 ? (Model.EnRiesgoRojo * 100.0 / total) : 0;
    var totalPred = Model.PrediccionesAltas + Model.PrediccionesMedias + Model.PrediccionesBajas;

    var hoy = DateTime.Now.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-MX"));
    var nombre = string.IsNullOrWhiteSpace(Model.ProfesorNombre) ? "Profesor" : Model.ProfesorNombre;

    var heroLead = Model.EnRiesgoRojo > 0
        ? $"Tienes {Model.EnRiesgoRojo} estudiante(s) en riesgo alto. Empieza por la lista priorizada y registra una acción concreta."
        : "Tus grupos no tienen estudiantes en riesgo alto. Mantén el seguimiento y revisa cambios recientes.";

    var hero = new HeroBand
    {
        Eyebrow = "Mis grupos · " + hoy,
        Title = "Hola, " + nombre.Split(' ')[0] + ".",
        Lead = heroLead,
        ActionsHtml =
            $"<a href='{Url.Action("Index", "Intervenciones")}' class='ra-btn ra-btn-primary ra-btn-lg'><i class='bi bi-clipboard-pulse'></i> Intervenciones</a>" +
            $"<a href='{Url.Action("Index", "Predicciones")}' class='ra-btn ra-btn-outline ra-btn-lg'><i class='bi bi-stars'></i> Análisis IA</a>"
    };
}

<partial name="_Hero" model="hero" />

<section class="ra-professor-command mb-4" aria-label="Centro de mando docente">
    <div class="ra-card ra-copilot-card h-100">
        <div class="ra-card-body">
            <div class="ra-copilot-head">
                <div>
                    <span class="ra-student-eyebrow">Prioridad docente</span>
                    <h2>@(Model.CopilotoCasos.Any() ? "Casos para atender primero" : "Sin casos críticos activos")</h2>
                    <p>@(Model.CopilotoCasos.Any()
                        ? "Lista única de estudiantes que concentran riesgo académico y predictivo. Atiende desde aquí sin repetir paneles."
                        : "No hay estudiantes con señales urgentes. Revisa grupos y mantén seguimiento preventivo.")</p>
                </div>
                <a asp-controller="Predicciones" asp-action="Index" class="ra-btn ra-btn-outline">
                    <i class="bi bi-stars"></i> Ver IA
                </a>
            </div>

            @if (Model.CopilotoCasos.Any())
            {
                <div class="ra-priority-list">
                    @foreach (var caso in Model.CopilotoCasos)
                    {
                        var color = caso.Probabilidad >= 0.55m ? "danger" : "warning";
                        <article class="ra-priority-row">
                            <div class="ra-priority-person">
                                <strong>@caso.Nombre</strong>
                                <small>@caso.Matricula · @caso.Grupo · Promedio @caso.Promedio.ToString("F2")</small>
                            </div>
                            <span class="ra-badge ra-badge-@color">@((caso.Probabilidad * 100).ToString("F0"))%</span>
                            <span class="ra-priority-action">@caso.SiguienteAccion</span>
                            <div class="ra-priority-buttons">
                                <a asp-controller="Predicciones" asp-action="Detalle" asp-route-matricula="@caso.Matricula" class="ra-btn ra-btn-sm ra-btn-primary">
                                    <i class="bi bi-brain"></i> Analizar
                                </a>
                                <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@caso.Matricula" class="ra-btn ra-btn-sm ra-btn-outline">
                                    <i class="bi bi-clipboard-pulse"></i> Intervenir
                                </a>
                                @if (!caso.TienePlanActivo)
                                {
                                    <a asp-controller="PlanesMejora" asp-action="Crear" asp-route-matricula="@caso.Matricula" class="ra-btn ra-btn-sm ra-btn-outline">
                                        <i class="bi bi-journal-check"></i> Plan
                                    </a>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="ra-empty py-4">
                    <i class="bi bi-check2-circle"></i>
                    <p>No hay estudiantes en prioridad alta.</p>
                </div>
            }
        </div>
    </div>

    <aside class="ra-card h-100">
        <div class="ra-card-header">
            <i class="bi bi-speedometer2"></i> Lectura rápida
        </div>
        <div class="ra-card-body">
            <div class="ra-professor-summary-grid">
                <a asp-controller="Alumnos" asp-action="MisTutorados" class="ra-professor-stat is-link">
                    <span class="ra-professor-stat-icon"><i class="bi bi-people"></i></span>
                    <span><strong>@Model.TotalEstudiantes</strong><small>Estudiantes</small></span>
                </a>
                <a asp-controller="PlanesMejora" asp-action="Index" class="ra-professor-stat is-link">
                    <span class="ra-professor-stat-icon"><i class="bi bi-journal-check"></i></span>
                    <span><strong>@Model.PlanesActivos</strong><small>Planes activos</small></span>
                </a>
                <a asp-controller="Intervenciones" asp-action="Index" class="ra-professor-stat is-link">
                    <span class="ra-professor-stat-icon"><i class="bi bi-clipboard-pulse"></i></span>
                    <span><strong>@Model.IntervencionesPendientes</strong><small>Seguimientos</small></span>
                </a>
            </div>

            @if (total > 0)
            {
                <div class="ra-risk-compact mt-3">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="ra-heading">Riesgo académico</span>
                        <small class="text-secondary">@total estudiantes</small>
                    </div>
                    <div class="ra-risk-bar" aria-label="Distribución de riesgo">
                        @if (pctVerde > 0)
                        {
                            <span style="width:@pctVerde.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-success);"></span>
                        }
                        @if (pctAmarillo > 0)
                        {
                            <span style="width:@pctAmarillo.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-warning);"></span>
                        }
                        @if (pctRojo > 0)
                        {
                            <span style="width:@pctRojo.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-danger);"></span>
                        }
                    </div>
                    <div class="ra-risk-legend">
                        <span><i style="background:var(--ra-success);"></i>@Model.EnRiesgoVerde verde</span>
                        <span><i style="background:var(--ra-warning);"></i>@Model.EnRiesgoAmarillo amarillo</span>
                        <span><i style="background:var(--ra-danger);"></i>@Model.EnRiesgoRojo rojo</span>
                    </div>
                </div>
            }

            @if (totalPred > 0)
            {
                <div class="ra-prediction-compact mt-3">
                    <div class="ra-heading mb-2"><i class="bi bi-brain me-1"></i>Predicción</div>
                    <div class="ra-prediction-pills">
                        <span class="ra-badge ra-badge-danger">@Model.PrediccionesAltas alta</span>
                        <span class="ra-badge ra-badge-warning">@Model.PrediccionesMedias media</span>
                        <span class="ra-badge ra-badge-success">@Model.PrediccionesBajas baja</span>
                    </div>
                </div>
            }

            <div class="ra-professor-quick-actions mt-3">
                <a asp-action="MateriasReprobadas" class="ra-btn ra-btn-outline">
                    <i class="bi bi-x-circle"></i> Reprobadas
                </a>
                <a asp-controller="Predicciones" asp-action="Index" class="ra-btn ra-btn-primary">
                    <i class="bi bi-brain"></i> Predicciones
                </a>
            </div>
        </div>
    </aside>
</section>

<section aria-label="Grupos asignados">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
        <div>
            <div class="ra-heading mb-1"><i class="bi bi-grid-3x3-gap me-1"></i> Tus grupos</div>
            <p class="text-secondary small mb-0">Entra al grupo para filtrar estudiantes, revisar riesgo y abrir acciones rápidas.</p>
        </div>
    </div>

    <div class="ra-group-grid">
        @foreach (var g in Model.Grupos)
        {
            var groupAlumnos = Model.Estudiantes.Where(a => a.Grupo?.Clave == g.Clave).ToList();
            var gv = groupAlumnos.Count(a => a.RiesgoAcademico == "Verde" || string.IsNullOrEmpty(a.RiesgoAcademico));
            var ga = groupAlumnos.Count(a => a.RiesgoAcademico == "Amarillo");
            var gr = groupAlumnos.Count(a => a.RiesgoAcademico == "Rojo");
            var gTotal = Math.Max(groupAlumnos.Count, 1);
            var gvPct = gv * 100.0 / gTotal;
            var gaPct = ga * 100.0 / gTotal;
            var grPct = gr * 100.0 / gTotal;

            <a asp-action="MisEstudiantes" asp-route-grupo="@g.Clave" class="ra-group-card">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div>
                        <h3>@g.Clave</h3>
                        <small>@g.Carrera · @g.Semestre° semestre · @g.Turno</small>
                    </div>
                    <span class="ra-badge @(g.EnRiesgo > 0 ? "ra-badge-warning" : "ra-badge-success")">
                        @(g.EnRiesgo > 0 ? $"{g.EnRiesgo} en riesgo" : "estable")
                    </span>
                </div>
                <div class="ra-group-metrics">
                    <span><strong>@g.TotalAlumnos</strong><small>alumnos</small></span>
                    <span><strong>@gr</strong><small>rojo</small></span>
                    <span><strong>@ga</strong><small>amarillo</small></span>
                </div>
                <div class="ra-risk-bar" aria-hidden="true">
                    @if (gvPct > 0)
                    {
                        <span style="width:@gvPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-success);"></span>
                    }
                    @if (gaPct > 0)
                    {
                        <span style="width:@gaPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-warning);"></span>
                    }
                    @if (grPct > 0)
                    {
                        <span style="width:@grPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-danger);"></span>
                    }
                </div>
                <span class="ra-group-open">Ver grupo <i class="bi bi-arrow-right"></i></span>
            </a>
        }
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            var alertas = [];
            @if (Model.EnRiesgoRojo > 0) { <text>alertas.push('@Model.EnRiesgoRojo estudiantes en riesgo alto');</text> }
            @if (Model.IntervencionesPendientes > 0) { <text>alertas.push('@Model.IntervencionesPendientes intervenciones pendientes');</text> }
            @if (Model.PlanesActivos > 0) { <text>alertas.push('@Model.PlanesActivos planes de mejora activos');</text> }
            if (alertas.length > 0) {
                setTimeout(function() {
                    RaToast.show('Resumen del día:\n' + alertas.join('\n'), 'info', 8000);
                }, 1200);
            }
        });
    </script>
}
