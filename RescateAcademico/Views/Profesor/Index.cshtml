@model RescateAcademico.Controllers.ProfesorDashboardViewModel
@{
    ViewData["Title"] = "Mis Grupos";
    Layout = "_Layout";
    var total = Model.TotalEstudiantes;
    var pctVerde = total > 0 ? (Model.EnRiesgoVerde * 100.0 / total) : 0;
    var pctAmarillo = total > 0 ? (Model.EnRiesgoAmarillo * 100.0 / total) : 0;
    var pctRojo = total > 0 ? (Model.EnRiesgoRojo * 100.0 / total) : 0;

    var hoy = DateTime.Now.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-MX"));
    var header = new PageHeader
    {
        Title = "Mis Grupos",
        SubtitleHtml = new Microsoft.AspNetCore.Html.HtmlString($"Bienvenido, <strong>{System.Net.WebUtility.HtmlEncode(Model.ProfesorNombre ?? "")}</strong> · {hoy}"),
        Icon = "bi-person-workspace",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

@if (Model.CopilotoCasos.Any())
{
    <section class="ra-card ra-copilot-card mb-4" aria-label="Copiloto académico">
        <div class="ra-card-body">
            <div class="ra-copilot-head">
                <div>
                    <span class="ra-student-eyebrow">Copiloto académico</span>
                    <h2>Casos que necesitan decisión docente</h2>
                    <p>Prioriza estudiantes con riesgo predictivo, revisa el análisis IA y convierte la recomendación en intervención o plan.</p>
                </div>
                <a asp-controller="Predicciones" asp-action="Index" class="ra-btn ra-btn-primary">
                    <i class="bi bi-stars"></i> Abrir IA
                </a>
            </div>
            <div class="ra-copilot-grid">
                @foreach (var caso in Model.CopilotoCasos)
                {
                    var color = caso.Probabilidad >= 0.55m ? "danger" : "warning";
                    <article class="ra-copilot-case">
                        <div class="d-flex justify-content-between gap-2 align-items-start">
                            <div>
                                <strong>@caso.Nombre</strong>
                                <small>@caso.Matricula · @caso.Grupo · @caso.Carrera</small>
                            </div>
                            <span class="ra-badge ra-badge-@color">@((caso.Probabilidad * 100).ToString("F0"))%</span>
                        </div>
                        <div class="ra-copilot-case-meta">
                            <span>Promedio @caso.Promedio.ToString("F2")</span>
                            <span>@caso.SiguienteAccion</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <a asp-controller="Predicciones" asp-action="Detalle" asp-route-matricula="@caso.Matricula" class="ra-btn ra-btn-sm ra-btn-primary">
                                <i class="bi bi-brain"></i> Analizar
                            </a>
                            <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@caso.Matricula" class="ra-btn ra-btn-sm ra-btn-outline">
                                <i class="bi bi-clipboard-pulse"></i> Intervenir
                            </a>
                            @if (!caso.TienePlanActivo)
                            {
                                <a asp-controller="PlanesMejora" asp-action="Crear" asp-route-matricula="@caso.Matricula" class="ra-btn ra-btn-sm ra-btn-outline">
                                    <i class="bi bi-journal-check"></i> Plan
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>
}

<!-- Smart Suggestions -->
@{
    var topRiesgo = Model.Estudiantes
        .Where(e => e.RiesgoAcademico == "Rojo")
        .OrderBy(e => e.PromedioGlobal)
        .Take(3)
        .ToList();
}
@if (topRiesgo.Any())
{
    <div class="ra-card mb-4">
        <div class="ra-card-header">
            <i class="bi bi-exclamation-triangle ra-text-warning me-1"></i> Estudiantes en riesgo alto (@Model.EnRiesgoRojo)
        </div>
        <div class="ra-card-body p-0">
            @foreach (var est in topRiesgo)
            {
                var hasPlan = Model.ExistingPlanMatriculas.Contains(est.Matricula);
                <div class="d-flex flex-wrap align-items-center gap-2 p-3" style="border-bottom:1px solid var(--ra-border-subtle);">
                    <ra-semaforo riesgo="Rojo" size="sm"></ra-semaforo>
                    <div style="flex:1;min-width:180px;">
                        <div class="fw-medium" style="font-size:0.875rem;">@est.Nombre @est.Apellidos</div>
                        <div class="text-secondary" style="font-size:0.6875rem;">@est.Carrera — Promedio @est.PromedioGlobal.ToString("F2") · @(est.MateriasReprobadas ?? 0) reprob.</div>
                    </div>
                    <div class="d-flex gap-1 ms-auto">
                        <a asp-action="HistorialAcademico" asp-route-boleta="@est.Matricula" class="ra-btn ra-btn-sm ra-btn-ghost" title="Ver perfil">
                            <i class="bi bi-person-badge"></i>
                        </a>
                        @if (hasPlan)
                        {
                            <a asp-controller="PlanesMejora" asp-action="Index" asp-route-matricula="@est.Matricula" class="ra-btn ra-btn-sm ra-btn-outline">
                                <i class="bi bi-eye"></i> Ver plan
                            </a>
                        }
                        else
                        {
                            <a asp-controller="PlanesMejora" asp-action="Crear" asp-route-matricula="@est.Matricula" class="ra-btn ra-btn-sm ra-btn-primary">
                                <i class="bi bi-plus-circle"></i> Crear plan
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
        @if (Model.EnRiesgoRojo > 3)
        {
            <div class="ra-card-footer text-center">
                <small class="text-secondary">+@(Model.EnRiesgoRojo - 3) estudiantes mas en riesgo alto</small>
            </div>
        }
    </div>
}

<!-- Risk Distribution Bar -->
@if (total > 0)
{
    <div class="ra-card mb-4">
        <div class="ra-card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <div class="ra-heading mb-1">Distribución de Riesgo</div>
                    <div class="text-secondary small">@total estudiantes en total</div>
                </div>
                <div class="d-flex gap-3">
                    <div class="text-center">
                        <div class="fw-bold" style="color:var(--ra-success);">@Model.EnRiesgoVerde</div>
                        <div class="ra-heading" style="font-size:0.65rem;">Verde</div>
                    </div>
                    <div class="text-center">
                        <div class="fw-bold" style="color:var(--ra-warning);">@Model.EnRiesgoAmarillo</div>
                        <div class="ra-heading" style="font-size:0.65rem;">Amarillo</div>
                    </div>
                    <div class="text-center">
                        <div class="fw-bold" style="color:var(--ra-danger);">@Model.EnRiesgoRojo</div>
                        <div class="ra-heading" style="font-size:0.65rem;">Rojo</div>
                    </div>
                </div>
            </div>
            <div style="height:12px;background:var(--ra-border);border-radius:6px;overflow:hidden;display:flex;">
                @if (pctVerde > 0)
                {
                    <div style="width:@pctVerde.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-success);transition:width 1s ease;"></div>
                }
                @if (pctAmarillo > 0)
                {
                    <div style="width:@pctAmarillo.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-warning);transition:width 1s ease;"></div>
                }
                @if (pctRojo > 0)
                {
                    <div style="width:@pctRojo.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:var(--ra-danger);transition:width 1s ease;"></div>
                }
            </div>
        </div>
    </div>
}

<!-- Prediction Glance -->
@{
    var totalPred = Model.PrediccionesAltas + Model.PrediccionesMedias + Model.PrediccionesBajas;
}
@if (totalPred > 0)
{
    <div class="ra-card mb-4">
        <div class="ra-card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-heading mb-1"><i class="bi bi-brain me-1"></i> Predicciones de Deserción</div>
                    <div class="text-secondary small">Análisis heurístico de tus @totalPred estudiantes</div>
                </div>
                <a asp-controller="Predicciones" asp-action="Index" class="ra-btn ra-btn-sm ra-btn-outline">
                    <i class="bi bi-eye"></i> Ver todas
                </a>
            </div>
            <div class="row g-3 mt-2">
                <div class="col-4">
                    <div class="text-center p-2 rounded-3" style="background: var(--ra-danger-bg);">
                        <div class="fw-bold fs-5" style="color: var(--ra-danger);">@Model.PrediccionesAltas</div>
                        <div class="text-secondary" style="font-size:0.6875rem;">Alta / Crítica</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center p-2 rounded-3" style="background: var(--ra-warning-bg);">
                        <div class="fw-bold fs-5" style="color: var(--ra-warning);">@Model.PrediccionesMedias</div>
                        <div class="text-secondary" style="font-size:0.6875rem;">Media</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center p-2 rounded-3" style="background: var(--ra-success-bg);">
                        <div class="fw-bold fs-5" style="color: var(--ra-success);">@Model.PrediccionesBajas</div>
                        <div class="text-secondary" style="font-size:0.6875rem;">Baja</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Groups Grid -->
<div class="mb-3">
    <div class="ra-heading mb-3"><i class="bi bi-grid-3x3-gap me-1"></i> Selecciona un Grupo</div>
    <div class="row g-3">
        @foreach (var g in Model.Grupos)
        {
            <div class="col-md-6 col-lg-4">
                <a asp-action="MisEstudiantes" asp-route-grupo="@g.Clave" class="text-decoration-none">
                    <div class="ra-card h-100" style="transition: var(--ra-transition); cursor: pointer;">
                        <div class="ra-card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h4 class="fw-bold mb-0 ra-text-accent" style="letter-spacing:-0.02em;">@g.Clave</h4>
                                <span class="ra-badge ra-badge-neutral">@g.Turno</span>
                            </div>
                            <p class="text-secondary small mb-3">@g.Carrera — @g.Semestre° Semestre</p>

                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="bi bi-people text-secondary"></i>
                                <span class="text-secondary small">@g.TotalAlumnos estudiantes</span>
                            </div>

                            <!-- Mini risk strip for this group -->
                            @{
                                var groupAlumnos = Model.Estudiantes.Where(a => a.Grupo?.Clave == g.Clave).ToList();
                                var gv = groupAlumnos.Count(a => a.RiesgoAcademico == "Verde" || string.IsNullOrEmpty(a.RiesgoAcademico));
                                var ga = groupAlumnos.Count(a => a.RiesgoAcademico == "Amarillo");
                                var gr = groupAlumnos.Count(a => a.RiesgoAcademico == "Rojo");
                            }
                            <div class="d-flex gap-1 mb-3">
                                @for (int i = 0; i < gr; i++)
                                {
                                    <span class="d-inline-block rounded-circle" style="width:10px;height:10px;background:var(--ra-danger);box-shadow:0 0 6px var(--ra-danger);"></span>
                                }
                                @for (int i = 0; i < ga; i++)
                                {
                                    <span class="d-inline-block rounded-circle" style="width:10px;height:10px;background:var(--ra-warning);box-shadow:0 0 6px var(--ra-warning);"></span>
                                }
                                @for (int i = 0; i < Math.Min(gv, 8); i++)
                                {
                                    <span class="d-inline-block rounded-circle" style="width:10px;height:10px;background:var(--ra-success);opacity:0.6;"></span>
                                }
                                @if (gv > 8)
                                {
                                    <span class="text-secondary small">+@(gv - 8)</span>
                                }
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                @if (g.EnRiesgo > 0)
                                {
                                    <span class="ra-badge ra-badge-danger"><i class="bi bi-exclamation-triangle me-1"></i>@g.EnRiesgo en riesgo</span>
                                }
                                else
                                {
                                    <span class="ra-badge ra-badge-success"><i class="bi bi-check-circle me-1"></i>Sin riesgo</span>
                                }
                                <span class="ra-btn ra-btn-sm ra-btn-ghost" style="pointer-events:none;">Ver grupo <i class="bi bi-arrow-right"></i></span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<!-- Quick Actions -->
<div class="ra-card">
    <div class="ra-card-header">
        <i class="bi bi-lightning"></i> Acciones Rápidas
    </div>
    <div class="ra-card-body d-flex flex-wrap gap-2">
        <a asp-action="MateriasReprobadas" class="ra-btn ra-btn-outline">
            <i class="bi bi-x-circle"></i> Materias Reprobadas
        </a>
        <a asp-controller="Intervenciones" asp-action="Index" class="ra-btn ra-btn-outline">
            <i class="bi bi-clipboard-pulse"></i> Intervenciones
        </a>
        <a asp-controller="PlanesMejora" asp-action="Index" class="ra-btn ra-btn-outline">
            <i class="bi bi-journal-check"></i> Planes de Mejora
        </a>
        <a asp-controller="Predicciones" asp-action="Index" class="ra-btn ra-btn-primary">
            <i class="bi bi-brain"></i> Predicciones
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Morning briefing toast
            var alertas = [];
            @if (Model.EnRiesgoRojo > 0) { <text>alertas.push('@Model.EnRiesgoRojo estudiantes en riesgo alto');</text> }
            @if (Model.IntervencionesPendientes > 0) { <text>alertas.push('@Model.IntervencionesPendientes intervenciones pendientes');</text> }
            @if (Model.PlanesActivos > 0) { <text>alertas.push('@Model.PlanesActivos planes de mejora activos');</text> }
            if (alertas.length > 0) {
                setTimeout(function() {
                    RaToast.show('Resumen del día:\n' + alertas.join('\n'), 'info', 8000);
                }, 1200);
            }
        });
    </script>
}
