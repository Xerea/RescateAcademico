@model RescateAcademico.Controllers.ProfesorDashboardViewModel
@{
    ViewData["Title"] = "Panel del Profesor";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-person-workspace ra-text-accent me-2"></i>Panel del Profesor</h1>
        <p class="text-secondary small mb-0">
            Bienvenido, <strong>@Model.ProfesorNombre</strong>.
            @(DateTime.Now.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-MX")))
        </p>
    </div>
    <div class="col-auto">
        <a asp-action="MisEstudiantes" class="ra-btn ra-btn-primary">
            <i class="bi bi-people"></i> Ver Todos
        </a>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-accent text-center">
            <div class="ra-stat-label">Total Estudiantes</div>
            <div class="ra-stat-value" data-countup="@Model.TotalEstudiantes">@Model.TotalEstudiantes</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-success text-center">
            <div class="ra-stat-label">Riesgo Verde</div>
            <div class="ra-stat-value" data-countup="@Model.EnRiesgoVerde">@Model.EnRiesgoVerde</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-warning text-center">
            <div class="ra-stat-label">Riesgo Amarillo</div>
            <div class="ra-stat-value" data-countup="@Model.EnRiesgoAmarillo">@Model.EnRiesgoAmarillo</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-danger text-center">
            <div class="ra-stat-label">Riesgo Rojo</div>
            <div class="ra-stat-value" data-countup="@Model.EnRiesgoRojo">@Model.EnRiesgoRojo</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
        <div class="ra-stat ra-stat-info text-center">
            <div class="ra-stat-label">Promedio General</div>
            <div class="ra-stat-value" data-countup="@Model.PromedioGeneral.ToString("F1")" data-countup-decimals="1">@Model.PromedioGeneral.ToString("F1")</div>
        </div>
    </div>
</div>

<!-- Smart Suggestions -->
@{
    var sugerencias = new List<(string Texto, string Accion, string Link, string Tipo)>();
    if (Model.EnRiesgoRojo >= 3)
    {
        sugerencias.Add(("Tienes " + Model.EnRiesgoRojo + " estudiantes en riesgo alto. Considera una tutoría grupal.", "Programar", "#", "warning"));
    }
    var ultimaSemana = DateTime.Now.AddDays(-7);
    var recientesRiesgo = Model.Estudiantes.Where(e => e.FechaUltimaActualizacion >= ultimaSemana && e.RiesgoAcademico == "Rojo").Take(1).ToList();
    if (recientesRiesgo.Any())
    {
        var est = recientesRiesgo.First();
        sugerencias.Add((est.Nombre + " pasó a riesgo alto recientemente. Recomendamos crear una intervención.", "Intervenir", Url.Action("Crear", "Intervenciones", new { matricula = est.Matricula })!, "danger"));
    }
    if (Model.IntervencionesPendientes > 0)
    {
        sugerencias.Add(("Tienes " + Model.IntervencionesPendientes + " intervenciones sin seguimiento.", "Revisar", Url.Action("Index", "Intervenciones")!, "info"));
    }
}
@if (sugerencias.Any())
{
    <div class="mb-4">
        <div class="ra-heading mb-2"><i class="bi bi-stars me-1"></i> Sugerencias Inteligentes</div>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var s in sugerencias)
            {
                <div class="ra-alert ra-alert-@s.Tipo py-2 px-3" style="width:auto;flex:1 1 300px;min-width:260px;">
                    <div style="flex:1;">
                        <div class="mb-1">@s.Texto</div>
                        <a href="@s.Link" class="ra-btn ra-btn-sm ra-btn-@s.Tipo" style="border-color:currentColor;color:currentColor;">@s.Accion</a>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Semaforo Grid -->
<div class="ra-card mb-4">
    <div class="ra-card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
        <span><i class="bi bi-grid-3x3-gap"></i> Mis Estudiantes</span>
        <div class="d-flex gap-1" role="group" aria-label="Filtro de riesgo">
            <button type="button" class="ra-btn ra-btn-sm ra-btn-primary active" data-filter="todos" onclick="filterGrid(this,'todos')">Todos</button>
            <button type="button" class="ra-btn ra-btn-sm ra-btn-outline" data-filter="rojo" onclick="filterGrid(this,'rojo')">
                <span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:var(--ra-danger);box-shadow:0 0 6px var(--ra-danger);"></span> Rojo
            </button>
            <button type="button" class="ra-btn ra-btn-sm ra-btn-outline" data-filter="amarillo" onclick="filterGrid(this,'amarillo')">
                <span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:var(--ra-warning);box-shadow:0 0 6px var(--ra-warning);"></span> Amarillo
            </button>
            <button type="button" class="ra-btn ra-btn-sm ra-btn-outline" data-filter="verde" onclick="filterGrid(this,'verde')">
                <span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:var(--ra-success);box-shadow:0 0 6px var(--ra-success);"></span> Verde
            </button>
        </div>
    </div>
    <div class="ra-card-body">
        <div class="row g-3" id="estudiantesGrid">
            @foreach (var a in Model.Estudiantes)
            {
                <div class="col-6 col-md-4 col-lg-3 col-xl-2 estudiante-card" data-riesgo="@((a.RiesgoAcademico ?? "Verde").ToLowerInvariant())">
                    <div class="ra-card h-100 text-center p-3" style="cursor:pointer;transition:transform 0.2s ease,box-shadow 0.2s ease;" onclick="location.href='@Url.Action("HistorialAcademico", new { boleta = a.Matricula })'">
                        <div class="ra-avatar mx-auto mb-2" style="width:48px;height:48px;font-size:1.1rem;">
                            @(a.Nombre?[0])@(a.Apellidos?[0])
                        </div>
                        <div class="ra-mono text-secondary small mb-1">@a.Matricula</div>
                        <div class="fw-semibold small mb-2" style="line-height:1.3;">@a.Nombre @a.Apellidos</div>
                        <ra-semaforo riesgo="@a.RiesgoAcademico" size="lg" tooltip="Promedio: @a.PromedioGlobal | Reprobadas: @a.MateriasReprobadas | Ausencias: @a.Ausencias"></ra-semaforo>
                        <div class="mt-2">
                            <span class="ra-badge @(a.PromedioGlobal >= 8 ? "ra-badge-success" : a.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                @a.PromedioGlobal.ToString("F1")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="ra-card h-100">
            <div class="ra-card-header">
                <i class="bi bi-grid-3x3-gap"></i> Mis Grupos
            </div>
            <div class="ra-card-body">
                <div class="row g-3">
                    @foreach (var g in Model.Grupos)
                    {
                        <div class="col-md-6">
                            <a asp-action="MisEstudiantes" asp-route-grupo="@g.Clave" class="text-decoration-none">
                                <div class="ra-card h-100" style="transition: var(--ra-transition);">
                                    <div class="ra-card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="fw-bold mb-0 ra-text-accent">@g.Clave</h5>
                                            <span class="ra-badge ra-badge-neutral">@g.Turno</span>
                                        </div>
                                        <p class="text-secondary small mb-2">@g.Carrera — @g.Semestre° Semestre</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-secondary small"><i class="bi bi-people me-1"></i>@g.TotalAlumnos estudiantes</span>
                                            @if (g.EnRiesgo > 0)
                                            {
                                                <span class="ra-badge ra-badge-danger"><i class="bi bi-exclamation-triangle me-1"></i>@g.EnRiesgo en riesgo</span>
                                            }
                                            else
                                            {
                                                <span class="ra-badge ra-badge-success"><i class="bi bi-check-circle me-1"></i>Sin riesgo</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ra-card h-100">
            <div class="ra-card-header">
                <i class="bi bi-lightning"></i> Acciones Rápidas
            </div>
            <div class="ra-card-body d-flex flex-column gap-2">
                <a asp-action="MisEstudiantes" class="ra-btn ra-btn-primary w-100">
                    <i class="bi bi-people"></i> Todos mis estudiantes
                </a>
                <a asp-action="MateriasReprobadas" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-x-circle"></i> Materias reprobadas
                </a>
                <a asp-controller="Intervenciones" asp-action="Index" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-clipboard-pulse"></i> Ver intervenciones
                </a>
                <a asp-controller="PlanesMejora" asp-action="Index" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-journal-check"></i> Planes de mejora
                </a>
            </div>
        </div>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-people"></i> Estudiantes Recientes</span>
        <a asp-action="MisEstudiantes" class="ra-btn ra-btn-sm ra-btn-ghost">Ver todos <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="ra-card-body p-0">
        <div class="table-responsive">
            <table class="table ra-table mb-0" id="tablaRecientes">
                <thead>
                    <tr>
                        <th>Boleta</th>
                        <th>Nombre</th>
                        <th>Grupo</th>
                        <th>Carrera</th>
                        <th>Promedio</th>
                        <th>Riesgo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Estudiantes)
                    {
                        <tr>
                            <td class="ra-mono"><strong>@a.Matricula</strong></td>
                            <td>@a.Nombre @a.Apellidos</td>
                            <td>@(a.Grupo?.Clave ?? "—")</td>
                            <td>@a.Carrera</td>
                            <td>
                                <span class="ra-badge @(a.PromedioGlobal >= 8 ? "ra-badge-success" : a.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                    @a.PromedioGlobal.ToString("F2")
                                </span>
                            </td>
                            <td>
                                <ra-semaforo riesgo="@a.RiesgoAcademico" size="sm"></ra-semaforo>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="HistorialAcademico" asp-route-boleta="@a.Matricula" class="ra-btn ra-btn-sm ra-btn-primary" title="Perfil">
                                        <i class="bi bi-graph-up"></i>
                                    </a>
                                    <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@a.Matricula" class="ra-btn ra-btn-sm ra-btn-accent" title="Intervención">
                                        <i class="bi bi-plus-circle"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<a asp-controller="Intervenciones" asp-action="Crear" class="ra-fab" title="Nueva Intervención">
    <i class="bi bi-plus-lg"></i>
</a>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaRecientes').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json' },
                pageLength: 10, ordering: false, searching: false, lengthChange: false, info: false
            });

            // Morning briefing toast
            var alertas = [];
            @if (Model.EnRiesgoRojo > 0) { <text>alertas.push('@Model.EnRiesgoRojo estudiantes en riesgo alto');</text> }
            @if (Model.IntervencionesPendientes > 0) { <text>alertas.push('@Model.IntervencionesPendientes intervenciones pendientes');</text> }
            @if (Model.PlanesActivos > 0) { <text>alertas.push('@Model.PlanesActivos planes de mejora activos');</text> }
            if (alertas.length > 0) {
                setTimeout(function() {
                    RaToast.show('<strong>Resumen del día</strong><br>' + alertas.join('<br>'), 'info', 8000);
                }, 1200);
            }
        });

        function filterGrid(btn, filtro) {
            document.querySelectorAll('[data-filter]').forEach(function(b) {
                b.classList.remove('ra-btn-primary');
                b.classList.add('ra-btn-outline');
            });
            btn.classList.remove('ra-btn-outline');
            btn.classList.add('ra-btn-primary');

            var cards = document.querySelectorAll('.estudiante-card');
            cards.forEach(function(card) {
                var riesgo = card.dataset.riesgo;
                if (filtro === 'todos' || riesgo === filtro) {
                    card.style.display = '';
                    if (typeof gsap !== 'undefined') {
                        gsap.fromTo(card, { opacity: 0, scale: 0.9 }, { opacity: 1, scale: 1, duration: 0.3, ease: 'power2.out' });
                    } else {
                        card.style.opacity = '1';
                    }
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
}
