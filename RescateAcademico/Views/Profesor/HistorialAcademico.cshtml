@model List<RescateAcademico.Controllers.HistorialPeriodo>
@{
    ViewData["Title"] = "Historial académico";
    var alumno = ViewBag.Alumno as RescateAcademico.Models.Alumno;
    var reprobadas = ViewBag.Reprobadas as List<string> ?? new List<string>();
    var dictamenes = ViewBag.Dictamenes as List<RescateAcademico.Models.DictamenAcademico> ?? new List<RescateAcademico.Models.DictamenAcademico>();
    var cosecovi = ViewBag.Cosecovi as List<RescateAcademico.Models.ReporteCosecovi> ?? new List<RescateAcademico.Models.ReporteCosecovi>();
    var probDesercion = (decimal)(ViewBag.ProbabilidadDesercion ?? 0m);
    var nivelPred = ViewBag.NivelPredictivo as string ?? "Bajo";
    var factoresRiesgo = ViewBag.FactoresRiesgo as List<string> ?? new List<string>();
    var sugerenciasPred = ViewBag.Sugerencias as List<string> ?? new List<string>();

    PageHeader? header = alumno == null ? null : new PageHeader
    {
        Title = alumno.Nombre + " " + alumno.Apellidos,
        Subtitle = $"Boleta {alumno.Matricula} · {alumno.Carrera} · Semestre {alumno.SemestreActual}",
        Icon = "bi-file-earmark-text",
        IconVariant = "accent",
        BackUrl = Url.Action("Index", "Profesor"),
        BackLabel = "Mis Grupos"
    };
}

@if (header != null)
{
    <partial name="_PageHeader" model="header" />
}

@if (TempData["Success"] != null)
{
    <div class="ra-alert ra-alert-success mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="ra-alert ra-alert-danger mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>@TempData["Error"]</div>
    </div>
}

@if (alumno != null)
{
    <div class="ra-card mb-4">
        <div class="ra-card-header">
            <i class="bi bi-info-circle"></i> Información general
        </div>
        <div class="ra-card-body">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-2"><span class="text-secondary small">Promedio general</span></p>
                    <p class="fs-4 fw-bold mb-3 @(alumno.PromedioGlobal < 6.0m ? "ra-text-danger" : alumno.PromedioGlobal < 7.5m ? "ra-text-warning" : "ra-text-success")">@alumno.PromedioGlobal.ToString("F2")</p>
                    <p class="mb-2"><span class="text-secondary small">Estatus:</span> <span class="ra-badge ra-badge-success">@alumno.Estatus</span></p>
                </div>
                <div class="col-md-6 d-flex flex-column justify-content-center">
                    <p class="mb-2 d-flex align-items-center gap-2">
                        <span class="text-secondary small">Riesgo académico:</span>
                        <ra-semaforo riesgo="@(alumno.RiesgoAcademico ?? "Verde")" size="sm"></ra-semaforo>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Predicción IA -->
    <div class="ra-card mb-4">
        <div class="ra-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-brain ra-text-primary me-2"></i>Predicción de Deserción</span>
            <div class="d-flex gap-2">
                <a asp-controller="PlanesMejora" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-sm ra-btn-primary">
                    <i class="bi bi-journal-plus"></i> Crear Plan
                </a>
                <a asp-controller="Predicciones" asp-action="Detalle" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-sm ra-btn-outline">
                    <i class="bi bi-eye"></i> Análisis completo
                </a>
            </div>
        </div>
        <div class="ra-card-body">
            <div class="row g-3 text-center">
                <div class="col-6 col-md-3">
                    <div class="fw-bold fs-4 @(probDesercion >= 0.55m ? "ra-text-danger" : probDesercion >= 0.35m ? "ra-text-warning" : "ra-text-success")">@((probDesercion * 100).ToString("F1"))%</div>
                    <div class="text-secondary" style="font-size:0.6875rem;">Probabilidad</div>
                </div>
                <div class="col-6 col-md-3">
                    <ra-semaforo riesgo="@(nivelPred == "Alto" || nivelPred == "Critico" ? "Rojo" : nivelPred == "Medio" ? "Amarillo" : "Verde")" size="sm"></ra-semaforo>
                    <div class="text-secondary" style="font-size:0.6875rem;">@nivelPred</div>
                </div>
                <div class="col-12 col-md-6 text-start">
                    <div class="text-secondary" style="font-size:0.6875rem;margin-bottom:0.25rem;">Factores detectados:</div>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var f in factoresRiesgo)
                        {
                            <span class="ra-badge ra-badge-neutral" style="font-size:0.6875rem;">@f</span>
                        }
                    </div>
                </div>
            </div>
            @if (sugerenciasPred.Any())
            {
                <div class="mt-3 pt-3" style="border-top:1px solid var(--ra-border-subtle);">
                    <div class="text-secondary small mb-1">Sugerencias:</div>
                    <ul class="mb-0 ps-3" style="font-size:0.8125rem;">
                        @foreach (var s in sugerenciasPred.Take(3))
                        {
                            <li class="mb-1">@s</li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>

    <!-- Contactar Tutor Legal -->
    @if (false && !string.IsNullOrEmpty(alumno.NombreTutorLegal))
    {
        <div class="ra-card mb-4">
            <div class="ra-card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="ra-avatar" style="width:40px;height:40px;"><i class="bi bi-person-heart"></i></div>
                    <div>
                        <div class="fw-semibold small">Tutor Legal: @alumno.NombreTutorLegal</div>
                        <div class="ra-mono text-secondary" style="font-size:0.8125rem;"><i class="bi bi-telephone me-1"></i>@alumno.TelefonoTutorLegal</div>
                    </div>
                </div>
                <button type="button" class="ra-btn ra-btn-outline" data-bs-toggle="modal" data-bs-target="#contactarTutorModal">
                    <i class="bi bi-chat-dots"></i> Contactar Tutor
                </button>
            </div>
        </div>

        <div class="modal fade" id="contactarTutorModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <form asp-action="EnviarMensajeTutorLegal" method="post" class="modal-content" style="border: 1px solid var(--ra-border); border-radius: var(--ra-radius-lg); background: var(--ra-surface);">
                    <input type="hidden" name="boleta" value="@alumno.Matricula" />
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold"><i class="bi bi-chat-dots me-2" style="color:var(--ra-primary);"></i>Contactar Tutor Legal</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <div class="text-secondary small">Estudiante</div>
                            <div class="fw-semibold">@alumno.Nombre @alumno.Apellidos <span class="ra-mono text-secondary">(@alumno.Matricula)</span></div>
                        </div>
                        <div class="mb-3">
                            <div class="text-secondary small">Tutor Legal</div>
                            <div class="fw-semibold">@alumno.NombreTutorLegal</div>
                        </div>
                        <div class="mb-3">
                            <div class="text-secondary small">Teléfono</div>
                            <div class="ra-mono">@alumno.TelefonoTutorLegal</div>
                        </div>
                        <div class="mb-3">
                            <label class="ra-label">Mensaje</label>
                            <textarea name="mensaje" class="ra-input" rows="4" maxlength="480" required placeholder="Escribe un mensaje para el tutor legal...">Buen día @alumno.NombreTutorLegal, me comunico con usted en mi calidad de profesor tutor de @alumno.Nombre @alumno.Apellidos. Le escribo para informarle sobre la situación académica de su pupilo y coordinar una reunión para discutir un plan de mejora. Quedo a sus órdenes.</textarea>
                            <div class="text-secondary small mt-1">Se enviará por SMS si el proveedor está configurado.</div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="ra-btn ra-btn-ghost" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-send"></i> Enviar SMS
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
    @if (reprobadas.Any())
    {
        <div class="ra-alert ra-alert-danger mb-4" role="alert">
            <i class="bi bi-x-circle-fill fs-5"></i>
            <div><strong>Materias reprobadas:</strong> @string.Join(", ", reprobadas)</div>
        </div>
    }

    @foreach (var periodo in Model)
    {
        <div class="ra-card mb-3">
            <div class="ra-card-header">
                <i class="bi bi-calendar-event me-2"></i> @periodo.Periodo
            </div>
            <div class="ra-card-body p-0">
                <div class="table-responsive">
                    <table class="table ra-table mb-0">
                        <thead>
                            <tr>
                                <th>Clave</th>
                                <th>Materia</th>
                                <th>Evaluación</th>
                                <th>Calificación</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in periodo.Materias)
                            {
                                <tr class="@(m.Calificacion < 6 ? "ra-bg-danger" : m.Tipo != "Ordinario" ? "ra-bg-warning" : "")">
                                    <td><code>@m.Clave</code></td>
                                    <td>@m.Nombre</td>
                                    <td>@m.Tipo @(m.VecesCursada > 1 ? $"({m.VecesCursada}° vez)" : "")</td>
                                    <td><strong>@m.Calificacion.ToString("F1")</strong></td>
                                    <td>
                                        @if (m.Aprobada)
                                        {
                                            <span class="ra-badge ra-badge-success">Aprobada</span>
                                        }
                                        else
                                        {
                                            <span class="ra-badge ra-badge-danger">Reprobada</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (dictamenes.Any())
    {
        <div class="ra-card ra-card-danger mb-3">
            <div class="ra-card-header">
                <i class="bi bi-file-earmark-lock me-2"></i> Dictámenes Académicos
            </div>
            <div class="ra-card-body">
                @foreach (var d in dictamenes)
                {
                    <div class="mb-2 p-2 rounded-3" style="border: 1px solid var(--ra-border);">
                        <strong>@d.Tipo</strong> <span class="ra-badge @(d.Estado == "Activo" ? "ra-badge-warning" : "ra-badge-neutral")">@d.Estado</span>
                        <p class="mb-1">@d.Descripcion</p>
                        <small class="text-secondary">Emitido: @d.FechaEmision.ToString("yyyy-MM-dd") | @d.EmitidoPor</small>
                        @if (!string.IsNullOrEmpty(d.Observaciones))
                        {
                            <p class="mb-0 mt-1"><small><strong>Obs:</strong> @d.Observaciones</small></p>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (cosecovi.Any())
    {
        <div class="ra-card ra-card-info mb-3">
            <div class="ra-card-header">
                <i class="bi bi-shield-exclamation me-2"></i> Historial COSECOVI
            </div>
            <div class="ra-card-body">
                @foreach (var r in cosecovi)
                {
                    var gravedadClass = r.Gravedad is "Alta" or "Critica" ? "ra-badge-danger" : r.Gravedad == "Media" ? "ra-badge-warning" : "ra-badge-neutral";
                    <div class="mb-2 p-2 rounded-3" style="border: 1px solid var(--ra-border);">
                        <strong>@r.TipoIncidente</strong> <span class="ra-badge @gravedadClass">@r.Gravedad</span>
                        <p class="mb-1">@r.SituacionObservada</p>
                        <small class="text-secondary">Estado: @r.Estado | Turnado: @(r.Canalizacion ?? "Sin turno") | @r.FechaIncidente.ToString("yyyy-MM-dd")</small>
                    </div>
                }
            </div>
        </div>
    }
}
