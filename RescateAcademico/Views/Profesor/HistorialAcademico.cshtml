@model List<RescateAcademico.Controllers.HistorialPeriodo>
@{
    ViewData["Title"] = "Historial Académico";
    var alumno = ViewBag.Alumno as RescateAcademico.Models.Alumno;
    var reprobadas = ViewBag.Reprobadas as List<string> ?? new List<string>();
    var dictamenes = ViewBag.Dictamenes as List<RescateAcademico.Models.DictamenAcademico> ?? new List<RescateAcademico.Models.DictamenAcademico>();
    var cosecovi = ViewBag.Cosecovi as List<RescateAcademico.Models.ReporteCosecovi> ?? new List<RescateAcademico.Models.ReporteCosecovi>();
}

@if (alumno != null)
{
    <div class="ra-card mb-4">
        <div class="ra-card-header">
            <i class="bi bi-file-earmark-text ra-text-accent me-2"></i> Historial Académico
        </div>
        <div class="ra-card-body">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-2"><span class="text-secondary small">Estudiante:</span> <strong>@alumno.Nombre @alumno.Apellidos</strong></p>
                    <p class="mb-2"><span class="text-secondary small">Boleta:</span> <strong>@alumno.Matricula</strong></p>
                    <p class="mb-2"><span class="text-secondary small">Carrera:</span> <strong>@alumno.Carrera</strong></p>
                    <p class="mb-0"><span class="text-secondary small">Semestre Actual:</span> <strong>@alumno.SemestreActual</strong></p>
                </div>
                <div class="col-md-6">
                    <p class="mb-2"><span class="text-secondary small">Promedio General:</span> <span class="fs-4 fw-bold @(alumno.PromedioGlobal < 6.0m ? "ra-text-danger" : alumno.PromedioGlobal < 7.5m ? "ra-text-warning" : "ra-text-success")">@alumno.PromedioGlobal.ToString("F2")</span></p>
                    <p class="mb-2"><span class="text-secondary small">Estatus:</span> <span class="ra-badge ra-badge-success">@alumno.Estatus</span></p>
                    <p class="mb-0"><span class="text-secondary small">Riesgo Académico:</span> <ra-semaforo riesgo="@(alumno.RiesgoAcademico ?? "Verde")" size="sm"></ra-semaforo></p>
                </div>
            </div>
        </div>
    </div>

    @if (reprobadas.Any())
    {
        <div class="ra-alert ra-alert-danger mb-4" role="alert">
            <i class="bi bi-x-circle-fill fs-5"></i>
            <div><strong>Materias reprobadas:</strong> @string.Join(", ", reprobadas)</div>
        </div>
    }

    @foreach (var periodo in Model)
    {
        <div class="ra-card mb-3">
            <div class="ra-card-header">
                <i class="bi bi-calendar-event me-2"></i> @periodo.Periodo
            </div>
            <div class="ra-card-body p-0">
                <div class="table-responsive">
                    <table class="table ra-table mb-0">
                        <thead>
                            <tr>
                                <th>Clave</th>
                                <th>Materia</th>
                                <th>Evaluación</th>
                                <th>Calificación</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in periodo.Materias)
                            {
                                <tr class="@(m.Calificacion < 6 ? "ra-bg-danger" : m.Tipo != "Ordinario" ? "ra-bg-warning" : "")">
                                    <td><code>@m.Clave</code></td>
                                    <td>@m.Nombre</td>
                                    <td>@m.Tipo @(m.VecesCursada > 1 ? $"({m.VecesCursada}° vez)" : "")</td>
                                    <td><strong>@m.Calificacion.ToString("F1")</strong></td>
                                    <td>
                                        @if (m.Aprobada)
                                        {
                                            <span class="ra-badge ra-badge-success">Aprobada</span>
                                        }
                                        else
                                        {
                                            <span class="ra-badge ra-badge-danger">Reprobada</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (dictamenes.Any())
    {
        <div class="ra-card ra-card-danger mb-3">
            <div class="ra-card-header">
                <i class="bi bi-file-earmark-lock me-2"></i> Dictámenes Académicos
            </div>
            <div class="ra-card-body">
                @foreach (var d in dictamenes)
                {
                    <div class="mb-2 p-2 rounded-3" style="border: 1px solid var(--ra-border);">
                        <strong>@d.Tipo</strong> <span class="ra-badge @(d.Estado == "Activo" ? "ra-badge-warning" : "ra-badge-neutral")">@d.Estado</span>
                        <p class="mb-1">@d.Descripcion</p>
                        <small class="text-secondary">Emitido: @d.FechaEmision.ToString("yyyy-MM-dd") | @d.EmitidoPor</small>
                        @if (!string.IsNullOrEmpty(d.Observaciones))
                        {
                            <p class="mb-0 mt-1"><small><strong>Obs:</strong> @d.Observaciones</small></p>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (cosecovi.Any())
    {
        <div class="ra-card ra-card-info mb-3">
            <div class="ra-card-header">
                <i class="bi bi-clipboard-pulse me-2"></i> Reportes COSECOVI
            </div>
            <div class="ra-card-body">
                @foreach (var r in cosecovi)
                {
                    <div class="mb-2 p-2 rounded-3" style="border: 1px solid var(--ra-border);">
                        <strong>@r.Periodo</strong> <span class="ra-badge @(r.Estado == "Atendido" ? "ra-badge-success" : "ra-badge-warning")">@r.Estado</span>
                        <p class="mb-1">@r.SituacionObservada</p>
                        <small class="text-secondary">Canalización: @r.Canalizacion | @r.FechaReporte.ToString("yyyy-MM-dd")</small>
                    </div>
                }
            </div>
        </div>
    }
}

<div class="mb-4">
    <a href="javascript:history.back()" class="ra-btn ra-btn-outline">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>
