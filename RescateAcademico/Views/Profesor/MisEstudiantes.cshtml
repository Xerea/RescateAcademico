@model List<RescateAcademico.Models.Alumno>
@{
    ViewData["Title"] = "Mis Estudiantes";
    var grupos = ViewBag.Grupos as List<string> ?? new List<string>();
}

<h2><i class="bi bi-people"></i> Mis Estudiantes</h2>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <input type="text" name="busqueda" class="form-control" placeholder="Buscar por boleta o nombre..." value="@ViewBag.Busqueda" />
            </div>
            <div class="col-md-2">
                <select name="riesgo" class="form-select">
                    <option value="Todos">Todos los riesgos</option>
                    <option value="Verde" selected="@(ViewBag.FiltroRiesgo == "Verde" ? "selected" : null)">Verde</option>
                    <option value="Amarillo" selected="@(ViewBag.FiltroRiesgo == "Amarillo" ? "selected" : null)">Amarillo</option>
                    <option value="Rojo" selected="@(ViewBag.FiltroRiesgo == "Rojo" ? "selected" : null)">Rojo</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="grupo" class="form-select">
                    <option value="Todos">Todos los grupos</option>
                    @foreach (var g in grupos)
                    {
                        <option value="@g" selected="@(ViewBag.FiltroGrupo == g ? "selected" : null)">@g</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i> Filtrar</button>
            </div>
            <div class="col-md-3 text-end">
                <a asp-action="MateriasReprobadas" class="btn btn-outline-danger"><i class="bi bi-x-circle"></i> Reprobadas</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Boleta</th>
                    <th>Nombre</th>
                    <th>Grupo</th>
                    <th>Carrera</th>
                    <th>Semestre</th>
                    <th>Promedio</th>
                    <th>Riesgo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr class="@(a.RiesgoAcademico == "Rojo" ? "table-danger" : a.RiesgoAcademico == "Amarillo" ? "table-warning" : "")">
                        <td><strong>@a.Matricula</strong></td>
                        <td>@a.Nombre @a.Apellidos</td>
                        <td>@a.Grupo?.Clave</td>
                        <td>@a.Carrera</td>
                        <td>@a.SemestreActual</td>
                        <td>@a.PromedioGlobal.ToString("F2")</td>
                        <td>
                            <span class="badge bg-@(a.RiesgoAcademico == "Rojo" ? "danger" : a.RiesgoAcademico == "Amarillo" ? "warning text-dark" : "success")">
                                @(a.RiesgoAcademico ?? "Verde")
                            </span>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="HistorialAcademico" asp-route-boleta="@a.Matricula" class="btn btn-info" title="Historial Académico"><i class="bi bi-file-earmark-text"></i></a>
                                <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@a.Matricula" class="btn btn-warning" title="Intervención"><i class="bi bi-clipboard-pulse"></i></a>
                                <a asp-controller="PlanesMejora" asp-action="Crear" asp-route-matricula="@a.Matricula" class="btn btn-success" title="Plan de Mejora"><i class="bi bi-journal-check"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver al Panel</a>
</div>
