@model List<RescateAcademico.Models.Alumno>
@{
    Layout = "_Layout";
    var grupos = ViewBag.Grupos as List<string> ?? new List<string>();
    var grupoActual = ViewBag.FiltroGrupo as string ?? "Todos";
    ViewData["Title"] = "Grupo " + grupoActual;

    ViewData["BreadcrumbTrail"] = new List<(string Label, string Url)>
    {
        ("Mis Grupos", Url.Action("Index", "Profesor") ?? "/"),
        (grupoActual, string.Empty)
    };

    var filterActive = !string.IsNullOrEmpty(ViewBag.Busqueda as string)
        || (!string.IsNullOrEmpty(ViewBag.FiltroRiesgo as string) && (string)ViewBag.FiltroRiesgo != "Todos");

    var header = new PageHeader
    {
        Title = grupoActual,
        Subtitle = $"{Model.Count} estudiantes asignados",
        Icon = "bi-people",
        IconVariant = "accent",
        BackUrl = Url.Action("Index", "Profesor"),
        BackLabel = "Mis Grupos"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card ra-filter-bar">
    <div class="ra-card-body">
        <form method="get" class="row g-2 align-items-end">
            <input type="hidden" name="grupo" value="@grupoActual" />
            <div class="col-md-4">
                <label class="ra-label">Buscar</label>
                <input type="text" name="busqueda" class="ra-input" placeholder="Boleta o nombre…" value="@ViewBag.Busqueda" />
            </div>
            <div class="col-md-3">
                <label class="ra-label">Riesgo</label>
                <select name="riesgo" class="ra-select">
                    <option value="Todos">Todos</option>
                    <option value="Verde" selected="@(ViewBag.FiltroRiesgo == "Verde" ? "selected" : null)">Verde</option>
                    <option value="Amarillo" selected="@(ViewBag.FiltroRiesgo == "Amarillo" ? "selected" : null)">Amarillo</option>
                    <option value="Rojo" selected="@(ViewBag.FiltroRiesgo == "Rojo" ? "selected" : null)">Rojo</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="ra-btn ra-btn-primary flex-fill">
                    <i class="bi bi-search"></i> Filtrar
                </button>
                @if (filterActive)
                {
                    <a asp-action="MisEstudiantes" asp-route-grupo="@grupoActual" class="ra-btn ra-btn-ghost" title="Limpiar filtros">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
            </div>
            <div class="col-md-3 text-md-end">
                <a asp-action="MateriasReprobadas" asp-route-grupo="@grupoActual" class="ra-btn ra-btn-outline">
                    <i class="bi bi-x-circle"></i> Reprobadas
                </a>
            </div>
        </form>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards mb-0" id="tablaEstudiantes">
                    <thead>
                        <tr>
                            <th>Boleta</th>
                            <th>Nombre</th>
                            <th>Carrera</th>
                            <th>Semestre</th>
                            <th>Promedio</th>
                            <th data-orderable="false">Riesgo</th>
                            <th style="width: 1px;" data-orderable="false">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td data-label="Boleta" class="ra-mono"><strong>@a.Matricula</strong></td>
                                <td data-label="Nombre">@a.Nombre @a.Apellidos</td>
                                <td data-label="Carrera" class="text-secondary">@a.Carrera</td>
                                <td data-label="Semestre">@a.SemestreActual</td>
                                <td data-label="Promedio">
                                    <span class="ra-badge @(a.PromedioGlobal >= 8 ? "ra-badge-success" : a.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                        @a.PromedioGlobal.ToString("F2")
                                    </span>
                                </td>
                                <td data-label="Riesgo">
                                    <ra-semaforo riesgo="@a.RiesgoAcademico" size="sm"></ra-semaforo>
                                </td>
                                <td data-label="Acciones">
                                    <div class="d-flex gap-1 flex-nowrap justify-content-end">
                                        <button type="button" class="ra-btn ra-btn-sm ra-btn-outline" onclick="RaQuickView.open('@a.Matricula')" aria-label="Vista rápida" title="Vista rápida">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <a asp-action="HistorialAcademico" asp-route-boleta="@a.Matricula" class="ra-btn ra-btn-sm ra-btn-primary" aria-label="Perfil académico" title="Perfil">
                                            <i class="bi bi-graph-up"></i>
                                        </a>
                                        <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@a.Matricula" class="ra-btn ra-btn-sm ra-btn-accent" aria-label="Nueva intervención" title="Nueva intervención">
                                            <i class="bi bi-plus-circle"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty py-5">
                <i class="bi bi-people"></i>
                <p>No se encontraron estudiantes con los filtros seleccionados.</p>
                <a asp-action="MisEstudiantes" asp-route-grupo="@grupoActual" class="ra-btn ra-btn-outline mt-2">Limpiar filtros</a>
            </div>
        }
    </div>
</div>

<partial name="_AlumnoQuickView" />

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaEstudiantes').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json' },
                pageLength: 25,
                columnDefs: [{ orderable: false, targets: [5, 6] }]
            });
        });

        RaQuickView.configure({
            profile:      '/Profesor/HistorialAcademico?boleta={matricula}',
            intervencion: '/Intervenciones/Crear?matricula={matricula}',
            plan:         '/PlanesMejora/Crear?matricula={matricula}'
        });
    </script>
}
