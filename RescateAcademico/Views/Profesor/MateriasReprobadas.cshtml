@model List<RescateAcademico.Models.Calificacion>
@{
    ViewData["Title"] = "Materias Reprobadas";
    Layout = "_Layout";
    var grupos = ViewBag.Grupos as List<string> ?? new List<string>();
}

<div class="row mb-4">
    <div class="col">
        <h2 style="color: #6c1d45;"><i class="bi bi-x-circle"></i> Materias Reprobadas</h2>
        <p class="text-muted">Listado de estudiantes con materias reprobadas en tus grupos asignados.</p>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover" id="tablaReprobadas">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Boleta</th>
                            <th>Estudiante</th>
                            <th>Grupo</th>
                            <th>Materia</th>
                            <th>Calificación</th>
                            <th>Veces Cursada</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td><strong>@c.AlumnoMatricula</strong></td>
                                <td>@(c.Alumno?.Nombre) @(c.Alumno?.Apellidos)</td>
                                <td>@(c.Alumno?.Grupo?.Clave ?? "—")</td>
                                <td><span class="badge bg-light text-dark border">@c.Materia?.Clave</span> @c.Materia?.Nombre</td>
                                <td><span class="badge bg-danger">@((c.Valor ?? 0).ToString("F1"))</span></td>
                                <td>@c.VecesCursada</td>
                                <td>
                                    <a asp-action="HistorialAcademico" asp-route-boleta="@c.AlumnoMatricula" class="btn btn-sm btn-outline-info" title="Ver historial">
                                        <i class="bi bi-journal-text"></i> Historial
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-check-circle fs-1 text-success"></i>
                <p class="text-muted mt-3">¡Excelente! No hay materias reprobadas en tus grupos.</p>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="MisEstudiantes" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver a Estudiantes
    </a>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaReprobadas').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}