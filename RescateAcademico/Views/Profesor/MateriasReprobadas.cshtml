@model List<RescateAcademico.Models.Calificacion>
@{
    ViewData["Title"] = "Materias Reprobadas";
    var grupos = ViewBag.Grupos as List<string> ?? new List<string>();
}

<h2><i class="bi bi-x-circle"></i> Materias Reprobadas</h2>
<p class="text-muted">Listado de estudiantes con materias reprobadas en tus grupos asignados.</p>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Boleta</th>
                    <th>Estudiante</th>
                    <th>Grupo</th>
                    <th>Materia</th>
                    <th>Calificación</th>
                    <th>Veces Cursada</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><strong>@c.AlumnoMatricula</strong></td>
                        <td>@(c.Alumno?.Nombre) @(c.Alumno?.Apellidos)</td>
                        <td>@(c.Alumno?.Grupo?.Clave)</td>
                        <td><span class="badge bg-secondary">@c.Materia?.Clave</span> @c.Materia?.Nombre</td>
                        <td><span class="badge bg-danger">@((c.Valor ?? 0).ToString("F1"))</span></td>
                        <td>@c.VecesCursada</td>
                        <td>
                            <a asp-action="HistorialAcademico" asp-route-boleta="@c.AlumnoMatricula" class="btn btn-sm btn-info">Ver Historial</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="MisEstudiantes" class="btn btn-secondary">Volver a Estudiantes</a>
</div>
