@model List<RescateAcademico.Models.Calificacion>
@{
    ViewData["Title"] = "Materias Reprobadas";
    Layout = "_Layout";
    var grupos = ViewBag.Grupos as List<string> ?? new List<string>();
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-x-circle ra-text-danger me-2"></i>Materias Reprobadas</h1>
        <p class="text-secondary small mb-0">Listado de estudiantes con materias reprobadas en tus grupos asignados.</p>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table" id="tablaReprobadas">
                    <thead>
                        <tr>
                            <th>Boleta</th>
                            <th>Estudiante</th>
                            <th>Grupo</th>
                            <th>Materia</th>
                            <th>Calificación</th>
                            <th>Veces</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td><strong>@c.AlumnoMatricula</strong></td>
                                <td>@(c.Alumno?.Nombre) @(c.Alumno?.Apellidos)</td>
                                <td>@(c.Alumno?.Grupo?.Clave ?? "—")</td>
                                <td><span class="ra-badge ra-badge-neutral">@c.Materia?.Clave</span> @c.Materia?.Nombre</td>
                                <td><span class="ra-badge ra-badge-danger">@((c.Valor ?? 0).ToString("F1"))</span></td>
                                <td>@c.VecesCursada</td>
                                <td>
                                    <a asp-action="HistorialAcademico" asp-route-boleta="@c.AlumnoMatricula" class="ra-btn ra-btn-sm ra-btn-outline" title="Ver historial">
                                        <i class="bi bi-journal-text"></i> Historial
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-check-circle ra-text-success"></i>
                <p>¡Excelente! No hay materias reprobadas en tus grupos.</p>
            </div>
        }
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="ra-btn ra-btn-outline">
        <i class="bi bi-arrow-left"></i> Volver a Mis Grupos
    </a>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaReprobadas').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
