@model RescateAcademico.Models.PlanMejora
@{
    ViewData["Title"] = "Detalles del Plan de Mejora";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-journal-check ra-text-accent me-2"></i>Detalles del Plan</h1>
        <p class="text-secondary small mb-0">Plan #@Model.Id — <span class="ra-badge @(Model.Estado == "Activo" ? "ra-badge-primary" : Model.Estado == "Cumplido" ? "ra-badge-success" : Model.Estado == "Vencido" ? "ra-badge-danger" : "ra-badge-neutral")">@Model.Estado</span></p>
    </div>
</div>

<div class="ra-card mb-4">
    <div class="ra-card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 text-secondary small">Alumno</dt>
            <dd class="col-sm-9 fw-medium">@Model.Alumno?.Nombre @Model.Alumno?.Apellidos (@Model.AlumnoMatricula)</dd>

            <dt class="col-sm-3 text-secondary small">Profesor</dt>
            <dd class="col-sm-9">@Model.Tutor?.Nombre @Model.Tutor?.Apellidos</dd>

            <dt class="col-sm-3 text-secondary small">Fecha de Creación</dt>
            <dd class="col-sm-9">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3 text-secondary small">Fecha de Cierre</dt>
            <dd class="col-sm-9">@(Model.FechaCierre?.ToString("dd/MM/yyyy") ?? "No definida")</dd>

            <dt class="col-sm-3 text-secondary small">Recomendaciones</dt>
            <dd class="col-sm-9">@(Model.Recomendaciones ?? "N/A")</dd>

            <dt class="col-sm-3 text-secondary small">Metas</dt>
            <dd class="col-sm-9">@(Model.Metas ?? "N/A")</dd>

            <dt class="col-sm-3 text-secondary small">Acciones Tomadas</dt>
            <dd class="col-sm-9 mb-0">@(Model.AccionesTomadas ?? "N/A")</dd>
        </dl>
    </div>
</div>

<div class="d-flex flex-wrap gap-2">
    @if (!User.IsInRole("Autoridad"))
    {
        <a asp-action="Editar" asp-route-id="@Model.Id" class="ra-btn ra-btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>
    }
    <a asp-action="Seguimiento" asp-route-id="@Model.Id" class="ra-btn ra-btn-outline">
        <i class="bi bi-clock-history"></i> Seguimiento
    </a>
    <a asp-action="Index" class="ra-btn ra-btn-ghost">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>
