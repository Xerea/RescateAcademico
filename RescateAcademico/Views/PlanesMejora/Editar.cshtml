@model RescateAcademico.Controllers.PlanMejoraViewModel
@{
    ViewData["Title"] = "Editar Plan de Mejora";
    Layout = "_Layout";
    var tutores = ViewBag.Tutores as List<RescateAcademico.Models.Tutor> ?? new List<RescateAcademico.Models.Tutor>();
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 mx-auto">
        <div class="ra-card">
            <div class="ra-card-header text-center">
                <h3 class="mb-0"><i class="bi bi-pencil-square"></i> Editar Plan de Mejora</h3>
            </div>
            <div class="ra-card-body">
                <form asp-action="Editar" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AlumnoMatricula" />

                    <div class="mb-3">
                        <label class="ra-label fw-bold">Alumno</label>
                        <input class="ra-input" value="@Model.AlumnoMatricula" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="TutorId" class="ra-label fw-bold">Profesor Asignado</label>
                        <select asp-for="TutorId" class="ra-select">
                            <option value="">-- Selecciona un Profesor --</option>
                            @foreach (var prof in tutores)
                            {
                                <option value="@prof.Id">@prof.Nombre @prof.Apellidos - @prof.Especialidad</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Estado" class="ra-label fw-bold">Estado</label>
                        <select asp-for="Estado" class="ra-select">
                            <option value="Activo">Activo</option>
                            <option value="Cumplido">Cumplido</option>
                            <option value="Vencido">Vencido</option>
                            <option value="Cancelado">Cancelado</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Recomendaciones" class="ra-label fw-bold">Recomendaciones</label>
                        <textarea asp-for="Recomendaciones" class="ra-input" rows="4"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Metas" class="ra-label fw-bold">Metas</label>
                        <textarea asp-for="Metas" class="ra-input" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AccionesTomadas" class="ra-label fw-bold">Acciones Tomadas</label>
                        <textarea asp-for="AccionesTomadas" class="ra-input" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FechaCierre" class="ra-label fw-bold">Fecha de Cierre Estimada</label>
                        <input asp-for="FechaCierre" type="date" class="ra-input" />
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Detalles" asp-route-id="@Model.Id" class="ra-btn ra-btn-ghost">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-check-circle"></i> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
