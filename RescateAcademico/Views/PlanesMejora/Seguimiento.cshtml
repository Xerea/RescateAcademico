@model RescateAcademico.Models.PlanMejora
@{
    ViewData["Title"] = "Seguimiento del plan #" + Model.Id;
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Seguimiento del plan #" + Model.Id,
        Subtitle = $"{Model.Alumno?.Nombre} {Model.Alumno?.Apellidos} — Boleta {Model.AlumnoMatricula}",
        Icon = "bi-clock-history",
        IconVariant = "accent",
        BackUrl = Url.Action("Index"),
        BackLabel = "Planes de mejora"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card mb-4">
    <div class="ra-card-header">
        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Información General</h5>
    </div>
    <div class="ra-card-body">
        <div class="row">
            <div class="col-md-6">
                <p><strong>Profesor:</strong> @Model.Tutor?.Nombre @Model.Tutor?.Apellidos</p>
                <p><strong>Estado:</strong> <span class="ra-badge ra-badge-@(Model.Estado == "Activo" ? "primary" : Model.Estado == "Cumplido" ? "success" : Model.Estado == "Vencido" ? "danger" : "secondary")">@Model.Estado</span></p>
            </div>
            <div class="col-md-6">
                <p><strong>Fecha de creación:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy")</p>
                <p><strong>Fecha de cierre:</strong> @(Model.FechaCierre?.ToString("dd/MM/yyyy") ?? "No definida")</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="ra-card mb-4">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-lightbulb"></i> Recomendaciones</h5>
            </div>
            <div class="ra-card-body">@(Model.Recomendaciones ?? "Sin recomendaciones registradas.")</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="ra-card mb-4">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-trophy"></i> Metas</h5>
            </div>
            <div class="ra-card-body">@(Model.Metas ?? "Sin metas registradas.")</div>
        </div>
    </div>
</div>

<div class="ra-card mb-4">
    <div class="ra-card-header">
        <h5 class="mb-0"><i class="bi bi-list-check"></i> Acciones Tomadas / Bitácora</h5>
    </div>
    <div class="ra-card-body">
        @if (!string.IsNullOrEmpty(Model.AccionesTomadas))
        {
            <pre style="white-space: pre-wrap;">@Model.AccionesTomadas</pre>
        }
        else
        {
            <div class="ra-empty">
                <p>No hay acciones registradas aún.</p>
            </div>
        }
    </div>
</div>

<div class="mb-3">
    @if (!User.IsInRole("Autoridad"))
    {
        <a asp-action="Editar" asp-route-id="@Model.Id" class="ra-btn ra-btn-primary">
            <i class="bi bi-pencil"></i> Actualizar acciones
        </a>
    }
    <a asp-action="Detalles" asp-route-id="@Model.Id" class="ra-btn ra-btn-outline">
        <i class="bi bi-eye"></i> Ver detalles
    </a>
</div>
