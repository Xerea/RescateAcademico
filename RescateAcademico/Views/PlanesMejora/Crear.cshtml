@model RescateAcademico.Controllers.PlanMejoraViewModel
@{
    ViewData["Title"] = "Crear Plan de Mejora";
    Layout = "_Layout";
    var tutores = ViewBag.Tutores as List<RescateAcademico.Models.Tutor> ?? new List<RescateAcademico.Models.Tutor>();
    var tutorNombre = ViewBag.TutorNombre as string;
    var alumnoSeleccionado = ViewBag.AlumnoSeleccionado as RescateAcademico.Models.Alumno;
    var factoresRiesgo = ViewBag.FactoresRiesgo as List<string> ?? new List<string>();
    var esAdmin = User.IsInRole("Administrador");
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-controller="Profesor" asp-action="Index" class="ra-btn ra-btn-sm ra-btn-ghost"><i class="bi bi-arrow-left"></i> Mis Grupos</a>
        </div>
        <h2 class="fw-bold h4 mb-3">Nuevo Plan de Mejora</h2>

        @if (alumnoSeleccionado != null)
        {
            <div class="ra-card mb-3">
                <div class="ra-card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h5 class="fw-semibold mb-0">@alumnoSeleccionado.Nombre @alumnoSeleccionado.Apellidos</h5>
                            <p class="text-secondary small mb-0">@alumnoSeleccionado.Carrera &mdash; @alumnoSeleccionado.SemestreActual Semestre</p>
                        </div>
                        <ra-semaforo riesgo="@alumnoSeleccionado.RiesgoAcademico" size="sm"></ra-semaforo>
                    </div>
                    <div class="row g-2 text-center mt-2">
                        <div class="col-4">
                            <div class="fw-bold @(alumnoSeleccionado.PromedioGlobal >= 8 ? "ra-text-success" : alumnoSeleccionado.PromedioGlobal >= 6 ? "ra-text-warning" : "ra-text-danger")">@alumnoSeleccionado.PromedioGlobal.ToString("F2")</div>
                            <div class="text-secondary" style="font-size:0.6875rem;">Promedio</div>
                        </div>
                        <div class="col-4">
                            <div class="fw-bold">@(alumnoSeleccionado.MateriasReprobadas ?? 0)</div>
                            <div class="text-secondary" style="font-size:0.6875rem;">Reprobadas</div>
                        </div>
                        <div class="col-4">
                            <div class="fw-bold">@(alumnoSeleccionado.Ausencias ?? 0)</div>
                            <div class="text-secondary" style="font-size:0.6875rem;">Ausencias</div>
                        </div>
                    </div>
                    @if (factoresRiesgo.Any())
                    {
                        <div class="mt-2 pt-2" style="border-top:1px solid var(--ra-border-subtle);">
                            <div class="text-secondary" style="font-size:0.6875rem;">Factores detectados</div>
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                @foreach (var f in factoresRiesgo)
                                {
                                    <span class="ra-badge ra-badge-neutral" style="font-size:0.6875rem;">@f</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="ra-card">
            <div class="ra-card-header d-flex justify-content-between align-items-center">
                <span>Plan Sugerido</span>
                <button type="button" id="btnPersonalizar" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="togglePersonalizar()">
                    Personalizar
                </button>
            </div>
            <div class="ra-card-body">
                <div id="planPreview" class="mb-0" style="font-size:0.875rem;line-height:1.6;white-space:pre-wrap;min-height:80px;">
                    @Model.Recomendaciones
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <form asp-action="Crear" method="post" id="planForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AlumnoMatricula" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            @if (esAdmin)
            {
                <div class="mb-3">
                    <label asp-for="TutorId" class="ra-label">Profesor Asignado</label>
                    <select asp-for="TutorId" class="ra-select">
                        <option value="">-- Selecciona un Profesor --</option>
                        @foreach (var prof in tutores)
                        {
                            <option value="@prof.Id">@prof.Nombre @prof.Apellidos &mdash; @prof.Especialidad</option>
                        }
                    </select>
                </div>
            }
            else
            {
                <input type="hidden" asp-for="TutorId" />
            }

            <div class="ra-card mb-3">
                <div class="ra-card-header">
                    Tipo de Intervencion
                </div>
                <div class="ra-card-body">
                    <div class="row g-2">
                        <div class="col-sm-6">
                            <label class="ra-check-label d-flex align-items-center gap-2 mb-1">
                                <input type="checkbox" class="ra-checkbox intervencion-check" asp-for="AsesoriaAcademica" />
                                <span>Asesoria academica</span>
                            </label>
                            <label class="ra-check-label d-flex align-items-center gap-2 mb-1">
                                <input type="checkbox" class="ra-checkbox intervencion-check" asp-for="ControlAusencias" />
                                <span>Control de ausencias</span>
                            </label>
                            <label class="ra-check-label d-flex align-items-center gap-2 mb-1">
                                <input type="checkbox" class="ra-checkbox intervencion-check" asp-for="RegularizacionETS" />
                                <span>Regularizacion ETS</span>
                            </label>
                        </div>
                        <div class="col-sm-6">
                            <label class="ra-check-label d-flex align-items-center gap-2 mb-1">
                                <input type="checkbox" class="ra-checkbox intervencion-check" asp-for="ApoyoPsicologico" />
                                <span>Apoyo psicologico</span>
                            </label>
                            <label class="ra-check-label d-flex align-items-center gap-2 mb-1">
                                <input type="checkbox" class="ra-checkbox intervencion-check" asp-for="TutoriaPersonalizada" />
                                <span>Tutoria personalizada</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div id="personalizarSection" style="display:none;">
                <input type="hidden" asp-for="EsPersonalizado" id="esPersonalizadoInput" />
                <div class="mb-3">
                    <label asp-for="Recomendaciones" class="ra-label">Plan de accion</label>
                    <textarea asp-for="Recomendaciones" class="ra-input" rows="5" placeholder="Describe el plan de accion para el alumno..."></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="Metas" class="ra-label">Objetivos medibles</label>
                    <textarea asp-for="Metas" class="ra-input" rows="3" placeholder="Que resultados concretos se esperan..."></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="AccionesTomadas" class="ra-label">Primera intervencion</label>
                    <textarea asp-for="AccionesTomadas" class="ra-input" rows="2" placeholder="Accion inmediata realizada por el tutor..."></textarea>
                </div>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-sm-6">
                    <label asp-for="FechaCierre" class="ra-label">Fecha limite</label>
                    <input asp-for="FechaCierre" type="date" class="ra-input" />
                </div>
                <div class="col-sm-6 d-flex align-items-end">
                    <label class="ra-check-label d-flex align-items-center gap-2 mb-0" style="padding-bottom:2px;">
                        <input type="checkbox" class="ra-checkbox" asp-for="NotificarAlumno" />
                        <span>Notificar al alumno</span>
                    </label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <a asp-controller="Profesor" asp-action="Index" class="ra-btn ra-btn-ghost">
                    Cancelar
                </a>
                <button type="submit" class="ra-btn ra-btn-primary flex-fill">
                    Guardar Plan
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var esPersonalizado = false;

        function togglePersonalizar() {
            esPersonalizado = !esPersonalizado;
            var section = document.getElementById('personalizarSection');
            var btn = document.getElementById('btnPersonalizar');
            var hiddenInput = document.getElementById('esPersonalizadoInput');

            if (esPersonalizado) {
                section.style.display = 'block';
                btn.textContent = 'Usar plan sugerido';
                btn.classList.add('ra-btn-accent');
                hiddenInput.value = 'true';
            } else {
                section.style.display = 'none';
                btn.textContent = 'Personalizar';
                btn.classList.remove('ra-btn-accent');
                hiddenInput.value = 'false';
            }
        }

        var checkboxes = document.querySelectorAll('.intervencion-check');
        checkboxes.forEach(function(cb) {
            cb.addEventListener('change', updatePlanPreview);
        });

        function updatePlanPreview() {
            if (esPersonalizado) return;

            var types = [];
            if (document.querySelector('[name="AsesoriaAcademica"]')?.checked) types.push('Asesoria academica');
            if (document.querySelector('[name="ControlAusencias"]')?.checked) types.push('Control de ausencias');
            if (document.querySelector('[name="RegularizacionETS"]')?.checked) types.push('Regularizacion ETS');
            if (document.querySelector('[name="ApoyoPsicologico"]')?.checked) types.push('Apoyo psicologico');
            if (document.querySelector('[name="TutoriaPersonalizada"]')?.checked) types.push('Tutoria personalizada');

            var preview = document.getElementById('planPreview');
            var baseText = `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.Recomendaciones ?? ""))`;
            if (types.length > 0) {
                preview.textContent = baseText + '\n\nIntervenciones seleccionadas: ' + types.join(', ') + '.';
            } else {
                preview.textContent = baseText;
            }
        }
    </script>
}
