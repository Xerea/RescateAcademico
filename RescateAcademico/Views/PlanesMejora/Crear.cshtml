@model RescateAcademico.Controllers.PlanMejoraViewModel
@{
    ViewData["Title"] = "Crear Plan de Mejora";
    Layout = "_Layout";
    var alumnos = ViewBag.Alumnos as List<RescateAcademico.Models.Alumno> ?? new List<RescateAcademico.Models.Alumno>();
    var tutores = ViewBag.Tutores as List<RescateAcademico.Models.Tutor> ?? new List<RescateAcademico.Models.Tutor>();
    var tutorNombre = ViewBag.TutorNombre as string;
    var alumnoSeleccionado = ViewBag.AlumnoSeleccionado as RescateAcademico.Models.Alumno;
    var factoresRiesgo = ViewBag.FactoresRiesgo as List<string> ?? new List<string>();
    var esAdmin = User.IsInRole("Administrador");
    var rojos = alumnos.Where(a => a.RiesgoAcademico == "Rojo").ToList();
    var amarillos = alumnos.Where(a => a.RiesgoAcademico == "Amarillo").ToList();
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-controller="Profesor" asp-action="Index" class="ra-btn ra-btn-sm ra-btn-ghost"><i class="bi bi-arrow-left"></i> Mis Grupos</a>
        </div>

        <h1 class="fw-bold h3 mb-4"><i class="bi bi-journal-plus ra-text-accent me-2"></i>Crear Plan de Mejora</h1>

        @if (alumnoSeleccionado != null)
        {
            <div class="ra-card mb-4">
                <div class="ra-card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="fw-semibold mb-1">@alumnoSeleccionado.Nombre @alumnoSeleccionado.Apellidos</h5>
                            <p class="text-secondary small mb-2">@alumnoSeleccionado.Carrera &mdash; @alumnoSeleccionado.SemestreActual° Semestre</p>
                        </div>
                        <ra-semaforo riesgo="@alumnoSeleccionado.RiesgoAcademico" size="sm"></ra-semaforo>
                    </div>
                    <div class="row g-2 text-center">
                        <div class="col-4">
                            <div class="fw-bold @(alumnoSeleccionado.PromedioGlobal >= 8 ? "ra-text-success" : alumnoSeleccionado.PromedioGlobal >= 6 ? "ra-text-warning" : "ra-text-danger")">@alumnoSeleccionado.PromedioGlobal.ToString("F2")</div>
                            <div class="text-secondary" style="font-size:0.6875rem;">Promedio</div>
                        </div>
                        <div class="col-4">
                            <div class="fw-bold">@(alumnoSeleccionado.MateriasReprobadas ?? 0)</div>
                            <div class="text-secondary" style="font-size:0.6875rem;">Reprobadas</div>
                        </div>
                        <div class="col-4">
                            <div class="fw-bold">@(alumnoSeleccionado.Ausencias ?? 0)</div>
                            <div class="text-secondary" style="font-size:0.6875rem;">Ausencias</div>
                        </div>
                    </div>
                    @if (factoresRiesgo.Any())
                    {
                        <div class="mt-3 pt-3" style="border-top:1px solid var(--ra-border-subtle);">
                            <div class="text-secondary small mb-1">Factores detectados:</div>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var f in factoresRiesgo)
                                {
                                    <span class="ra-badge ra-badge-neutral" style="font-size:0.6875rem;">@f</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="ra-card">
            <div class="ra-card-body">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="AlumnoMatricula" class="ra-label">Alumno <span class="text-danger">*</span></label>
                        <select asp-for="AlumnoMatricula" class="ra-select" required>
                            <option value="">-- Selecciona un alumno --</option>
                            @if (rojos.Any())
                            {
                                <optgroup label="🔴 Riesgo Rojo">
                                    @foreach (var a in rojos)
                                    {
                                        <option value="@a.Matricula" selected="@(Model.AlumnoMatricula == a.Matricula ? "selected" : null)">
                                            @a.Apellidos, @a.Nombre — @a.Matricula
                                        </option>
                                    }
                                </optgroup>
                            }
                            @if (amarillos.Any())
                            {
                                <optgroup label="🟡 Riesgo Amarillo">
                                    @foreach (var a in amarillos)
                                    {
                                        <option value="@a.Matricula" selected="@(Model.AlumnoMatricula == a.Matricula ? "selected" : null)">
                                            @a.Apellidos, @a.Nombre — @a.Matricula
                                        </option>
                                    }
                                </optgroup>
                            }
                        </select>
                        <span asp-validation-for="AlumnoMatricula" class="text-danger small"></span>
                    </div>

                    @if (esAdmin)
                    {
                        <div class="mb-4">
                            <label asp-for="TutorId" class="ra-label">Profesor Asignado</label>
                            <select asp-for="TutorId" class="ra-select">
                                <option value="">-- Selecciona un Profesor --</option>
                                @foreach (var prof in tutores)
                                {
                                    <option value="@prof.Id">@prof.Nombre @prof.Apellidos — @prof.Especialidad</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" asp-for="TutorId" />
                        <div class="mb-4">
                            <label class="ra-label">Profesor Asignado</label>
                            <div class="ra-input d-flex align-items-center gap-2" style="background:var(--ra-border-subtle);">
                                <i class="bi bi-person-check text-secondary"></i>
                                <span class="fw-medium">@(tutorNombre ?? "Tú")</span>
                                <span class="ra-badge ra-badge-neutral ms-auto" style="font-size:0.6875rem;">Asignado</span>
                            </div>
                        </div>
                    }

                    <div class="mb-4">
                        <label asp-for="Recomendaciones" class="ra-label">Recomendaciones</label>
                        <textarea asp-for="Recomendaciones" class="ra-input" rows="5" placeholder="Ej: Asistir a asesorías de cálculo, organizar horario de estudio, mantener comunicación con el tutor..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Metas" class="ra-label">Metas</label>
                        <textarea asp-for="Metas" class="ra-input" rows="3" placeholder="Ej: Subir promedio a 8.0 en el siguiente parcial, no faltar más de 2 clases, aprobar todas las materias..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label asp-for="AccionesTomadas" class="ra-label">Acciones Tomadas (iniciales)</label>
                        <textarea asp-for="AccionesTomadas" class="ra-input" rows="2" placeholder="Ej: Primera reunión de seguimiento realizada con el estudiante..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label asp-for="FechaCierre" class="ra-label">Fecha de Cierre Estimada</label>
                        <input asp-for="FechaCierre" type="date" class="ra-input" />
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="ra-btn ra-btn-ghost">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="ra-btn ra-btn-primary flex-fill">
                            <i class="bi bi-check-circle"></i> Guardar Plan
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
