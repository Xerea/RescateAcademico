@model RescateAcademico.Controllers.PlanMejoraViewModel
@{
    ViewData["Title"] = "Crear Plan de Mejora";
    Layout = "_Layout";
    var alumnos = ViewBag.Alumnos as List<RescateAcademico.Models.Alumno> ?? new List<RescateAcademico.Models.Alumno>();
    var tutores = ViewBag.Tutores as List<RescateAcademico.Models.Tutor> ?? new List<RescateAcademico.Models.Tutor>();
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header text-center" style="background-color: #6c1d45; color: white;">
                <h3 class="mb-0"><i class="bi bi-journal-plus"></i> Crear Plan de Mejora</h3>
            </div>
            <div class="card-body">
                <form asp-action="Crear" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="AlumnoMatricula" class="form-label fw-bold">Alumno <span class="text-danger">*</span></label>
                        <select asp-for="AlumnoMatricula" class="form-select" required>
                            <option value="">-- Selecciona un alumno --</option>
                            @foreach (var alumno in alumnos)
                            {
                                <option value="@alumno.Matricula" selected="@(Model.AlumnoMatricula == alumno.Matricula ? "selected" : null)">
                                    @alumno.Apellidos, @alumno.Nombre (@alumno.Matricula) - Riesgo: @alumno.RiesgoAcademico
                                </option>
                            }
                        </select>
                        <span asp-validation-for="AlumnoMatricula" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TutorId" class="form-label fw-bold">Profesor Asignado</label>
                        <select asp-for="TutorId" class="form-select">
                            <option value="">-- Selecciona un Profesor --</option>
                            @foreach (var prof in tutores)
                            {
                                <option value="@prof.Id">@prof.Nombre @prof.Apellidos - @prof.Especialidad</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Recomendaciones" class="form-label fw-bold">Recomendaciones</label>
                        <textarea asp-for="Recomendaciones" class="form-control" rows="4" placeholder="Ej: Asistir a asesorías de cálculo, organizar horario de estudio..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Metas" class="form-label fw-bold">Metas</label>
                        <textarea asp-for="Metas" class="form-control" rows="3" placeholder="Ej: Subir promedio a 8.0 en el siguiente parcial, no faltar más de 2 clases..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AccionesTomadas" class="form-label fw-bold">Acciones Tomadas (iniciales)</label>
                        <textarea asp-for="AccionesTomadas" class="form-control" rows="2" placeholder="Ej: Primera reunión de seguimiento realizada..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FechaCierre" class="form-label fw-bold">Fecha de Cierre Estimada</label>
                        <input asp-for="FechaCierre" type="date" class="form-control" />
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary" style="background-color: #6c1d45; border-color: #6c1d45;">
                            <i class="bi bi-check-circle"></i> Guardar Plan
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}