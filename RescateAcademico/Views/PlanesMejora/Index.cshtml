@model IEnumerable<RescateAcademico.Models.PlanMejora>
@{
    ViewData["Title"] = "Planes de Mejora";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-journal-check ra-text-accent me-2"></i>Planes de Mejora</h1>
        <p class="text-secondary small mb-0">Seguimiento académico personalizado.</p>
    </div>
    @if (!User.IsInRole("Autoridad"))
    {
        <div class="col-auto">
            <a asp-action="Crear" class="ra-btn ra-btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Plan
            </a>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(ViewBag.MatriculaFiltro))
{
    <div class="ra-alert ra-alert-info mb-4" role="alert">
        <i class="bi bi-info-circle-fill fs-5"></i>
        <div>
            Filtrando por matrícula: <strong>@ViewBag.MatriculaFiltro</strong>
            <a asp-action="Index" class="ms-2">Ver todos</a>
        </div>
    </div>
}

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table" id="tablaPlanes">
                    <thead>
                        <tr>
                            <th>Alumno</th>
                            <th>Profesor</th>
                            <th>Fecha Creación</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var plan in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@plan.Alumno?.Nombre @plan.Alumno?.Apellidos</strong>
                                    <br />
                                    <span class="text-secondary small">@plan.AlumnoMatricula</span>
                                </td>
                                <td>@plan.Tutor?.Nombre @plan.Tutor?.Apellidos</td>
                                <td>@plan.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="ra-badge @(plan.Estado == "Activo" ? "ra-badge-primary" : plan.Estado == "Cumplido" ? "ra-badge-success" : plan.Estado == "Vencido" ? "ra-badge-danger" : "ra-badge-neutral")">
                                        @plan.Estado
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Detalles" asp-route-id="@plan.Id" class="ra-btn ra-btn-sm ra-btn-outline" title="Ver detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (!User.IsInRole("Autoridad"))
                                        {
                                            <a asp-action="Editar" asp-route-id="@plan.Id" class="ra-btn ra-btn-sm ra-btn-outline" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        <a asp-action="Seguimiento" asp-route-id="@plan.Id" class="ra-btn ra-btn-sm ra-btn-outline" title="Seguimiento">
                                            <i class="bi bi-clock-history"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-journal-x"></i>
                <p>No hay planes de mejora registrados.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaPlanes').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
