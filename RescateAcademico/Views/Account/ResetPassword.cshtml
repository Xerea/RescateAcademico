@model RescateAcademico.Controllers.ResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px; background: var(--ra-primary-soft);">
                <i class="bi bi-shield-lock-fill fs-2" style="color: var(--ra-primary);"></i>
            </div>
            <h1 class="fw-bold h3 mb-1">Nueva Contraseña</h1>
            <p class="text-secondary small">Establece una contraseña segura para tu cuenta</p>
        </div>

        <div class="ra-card">
            <div class="ra-card-body">
                <form asp-controller="Account" asp-action="ResetPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Code" />
                    <input type="hidden" asp-for="Email" />

                    <div class="mb-3">
                        <label asp-for="Password" class="ra-label">Nueva contraseña</label>
                        <input asp-for="Password" class="ra-input" type="password" placeholder="Tu nueva contraseña" required />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="ra-label">Confirmar contraseña</label>
                        <input asp-for="ConfirmPassword" class="ra-input" type="password" placeholder="Confirma tu contraseña" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">Guardar Contraseña</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
