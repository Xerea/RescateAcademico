@{
    ViewData["Title"] = "Cambiar contraseña";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="ra-card">
            <div class="ra-card-header text-center">
                <i class="bi bi-shield-lock fs-2 ra-text-primary mb-2 d-block"></i>
                <h5 class="fw-bold mb-0">Cambiar Contraseña</h5>
            </div>
            <div class="ra-card-body">
                <form method="post" asp-action="CambiarContrasena">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="ra-label">Contraseña actual</label>
                        <input type="password" name="currentPassword" class="ra-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Nueva contraseña</label>
                        <input type="password" name="newPassword" class="ra-input" required minlength="8" />
                    </div>
                    <div class="mb-4">
                        <label class="ra-label">Confirmar nueva contraseña</label>
                        <input type="password" name="confirmPassword" class="ra-input" required minlength="8" />
                    </div>
                    <button type="submit" class="ra-btn ra-btn-primary w-100">
                        <i class="bi bi-check-lg"></i> Actualizar Contraseña
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
