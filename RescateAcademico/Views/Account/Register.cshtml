@model RescateAcademico.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header text-center" style="background-color: #6c1d45; color: white;">
                    <h3 class="font-weight-light my-4">Registrar Nuevo Alumno</h3>
                </div>
                <div class="card-body">
                    <form asp-controller="Account" asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="nombre@alumno.ipn.mx" required />
                            <label asp-for="Email">Correo Institucional (Alumnos)</label>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control" type="password" placeholder="Contraseña" required />
                            <label asp-for="Password">Contraseña</label>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirmar Contraseña" required />
                            <label asp-for="ConfirmPassword">Confirmar Contraseña</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid mt-4 mb-0">
                            <button type="submit" class="btn btn-primary btn-block" style="background-color: #6c1d45; border-color: #6c1d45;">Crear Cuenta</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a asp-controller="Account" asp-action="Login" style="color: #6c1d45;">¿Ya tienes una cuenta? Inicia sesión</a></div>
                </div>
            </div>
        </div>
    </div>
</div>
