@model RescateAcademico.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Crear Cuenta";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header text-center" style="background-color: #6c1d45; color: white;">
                    <h3 class="font-weight-light my-4">Registrar Nueva Cuenta</h3>
                </div>
                <div class="card-body">
                    <form asp-controller="Account" asp-action="Register" method="post" id="registerForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Step 1: Cuenta -->
                        <div id="step1">
                            <h5 class="text-muted mb-3"><span class="badge bg-secondary">1/3</span> Datos de Cuenta</h5>
                            <div class="form-floating mb-3">
                                <input asp-for="Email" class="form-control" placeholder="nombre@alumno.ipn.mx" required />
                                <label asp-for="Email">Correo Institucional <span class="text-danger">*</span></label>
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="form-floating mb-3 position-relative">
                                <input asp-for="Password" class="form-control pe-5" id="regPassword" type="password" placeholder="Contraseña" required />
                                <label asp-for="Password">Contraseña <span class="text-danger">*</span></label>
                                <button type="button" class="btn btn-link position-absolute end-0 top-50 translate-middle-y me-2" style="z-index: 10;" onclick="toggleRegPassword('regPassword', 'regPassIcon')">
                                    <i class="bi bi-eye" id="regPassIcon"></i>
                                </button>
                                <span asp-validation-for="Password" class="text-danger"></span>
                                <div class="form-text">Mínimo 6 caracteres.</div>
                            </div>
                            <div class="form-floating mb-3 position-relative">
                                <input asp-for="ConfirmPassword" class="form-control pe-5" id="regConfirm" type="password" placeholder="Confirmar Contraseña" required />
                                <label asp-for="ConfirmPassword">Confirmar Contraseña <span class="text-danger">*</span></label>
                                <button type="button" class="btn btn-link position-absolute end-0 top-50 translate-middle-y me-2" style="z-index: 10;" onclick="toggleRegPassword('regConfirm', 'regConfirmIcon')">
                                    <i class="bi bi-eye" id="regConfirmIcon"></i>
                                </button>
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                            <div class="d-grid">
                                <button type="button" class="btn btn-primary" style="background-color: #6c1d45; border-color: #6c1d45;" onclick="showStep(2)">
                                    Siguiente <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Step 2: Identidad -->
                        <div id="step2" style="display:none;">
                            <h5 class="text-muted mb-3"><span class="badge bg-secondary">2/3</span> Identidad del Estudiante</h5>
                            <div class="form-floating mb-3">
                                <input asp-for="Matricula" class="form-control" placeholder="Boleta" required />
                                <label asp-for="Matricula">Boleta <span class="text-danger">*</span></label>
                                <span asp-validation-for="Matricula" class="text-danger"></span>
                            </div>
                            <div class="form-floating mb-3">
                                <input asp-for="Nombre" class="form-control" placeholder="Nombre" required />
                                <label asp-for="Nombre">Nombre <span class="text-danger">*</span></label>
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="form-floating mb-3">
                                <input asp-for="Apellidos" class="form-control" placeholder="Apellidos" required />
                                <label asp-for="Apellidos">Apellidos <span class="text-danger">*</span></label>
                                <span asp-validation-for="Apellidos" class="text-danger"></span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-outline-secondary" onclick="showStep(1)">
                                    <i class="bi bi-arrow-left"></i> Atrás
                                </button>
                                <button type="button" class="btn btn-primary" style="background-color: #6c1d45; border-color: #6c1d45;" onclick="showStep(3)">
                                    Siguiente <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Step 3: Académico -->
                        <div id="step3" style="display:none;">
                            <h5 class="text-muted mb-3"><span class="badge bg-secondary">3/3</span> Información Académica</h5>
                            <div class="form-floating mb-3">
                                <input asp-for="Carrera" class="form-control" placeholder="Carrera" />
                                <label asp-for="Carrera">Carrera</label>
                                <span asp-validation-for="Carrera" class="text-danger"></span>
                            </div>
                            <div class="form-floating mb-3">
                                <input asp-for="SemestreActual" class="form-control" type="number" min="1" max="20" placeholder="Semestre Actual" />
                                <label asp-for="SemestreActual">Semestre Actual</label>
                                <span asp-validation-for="SemestreActual" class="text-danger"></span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-outline-secondary" onclick="showStep(2)">
                                    <i class="bi bi-arrow-left"></i> Atrás
                                </button>
                                <button type="submit" class="btn btn-primary" style="background-color: #6c1d45; border-color: #6c1d45;">
                                    <i class="bi bi-check-circle"></i> Crear Cuenta
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a asp-controller="Account" asp-action="Login" style="color: #6c1d45;">¿Ya tienes una cuenta? Inicia sesión</a></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showStep(step) {
            document.getElementById('step1').style.display = step === 1 ? 'block' : 'none';
            document.getElementById('step2').style.display = step === 2 ? 'block' : 'none';
            document.getElementById('step3').style.display = step === 3 ? 'block' : 'none';
        }

        function toggleRegPassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
}