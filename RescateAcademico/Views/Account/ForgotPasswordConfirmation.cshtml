@{
    ViewData["Title"] = "Recuperación de Contraseña";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-6 col-lg-5">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px; background: var(--ra-primary-soft);">
                <i class="bi bi-envelope-check-fill fs-2" style="color: var(--ra-primary);"></i>
            </div>
            <h1 class="fw-bold h3 mb-1">Solicitud recibida</h1>
            <p class="text-secondary small">Instrucciones de recuperación generadas</p>
        </div>

        <div class="ra-card">
            <div class="ra-card-body text-center">
                <i class="bi bi-envelope-paper fs-1 text-secondary mb-3"></i>
                <p class="mb-3">
                    Si tu cuenta está registrada en el sistema, se ha generado un enlace de recuperación. Contacta a tu administrador académico para completar el restablecimiento de tu contraseña.
                </p>
                <p class="text-secondary small">
                    Por motivos de seguridad institucional, el restablecimiento de contraseñas se realiza a través de los coordinadores académicos.
                </p>
            </div>
            <div class="ra-card-footer text-center py-3">
                <a asp-action="Login" class="ra-btn ra-btn-ghost">
                    <i class="bi bi-arrow-left"></i> Volver al inicio de sesión
                </a>
            </div>
        </div>
    </div>
</div>
