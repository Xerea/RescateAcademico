@{
    ViewData["Title"] = "Token Solicitado";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-success mt-4">
                <h4 class="alert-heading text-center">¡Solicitud recibida!</h4>
                <p>Se ha enviado un enlace de recuperación a tu correo institucional.</p>
                <hr>
                <p class="mb-0 text-muted small">
                    <em>(Nota para desarrollo): Como no hay SMTP configurado, utiliza la liga impresa en la consola o este <a href="@TempData["ResetLink"]">Enlace Temporal de Reseteo</a>.</em>
                </p>
                <div class="text-center mt-3">
                   <a class="btn" style="background-color: #6c1d45; color: white;" asp-action="Login">Regresar al Login</a>
                </div>
            </div>
        </div>
    </div>
</div>
