@model dynamic
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnv
@{
    ViewData["Title"] = "Acceder";
    Layout = "_Layout";
    // Demo credentials are only displayed in non-production environments OR when
    // the env var SHOW_DEMO_CREDENTIALS is explicitly set to "true".
    var showDemoCredentials = HostEnv.IsDevelopment()
        || string.Equals(Configuration["SHOW_DEMO_CREDENTIALS"], "true", StringComparison.OrdinalIgnoreCase);
    var adminPw = Configuration["DEMO_ADMIN_PASSWORD"] ?? "Admin123!";
    var autoridadPw = Configuration["DEMO_AUTORIDAD_PASSWORD"] ?? "Autoridad123!";
    var tutorPw = Configuration["DEMO_TUTOR_PASSWORD"] ?? "Demo123!";
    var alumnoPw = Configuration["DEMO_ALUMNO_PASSWORD"] ?? "Demo123!";
    var recaptchaSiteKey = Configuration["RECAPTCHA_SITE_KEY"] ?? string.Empty;
    var enforceRecaptcha = string.Equals(Configuration["ENFORCE_RECAPTCHA"], "true", StringComparison.OrdinalIgnoreCase);
}

<div class="ra-auth-bg" aria-hidden="true"></div>
<div class="ra-auth-grid" aria-hidden="true"></div>

@if (enforceRecaptcha && !string.IsNullOrEmpty(recaptchaSiteKey))
{
    <script src="https://www.google.com/recaptcha/api.js?render=@recaptchaSiteKey"></script>
}

<div class="row justify-content-center align-items-center position-relative" style="min-height: 82vh; z-index: 1;">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px; background: var(--ra-primary-soft);">
                <i class="bi bi-mortarboard-fill fs-2" style="color: var(--ra-primary);"></i>
            </div>
            <h1 class="fw-bold h3 mb-1">Rescate Académico</h1>
            <p class="text-secondary small mb-0">Accede con tu correo institucional del IPN.</p>
        </div>

        <div class="ra-card" style="backdrop-filter: blur(12px); background: rgba(var(--ra-surface-rgb), 0.85);">
            <div class="ra-card-body">
                <form asp-controller="Account" asp-action="Login" method="post">
                    @if (ViewData["ReturnUrl"] != null)
                    {
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    }
                    <input type="hidden" name="g-recaptcha-response" id="g-recaptcha-response" />

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
                    {
                        <div class="ra-alert ra-alert-danger mb-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <div>
                                @foreach (var err in ViewData.ModelState[""]!.Errors)
                                {
                                    <div>@err.ErrorMessage</div>
                                }
                            </div>
                        </div>
                    }

                    <div id="recaptchaError" class="ra-alert ra-alert-danger mb-3" role="alert" style="display:none;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <div>No se pudo cargar la verificación de seguridad. Recarga la página e intenta de nuevo.</div>
                    </div>

                    <div class="mb-3">
                        <label for="inputEmail" class="ra-label">Correo institucional</label>
                        <input name="email" class="ra-input" id="inputEmail" type="email" autocomplete="username" placeholder="correo@alumno.ipn.mx" required autofocus />
                    </div>

                    <div class="mb-2">
                        <label for="inputPassword" class="ra-label">Contraseña</label>
                        <div class="position-relative">
                            <input name="password" class="ra-input pe-5" id="inputPassword" type="password" autocomplete="current-password" placeholder="••••••••" required />
                            <button type="button" class="btn btn-link position-absolute end-0 top-50 translate-middle-y me-2 p-1" style="color: var(--ra-text-muted); z-index: 10;" onclick="togglePassword()" aria-label="Mostrar u ocultar contraseña">
                                <i class="bi bi-eye" id="togglePasswordIcon"></i>
                            </button>
                        </div>
                        <div class="small mt-1" id="capsLockHint" style="display:none; color: var(--ra-warning);">
                            <i class="bi bi-exclamation-triangle-fill"></i> Bloq. Mayús está activado
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <label class="ra-check-label">
                            <input name="rememberMe" class="ra-checkbox" type="checkbox" value="true" />
                            <span class="small">Recordarme</span>
                        </label>
                        <a asp-controller="Account" asp-action="ForgotPassword" class="small" style="color: var(--ra-primary);">¿Olvidaste tu contraseña?</a>
                    </div>

                    <button type="submit" class="ra-btn ra-btn-primary w-100 ra-btn-lg mb-3">
                        <i class="bi bi-box-arrow-in-right"></i> Acceder
                    </button>

                    <div class="text-center d-grid gap-2">
                        <a asp-controller="Account" asp-action="Register" class="ra-btn ra-btn-outline w-100">
                            <i class="bi bi-person-plus"></i> Solicitar acceso
                        </a>
                        <span class="small text-secondary">Tu cuenta se vincula con un expediente existente antes de mostrar datos academicos.</span>
                    </div>

                </form>
            </div>
        </div>

        @if (showDemoCredentials)
        {
            <div class="accordion mt-3" id="demoCredentialsAccordion">
                <div class="accordion-item border-0 bg-transparent">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed bg-transparent shadow-none small text-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDemo" aria-expanded="false" aria-controls="collapseDemo">
                            <i class="bi bi-info-circle me-2"></i> Credenciales de demostración
                        </button>
                    </h2>
                    <div id="collapseDemo" class="accordion-collapse collapse" data-bs-parent="#demoCredentialsAccordion">
                        <div class="accordion-body p-0 pt-2">
                            <p class="text-secondary small text-center mb-2">Haz clic en una tarjeta para autocompletar.</p>
                            <div class="row g-2">
                                <div class="col-6">
                                    <button type="button" class="ra-card text-center py-2 w-100 border-0" data-demo-fill data-email="admin@ipn.mx" data-password="@adminPw" style="cursor:pointer;">
                                        <small class="text-secondary d-block fw-semibold">Administrador</small>
                                        <code class="small d-block">admin@ipn.mx</code>
                                        <code class="small">@adminPw</code>
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button type="button" class="ra-card text-center py-2 w-100 border-0" data-demo-fill data-email="autoridad@ipn.mx" data-password="@autoridadPw" style="cursor:pointer;">
                                        <small class="text-secondary d-block fw-semibold">Autoridad</small>
                                        <code class="small d-block">autoridad@ipn.mx</code>
                                        <code class="small">@autoridadPw</code>
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button type="button" class="ra-card text-center py-2 w-100 border-0" data-demo-fill data-email="profesor1@ipn.mx" data-password="@tutorPw" style="cursor:pointer;">
                                        <small class="text-secondary d-block fw-semibold">Profesor</small>
                                        <code class="small d-block">profesor1@ipn.mx</code>
                                        <code class="small">@tutorPw</code>
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button type="button" class="ra-card text-center py-2 w-100 border-0" data-demo-fill data-email="demo.alumno@alumno.ipn.mx" data-password="@alumnoPw" style="cursor:pointer;">
                                        <small class="text-secondary d-block fw-semibold">Alumno</small>
                                        <code class="small d-block">demo.alumno@alumno.ipn.mx</code>
                                        <code class="small">@alumnoPw</code>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword() {
            var input = document.getElementById('inputPassword');
            var icon = document.getElementById('togglePasswordIcon');
            var show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            icon.classList.toggle('bi-eye', !show);
            icon.classList.toggle('bi-eye-slash', show);
        }

        document.querySelectorAll('[data-demo-fill]').forEach(function (button) {
            button.addEventListener('click', function () {
                var e = document.getElementById('inputEmail');
                var p = document.getElementById('inputPassword');
                if (e) e.value = button.dataset.email || '';
                if (p) p.value = button.dataset.password || '';
                if (p) p.focus();
            });
        });

        // CapsLock detector (password field only)
        (function () {
            var pw = document.getElementById('inputPassword');
            var hint = document.getElementById('capsLockHint');
            if (!pw || !hint) return;
            function onKey(e) {
                if (typeof e.getModifierState === 'function') {
                    hint.style.display = e.getModifierState('CapsLock') ? 'block' : 'none';
                }
            }
            pw.addEventListener('keydown', onKey);
            pw.addEventListener('keyup', onKey);
            pw.addEventListener('blur', function () { hint.style.display = 'none'; });
        })();

        // reCAPTCHA v3 only blocks login when explicitly enforced.
        var siteKey = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(recaptchaSiteKey));
        var enforceRecaptcha = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(enforceRecaptcha));
        if (enforceRecaptcha && siteKey) {
            document.forms[0].addEventListener('submit', function (e) {
                e.preventDefault();
                var form = this;
                var error = document.getElementById('recaptchaError');
                if (!window.grecaptcha || typeof grecaptcha.ready !== 'function' || typeof grecaptcha.execute !== 'function') {
                    if (error) error.style.display = '';
                    return;
                }

                if (error) error.style.display = 'none';
                grecaptcha.ready(function () {
                    grecaptcha.execute(siteKey, { action: 'login' }).then(function (token) {
                        document.getElementById('g-recaptcha-response').value = token;
                        form.submit();
                    }).catch(function () {
                        if (error) error.style.display = '';
                    });
                });
            });
        }
    </script>
}
