@model dynamic
@{
    ViewData["Title"] = "Inicio de Sesión";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header text-center" style="background-color: #6c1d45; color: white;">
                    <h3 class="font-weight-light my-4">Rescate Académico</h3>
                    <h4 class="mb-0">Acceso al sistema</h4>
                </div>
                <div class="card-body">
                    <form asp-controller="Account" asp-action="Login" method="post">
                        @if (ViewData["ReturnUrl"] != null)
                        {
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                        }
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input name="email" class="form-control" id="inputEmail" type="email" placeholder="correo@alumno.ipn.mx" required />
                            <label for="inputEmail">Correo institucional</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input name="password" class="form-control" id="inputPassword" type="password" placeholder="Contraseña" required />
                            <label for="inputPassword">Contraseña</label>
                        </div>
                        <div class="form-check mb-3">
                            <input name="rememberMe" class="form-check-input" id="inputRememberPassword" type="checkbox" value="true" />
                            <label class="form-check-label" for="inputRememberPassword">Recordar sesión en este equipo</label>
                        </div>
                        <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                            <a class="small" asp-controller="Account" asp-action="ForgotPassword" style="color: #6c1d45;">¿Olvidaste tu contraseña?</a>
                            <button type="submit" class="btn btn-primary" style="background-color: #6c1d45; border-color: #6c1d45;">Acceder</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small text-muted mb-2">Aviso: El acceso es validado según el sistema escolar central.</div>
                    <div class="small text-muted">Las credenciales son gestionadas institucionalmente. Si no tienes cuenta, contacta a administración.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="accordion" id="demoCredentialsAccordion">
            <div class="accordion-item border-0 shadow-sm">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDemo" aria-expanded="false" aria-controls="collapseDemo" style="background-color: #f8f9fa; color: #6c1d45;">
                        <i class="bi bi-info-circle-fill me-2"></i> Credenciales de demostración
                    </button>
                </h2>
                <div id="collapseDemo" class="accordion-collapse collapse" data-bs-parent="#demoCredentialsAccordion">
                    <div class="accordion-body">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <div class="card h-100 border-0 bg-light">
                                    <div class="card-body p-2">
                                        <small class="text-muted d-block fw-bold">Administrador</small>
                                        <code class="small d-block">admin@ipn.mx</code>
                                        <code class="small d-block">Admin123!</code>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card h-100 border-0 bg-light">
                                    <div class="card-body p-2">
                                        <small class="text-muted d-block fw-bold">Autoridad Académica</small>
                                        <code class="small d-block">autoridad@ipn.mx</code>
                                        <code class="small d-block">Autoridad123!</code>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card h-100 border-0 bg-light">
                                    <div class="card-body p-2">
                                        <small class="text-muted d-block fw-bold">Profesor / Tutor</small>
                                        <code class="small d-block">profesor1@ipn.mx</code>
                                        <code class="small d-block">Demo123!</code>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card h-100 border-0 bg-light">
                                    <div class="card-body p-2">
                                        <small class="text-muted d-block fw-bold">Alumno</small>
                                        <code class="small d-block">demo.alumno@alumno.ipn.mx</code>
                                        <code class="small d-block">Demo123!</code>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
