@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center text-center" style="min-height: 80vh;">
    <div class="col-md-8 col-lg-6">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px; background: var(--ra-danger-soft);">
            <i class="bi bi-shield-exclamation fs-2" style="color: var(--ra-danger);"></i>
        </div>
        <h1 class="display-1 fw-bold text-danger">403</h1>
        <h2 class="mb-4">Acceso Denegado</h2>
        <p class="lead">Lo sentimos, tu rol no tiene los permisos suficientes para acceder a esta sección o realizar esta acción.</p>
        <p class="text-secondary">Si consideras que es un error, contacta al administrador del sistema.</p>
        <a asp-controller="Dashboard" asp-action="Index" class="ra-btn ra-btn-primary mt-4">Volver al Inicio</a>
    </div>
</div>
