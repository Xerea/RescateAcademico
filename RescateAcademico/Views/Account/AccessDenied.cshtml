@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_Layout";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="display-1 fw-bold text-danger">403</h1>
            <h2 class="mb-4">Acceso Denegado</h2>
            <p class="lead">Lo sentimos, tu rol no tiene los permisos suficientes para acceder a esta sección o realizar esta acción.</p>
            <p>Si consideras que es un error, contacta al administrador del sistema.</p>
            <a asp-controller="Dashboard" asp-action="Index" class="btn mt-4 text-white" style="background-color: #6c1d45;">Volver al Inicio</a>
        </div>
    </div>
</div>
