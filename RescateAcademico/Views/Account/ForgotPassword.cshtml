@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px; background: var(--ra-primary-soft);">
                <i class="bi bi-key-fill fs-2" style="color: var(--ra-primary);"></i>
            </div>
            <h1 class="fw-bold h3 mb-1">Recuperar Contraseña</h1>
            <p class="text-secondary small">Restablece el acceso a tu cuenta institucional</p>
        </div>

        <div class="ra-card">
            <div class="ra-card-header text-center">
                <h4 class="my-3">Recuperar contraseña</h4>
            </div>
            <div class="ra-card-body">
                <p class="text-secondary small">
                    Ingresa tu correo institucional y, si existe en el sistema, te enviaremos una liga única para restablecer tu contraseña.
                </p>
                <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label for="inputEmail" class="ra-label">Correo institucional</label>
                        <input name="email" class="ra-input" id="inputEmail" type="email" placeholder="correo@alumno.ipn.mx" required />
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">Enviar enlace de recuperación</button>
                    </div>
                </form>
            </div>
            <div class="ra-card-footer text-center py-3">
                <a class="small" asp-controller="Account" asp-action="Login">Volver al inicio de sesión</a>
            </div>
        </div>
    </div>
</div>
