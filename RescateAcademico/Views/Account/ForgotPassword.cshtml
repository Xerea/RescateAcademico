@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header text-center" style="background-color: #6c1d45; color: white;">
                    <h4 class="my-3">Recuperar Contraseña</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Ingresa tu correo institucional y enviaremos una liga única de reseteo válida por 10 minutos (HU-RA-02).</p>
                    <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="form-floating mb-3">
                            <input name="email" class="form-control" id="inputEmail" type="email" placeholder="name@example.com" required />
                            <label for="inputEmail">Correo Institucional</label>
                        </div>
                        <div class="d-grid gap-2">
                           <button type="submit" class="btn text-white" style="background-color: #6c1d45;">Enviar Enlace de Recuperación</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <a class="small" asp-controller="Account" asp-action="Login">Volver al inicio de sesión</a>
                </div>
            </div>
        </div>
    </div>
</div>
