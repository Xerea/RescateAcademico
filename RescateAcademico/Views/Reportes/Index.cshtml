@{
    ViewData["Title"] = "Reportes";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Reportes",
        Subtitle = "Estadísticas, predicciones y exportes institucionales.",
        Icon = "bi-bar-chart-line",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-tabs" role="tablist">
    <button class="ra-tab active" data-bs-toggle="tab" data-bs-target="#tab-estadisticas" role="tab" aria-selected="true">
        <i class="bi bi-bar-chart"></i> Estadísticas
    </button>
    <button class="ra-tab" data-bs-toggle="tab" data-bs-target="#tab-predicciones" role="tab" aria-selected="false">
        <i class="bi bi-brain"></i> Predicciones IA
    </button>
    <button class="ra-tab" data-bs-toggle="tab" data-bs-target="#tab-exportes" role="tab" aria-selected="false">
        <i class="bi bi-download"></i> Exportes
    </button>
</div>

<div class="tab-content">
    <div class="tab-pane fade show active" id="tab-estadisticas" role="tabpanel">
        <div class="row g-3">
            <div class="col-md-6 col-lg-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-bar-chart-line fs-1 mb-3" style="color: var(--ra-primary);"></i>
                        <h5 class="fw-semibold">Tablero estadístico</h5>
                        <p class="text-secondary small">Métricas globales de desempeño.</p>
                        <a asp-controller="Estadisticas" asp-action="Index" class="ra-btn ra-btn-primary w-100">Ver</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-pie-chart fs-1 mb-3" style="color: var(--ra-accent);"></i>
                        <h5 class="fw-semibold">Reporte por carrera</h5>
                        <p class="text-secondary small">Análisis desagregado por programa.</p>
                        <a asp-controller="Estadisticas" asp-action="PorCarrera" class="ra-btn ra-btn-outline w-100">Ver</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-file-earmark-text fs-1 mb-3" style="color: var(--ra-info);"></i>
                        <h5 class="fw-semibold">Reporte institucional</h5>
                        <p class="text-secondary small">Documento imprimible.</p>
                        <a asp-controller="Export" asp-action="ReporteImprimible" target="_blank" class="ra-btn ra-btn-outline w-100">Generar PDF</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="tab-predicciones" role="tabpanel">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-brain fs-1 mb-3" style="color: var(--ra-primary);"></i>
                        <h5 class="fw-semibold">Predicciones de deserción</h5>
                        <p class="text-secondary small">Análisis heurístico e IA para todo el alumnado.</p>
                        <a asp-controller="Predicciones" asp-action="Index" class="ra-btn ra-btn-primary w-100">Ver</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-journal-check fs-1 mb-3" style="color: var(--ra-accent);"></i>
                        <h5 class="fw-semibold">Planes de mejora</h5>
                        <p class="text-secondary small">Seguimiento de intervenciones activas.</p>
                        <a asp-controller="PlanesMejora" asp-action="Index" class="ra-btn ra-btn-outline w-100">Ver</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-shield-exclamation fs-1 mb-3" style="color: var(--ra-info);"></i>
                        <h5 class="fw-semibold">Panel COSECOVI</h5>
                        <p class="text-secondary small">Incidentes, reincidencia y seguimiento disciplinario.</p>
                        <a asp-controller="Cosecovi" asp-action="Dashboard" class="ra-btn ra-btn-outline w-100">Ver</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="tab-exportes" role="tabpanel">
        <div class="row g-3">
            <div class="col-md-6 col-lg-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-people fs-1 mb-3" style="color: var(--ra-primary);"></i>
                        <h5 class="fw-semibold">Alumnos (CSV)</h5>
                        <p class="text-secondary small">Catálogo completo del alumnado.</p>
                        <a asp-controller="Export" asp-action="AlumnosCSV" class="ra-btn ra-btn-primary w-100">Descargar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-send-check fs-1 mb-3" style="color: var(--ra-accent);"></i>
                        <h5 class="fw-semibold">Postulaciones (CSV)</h5>
                        <p class="text-secondary small">Todas las postulaciones registradas.</p>
                        <a asp-controller="Export" asp-action="PostulacionesCSV" class="ra-btn ra-btn-outline w-100">Descargar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-exclamation-triangle fs-1 mb-3" style="color: var(--ra-danger);"></i>
                        <h5 class="fw-semibold">Alumnos en riesgo (CSV)</h5>
                        <p class="text-secondary small">Solo estudiantes con riesgo académico.</p>
                        <a asp-controller="Export" asp-action="AlumnosEnRiesgoCSV" class="ra-btn ra-btn-outline w-100">Descargar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
