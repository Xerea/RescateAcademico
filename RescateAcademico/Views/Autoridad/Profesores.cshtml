@model IEnumerable<RescateAcademico.Models.Tutor>
@{
    ViewData["Title"] = "Catálogo de Profesores";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;"><i class="bi bi-person-badge"></i> Catálogo de Profesores</h2>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover" id="tablaProfesores">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Nombre</th>
                            <th>No. Empleado</th>
                            <th>Email</th>
                            <th>Especialidad</th>
                            <th>Grupos Asignados</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Nombre @item.Apellidos</td>
                                <td><span class="badge bg-light text-dark border">@item.NumeroEmpleado</span></td>
                                <td>@item.Email</td>
                                <td>@item.Especialidad</td>
                                <td>
                                    @{
                                        var grupos = ViewBag.GruposPorProfesor.ContainsKey(item.Id) ? ViewBag.GruposPorProfesor[item.Id] : null;
                                    }
                                    @if (grupos?.Any() == true)
                                    {
                                        @foreach (var g in grupos)
                                        {
                                            <span class="badge bg-info me-1">@g.Clave</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin grupos</span>
                                    }
                                </td>
                                <td>
                                    @if (item.EstaActivo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-person-badge fs-1 text-muted"></i>
                <p class="text-muted mt-2">No hay profesores registrados</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaProfesores').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}