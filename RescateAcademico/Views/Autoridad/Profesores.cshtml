@model IEnumerable<RescateAcademico.Models.Tutor>
@{
    ViewData["Title"] = "Catálogo de profesores";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Catálogo de profesores",
        Subtitle = "Plantilla docente y grupos asignados.",
        Icon = "bi-person-badge",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards mb-0" id="tablaProfesores">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>No. empleado</th>
                            <th>Email</th>
                            <th>Especialidad</th>
                            <th>Grupos</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="Nombre">@item.Nombre @item.Apellidos</td>
                                <td data-label="No. empleado"><span class="ra-badge ra-badge-neutral">@item.NumeroEmpleado</span></td>
                                <td data-label="Email" class="ra-mono small">@item.Email</td>
                                <td data-label="Especialidad">@item.Especialidad</td>
                                <td data-label="Grupos">
                                    @{
                                        var grupos = ViewBag.GruposPorProfesor.ContainsKey(item.Id) ? ViewBag.GruposPorProfesor[item.Id] : null;
                                    }
                                    @if (grupos?.Any() == true)
                                    {
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var g in grupos)
                                            {
                                                <span class="ra-badge ra-badge-info">@g.Clave</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-secondary small">Sin grupos</span>
                                    }
                                </td>
                                <td data-label="Estado">
                                    @if (item.EstaActivo)
                                    {
                                        <span class="ra-badge ra-badge-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-danger">Inactivo</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-person-badge"></i>
                <p>No hay profesores registrados.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaProfesores').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json' },
                pageLength: 25
            });
        });
    </script>
}
