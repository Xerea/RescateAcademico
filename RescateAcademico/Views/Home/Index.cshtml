@{
    ViewData["Title"] = "Rescate Académico";
    Layout = "_Layout";
}

<style>
    .ra-hero {
        min-height: calc(100vh - 140px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem 1rem;
    }
    .ra-hero-icon {
        width: 80px;
        height: 80px;
        border-radius: 24px;
        background: var(--ra-accent-soft);
        color: var(--ra-accent);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
    }
    .ra-hero h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 1rem;
        color: var(--ra-text);
    }
    .ra-hero p {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: var(--ra-text-secondary);
        max-width: 520px;
        margin: 0 auto 2rem;
        line-height: 1.6;
    }
    .ra-hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 2.5rem;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: var(--ra-radius);
        background: var(--ra-accent);
        color: #fff;
        border: none;
        text-decoration: none;
        transition: var(--ra-transition);
    }
    .ra-hero-cta:hover {
        background: var(--ra-accent-hover);
        color: #fff;
        transform: translateY(-2px);
    }
    .ra-hero-meta {
        margin-top: 3rem;
        font-size: 0.8125rem;
        color: var(--ra-text-muted);
    }
    .ra-hero-meta span {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: var(--ra-radius-full);
        background: var(--ra-border-subtle);
        margin: 0 0.25rem;
    }
</style>

<div class="ra-hero ra-fade-in">
    <div class="ra-hero-icon">
        <i class="bi bi-mortarboard-fill"></i>
    </div>
    <h1>Rescate Académico</h1>
    <p>
        Sistema institucional de monitoreo y prevención de deserción estudiantil del
        <strong>CECyT No. 13</strong>, Instituto Politécnico Nacional.
    </p>

    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <a asp-controller="Account" asp-action="Login" class="ra-hero-cta">
            <i class="bi bi-box-arrow-in-right"></i> Acceder al Sistema
        </a>
    }
    else
    {
        <a asp-controller="Dashboard" asp-action="Index" class="ra-hero-cta">
            <i class="bi bi-grid-1x2"></i> Ir al Panel
        </a>
    }

    <div class="ra-hero-meta">
        <span><i class="bi bi-shield-check"></i> Seguro</span>
        <span><i class="bi bi-cpu"></i> IA Integrada</span>
        <span><i class="bi bi-graph-up"></i> Analítica en Tiempo Real</span>
    </div>
</div>
