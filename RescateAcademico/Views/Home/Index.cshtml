@inject IWebHostEnvironment Env
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Rescate Académico";
    Layout = "_Layout";
    var isAuth = User.Identity?.IsAuthenticated == true;
    var demoAccessEnabled = Env.IsDevelopment()
        || string.Equals(Configuration["SHOW_DEMO_ACCESS"], "true", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Configuration["SHOW_DEMO_CREDENTIALS"], "true", StringComparison.OrdinalIgnoreCase);
}

<style>
    .ra-landing {
        min-height: calc(100vh - 190px);
        display: grid;
        align-content: center;
        gap: 1rem;
        padding: clamp(1rem, 3vw, 2rem) 0 2.5rem;
        position: relative;
        z-index: 1;
    }
    .ra-landing::before {
        content: "";
        position: absolute;
        inset: -12% -10% auto -10%;
        height: min(560px, 72vh);
        border-radius: 0 0 48px 48px;
        background:
            radial-gradient(42% 48% at 12% 16%, color-mix(in srgb, var(--ra-primary) 22%, transparent), transparent 72%),
            radial-gradient(38% 42% at 90% 10%, color-mix(in srgb, var(--ra-accent) 20%, transparent), transparent 74%),
            linear-gradient(135deg, color-mix(in srgb, var(--ra-primary) 10%, transparent), transparent 58%);
        filter: blur(2px);
        opacity: 0.9;
        pointer-events: none;
        z-index: -1;
    }
    .ra-landing-board {
        display: grid;
        grid-template-columns: minmax(280px, 0.82fr) minmax(360px, 1.18fr);
        gap: 1rem;
        align-items: stretch;
    }
    .ra-landing-card {
        border: 1px solid var(--ra-border);
        border-radius: 24px;
        background: color-mix(in srgb, var(--ra-surface) 88%, transparent);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.22);
        overflow: hidden;
    }
    [data-bs-theme="dark"] .ra-landing-card {
        background: color-mix(in srgb, var(--ra-surface) 84%, transparent);
    }
    .ra-landing-profile {
        display: grid;
        align-content: end;
        min-height: 310px;
        padding: clamp(1.25rem, 3vw, 1.8rem);
        background:
            linear-gradient(145deg, color-mix(in srgb, var(--ra-accent) 18%, transparent), transparent 58%),
            color-mix(in srgb, var(--ra-surface) 92%, transparent);
    }
    .ra-landing-icon {
        width: 74px;
        height: 74px;
        border-radius: 20px;
        background: var(--ra-accent-soft);
        color: var(--ra-accent);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        margin-bottom: 1.5rem;
    }
    .ra-landing h1 {
        font-size: clamp(2.1rem, 5vw, 3.45rem);
        font-weight: 800;
        letter-spacing: 0;
        line-height: 1.05;
        margin-bottom: 0.8rem;
        color: var(--ra-text);
    }
    .ra-landing h1 .ra-landing-accent {
        background: linear-gradient(120deg, var(--ra-primary), var(--ra-accent));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    .ra-landing-lead {
        font-size: 1rem;
        color: var(--ra-text-secondary);
        max-width: 46ch;
        margin: 0;
        line-height: 1.5;
    }
    .ra-landing-panel {
        display: grid;
        grid-template-rows: auto 1fr;
        min-height: 310px;
    }
    .ra-landing-panel-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 1.25rem 1.4rem;
        border-bottom: 1px solid var(--ra-border);
        background: color-mix(in srgb, var(--ra-surface-raised) 78%, transparent);
    }
    .ra-landing-panel-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 0;
    }
    .ra-landing-mini-icon {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 12px;
        background: var(--ra-primary-soft);
        color: var(--ra-primary);
        flex: 0 0 auto;
    }
    .ra-landing-panel-title strong,
    .ra-landing-panel-title small {
        display: block;
    }
    .ra-landing-panel-title small {
        color: var(--ra-text-secondary);
        margin-top: 0.1rem;
    }
    .ra-landing-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.65rem;
        padding: clamp(1.25rem, 3vw, 1.8rem);
        align-content: center;
        align-items: center;
    }
    .ra-landing-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        min-width: 168px;
        padding: 0.85rem 1.3rem;
        font-size: 0.98rem;
        font-weight: 600;
        border-radius: 14px;
        background: var(--ra-accent);
        color: #fff;
        border: none;
        text-decoration: none;
        transition: var(--ra-transition);
    }
    .ra-landing-cta:hover {
        background: var(--ra-accent-hover);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: var(--ra-shadow-lg);
    }
    .ra-landing-cta-secondary {
        background: transparent;
        color: var(--ra-text);
        border: 1px solid var(--ra-border);
    }
    .ra-landing-cta-secondary:hover {
        background: var(--ra-surface-raised);
        color: var(--ra-text);
        border-color: var(--ra-primary);
    }
    .ra-landing-features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        margin: 1rem 0 0;
        text-align: left;
    }
    .ra-landing-feature {
        background: color-mix(in srgb, var(--ra-surface) 92%, transparent);
        border: 1px solid var(--ra-border);
        border-radius: var(--ra-radius-lg);
        padding: 1.25rem 1.5rem;
        transition: var(--ra-transition);
    }
    .ra-landing-feature:hover {
        border-color: var(--ra-primary);
        box-shadow: var(--ra-shadow-md);
    }
    .ra-landing-feature i {
        font-size: 1.4rem;
        color: var(--ra-primary);
        margin-bottom: 0.5rem;
        display: block;
    }
    .ra-landing-feature h5 {
        font-weight: 600;
        font-size: 0.975rem;
        margin: 0 0 0.25rem;
    }
    .ra-landing-feature p {
        margin: 0;
        color: var(--ra-text-secondary);
        font-size: 0.8125rem;
    }
    .ra-demo-access {
        width: 100%;
        margin: 1rem 0 0;
        padding: 1rem;
        border: 1px solid var(--ra-border);
        border-radius: var(--ra-radius-lg);
        background: color-mix(in srgb, var(--ra-surface) 88%, transparent);
        box-shadow: var(--ra-shadow);
    }
    .ra-demo-access-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
    }
    .ra-demo-persona {
        display: grid;
        gap: 0.5rem;
        padding: 1rem;
        border: 1px solid var(--ra-border);
        border-radius: var(--ra-radius);
        background: var(--ra-surface-raised);
        text-align: left;
    }
    .ra-demo-persona strong,
    .ra-demo-persona small {
        display: block;
    }
    .ra-demo-persona small {
        color: var(--ra-text-secondary);
    }
    @@media (max-width: 991.98px) {
        .ra-landing {
            min-height: auto;
        }
        .ra-landing-board {
            grid-template-columns: 1fr;
        }
        .ra-landing-profile,
        .ra-landing-panel {
            min-height: 0;
        }
    }
    @@media (max-width: 767.98px) {
        .ra-demo-access-grid {
            grid-template-columns: 1fr;
        }
        .ra-landing::before {
            inset-inline: -20%;
        }
        .ra-landing-panel-head {
            align-items: flex-start;
            flex-direction: column;
        }
        .ra-landing-actions {
            justify-content: stretch;
        }
        .ra-landing-cta {
            width: 100%;
        }
    }
</style>

<div class="ra-landing">
    <div class="ra-landing-board">
        <section class="ra-landing-card ra-landing-profile" aria-label="Presentación">
            <div class="ra-landing-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <h1>
                Rescate<br>
                <span class="ra-landing-accent">Académico.</span>
            </h1>
            <p class="ra-landing-lead">
                Plataforma del <strong>CECyT No. 13</strong> para detectar riesgo académico
                a tiempo y coordinar acciones entre profesores, autoridades y alumnos.
            </p>
        </section>

        <section class="ra-landing-card ra-landing-panel" aria-label="Acceso principal">
            <div class="ra-landing-panel-head">
                <div class="ra-landing-panel-title">
                    <span class="ra-landing-mini-icon"><i class="bi bi-grid-1x2"></i></span>
                    <span>
                        <strong>Entrada rápida</strong>
                        <small>Acceso seguro, demo o solicitud de cuenta.</small>
                    </span>
                </div>
                <span class="ra-badge ra-badge-primary">IPN · CECyT 13</span>
            </div>
            <div class="ra-landing-actions">
                @if (!isAuth)
                {
                    <a asp-controller="Account" asp-action="Login" class="ra-landing-cta">
                        <i class="bi bi-box-arrow-in-right"></i> Acceder
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="ra-landing-cta ra-landing-cta-secondary">
                        <i class="bi bi-person-plus"></i> Solicitar acceso
                    </a>
                }
                else
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="ra-landing-cta">
                        <i class="bi bi-grid-1x2"></i> Ir al panel
                    </a>
                    @if (User.IsInRole("Alumno"))
                    {
                        <a asp-controller="PerfilAcademico" asp-action="MiPerfil" class="ra-landing-cta ra-landing-cta-secondary">
                            <i class="bi bi-person-badge"></i> Mi perfil
                        </a>
                    }
                }
            </div>
        </section>
    </div>

    <div class="ra-landing-features">
        <div class="ra-landing-feature">
            <i class="bi bi-shield-check"></i>
            <h5>Cuenta verificada</h5>
            <p>La cuenta se vincula con un expediente académico existente.</p>
        </div>
        <div class="ra-landing-feature">
            <i class="bi bi-cpu"></i>
            <h5>Alertas tempranas</h5>
            <p>Identifica estudiantes que necesitan atención antes del cierre.</p>
        </div>
        <div class="ra-landing-feature">
            <i class="bi bi-graph-up-arrow"></i>
            <h5>Seguimiento claro</h5>
            <p>Indicadores por carrera, grupo, semestre y estado académico.</p>
        </div>
    </div>

    @if (!isAuth && demoAccessEnabled)
    {
        <section class="ra-demo-access" aria-label="Acceso demo">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <div class="text-start">
                    <div class="ra-heading mb-1">Demo guiada</div>
                    <p class="text-secondary small mb-0">Explora el producto con perfiles seguros para presentación pública.</p>
                </div>
                <span class="ra-badge ra-badge-info">Sin credenciales visibles</span>
            </div>
            <div class="ra-demo-access-grid">
                <form asp-controller="Account" asp-action="DemoLogin" method="post" class="ra-demo-persona">
                    <input type="hidden" name="role" value="alumno" />
                    <i class="bi bi-person-badge fs-4" style="color:var(--ra-primary);"></i>
                    <strong>Alumno</strong>
                    <small>Perfil académico, convocatorias y postulaciones.</small>
                    <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline">Entrar como alumno</button>
                </form>
                <form asp-controller="Account" asp-action="DemoLogin" method="post" class="ra-demo-persona">
                    <input type="hidden" name="role" value="tutor" />
                    <i class="bi bi-person-workspace fs-4" style="color:var(--ra-accent);"></i>
                    <strong>Profesor</strong>
                    <small>Grupos, riesgo, copilotaje e intervenciones.</small>
                    <button type="submit" class="ra-btn ra-btn-sm ra-btn-primary">Entrar como profesor</button>
                </form>
                <form asp-controller="Account" asp-action="DemoLogin" method="post" class="ra-demo-persona">
                    <input type="hidden" name="role" value="autoridad" />
                    <i class="bi bi-bar-chart-line fs-4" style="color:var(--ra-info);"></i>
                    <strong>Autoridad</strong>
                    <small>Panel institucional y seguimiento agregado.</small>
                    <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline">Entrar como autoridad</button>
                </form>
            </div>
            <div class="ra-alert ra-alert-info mt-3 mb-0 text-start">
                <i class="bi bi-qr-code"></i>
                <div>
                    <strong>Prueba de registro público:</strong>
                    usa la boleta <code>2024000001</code> con el código <code>RESCATE-1</code> para simular la vinculación inmediata de un expediente.
                </div>
            </div>
        </section>
    }
</div>
