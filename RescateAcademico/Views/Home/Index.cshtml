@inject IWebHostEnvironment Env
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Rescate Académico";
    Layout = "_Layout";
    var isAuth = User.Identity?.IsAuthenticated == true;
    var demoAccessEnabled = Env.IsDevelopment()
        || string.Equals(Configuration["SHOW_DEMO_ACCESS"], "true", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Configuration["SHOW_DEMO_CREDENTIALS"], "true", StringComparison.OrdinalIgnoreCase);
}

<style>
    .ra-landing {
        min-height: calc(100vh - 160px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 3rem 1rem 2rem;
        position: relative;
        z-index: 1;
    }
    .ra-landing-icon {
        width: 84px;
        height: 84px;
        border-radius: 22px;
        background: var(--ra-accent-soft);
        color: var(--ra-accent);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 1.75rem;
    }
    .ra-landing h1 {
        font-size: clamp(2.2rem, 5vw, 3.75rem);
        font-weight: 800;
        letter-spacing: 0;
        line-height: 1.05;
        margin-bottom: 1.1rem;
        color: var(--ra-text);
    }
    .ra-landing h1 .ra-landing-accent {
        background: linear-gradient(120deg, var(--ra-primary), var(--ra-accent));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    .ra-landing-lead {
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: var(--ra-text-secondary);
        max-width: 560px;
        margin: 0 auto 2rem;
        line-height: 1.5;
    }
    .ra-landing-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.85rem 2.25rem;
        font-size: 1.05rem;
        font-weight: 600;
        border-radius: var(--ra-radius);
        background: var(--ra-accent);
        color: #fff;
        border: none;
        text-decoration: none;
        transition: var(--ra-transition);
    }
    .ra-landing-cta:hover {
        background: var(--ra-accent-hover);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: var(--ra-shadow-lg);
    }
    .ra-landing-cta-secondary {
        background: transparent;
        color: var(--ra-text);
        border: 1px solid var(--ra-border);
    }
    .ra-landing-cta-secondary:hover {
        background: var(--ra-surface-raised);
        color: var(--ra-text);
        border-color: var(--ra-primary);
    }
    .ra-landing-features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        max-width: 900px;
        margin: 3.5rem auto 0;
        text-align: left;
    }
    .ra-landing-feature {
        background: var(--ra-surface);
        border: 1px solid var(--ra-border);
        border-radius: var(--ra-radius-lg);
        padding: 1.25rem 1.5rem;
        transition: var(--ra-transition);
    }
    .ra-landing-feature:hover {
        border-color: var(--ra-primary);
        box-shadow: var(--ra-shadow-md);
    }
    .ra-landing-feature i {
        font-size: 1.4rem;
        color: var(--ra-primary);
        margin-bottom: 0.5rem;
        display: block;
    }
    .ra-landing-feature h5 {
        font-weight: 600;
        font-size: 0.975rem;
        margin: 0 0 0.25rem;
    }
    .ra-landing-feature p {
        margin: 0;
        color: var(--ra-text-secondary);
        font-size: 0.8125rem;
    }
    .ra-demo-access {
        max-width: 900px;
        width: 100%;
        margin: 2rem auto 0;
        padding: 1rem;
        border: 1px solid var(--ra-border);
        border-radius: var(--ra-radius-lg);
        background: color-mix(in srgb, var(--ra-surface) 88%, transparent);
        box-shadow: var(--ra-shadow);
    }
    .ra-demo-access-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
    }
    .ra-demo-persona {
        display: grid;
        gap: 0.5rem;
        padding: 1rem;
        border: 1px solid var(--ra-border);
        border-radius: var(--ra-radius);
        background: var(--ra-surface-raised);
        text-align: left;
    }
    .ra-demo-persona strong,
    .ra-demo-persona small {
        display: block;
    }
    .ra-demo-persona small {
        color: var(--ra-text-secondary);
    }
    @@media (max-width: 767.98px) {
        .ra-demo-access-grid {
            grid-template-columns: 1fr;
        }
        .ra-landing-cta {
            width: 100%;
        }
    }
</style>

<div class="ra-auth-bg" aria-hidden="true"></div>

<div class="ra-landing">
    <div class="ra-landing-icon">
        <i class="bi bi-mortarboard-fill"></i>
    </div>
    <h1>
        Rescate<br>
        <span class="ra-landing-accent">Académico.</span>
    </h1>
    <p class="ra-landing-lead">
        Sigue tu progreso. Recupera estudiantes. Plataforma del
        <strong>CECyT No. 13</strong>, IPN, para detectar riesgo académico a
        tiempo y coordinar intervenciones entre profesores, autoridades y alumnos.
    </p>

    @if (!isAuth)
    {
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a asp-controller="Account" asp-action="Login" class="ra-landing-cta">
                <i class="bi bi-box-arrow-in-right"></i> Acceder
            </a>
            <a asp-controller="Account" asp-action="Register" class="ra-landing-cta ra-landing-cta-secondary">
                <i class="bi bi-person-plus"></i> Solicitar acceso
            </a>
        </div>
    }
    else
    {
        <a asp-controller="Dashboard" asp-action="Index" class="ra-landing-cta">
            <i class="bi bi-grid-1x2"></i> Ir al panel
        </a>
    }

    <div class="ra-landing-features">
        <div class="ra-landing-feature">
            <i class="bi bi-shield-check"></i>
            <h5>Cuenta verificada</h5>
            <p>La cuenta se vincula con un expediente académico existente.</p>
        </div>
        <div class="ra-landing-feature">
            <i class="bi bi-cpu"></i>
            <h5>Alertas tempranas</h5>
            <p>Modelo predictivo que identifica alumnos en riesgo.</p>
        </div>
        <div class="ra-landing-feature">
            <i class="bi bi-graph-up-arrow"></i>
            <h5>Indicadores en vivo</h5>
            <p>Dashboards de desempeño por carrera, grupo y semestre.</p>
        </div>
    </div>

    @if (!isAuth && demoAccessEnabled)
    {
        <section class="ra-demo-access" aria-label="Acceso demo">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <div class="text-start">
                    <div class="ra-heading mb-1">Demo guiada</div>
                    <p class="text-secondary small mb-0">Explora el producto con personas seguras para presentación pública.</p>
                </div>
                <span class="ra-badge ra-badge-info">Sin credenciales visibles</span>
            </div>
            <div class="ra-demo-access-grid">
                <form asp-controller="Account" asp-action="DemoLogin" method="post" class="ra-demo-persona">
                    <input type="hidden" name="role" value="alumno" />
                    <i class="bi bi-person-badge fs-4" style="color:var(--ra-primary);"></i>
                    <strong>Alumno</strong>
                    <small>Perfil académico, convocatorias y postulaciones.</small>
                    <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline">Entrar como alumno</button>
                </form>
                <form asp-controller="Account" asp-action="DemoLogin" method="post" class="ra-demo-persona">
                    <input type="hidden" name="role" value="tutor" />
                    <i class="bi bi-person-workspace fs-4" style="color:var(--ra-accent);"></i>
                    <strong>Profesor</strong>
                    <small>Grupos, riesgo, copilotaje e intervenciones.</small>
                    <button type="submit" class="ra-btn ra-btn-sm ra-btn-primary">Entrar como profesor</button>
                </form>
                <form asp-controller="Account" asp-action="DemoLogin" method="post" class="ra-demo-persona">
                    <input type="hidden" name="role" value="autoridad" />
                    <i class="bi bi-bar-chart-line fs-4" style="color:var(--ra-info);"></i>
                    <strong>Autoridad</strong>
                    <small>Panel institucional y seguimiento agregado.</small>
                    <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline">Entrar como autoridad</button>
                </form>
            </div>
            <div class="ra-alert ra-alert-info mt-3 mb-0 text-start">
                <i class="bi bi-qr-code"></i>
                <div>
                    <strong>Prueba de registro público:</strong>
                    usa la boleta <code>2024000001</code> con el código <code>RESCATE-1</code> para simular la vinculación inmediata de un expediente.
                </div>
            </div>
        </section>
    }
</div>
