@{
    ViewData["Title"] = "Inicio - Rescate Académico";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="text-center mb-5">
            <i class="bi bi-mortarboard-fill fs-1" style="color: #6c1d45;"></i>
            <h1 class="display-4 mt-3" style="color: #6c1d45;">Rescate Académico</h1>
            <p class="lead text-muted">Acceso institucional para alumnos, tutores, administracion y autoridad academica.</p>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-person-badge fs-1 mb-3" style="color: #6c1d45;"></i>
                        <h5 class="card-title">Perfil Académico</h5>
                        <p class="card-text text-muted small">Consulta tu situación académica integral, promedio y carga actual.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-traffic-light fs-1 mb-3" style="color: #6c1d45;"></i>
                        <h5 class="card-title">Semáforo de Riesgo</h5>
                        <p class="card-text text-muted small">Identificación visual del nivel de riesgo académico de cada alumno.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-megaphone fs-1 mb-3" style="color: #6c1d45;"></i>
                        <h5 class="card-title">Convocatorias</h5>
                        <p class="card-text text-muted small">Explora proyectos de servicio social, investigación y apoyo académico.</p>
                    </div>
                </div>
            </div>
        </div>

        @if (!User.Identity?.IsAuthenticated ?? true)
        {
            <div class="text-center">
                <p class="text-muted mb-3">¿Ya tienes una cuenta?</p>
                <a asp-controller="Account" asp-action="Login" class="btn btn-lg px-5" style="background-color: #6c1d45; color: white;">
                    <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
                </a>
            </div>
        }
        else
        {
            <div class="text-center">
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-lg px-5" style="background-color: #6c1d45; color: white;">
                    <i class="bi bi-grid-1x2"></i> Ir al Dashboard
                </a>
            </div>
        }
    </div>
</div>
