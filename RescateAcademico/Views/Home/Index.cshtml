@{
    ViewData["Title"] = "Rescate Académico";
    Layout = "_Layout";
    var isAuth = User.Identity?.IsAuthenticated == true;
}

<style>
    .ra-hero {
        min-height: calc(100vh - 160px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 3rem 1rem 2rem;
        position: relative;
        z-index: 1;
    }
    .ra-hero-icon {
        width: 84px;
        height: 84px;
        border-radius: 22px;
        background: var(--ra-accent-soft);
        color: var(--ra-accent);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 1.75rem;
    }
    .ra-hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.05;
        margin-bottom: 1.1rem;
        color: var(--ra-text);
    }
    .ra-hero h1 .ra-hero-accent {
        background: linear-gradient(120deg, var(--ra-primary), var(--ra-accent));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    .ra-hero-lead {
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: var(--ra-text-secondary);
        max-width: 560px;
        margin: 0 auto 2rem;
        line-height: 1.5;
    }
    .ra-hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 2.25rem;
        font-size: 1.05rem;
        font-weight: 600;
        border-radius: var(--ra-radius);
        background: var(--ra-accent);
        color: #fff;
        border: none;
        text-decoration: none;
        transition: var(--ra-transition);
    }
    .ra-hero-cta:hover {
        background: var(--ra-accent-hover);
        color: #fff;
        transform: translateY(-2px);
        box-shadow: var(--ra-shadow-lg);
    }
    .ra-hero-features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        max-width: 900px;
        margin: 3.5rem auto 0;
        text-align: left;
    }
    .ra-hero-feature {
        background: var(--ra-surface);
        border: 1px solid var(--ra-border);
        border-radius: var(--ra-radius-lg);
        padding: 1.25rem 1.5rem;
        transition: var(--ra-transition);
    }
    .ra-hero-feature:hover {
        border-color: var(--ra-primary);
        box-shadow: var(--ra-shadow-md);
    }
    .ra-hero-feature i {
        font-size: 1.4rem;
        color: var(--ra-primary);
        margin-bottom: 0.5rem;
        display: block;
    }
    .ra-hero-feature h5 {
        font-weight: 600;
        font-size: 0.975rem;
        margin: 0 0 0.25rem;
    }
    .ra-hero-feature p {
        margin: 0;
        color: var(--ra-text-secondary);
        font-size: 0.8125rem;
    }
</style>

<div class="ra-auth-bg" aria-hidden="true"></div>

<div class="ra-hero">
    <div class="ra-hero-icon">
        <i class="bi bi-mortarboard-fill"></i>
    </div>
    <h1>
        Sigue tu progreso.<br>
        <span class="ra-hero-accent">Recupera estudiantes.</span>
    </h1>
    <p class="ra-hero-lead">
        Plataforma del <strong>CECyT No. 13</strong>, IPN, para detectar riesgo
        académico a tiempo y coordinar intervenciones entre profesores,
        autoridades y alumnos.
    </p>

    @if (!isAuth)
    {
        <a asp-controller="Account" asp-action="Login" class="ra-hero-cta">
            <i class="bi bi-box-arrow-in-right"></i> Acceder al Sistema
        </a>
    }
    else
    {
        <a asp-controller="Dashboard" asp-action="Index" class="ra-hero-cta">
            <i class="bi bi-grid-1x2"></i> Ir al Panel
        </a>
    }

    <div class="ra-hero-features">
        <div class="ra-hero-feature">
            <i class="bi bi-shield-check"></i>
            <h5>Cuenta institucional</h5>
            <p>Acceso con tu correo @@ipn.mx o @@alumno.ipn.mx.</p>
        </div>
        <div class="ra-hero-feature">
            <i class="bi bi-cpu"></i>
            <h5>Alertas tempranas</h5>
            <p>Modelo predictivo que identifica alumnos en riesgo.</p>
        </div>
        <div class="ra-hero-feature">
            <i class="bi bi-graph-up-arrow"></i>
            <h5>Indicadores en vivo</h5>
            <p>Dashboards de desempeño por carrera, grupo y semestre.</p>
        </div>
    </div>
</div>
