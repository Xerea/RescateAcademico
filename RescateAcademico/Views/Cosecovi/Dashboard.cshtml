@model RescateAcademico.Controllers.CosecoviDashboardViewModel
@{
    ViewData["Title"] = "COSECOVI";
    Layout = "_Layout";
    var actionsHtml = $"<a href=\"{Url.Action("Index")}\" class=\"ra-btn ra-btn-outline\"><i class=\"bi bi-list-ul\"></i> Ver incidentes</a>"
        + $"<a href=\"{Url.Action("Crear")}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-plus-circle\"></i> Nuevo incidente</a>";
    var header = new PageHeader
    {
        Title = "Panel COSECOVI",
        Subtitle = "Seguridad escolar, disciplina, violencia, sustancias y seguimiento institucional.",
        Icon = "bi-shield-exclamation",
        IconVariant = "accent",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-warning">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Registrados</div>
                    <div class="ra-stat-value" data-countup="@Model.Registrados">@Model.Registrados</div>
                </div>
                <i class="bi bi-clipboard-plus ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-info">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Seguimiento</div>
                    <div class="ra-stat-value" data-countup="@Model.EnSeguimiento">@Model.EnSeguimiento</div>
                </div>
                <i class="bi bi-arrow-repeat ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-danger">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Alta prioridad</div>
                    <div class="ra-stat-value" data-countup="@Model.AltaPrioridad">@Model.AltaPrioridad</div>
                </div>
                <i class="bi bi-exclamation-octagon ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-accent">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Total</div>
                    <div class="ra-stat-value" data-countup="@Model.Total">@Model.Total</div>
                </div>
                <i class="bi bi-shield-check ra-stat-icon"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="ra-card h-100">
            <div class="ra-card-header"><i class="bi bi-pie-chart"></i> Incidentes por tipo</div>
            <div class="ra-card-body">
                @if (Model.PorTipoIncidente.Any())
                {
                    var tiposOrdenados = Model.PorTipoIncidente
                        .OrderByDescending(x => x.Value)
                        .ThenBy(x => x.Key)
                        .ToList();
                    var totalTipos = tiposOrdenados.Sum(x => x.Value);
                    <div class="ra-cosecovi-chart-frame">
                        <canvas id="chartTipos"></canvas>
                    </div>
                    <div class="ra-cosecovi-type-list mt-3">
                        @foreach (var item in tiposOrdenados)
                        {
                            var index = tiposOrdenados.IndexOf(item);
                            var pct = totalTipos > 0 ? Math.Round(item.Value * 100m / totalTipos, 1) : 0;
                            <div class="ra-cosecovi-type-row">
                                <span class="ra-cosecovi-swatch" data-swatch="@index"></span>
                                <span class="ra-cosecovi-type-name">@item.Key</span>
                                <strong>@item.Value</strong>
                                <span class="text-secondary small">@pct%</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="ra-empty py-4"><i class="bi bi-pie-chart"></i><p>Sin datos de incidentes.</p></div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="ra-card h-100">
            <div class="ra-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-exclamation-octagon ra-text-danger"></i> Reincidencia (2+ reportes)</span>
                <span class="ra-badge ra-badge-danger">@Model.Reincidentes.Count</span>
            </div>
            <div class="ra-card-body p-0">
                @if (Model.Reincidentes.Any())
                {
                    <div class="table-responsive">
                        <table class="table ra-table ra-table-cards mb-0">
                            <thead>
                                <tr>
                                    <th>Alumno</th>
                                    <th>Carrera</th>
                                    <th>Reportes</th>
                                    <th>Ultimo</th>
                                    <th data-orderable="false"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Reincidentes)
                                {
                                    <tr>
                                        <td data-label="Alumno">
                                            <strong>@c.Nombre</strong><br />
                                            <span class="ra-mono text-secondary small">@c.Matricula</span>
                                        </td>
                                        <td data-label="Carrera" class="text-secondary">@c.Carrera</td>
                                        <td data-label="Reportes"><span class="ra-badge ra-badge-danger">@c.TotalReportes</span></td>
                                        <td data-label="Ultimo" class="text-secondary small">@c.UltimoReporte.ToString("dd/MM/yyyy")</td>
                                        <td data-label="Accion">
                                            <a asp-action="Alumno" asp-route-matricula="@c.Matricula" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver historial">
                                                <i class="bi bi-clock-history"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="ra-empty py-4"><i class="bi bi-check-circle ra-text-success"></i><p>No hay reincidencias registradas.</p></div>
                }
            </div>
        </div>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-clock-history"></i> Incidentes recientes</span>
        <a asp-action="Index" class="ra-btn ra-btn-sm ra-btn-ghost">Ver todos <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="ra-card-body p-0">
        @if (Model.Recientes.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards mb-0">
                    <thead>
                        <tr>
                            <th>Alumno</th>
                            <th>Tipo</th>
                            <th>Gravedad</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th data-orderable="false"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Recientes)
                        {
                            var gravedadClass = r.Gravedad is "Alta" or "Critica" ? "ra-badge-danger" : r.Gravedad == "Media" ? "ra-badge-warning" : "ra-badge-neutral";
                            <tr>
                                <td data-label="Alumno">@(r.Alumno != null ? $"{r.Alumno.Nombre} {r.Alumno.Apellidos}" : r.AlumnoMatricula)</td>
                                <td data-label="Tipo">@r.TipoIncidente</td>
                                <td data-label="Gravedad"><span class="ra-badge @gravedadClass">@r.Gravedad</span></td>
                                <td data-label="Estado"><partial name="_CosecoviEstadoBadge" model="r.Estado" /></td>
                                <td data-label="Fecha" class="text-secondary small">@r.FechaIncidente.ToString("dd/MM/yyyy")</td>
                                <td data-label="Accion">
                                    <a asp-action="Detalle" asp-route-id="@r.Id" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver reporte">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty py-4"><i class="bi bi-inbox"></i><p>No hay incidentes registrados.</p></div>
        }
    </div>
</div>

@section Scripts {
    <style>
        .ra-cosecovi-chart-frame {
            position: relative;
            min-height: 280px;
            height: clamp(280px, 34vw, 380px);
        }

        .ra-cosecovi-type-list {
            display: grid;
            gap: .5rem;
        }

        .ra-cosecovi-type-row {
            display: grid;
            grid-template-columns: 14px minmax(0, 1fr) auto auto;
            align-items: center;
            gap: .6rem;
            padding: .45rem .55rem;
            border: 1px solid var(--ra-border);
            border-radius: 8px;
            background: var(--ra-surface-subtle);
        }

        .ra-cosecovi-swatch {
            width: 14px;
            height: 14px;
            border-radius: 4px;
            box-shadow: inset 0 0 0 2px rgba(255,255,255,.72), 0 0 0 1px rgba(0,0,0,.38);
        }

        .ra-cosecovi-type-name {
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-weight: 600;
        }

        .ra-cosecovi-swatch[data-swatch="0"] { background: #e11d48; }
        .ra-cosecovi-swatch[data-swatch="1"] { background: #2563eb; }
        .ra-cosecovi-swatch[data-swatch="2"] { background: #f59e0b; }
        .ra-cosecovi-swatch[data-swatch="3"] { background: #16a34a; }
        .ra-cosecovi-swatch[data-swatch="4"] { background: #7c3aed; }
        .ra-cosecovi-swatch[data-swatch="5"] { background: #0891b2; }
        .ra-cosecovi-swatch[data-swatch="6"] { background: #ea580c; }
        .ra-cosecovi-swatch[data-swatch="7"] { background: #be123c; }
        .ra-cosecovi-swatch[data-swatch="8"] { background: #4f46e5; }
        .ra-cosecovi-swatch[data-swatch="9"] { background: #0f766e; }

        @@media (max-width: 576px) {
            .ra-cosecovi-chart-frame {
                min-height: 340px;
            }

            .ra-cosecovi-type-row {
                grid-template-columns: 14px minmax(0, 1fr) auto;
            }

            .ra-cosecovi-type-row .small {
                display: none;
            }
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        @if (Model.PorTipoIncidente.Any())
        {
            <text>
            (function () {
                var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                var labelColor = isDark ? '#e5e7eb' : '#111827';
                var mutedColor = isDark ? '#94a3b8' : '#64748b';
                var gridColor = isDark ? 'rgba(148, 163, 184, .22)' : 'rgba(15, 23, 42, .12)';
                var borderColor = isDark ? '#020617' : '#ffffff';
                Chart.defaults.color = mutedColor;
                Chart.defaults.font.family = "'Inter', sans-serif";
                var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PorTipoIncidente.OrderByDescending(x => x.Value).ThenBy(x => x.Key).Select(x => x.Key)));
                var values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PorTipoIncidente.OrderByDescending(x => x.Value).ThenBy(x => x.Key).Select(x => x.Value)));
                var palette = ['#e11d48', '#2563eb', '#f59e0b', '#16a34a', '#7c3aed', '#0891b2', '#ea580c', '#be123c', '#4f46e5', '#0f766e'];
                var valueLabelPlugin = {
                    id: 'cosecoviValueLabels',
                    afterDatasetsDraw: function (chart) {
                        var ctx = chart.ctx;
                        var meta = chart.getDatasetMeta(0);
                        ctx.save();
                        ctx.fillStyle = labelColor;
                        ctx.font = '700 12px Inter, sans-serif';
                        ctx.textBaseline = 'middle';
                        meta.data.forEach(function (bar, index) {
                            var value = values[index];
                            ctx.textAlign = 'left';
                            ctx.fillText(value, bar.x + 8, bar.y);
                        });
                        ctx.restore();
                    }
                };

                new Chart(document.getElementById('chartTipos'), {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Incidentes',
                            data: values,
                            backgroundColor: values.map(function (_, index) { return palette[index % palette.length]; }),
                            borderColor: borderColor,
                            borderWidth: 2,
                            borderRadius: 8,
                            borderSkipped: false,
                            barPercentage: .72,
                            categoryPercentage: .72
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        layout: { padding: { right: 28 } },
                        scales: {
                            x: {
                                beginAtZero: true,
                                ticks: { precision: 0, color: mutedColor },
                                grid: { color: gridColor },
                                border: { display: false }
                            },
                            y: {
                                ticks: { color: labelColor, font: { weight: 700 } },
                                grid: { display: false },
                                border: { display: false }
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        var total = values.reduce(function (acc, value) { return acc + value; }, 0);
                                        var pct = total > 0 ? ((ctx.raw * 100) / total).toFixed(1) : '0.0';
                                        return ' ' + ctx.raw + ' incidentes · ' + pct + '%';
                                    }
                                }
                            }
                        }
                    },
                    plugins: [valueLabelPlugin]
                });
            })();
            </text>
        }
    </script>
}
