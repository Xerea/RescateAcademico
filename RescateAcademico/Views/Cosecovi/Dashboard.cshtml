@model RescateAcademico.Controllers.CosecoviDashboardViewModel
@{
    ViewData["Title"] = "COSECOVI";
    Layout = "_Layout";
    var actionsHtml = $"<a href=\"{Url.Action("Index")}\" class=\"ra-btn ra-btn-outline\"><i class=\"bi bi-list-ul\"></i> Ver incidentes</a>"
        + $"<a href=\"{Url.Action("Crear")}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-plus-circle\"></i> Nuevo incidente</a>";
    var header = new PageHeader
    {
        Title = "Panel COSECOVI",
        Subtitle = "Seguridad escolar, disciplina, violencia, sustancias y seguimiento institucional.",
        Icon = "bi-shield-exclamation",
        IconVariant = "accent",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-warning">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Registrados</div>
                    <div class="ra-stat-value" data-countup="@Model.Registrados">@Model.Registrados</div>
                </div>
                <i class="bi bi-clipboard-plus ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-info">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Seguimiento</div>
                    <div class="ra-stat-value" data-countup="@Model.EnSeguimiento">@Model.EnSeguimiento</div>
                </div>
                <i class="bi bi-arrow-repeat ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-danger">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Alta prioridad</div>
                    <div class="ra-stat-value" data-countup="@Model.AltaPrioridad">@Model.AltaPrioridad</div>
                </div>
                <i class="bi bi-exclamation-octagon ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-accent">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Total</div>
                    <div class="ra-stat-value" data-countup="@Model.Total">@Model.Total</div>
                </div>
                <i class="bi bi-shield-check ra-stat-icon"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="ra-card h-100">
            <div class="ra-card-header"><i class="bi bi-pie-chart"></i> Incidentes por tipo</div>
            <div class="ra-card-body">
                @if (Model.PorTipoIncidente.Any())
                {
                    <canvas id="chartTipos" height="240"></canvas>
                }
                else
                {
                    <div class="ra-empty py-4"><i class="bi bi-pie-chart"></i><p>Sin datos de incidentes.</p></div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="ra-card h-100">
            <div class="ra-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-exclamation-octagon ra-text-danger"></i> Reincidencia (2+ reportes)</span>
                <span class="ra-badge ra-badge-danger">@Model.Reincidentes.Count</span>
            </div>
            <div class="ra-card-body p-0">
                @if (Model.Reincidentes.Any())
                {
                    <div class="table-responsive">
                        <table class="table ra-table ra-table-cards mb-0">
                            <thead>
                                <tr>
                                    <th>Alumno</th>
                                    <th>Carrera</th>
                                    <th>Reportes</th>
                                    <th>Ultimo</th>
                                    <th data-orderable="false"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Reincidentes)
                                {
                                    <tr>
                                        <td data-label="Alumno">
                                            <strong>@c.Nombre</strong><br />
                                            <span class="ra-mono text-secondary small">@c.Matricula</span>
                                        </td>
                                        <td data-label="Carrera" class="text-secondary">@c.Carrera</td>
                                        <td data-label="Reportes"><span class="ra-badge ra-badge-danger">@c.TotalReportes</span></td>
                                        <td data-label="Ultimo" class="text-secondary small">@c.UltimoReporte.ToString("dd/MM/yyyy")</td>
                                        <td data-label="Accion">
                                            <a asp-action="Alumno" asp-route-matricula="@c.Matricula" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver historial">
                                                <i class="bi bi-clock-history"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="ra-empty py-4"><i class="bi bi-check-circle ra-text-success"></i><p>No hay reincidencias registradas.</p></div>
                }
            </div>
        </div>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-clock-history"></i> Incidentes recientes</span>
        <a asp-action="Index" class="ra-btn ra-btn-sm ra-btn-ghost">Ver todos <i class="bi bi-arrow-right"></i></a>
    </div>
    <div class="ra-card-body p-0">
        @if (Model.Recientes.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards mb-0">
                    <thead>
                        <tr>
                            <th>Alumno</th>
                            <th>Tipo</th>
                            <th>Gravedad</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th data-orderable="false"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Recientes)
                        {
                            var gravedadClass = r.Gravedad is "Alta" or "Critica" ? "ra-badge-danger" : r.Gravedad == "Media" ? "ra-badge-warning" : "ra-badge-neutral";
                            <tr>
                                <td data-label="Alumno">@(r.Alumno != null ? $"{r.Alumno.Nombre} {r.Alumno.Apellidos}" : r.AlumnoMatricula)</td>
                                <td data-label="Tipo">@r.TipoIncidente</td>
                                <td data-label="Gravedad"><span class="ra-badge @gravedadClass">@r.Gravedad</span></td>
                                <td data-label="Estado"><partial name="_CosecoviEstadoBadge" model="r.Estado" /></td>
                                <td data-label="Fecha" class="text-secondary small">@r.FechaIncidente.ToString("dd/MM/yyyy")</td>
                                <td data-label="Accion">
                                    <a asp-action="Detalle" asp-route-id="@r.Id" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver reporte">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty py-4"><i class="bi bi-inbox"></i><p>No hay incidentes registrados.</p></div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        @if (Model.PorTipoIncidente.Any())
        {
            <text>
            (function () {
                var rootStyle = getComputedStyle(document.documentElement);
                var get = function (v) { return (rootStyle.getPropertyValue(v) || '').trim(); };
                var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                Chart.defaults.color = isDark ? '#cbd5e1' : '#475569';
                Chart.defaults.font.family = "'Inter', sans-serif";
                var palette = [get('--ra-danger'), get('--ra-warning'), get('--ra-primary'), get('--ra-accent'), get('--ra-info'), get('--ra-success')];
                new Chart(document.getElementById('chartTipos'), {
                    type: 'doughnut',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PorTipoIncidente.Keys)),
                        datasets: [{
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PorTipoIncidente.Values)),
                            backgroundColor: palette,
                            borderWidth: 0,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '60%',
                        plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 14 } } }
                    }
                });
            })();
            </text>
        }
    </script>
}
