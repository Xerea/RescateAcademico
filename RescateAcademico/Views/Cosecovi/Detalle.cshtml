@model RescateAcademico.Models.ReporteCosecovi
@{
    ViewData["Title"] = "Incidente COSECOVI";
    Layout = "_Layout";
    var historial = ViewBag.HistorialAlumno as List<RescateAcademico.Models.ReporteCosecovi> ?? new();
    var canEdit = User.IsInRole("Administrador") || User.IsInRole("Autoridad");
    var gravedadClass = Model.Gravedad is "Alta" or "Critica" ? "ra-badge-danger" : Model.Gravedad == "Media" ? "ra-badge-warning" : "ra-badge-neutral";
    var actionsHtml = canEdit
        ? $"<a href=\"{Url.Action("Editar", new { id = Model.Id })}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-pencil\"></i> Editar</a>"
        : string.Empty;
    var header = new PageHeader
    {
        Title = "Incidente COSECOVI",
        Subtitle = $"{Model.TipoIncidente} · {Model.Gravedad} · {Model.FechaIncidente:dd/MM/yyyy}",
        Icon = "bi-shield-exclamation",
        IconVariant = "accent",
        BackUrl = canEdit ? Url.Action("Index") : Url.Action("Alumno", new { matricula = Model.AlumnoMatricula }),
        BackLabel = canEdit ? "Reportes" : "Historial",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="row g-3">
    <div class="col-lg-4">
        <div class="ra-card mb-3">
            <div class="ra-card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h5 class="fw-semibold mb-0">@(Model.Alumno != null ? $"{Model.Alumno.Nombre} {Model.Alumno.Apellidos}" : Model.AlumnoMatricula)</h5>
                        <p class="text-secondary small mb-0 ra-mono">@Model.AlumnoMatricula</p>
                    </div>
                    <span class="ra-badge @gravedadClass">@Model.Gravedad</span>
                </div>
                <dl class="row mb-0 mt-2" style="font-size:0.8125rem;">
                    <dt class="col-5 text-secondary">Carrera</dt>
                    <dd class="col-7">@(Model.Alumno?.Carrera ?? "-")</dd>
                    <dt class="col-5 text-secondary">Tipo</dt>
                    <dd class="col-7">@Model.TipoIncidente</dd>
                    <dt class="col-5 text-secondary">Lugar</dt>
                    <dd class="col-7">@(Model.Lugar ?? "-")</dd>
                    <dt class="col-5 text-secondary">Turnado</dt>
                    <dd class="col-7">@(Model.Canalizacion ?? "Sin turno")</dd>
                    <dt class="col-5 text-secondary">Estado</dt>
                    <dd class="col-7"><partial name="_CosecoviEstadoBadge" model="Model.Estado" /></dd>
                    <dt class="col-5 text-secondary">Fecha del incidente</dt>
                    <dd class="col-7">@Model.FechaIncidente.ToString("dd/MM/yyyy HH:mm")</dd>
                    <dt class="col-5 text-secondary">Elaboro</dt>
                    <dd class="col-7">@(Model.ElaboradoPor ?? "-")</dd>
                </dl>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    @if (Model.TutorNotificado)
                    {
                        <span class="ra-badge ra-badge-info"><i class="bi bi-person-check"></i> Tutor notificado</span>
                    }
                    @if (Model.PadreTutorCitado)
                    {
                        <span class="ra-badge ra-badge-warning"><i class="bi bi-people"></i> Tutor legal citado</span>
                    }
                </div>
                @if (Model.Alumno != null)
                {
                    <a asp-controller="Alumnos" asp-action="Timeline" asp-route-matricula="@Model.AlumnoMatricula" class="ra-btn ra-btn-sm ra-btn-outline w-100 mt-3">
                        <i class="bi bi-clock-history"></i> Linea de tiempo del alumno
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="ra-card mb-3">
            <div class="ra-card-header"><i class="bi bi-eye"></i> Hechos observados</div>
            <div class="ra-card-body" style="white-space:pre-wrap;">@(string.IsNullOrWhiteSpace(Model.SituacionObservada) ? "Sin descripcion." : Model.SituacionObservada)</div>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <div class="ra-card h-100">
                    <div class="ra-card-header"><i class="bi bi-clipboard-check"></i> Medidas tomadas</div>
                    <div class="ra-card-body" style="white-space:pre-wrap;">@(string.IsNullOrWhiteSpace(Model.MedidasTomadas) ? "-" : Model.MedidasTomadas)</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="ra-card h-100">
                    <div class="ra-card-header"><i class="bi bi-list-check"></i> Seguimiento</div>
                    <div class="ra-card-body" style="white-space:pre-wrap;">@(string.IsNullOrWhiteSpace(Model.AccionesPropuestas) ? "-" : Model.AccionesPropuestas)</div>
                </div>
            </div>
        </div>

        @if (historial.Any())
        {
            <div class="ra-card mt-3">
                <div class="ra-card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-archive"></i> Historial COSECOVI del alumno</span>
                    <span class="ra-badge ra-badge-neutral">@historial.Count</span>
                </div>
                <div class="ra-card-body p-0">
                    @foreach (var h in historial)
                    {
                        <div class="d-flex justify-content-between align-items-center p-3" style="border-bottom:1px solid var(--ra-border-subtle);">
                            <div>
                                <div class="fw-medium small">@h.TipoIncidente · @h.Gravedad · @h.Periodo</div>
                                <div class="text-secondary" style="font-size:0.75rem;">@h.FechaIncidente.ToString("dd/MM/yyyy")</div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <partial name="_CosecoviEstadoBadge" model="h.Estado" />
                                <a asp-action="Detalle" asp-route-id="@h.Id" class="ra-btn ra-btn-sm ra-btn-ghost" aria-label="Ver reporte"><i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
