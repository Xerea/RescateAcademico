@model RescateAcademico.Models.ReporteCosecovi
@{
    ViewData["Title"] = "Editar incidente COSECOVI";
    Layout = "_Layout";
    var tipos = ViewBag.TiposIncidente as string[] ?? Array.Empty<string>();
    var gravedades = ViewBag.Gravedades as string[] ?? Array.Empty<string>();
    var turnados = ViewBag.Turnados as string[] ?? Array.Empty<string>();
    var estados = ViewBag.Estados as string[] ?? Array.Empty<string>();
    var fechaMin = ViewBag.FechaIncidenteMin as string;
    var fechaMax = ViewBag.FechaIncidenteMax as string;
    var header = new PageHeader
    {
        Title = "Editar incidente",
        Subtitle = Model.Alumno != null ? $"{Model.Alumno.Nombre} {Model.Alumno.Apellidos} · {Model.Periodo}" : Model.AlumnoMatricula,
        Icon = "bi-pencil-square",
        IconVariant = "accent",
        BackUrl = Url.Action("Detalle", new { id = Model.Id }),
        BackLabel = "Detalle"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row">
    <div class="col-lg-9 mx-auto">
        <div class="ra-card">
            <div class="ra-card-body">
                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="mb-3">
                        <label class="ra-label">Estado del caso</label>
                        <div class="ra-tabs" role="radiogroup" id="estadoTabs">
                            @foreach (var e in estados)
                            {
                                <label class="ra-tab @(Model.Estado == e ? "active" : "")" data-estado="@e">
                                    <input type="radio" name="Estado" value="@e" checked="@(Model.Estado == e)" style="display:none;" />
                                    @e
                                </label>
                            }
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="ra-label">Fecha del incidente</label>
                            <input asp-for="FechaIncidente" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="ra-input" min="@fechaMin" max="@fechaMax" step="60" required />
                            <span asp-validation-for="FechaIncidente" class="text-danger small d-block mt-1"></span>
                            <div class="text-secondary small mt-1">Maximo 7 dias de antiguedad.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="ra-label">Tipo</label>
                            <select asp-for="TipoIncidente" class="ra-select">
                                @foreach (var t in tipos)
                                {
                                    <option value="@t" selected="@(Model.TipoIncidente == t ? "selected" : null)">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="ra-label">Gravedad</label>
                            <select asp-for="Gravedad" class="ra-select">
                                @foreach (var g in gravedades)
                                {
                                    <option value="@g" selected="@(Model.Gravedad == g ? "selected" : null)">@g</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="ra-label">Lugar</label>
                            <input asp-for="Lugar" class="ra-input" maxlength="80" />
                        </div>
                        <div class="col-md-6">
                            <label class="ra-label">Turnado a</label>
                            <select asp-for="Canalizacion" class="ra-select">
                                @foreach (var t in turnados)
                                {
                                    <option value="@t" selected="@(Model.Canalizacion == t ? "selected" : null)">@t</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3 mt-3">
                        <label class="ra-label">Hechos observados</label>
                        <textarea asp-for="SituacionObservada" class="ra-input" rows="4"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Medidas tomadas</label>
                        <textarea asp-for="MedidasTomadas" class="ra-input" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Seguimiento propuesto</label>
                        <textarea asp-for="AccionesPropuestas" class="ra-input" rows="3"></textarea>
                    </div>

                    <div class="d-flex gap-3 flex-wrap mb-4">
                        <label class="ra-check-label">
                            <input asp-for="TutorNotificado" class="ra-checkbox" />
                            <span>Profesor tutor notificado</span>
                        </label>
                        <label class="ra-check-label">
                            <input asp-for="PadreTutorCitado" class="ra-checkbox" />
                            <span>Madre, padre o tutor citado</span>
                        </label>
                    </div>

                    <div class="ra-form-actions">
                        <a asp-action="Detalle" asp-route-id="@Model.Id" class="ra-btn ra-btn-ghost">Cancelar</a>
                        <button type="submit" class="ra-btn ra-btn-primary"><i class="bi bi-save"></i> Guardar cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    #estadoTabs .ra-tab { cursor:pointer; border:1px solid var(--ra-border); border-radius:var(--ra-radius-full); margin-bottom:0; }
    #estadoTabs .ra-tab.active { background:var(--ra-primary-soft); border-color:var(--ra-primary); color:var(--ra-primary); }
</style>

@section Scripts {
    <script>
        document.querySelectorAll('#estadoTabs .ra-tab').forEach(function (tab) {
            tab.addEventListener('click', function () {
                document.querySelectorAll('#estadoTabs .ra-tab').forEach(function (t) { t.classList.remove('active'); });
                tab.classList.add('active');
                var radio = tab.querySelector('input');
                if (radio) radio.checked = true;
            });
        });
    </script>
}
