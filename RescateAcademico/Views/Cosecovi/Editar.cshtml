@model RescateAcademico.Models.ReporteCosecovi
@{
    ViewData["Title"] = "Editar reporte COSECOVI";
    Layout = "_Layout";
    var canalizaciones = ViewBag.Canalizaciones as string[] ?? Array.Empty<string>();
    var estados = ViewBag.Estados as string[] ?? Array.Empty<string>();
    var header = new PageHeader
    {
        Title = "Editar reporte",
        Subtitle = Model.Alumno != null ? $"{Model.Alumno.Nombre} {Model.Alumno.Apellidos} · {Model.Periodo}" : Model.AlumnoMatricula,
        Icon = "bi-pencil-square",
        IconVariant = "accent",
        BackUrl = Url.Action("Detalle", new { id = Model.Id }),
        BackLabel = "Detalle"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row">
    <div class="col-md-9 col-lg-8 mx-auto">
        <div class="ra-card">
            <div class="ra-card-body">
                <form asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="ra-label">Estado del caso</label>
                        <div class="ra-tabs" role="radiogroup" id="estadoTabs">
                            @foreach (var e in estados)
                            {
                                <label class="ra-tab @(Model.Estado == e ? "active" : "")" data-estado="@e">
                                    <input type="radio" name="Estado" value="@e" checked="@(Model.Estado == e)" style="display:none;" />
                                    @e
                                </label>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="ra-label">Canalización</label>
                        <select name="Canalizacion" class="ra-select">
                            <option value="">— Sin canalización —</option>
                            @foreach (var c in canalizaciones)
                            {
                                <option value="@c" selected="@(Model.Canalizacion == c ? "selected" : null)">@c</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="ra-label">Situación observada</label>
                        <textarea name="SituacionObservada" class="ra-input" rows="3">@Model.SituacionObservada</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Recomendaciones</label>
                        <textarea name="Recomendaciones" class="ra-input" rows="2">@Model.Recomendaciones</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Acciones propuestas / notas de seguimiento</label>
                        <textarea name="AccionesPropuestas" class="ra-input" rows="3">@Model.AccionesPropuestas</textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary flex-fill"><i class="bi bi-save"></i> Guardar cambios</button>
                        <a asp-action="Detalle" asp-route-id="@Model.Id" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    #estadoTabs .ra-tab { cursor:pointer; border:1px solid var(--ra-border); border-radius:var(--ra-radius-full); margin-bottom:0; }
    #estadoTabs .ra-tab.active { background:var(--ra-primary-soft); border-color:var(--ra-primary); color:var(--ra-primary); }
</style>

@section Scripts {
    <script>
        document.querySelectorAll('#estadoTabs .ra-tab').forEach(function (tab) {
            tab.addEventListener('click', function () {
                document.querySelectorAll('#estadoTabs .ra-tab').forEach(function (t) { t.classList.remove('active'); });
                tab.classList.add('active');
                var radio = tab.querySelector('input');
                if (radio) radio.checked = true;
            });
        });
    </script>
}
