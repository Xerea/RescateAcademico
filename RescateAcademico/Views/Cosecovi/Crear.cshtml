@model RescateAcademico.Models.ReporteCosecovi
@{
    ViewData["Title"] = "Nuevo incidente COSECOVI";
    Layout = "_Layout";
    var alumnos = ViewBag.Alumnos as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
    var tipos = ViewBag.TiposIncidente as string[] ?? Array.Empty<string>();
    var gravedades = ViewBag.Gravedades as string[] ?? Array.Empty<string>();
    var turnados = ViewBag.Turnados as string[] ?? Array.Empty<string>();
    var header = new PageHeader
    {
        Title = "Nuevo incidente COSECOVI",
        Subtitle = "Registra hechos disciplinarios o de seguridad escolar y las medidas tomadas.",
        Icon = "bi-shield-exclamation",
        IconVariant = "accent",
        BackUrl = Url.Action("Index"),
        BackLabel = "Reportes"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row">
    <div class="col-lg-9 mx-auto">
        <div class="ra-card">
            <div class="ra-card-body">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-7">
                            <label class="ra-label">Alumno *</label>
                            <select asp-for="AlumnoMatricula" class="ra-select" required>
                                <option value="">Selecciona un alumno</option>
                                @foreach (var a in alumnos)
                                {
                                    <option value="@a.Value" selected="@(a.Value == Model.AlumnoMatricula ? "selected" : null)">@a.Text</option>
                                }
                            </select>
                            <span asp-validation-for="AlumnoMatricula" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <label class="ra-label">Fecha del incidente *</label>
                            <input asp-for="FechaIncidente" type="datetime-local" class="ra-input" required />
                        </div>
                        <div class="col-md-2">
                            <label class="ra-label">Periodo *</label>
                            <input asp-for="Periodo" class="ra-input" placeholder="2026-A" required />
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-5">
                            <label class="ra-label">Tipo de incidente *</label>
                            <select asp-for="TipoIncidente" class="ra-select" required>
                                @foreach (var t in tipos)
                                {
                                    <option value="@t" selected="@(Model.TipoIncidente == t ? "selected" : null)">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="ra-label">Gravedad *</label>
                            <select asp-for="Gravedad" class="ra-select" required>
                                @foreach (var g in gravedades)
                                {
                                    <option value="@g" selected="@(Model.Gravedad == g ? "selected" : null)">@g</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="ra-label">Lugar</label>
                            <input asp-for="Lugar" class="ra-input" placeholder="Aula, pasillo, patio..." maxlength="80" />
                        </div>
                    </div>

                    <div class="mb-3 mt-3">
                        <label class="ra-label">Hechos observados *</label>
                        <textarea asp-for="SituacionObservada" class="ra-input" rows="4" placeholder="Describe hechos, personas involucradas, lugar y contexto..." required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Medidas tomadas *</label>
                        <textarea asp-for="MedidasTomadas" class="ra-input" rows="3" placeholder="Llamado de atencion, citatorio, compromiso firmado, resguardo, etc." required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Seguimiento propuesto</label>
                        <textarea asp-for="AccionesPropuestas" class="ra-input" rows="3" placeholder="Proxima revision, area responsable, fecha estimada de cierre..."></textarea>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="ra-label">Turnado a</label>
                            <select asp-for="Canalizacion" class="ra-select">
                                @foreach (var t in turnados)
                                {
                                    <option value="@t" selected="@(Model.Canalizacion == t ? "selected" : null)">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-7 d-flex align-items-end gap-3 flex-wrap">
                            <label class="ra-check-label mb-2">
                                <input asp-for="TutorNotificado" class="ra-checkbox" />
                                <span>Profesor tutor notificado</span>
                            </label>
                            <label class="ra-check-label mb-2">
                                <input asp-for="PadreTutorCitado" class="ra-checkbox" />
                                <span>Madre, padre o tutor citado</span>
                            </label>
                        </div>
                    </div>

                    <input type="hidden" asp-for="Estado" value="Registrado" />

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="ra-btn ra-btn-primary flex-fill">
                            <i class="bi bi-save"></i> Registrar incidente
                        </button>
                        <a asp-action="Index" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
