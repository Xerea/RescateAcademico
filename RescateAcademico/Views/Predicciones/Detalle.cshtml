@model RescateAcademico.Services.DesercionOutput
@{
    ViewData["Title"] = "Detalle de Predicción";
    Layout = "_Layout";
    var alumno = ViewBag.Alumno as RescateAcademico.Models.Alumno;
    var historial = ViewBag.Historial as List<RescateAcademico.Models.PrediccionDesercion> ?? new List<RescateAcademico.Models.PrediccionDesercion>();
    var analisisJson = TempData["AnalisisIA"] as string;
    RescateAcademico.Services.AnalisisIAResultado? analisisIA = null;
    if (!string.IsNullOrEmpty(analisisJson))
    {
        try { analisisIA = System.Text.Json.JsonSerializer.Deserialize<RescateAcademico.Services.AnalisisIAResultado>(analisisJson); } catch { }
    }
}

<div class="row mb-4">
    <div class="col">
        <h2 class="ra-text-accent"><i class="bi bi-brain"></i> Análisis de Riesgo de Deserción</h2>
    </div>
</div>

@if (alumno != null)
{
    <div class="ra-card mb-4">
        <div class="ra-card-header">
            <h5 class="mb-0"><i class="bi bi-person-badge"></i> @alumno.Nombre @alumno.Apellidos (@alumno.Matricula)</h5>
        </div>
        <div class="ra-card-body">
            <div class="row">
                <div class="col-md-6">
                    <p><strong>Carrera:</strong> @alumno.Carrera</p>
                    <p><strong>Semestre:</strong> @alumno.SemestreActual</p>
                    <p><strong>Promedio Global:</strong> <span class="ra-badge @(alumno.PromedioGlobal >= 8 ? "ra-badge-success" : alumno.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">@alumno.PromedioGlobal.ToString("F2")</span></p>
                    <p><strong>Carga Académica:</strong> @(alumno.CargaAcademicaActual ?? 0) materias</p>
                </div>
                <div class="col-md-6">
                    <p><strong>Materias Reprobadas:</strong> @(alumno.MateriasReprobadas ?? 0)</p>
                    <p><strong>Ausencias:</strong> @(alumno.Ausencias ?? 0)</p>
                    <p><strong>Parciales Bajos:</strong> @(alumno.ParcialesBajos ?? 0)</p>
                    <p><strong>ETS Presentados:</strong> @(alumno.EtsPresentados ?? 0)</p>
                </div>
            </div>
            <hr />
            <div class="text-center">
                <h4 class="mb-2">Probabilidad de Deserción: <span class="ra-text-@(Model.Probabilidad > 0.7m ? "danger" : Model.Probabilidad > 0.5m ? "warning" : Model.Probabilidad > 0.3m ? "info" : "success")">@((Model.Probabilidad * 100).ToString("F1"))%</span></h4>
                <span class="ra-badge ra-badge-@(Model.Probabilidad > 0.7m ? "danger" : Model.Probabilidad > 0.5m ? "warning" : Model.Probabilidad > 0.3m ? "info" : "success") fs-6">Nivel: @(Model.Probabilidad > 0.7m ? "Crítico" : Model.Probabilidad > 0.5m ? "Alto" : Model.Probabilidad > 0.3m ? "Medio" : "Bajo")</span>
                <p class="text-secondary mt-2"><small>Método: Heurística Institucional (basada en promedio, reprobadas, ausencias, recursamientos)</small></p>
            </div>
        </div>
    </div>

    @if (analisisIA != null)
    {
        <div class="ra-card mb-4" id="iaCard">
            <div class="ra-card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-stars"></i> Análisis con Inteligencia Artificial</span>
                <div class="d-flex gap-1">
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="copiarAnalisis()" title="Copiar"><i class="bi bi-copy"></i></button>
                    <form asp-action="AnalisisIA" method="post" class="m-0 d-inline">
                        <input type="hidden" name="matricula" value="@alumno.Matricula" />
                        <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline"><i class="bi bi-arrow-repeat"></i> Re-analizar</button>
                    </form>
                </div>
            </div>
            <div class="ra-card-body">
                <div id="iaContent" data-resumen="@analisisIA.ResumenRiesgo" data-analisis="@analisisIA.Analisis" data-recomendaciones="@analisisIA.Recomendaciones" data-alertas="@(analisisIA.Alertas ?? "Ninguna")" data-fecha="@analisisIA.FechaGeneracion.ToString("dd/MM/yyyy HH:mm")">
                    <div class="mb-3">
                        <div class="ra-heading mb-1">Resumen del Riesgo</div>
                        <p class="fw-bold ra-typewriter" id="iaResumen"></p>
                    </div>
                    <div class="mb-3">
                        <div class="ra-heading mb-1">Análisis Detallado</div>
                        <p class="ra-serif ra-typewriter" id="iaAnalisis"></p>
                    </div>
                    <div class="mb-3">
                        <div class="ra-heading mb-1">Recomendaciones</div>
                        <p class="ra-typewriter" id="iaRecomendaciones" style="white-space: pre-wrap;"></p>
                    </div>
                    <div id="iaAlertasContainer" class="d-none">
                        <div class="ra-alert ra-alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> <strong>Alertas:</strong> <span id="iaAlertas" class="ra-typewriter"></span>
                        </div>
                    </div>
                    <p class="text-secondary small mb-0 mt-3"><i class="bi bi-clock"></i> Generado el <span id="iaFecha"></span></p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="ra-card mb-4" id="iaCard">
            <div class="ra-card-body text-center py-5">
                <i class="bi bi-stars fs-1 text-secondary mb-3 d-block"></i>
                @if (ViewBag.OpenAIConfigurado as bool? == true)
                {
                    <p class="text-secondary mb-3">Genera un análisis personalizado con Inteligencia Artificial basado en el perfil académico de este estudiante.</p>
                    <form asp-action="AnalisisIA" method="post" class="d-inline" id="iaForm">
                        <input type="hidden" name="matricula" value="@alumno.Matricula" />
                        <button type="submit" class="ra-btn ra-btn-primary ra-btn-lg" id="iaSubmitBtn">
                            <i class="bi bi-magic"></i> Generar Análisis con IA
                        </button>
                    </form>
                    <div id="iaLoading" class="d-none mt-3">
                        <div class="ra-mono text-secondary mb-2" id="iaLoadingText">Analizando patrones académicos...</div>
                        <div style="height:3px;background:var(--ra-border);border-radius:2px;overflow:hidden;max-width:300px;margin:0 auto;">
                            <div id="iaLoadingBar" style="height:100%;width:0;background:var(--ra-primary);transition:width 8s ease-in-out;"></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="ra-alert ra-alert-info text-start mb-3" style="max-width:500px;margin:0 auto;">
                        <i class="bi bi-info-circle-fill"></i>
                        <div>
                            <strong>Análisis IA no disponible</strong>
                            <p class="mb-0 mt-1">La clave de API de OpenAI (OPENAI_API_KEY) no está configurada. El análisis heurístico institucional sigue activo para todos los estudiantes.</p>
                        </div>
                    </div>
                    <p class="text-secondary small">Para habilitar el análisis con IA, configura la variable de entorno <code>OPENAI_API_KEY</code> con tu clave de API de OpenAI.</p>
                }
            </div>
        </div>
    }

    <div class="ra-card mb-4">
        <div class="ra-card-header">
            <h5 class="mb-0"><i class="bi bi-clock-history"></i> Historial de Predicciones</h5>
        </div>
        <div class="ra-card-body">
            @if (historial.Any())
            {
                <div class="table-responsive">
                    <table class="table ra-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Probabilidad</th>
                                <th>Nivel</th>
                                <th>Factores</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in historial)
                            {
                                <tr>
                                    <td>@h.FechaPrediccion.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@((h.ProbabilidadDesercion * 100)?.ToString("F1"))%</td>
                                    <td>@h.NivelRiesgo</td>
                                    <td>@h.FactoresDetectados</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="ra-empty">
                    <p>No hay predicciones previas registradas.</p>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('iaForm')?.addEventListener('submit', function() {
            var btn = document.getElementById('iaSubmitBtn');
            var loading = document.getElementById('iaLoading');
            var bar = document.getElementById('iaLoadingBar');
            if (btn && loading && bar) {
                btn.disabled = true; btn.classList.add('d-none'); loading.classList.remove('d-none');
                setTimeout(function() { bar.style.width = '100%'; }, 50);
                var texts = ['Analizando patrones académicos...','Consultando historial de intervenciones...','Evaluando factores de riesgo...','Generando recomendaciones personalizadas...'];
                var idx = 0; var el = document.getElementById('iaLoadingText');
                setInterval(function() { idx = (idx + 1) % texts.length; if (el) el.textContent = texts[idx]; }, 2000);
            }
        });

        (function() {
            var container = document.getElementById('iaContent');
            if (!container) return;
            var resumen = container.dataset.resumen || '';
            var analisis = container.dataset.analisis || '';
            var recomendaciones = container.dataset.recomendaciones || '';
            var alertas = container.dataset.alertas || '';
            var fecha = container.dataset.fecha || '';
            document.getElementById('iaFecha').textContent = fecha;
            if (alertas && alertas !== 'Ninguna') {
                document.getElementById('iaAlertasContainer')?.classList.remove('d-none');
            }
            function typeWriter(element, text, speed, callback) {
                if (!element) { if (callback) callback(); return; }
                element.innerHTML = '';
                var i = 0;
                var cursor = document.createElement('span');
                cursor.textContent = '|';
                cursor.style.opacity = '1';
                cursor.style.animation = 'raBlink 1s step-end infinite';
                element.appendChild(cursor);
                function step() {
                    if (i < text.length) {
                        cursor.before(document.createTextNode(text.charAt(i)));
                        i++; setTimeout(step, speed);
                    } else { cursor.remove(); if (callback) callback(); }
                }
                step();
            }
            var speed = 18;
            setTimeout(function() {
                typeWriter(document.getElementById('iaResumen'), resumen, speed, function() {
                    typeWriter(document.getElementById('iaAnalisis'), analisis, speed, function() {
                        typeWriter(document.getElementById('iaRecomendaciones'), recomendaciones, speed, function() {
                            if (alertas && alertas !== 'Ninguna') {
                                typeWriter(document.getElementById('iaAlertas'), alertas, speed);
                            }
                        });
                    });
                });
            }, 400);
        })();

        function copiarAnalisis() {
            var container = document.getElementById('iaContent');
            if (!container) return;
            var text = 'Resumen: ' + (container.dataset.resumen || '') + '\n\nAnalisis: ' + (container.dataset.analisis || '') + '\n\nRecomendaciones: ' + (container.dataset.recomendaciones || '');
            navigator.clipboard.writeText(text).then(function() { RaToast.show('Análisis copiado al portapapeles', 'success'); });
        }
    </script>
}

<div class="mb-3">
    <a asp-action="Index" class="ra-btn ra-btn-ghost">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
    @if (!User.IsInRole("Autoridad") && alumno != null)
    {
        <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-warning">
            <i class="bi bi-clipboard-pulse"></i> Registrar Intervención
        </a>
        <a asp-controller="PlanesMejora" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-success">
            <i class="bi bi-journal-check"></i> Crear Plan de Mejora
        </a>
    }
</div>
