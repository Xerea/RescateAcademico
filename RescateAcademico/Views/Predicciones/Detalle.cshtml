@model RescateAcademico.Services.DesercionOutput
@{
    ViewData["Title"] = "Análisis de riesgo";
    Layout = "_Layout";
    var alumno = ViewBag.Alumno as RescateAcademico.Models.Alumno;
    var historial = ViewBag.Historial as List<RescateAcademico.Models.PrediccionDesercion> ?? new List<RescateAcademico.Models.PrediccionDesercion>();
    var analisisJson = TempData["AnalisisIA"] as string;
    RescateAcademico.Services.AnalisisIAResultado? analisisIA = null;
    if (!string.IsNullOrEmpty(analisisJson))
    {
        try { analisisIA = System.Text.Json.JsonSerializer.Deserialize<RescateAcademico.Services.AnalisisIAResultado>(analisisJson); } catch { }
    }
    analisisIA?.Normalize();
    var recomendacionesIA = analisisIA?.RecomendacionesLista ?? new List<string>();
    var alertasIA = analisisIA?.AlertasLista ?? new List<string>();
    var factoresIA = analisisIA?.FactoresClave ?? new List<string>();
    var prioridadIA = analisisIA?.Prioridad;
    var prioridadClass = prioridadIA?.Equals("Critica", StringComparison.OrdinalIgnoreCase) == true || prioridadIA?.Equals("Crítica", StringComparison.OrdinalIgnoreCase) == true
        ? "danger"
        : prioridadIA?.Equals("Alta", StringComparison.OrdinalIgnoreCase) == true
            ? "warning"
            : prioridadIA?.Equals("Media", StringComparison.OrdinalIgnoreCase) == true
                ? "info"
                : "success";
    var header = new PageHeader
    {
        Title = "Análisis de riesgo de deserción",
        Subtitle = alumno == null ? null : $"{alumno.Nombre} {alumno.Apellidos} · Boleta {alumno.Matricula}",
        Icon = "bi-brain",
        IconVariant = "accent",
        BackUrl = Url.Action("Index"),
        BackLabel = "Predicciones"
    };
}

<partial name="_PageHeader" model="header" />

@if (alumno != null)
{
    var pct = (double)(Model.Probabilidad * 100);
    var riskColor = Model.Probabilidad > 0.7m ? "danger" : Model.Probabilidad > 0.5m ? "warning" : Model.Probabilidad > 0.3m ? "info" : "success";
    var riskLevel = Model.Probabilidad > 0.7m ? "Crítico" : Model.Probabilidad > 0.5m ? "Alto" : Model.Probabilidad > 0.3m ? "Medio" : "Bajo";
    var factores = ViewBag.Factores as List<string> ?? new List<string>();

    <section class="ra-ai-hero mb-4" aria-label="Riesgo de deserción">
        <div class="ra-ai-gauge is-@riskColor" style="--ra-gauge: @pct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture);">
            <div class="ra-ai-gauge-inner">
                <span class="ra-ai-gauge-num" data-countup="@pct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)" data-countup-suffix="%">@pct.ToString("F0")%</span>
                <span class="ra-ai-gauge-label">probabilidad</span>
            </div>
        </div>
        <div class="ra-ai-hero-text">
            <span class="ra-hero-eyebrow"><i class="bi bi-brain"></i> Análisis de deserción</span>
            <h1 class="ra-page-title mb-1">@alumno.Nombre @alumno.Apellidos</h1>
            <p class="ra-page-subtitle mb-2">@alumno.Carrera · @alumno.SemestreActual° semestre · Boleta @alumno.Matricula</p>
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <span class="ra-badge ra-badge-@riskColor" style="font-size:0.95rem;padding:0.35em 0.9em;">Riesgo @riskLevel</span>
                <span class="ra-badge ra-badge-neutral">Promedio @alumno.PromedioGlobal.ToString("F2")</span>
                <span class="ra-badge ra-badge-neutral">@(alumno.MateriasReprobadas ?? 0) reprobadas</span>
                <span class="ra-badge ra-badge-neutral">@(alumno.Ausencias ?? 0) ausencias</span>
            </div>
            @if (factores.Any())
            {
                <p class="text-secondary small mb-3"><i class="bi bi-flag me-1"></i><strong>Factores:</strong> @string.Join(" · ", factores)</p>
            }
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="ra-btn ra-btn-primary ra-btn-lg" data-bs-toggle="modal" data-bs-target="#simuladorModal">
                    <i class="bi bi-sliders"></i> Simular escenarios
                </button>
                @if (!User.IsInRole("Autoridad"))
                {
                    <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-outline ra-btn-lg">
                        <i class="bi bi-clipboard-pulse"></i> Intervenir
                    </a>
                }
            </div>
        </div>
    </section>

    @* ── What-if simulator ─────────────────────────────────────────── *@
    <div class="modal fade" id="simuladorModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content ra-modal-content">
                <div class="ra-card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-sliders"></i> Simulador de riesgo — ¿Qué pasaría si...?</span>
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" data-bs-dismiss="modal" aria-label="Cerrar"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="ra-card-body">
                    <p class="text-secondary small">Ajusta los indicadores para ver cómo cambiaría la probabilidad de deserción en tiempo real. El cálculo es instantáneo (heurística institucional, sin costo de IA).</p>
                    <div class="row g-4">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="ra-label d-flex justify-content-between">Promedio global <span class="ra-mono" id="simPromedioVal">@alumno.PromedioGlobal.ToString("F1")</span></label>
                                <input type="range" class="form-range ra-sim" id="simPromedio" min="0" max="10" step="0.1" value="@alumno.PromedioGlobal.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="mb-3">
                                <label class="ra-label d-flex justify-content-between">Materias reprobadas <span class="ra-mono" id="simReprobadasVal">@(alumno.MateriasReprobadas ?? 0)</span></label>
                                <input type="range" class="form-range ra-sim" id="simReprobadas" min="0" max="10" step="1" value="@(alumno.MateriasReprobadas ?? 0)">
                            </div>
                            <div class="mb-3">
                                <label class="ra-label d-flex justify-content-between">Ausencias <span class="ra-mono" id="simAusenciasVal">@(alumno.Ausencias ?? 0)</span></label>
                                <input type="range" class="form-range ra-sim" id="simAusencias" min="0" max="20" step="1" value="@(alumno.Ausencias ?? 0)">
                            </div>
                            <div class="mb-3">
                                <label class="ra-label d-flex justify-content-between">Recursamientos <span class="ra-mono" id="simRecursamientosVal">@(alumno.Recursamientos ?? 0)</span></label>
                                <input type="range" class="form-range ra-sim" id="simRecursamientos" min="0" max="8" step="1" value="@(alumno.Recursamientos ?? 0)">
                            </div>
                            <div class="mb-3">
                                <label class="ra-label d-flex justify-content-between">Carga académica <span class="ra-mono" id="simCargaVal">@(alumno.CargaAcademicaActual ?? 0)</span></label>
                                <input type="range" class="form-range ra-sim" id="simCarga" min="0" max="10" step="1" value="@(alumno.CargaAcademicaActual ?? 0)">
                            </div>
                            <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" id="simReset"><i class="bi bi-arrow-counterclockwise"></i> Valores actuales</button>
                        </div>
                        <div class="col-md-5">
                            <div class="ra-card h-100 text-center">
                                <div class="ra-card-body d-flex flex-column justify-content-center">
                                    <div class="ra-heading mb-1">Probabilidad proyectada</div>
                                    <div class="ra-stat-value" id="simResultado" style="font-size:3rem;">—</div>
                                    <div class="mb-3"><ra-semaforo id="simSemaforo" riesgo="@alumno.RiesgoAcademico" size="lg"></ra-semaforo></div>
                                    <div class="ra-heading mb-1">Nivel</div>
                                    <div class="fw-semibold mb-3" id="simNivel">—</div>
                                    <div style="height:10px;background:var(--ra-border);border-radius:6px;overflow:hidden;">
                                        <div id="simBarra" style="height:100%;width:0;background:var(--ra-warning);transition:width 0.3s ease,background 0.3s ease;"></div>
                                    </div>
                                    <div class="mt-2 small" id="simDelta"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (analisisIA != null)
    {
        <div class="ra-card ra-ai-report mb-4" id="iaCard">
            <div class="ra-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <span><i class="bi bi-stars"></i> Informe asistido por IA</span>
                <div class="d-flex gap-1">
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="copiarAnalisis()" title="Copiar informe">
                        <i class="bi bi-copy"></i>
                    </button>
                    @if (ViewBag.OpenAIConfigurado as bool? == true)
                    {
                        <form asp-action="AnalisisIA" method="post" class="m-0 d-inline">
                            <input type="hidden" name="matricula" value="@alumno.Matricula" />
                            <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline"><i class="bi bi-arrow-repeat"></i> Re-analizar</button>
                        </form>
                    }
                    else
                    {
                        <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" disabled title="API key no configurada" style="opacity:0.4;cursor:not-allowed;">
                            <i class="bi bi-arrow-repeat"></i> Re-analizar
                        </button>
                    }
                </div>
            </div>
            <div class="ra-card-body">
                <div id="iaContent">
                    <section class="ra-ai-summary">
                        <div>
                            <span class="ra-student-eyebrow">Resumen del riesgo</span>
                            <h3>@analisisIA.ResumenRiesgo</h3>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(prioridadIA))
                        {
                            <span class="ra-badge ra-badge-@prioridadClass">Prioridad @prioridadIA</span>
                        }
                    </section>

                    @if (factoresIA.Any())
                    {
                        <div class="ra-ai-section">
                            <div class="ra-heading mb-2">Factores clave</div>
                            <div class="ra-ai-factor-grid">
                                @foreach (var factor in factoresIA)
                                {
                                    <div class="ra-ai-factor">
                                        <i class="bi bi-check2-circle"></i>
                                        <span>@factor</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="ra-ai-section">
                        <div class="ra-heading mb-2">Análisis profesional</div>
                        <p class="ra-ai-analysis">@analisisIA.Analisis</p>
                    </div>

                    <div class="ra-ai-section">
                        <div class="ra-heading mb-2">Recomendaciones accionables</div>
                        @if (recomendacionesIA.Any())
                        {
                            <ol class="ra-ai-recommendations">
                                @foreach (var recomendacion in recomendacionesIA)
                                {
                                    <li>@recomendacion</li>
                                }
                            </ol>
                        }
                        else
                        {
                            <p class="text-secondary mb-0">@analisisIA.Recomendaciones</p>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(analisisIA.IntervencionSugerida) || !string.IsNullOrWhiteSpace(analisisIA.MensajeSugerido))
                    {
                        <div class="ra-ai-section">
                            <div class="ra-heading mb-2">Siguiente acción docente</div>
                            <div class="ra-ai-action-box">
                                <div>
                                    <strong>@(string.IsNullOrWhiteSpace(analisisIA.IntervencionSugerida) ? "Intervención sugerida" : analisisIA.IntervencionSugerida)</strong>
                                    <small>@(string.IsNullOrWhiteSpace(analisisIA.FechaSeguimientoSugerida) ? "Definir seguimiento según disponibilidad del profesor." : $"Seguimiento sugerido: {analisisIA.FechaSeguimientoSugerida}")</small>
                                    @if (!string.IsNullOrWhiteSpace(analisisIA.MensajeSugerido))
                                    {
                                        <p>@analisisIA.MensajeSugerido</p>
                                    }
                                </div>
                                @if (!User.IsInRole("Autoridad"))
                                {
                                    <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-primary">
                                        <i class="bi bi-clipboard-pulse"></i> Registrar intervención
                                    </a>
                                }
                            </div>
                        </div>
                    }

                    <div class="ra-ai-section mb-0">
                        @if (alertasIA.Any())
                        {
                            <div class="ra-alert ra-alert-warning mb-0">
                                <i class="bi bi-exclamation-triangle"></i>
                                <div>
                                    <strong>Alertas de seguimiento</strong>
                                    <ul class="mb-0 mt-1">
                                        @foreach (var alerta in alertasIA)
                                        {
                                            <li>@alerta</li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="ra-ai-clear">
                                <i class="bi bi-shield-check"></i>
                                <span>Sin alertas adicionales reportadas por la IA.</span>
                            </div>
                        }
                    </div>

                    <p class="text-secondary small mb-0 mt-3">
                        <i class="bi bi-clock"></i> Generado el @analisisIA.FechaGeneracion.ToString("dd/MM/yyyy HH:mm")
                    </p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="ra-card mb-4" id="iaCard">
            <div class="ra-card-body text-center py-5">
                <i class="bi bi-stars fs-1 text-secondary mb-3 d-block"></i>
                @if (ViewBag.OpenAIConfigurado as bool? == true)
                {
                    <p class="text-secondary mb-3">Genera un análisis personalizado con Inteligencia Artificial basado en el perfil académico de este estudiante.</p>
                    <form asp-action="AnalisisIA" method="post" class="d-inline" id="iaForm">
                        <input type="hidden" name="matricula" value="@alumno.Matricula" />
                        <button type="submit" class="ra-btn ra-btn-primary ra-btn-lg" id="iaSubmitBtn">
                            <i class="bi bi-magic"></i> Generar Análisis con IA
                        </button>
                    </form>
                    <div id="iaLoading" class="d-none mt-3">
                        <div class="ra-mono text-secondary mb-2" id="iaLoadingText">Analizando patrones académicos...</div>
                        <div style="height:3px;background:var(--ra-border);border-radius:2px;overflow:hidden;max-width:300px;margin:0 auto;">
                            <div id="iaLoadingBar" style="height:100%;width:0;background:var(--ra-primary);transition:width 8s ease-in-out;"></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="ra-alert ra-alert-info text-start mb-3" style="max-width:500px;margin:0 auto;">
                        <i class="bi bi-info-circle-fill"></i>
                        <div>
                            <strong>Análisis IA no disponible</strong>
                            <p class="mb-0 mt-1">La clave de API de OpenAI (OPENAI_API_KEY) no está configurada. El análisis heurístico institucional sigue activo para todos los estudiantes.</p>
                        </div>
                    </div>
                    <p class="text-secondary small">Para habilitar el análisis con IA, configura la variable de entorno <code>OPENAI_API_KEY</code> con tu clave de API de OpenAI.</p>
                }
            </div>
        </div>
    }

    <div class="ra-card mb-4">
        <div class="ra-card-header">
            <h5 class="mb-0"><i class="bi bi-clock-history"></i> Historial de Predicciones</h5>
        </div>
        <div class="ra-card-body">
            @if (historial.Any())
            {
                <div class="table-responsive">
                    <table class="table ra-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Probabilidad</th>
                                <th>Nivel</th>
                                <th>Factores</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in historial)
                            {
                                <tr>
                                    <td>@h.FechaPrediccion.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@((h.ProbabilidadDesercion * 100)?.ToString("F1"))%</td>
                                    <td>@h.NivelRiesgo</td>
                                    <td>@h.FactoresDetectados</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="ra-empty">
                    <p>No hay predicciones previas registradas.</p>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('iaForm')?.addEventListener('submit', function() {
            var btn = document.getElementById('iaSubmitBtn');
            var loading = document.getElementById('iaLoading');
            var bar = document.getElementById('iaLoadingBar');
            if (btn && loading && bar) {
                btn.disabled = true; btn.classList.add('d-none'); loading.classList.remove('d-none');
                setTimeout(function() { bar.style.width = '100%'; }, 50);
                var texts = ['Analizando patrones académicos...','Consultando historial de intervenciones...','Evaluando factores de riesgo...','Generando recomendaciones personalizadas...'];
                var idx = 0; var el = document.getElementById('iaLoadingText');
                setInterval(function() { idx = (idx + 1) % texts.length; if (el) el.textContent = texts[idx]; }, 2000);
            }
        });

        function copiarAnalisis() {
            var container = document.getElementById('iaContent');
            if (!container) return;
            var text = container.innerText.replace(/\n{3,}/g, '\n\n').trim();
            navigator.clipboard.writeText(text).then(function() { RaToast.show('Informe IA copiado al portapapeles', 'success'); });
        }

        // ── What-if simulator (real-time, no AI cost) ──────────────────
        (function () {
            var ids = ['simPromedio', 'simReprobadas', 'simAusencias', 'simRecursamientos', 'simCarga'];
            var baseline = {
                promedio: parseFloat('@((alumno?.PromedioGlobal ?? 0m).ToString("F1", System.Globalization.CultureInfo.InvariantCulture))'),
                reprobadas: @(alumno?.MateriasReprobadas ?? 0),
                ausencias: @(alumno?.Ausencias ?? 0),
                recursamientos: @(alumno?.Recursamientos ?? 0),
                carga: @(alumno?.CargaAcademicaActual ?? 0)
            };
            var actual = @((Model.Probabilidad * 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture));
            var debounceTimer = null;

            function setText(id, v) { var el = document.getElementById(id); if (el) el.textContent = v; }

            function recalc() {
                var pEl = document.getElementById('simPromedio');
                if (!pEl) return;
                var p = pEl.value;
                var r = document.getElementById('simReprobadas').value;
                var a = document.getElementById('simAusencias').value;
                var rc = document.getElementById('simRecursamientos').value;
                var c = document.getElementById('simCarga').value;
                setText('simPromedioVal', parseFloat(p).toFixed(1));
                setText('simReprobadasVal', r);
                setText('simAusenciasVal', a);
                setText('simRecursamientosVal', rc);
                setText('simCargaVal', c);

                var url = '/Predicciones/Simular?promedio=' + p + '&reprobadas=' + r + '&ausencias=' + a + '&recursamientos=' + rc + '&carga=' + c;
                fetch(url, { credentials: 'same-origin' })
                    .then(function (res) { return res.ok ? res.json() : null; })
                    .then(function (d) {
                        if (!d) return;
                        var color = 'var(--ra-' + d.color + ')';
                        setText('simResultado', d.porcentaje + '%');
                        document.getElementById('simResultado').style.color = color;
                        setText('simNivel', d.nivel);
                        var barra = document.getElementById('simBarra');
                        barra.style.width = Math.min(d.porcentaje, 100) + '%';
                        barra.style.background = color;
                        var sem = document.getElementById('simSemaforo');
                        if (sem) sem.setAttribute('riesgo', d.semaforo);
                        var delta = (d.porcentaje - actual).toFixed(1);
                        var deltaEl = document.getElementById('simDelta');
                        var arrowDown = String.fromCharCode(8595);
                        var arrowUp = String.fromCharCode(8593);
                        if (Math.abs(delta) < 0.05) {
                            deltaEl.textContent = 'Sin cambio respecto al ' + actual + '% actual';
                            deltaEl.className = 'mt-2 small text-secondary';
                        } else if (delta < 0) {
                            deltaEl.textContent = arrowDown + ' ' + Math.abs(delta) + ' pts menos que el ' + actual + '% actual';
                            deltaEl.className = 'mt-2 small ra-text-success';
                        } else {
                            deltaEl.textContent = arrowUp + ' ' + delta + ' pts mas que el ' + actual + '% actual';
                            deltaEl.className = 'mt-2 small ra-text-danger';
                        }
                    });
            }

            function onInput() { clearTimeout(debounceTimer); debounceTimer = setTimeout(recalc, 120); }
            ids.forEach(function (id) { var el = document.getElementById(id); if (el) el.addEventListener('input', onInput); });

            var resetBtn = document.getElementById('simReset');
            if (resetBtn) resetBtn.addEventListener('click', function () {
                document.getElementById('simPromedio').value = baseline.promedio;
                document.getElementById('simReprobadas').value = baseline.reprobadas;
                document.getElementById('simAusencias').value = baseline.ausencias;
                document.getElementById('simRecursamientos').value = baseline.recursamientos;
                document.getElementById('simCarga').value = baseline.carga;
                recalc();
            });

            var modalEl = document.getElementById('simuladorModal');
            if (modalEl) modalEl.addEventListener('shown.bs.modal', recalc);
        })();
    </script>
}

<div class="mb-3 d-flex flex-wrap gap-2">
    @if (!User.IsInRole("Autoridad") && alumno != null)
    {
        <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-accent">
            <i class="bi bi-clipboard-pulse"></i> Registrar intervención
        </a>
        <a asp-controller="PlanesMejora" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-primary">
            <i class="bi bi-journal-check"></i> Crear plan de mejora
        </a>
    }
    @if ((User.IsInRole("Administrador") || User.IsInRole("Autoridad")) && alumno != null)
    {
        <a asp-controller="Cosecovi" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-outline">
            <i class="bi bi-shield-exclamation"></i> Registrar incidente COSECOVI
        </a>
    }
</div>
