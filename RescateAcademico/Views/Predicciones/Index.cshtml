@model List<RescateAcademico.Services.PrediccionAlumnoViewModel>
@{
    ViewData["Title"] = "Predicción de deserción";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Predicción de deserción",
        Subtitle = "Modelo heurístico institucional basado en indicadores académicos.",
        Icon = "bi-brain",
        IconVariant = "accent"
    };

    var filterActive = ViewBag.FiltroSemestre != null
        || !string.IsNullOrEmpty(ViewBag.FiltroGrupo as string)
        || !string.IsNullOrEmpty(ViewBag.FiltroRiesgo as string);
}

<partial name="_PageHeader" model="header" />

<div class="ra-alert ra-alert-info mb-4" role="alert">
    <i class="bi bi-info-circle-fill fs-5"></i>
    <div>Las predicciones se calculan con un modelo heurístico institucional basado en indicadores académicos (promedio, reprobadas, ausencias, recursamientos).</div>
</div>

<div class="ra-card ra-filter-bar">
    <div class="ra-card-body">
        <form method="get">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="ra-label">Semestre</label>
                    <select name="semestre" class="ra-select">
                        <option value="">Todos</option>
                        @foreach (var s in (ViewBag.Semestres as List<int>)!)
                        {
                            <option value="@s" selected="@(ViewBag.FiltroSemestre == s ? "selected" : null)">@s° semestre</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="ra-label">Grupo</label>
                    <select name="grupo" class="ra-select">
                        <option value="">Todos</option>
                        @foreach (var g in (ViewBag.Grupos as List<string>)!)
                        {
                            <option value="@g" selected="@(ViewBag.FiltroGrupo as string == g ? "selected" : null)">@g</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="ra-label">Nivel de riesgo</label>
                    <select name="riesgo" class="ra-select">
                        <option value="">Todos</option>
                        <option value="Crítico" selected="@(ViewBag.FiltroRiesgo == "Crítico" ? "selected" : null)">Crítico</option>
                        <option value="Alto" selected="@(ViewBag.FiltroRiesgo == "Alto" ? "selected" : null)">Alto</option>
                        <option value="Medio" selected="@(ViewBag.FiltroRiesgo == "Medio" ? "selected" : null)">Medio</option>
                        <option value="Bajo" selected="@(ViewBag.FiltroRiesgo == "Bajo" ? "selected" : null)">Bajo</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="ra-btn ra-btn-primary flex-fill">
                        <i class="bi bi-funnel"></i> Ver predicciones
                    </button>
                    @if (filterActive)
                    {
                        <a asp-action="Index" class="ra-btn ra-btn-ghost" title="Limpiar filtros" aria-label="Limpiar filtros">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-danger text-center">
            <div class="ra-stat-label">Riesgo Crítico (&gt;70%)</div>
            <div class="ra-stat-value">@Model.Count(m => m.Riesgo == "Crítico")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-warning text-center">
            <div class="ra-stat-label">Riesgo Alto (50-70%)</div>
            <div class="ra-stat-value">@Model.Count(m => m.Riesgo == "Alto")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-info text-center">
            <div class="ra-stat-label">Riesgo Medio (30-50%)</div>
            <div class="ra-stat-value">@Model.Count(m => m.Riesgo == "Medio")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-success text-center">
            <div class="ra-stat-label">Riesgo Bajo (&lt;30%)</div>
            <div class="ra-stat-value">@Model.Count(m => m.Riesgo == "Bajo")</div>
        </div>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards" id="tablaPredicciones">
                    <thead>
                        <tr>
                            <th>Boleta</th>
                            <th>Nombre</th>
                            <th>Carrera</th>
                            <th>Sem.</th>
                            <th>Grupo</th>
                            <th>Promedio</th>
                            <th>Prob. deserción</th>
                            <th>Riesgo</th>
                            <th data-orderable="false">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="Boleta"><strong class="ra-mono">@item.Matricula</strong></td>
                                <td data-label="Nombre">@item.Nombre</td>
                                <td data-label="Carrera">@item.Carrera</td>
                                <td data-label="Semestre">@item.Semestre</td>
                                <td data-label="Grupo"><span class="ra-badge ra-badge-neutral">@(!string.IsNullOrEmpty(item.Grupo) ? item.Grupo : "Sin grupo")</span></td>
                                <td data-label="Promedio">
                                    <span class="ra-badge @(item.Promedio >= 8 ? "ra-badge-success" : item.Promedio >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                        @item.Promedio.ToString("F2")
                                    </span>
                                </td>
                                <td data-label="Prob." style="min-width: 140px;">
                                    <div class="progress" style="height: 18px; background: var(--ra-border-subtle);">
                                        <div class="progress-bar" role="progressbar" style="width: @(item.ProbabilidadDesercion * 100)%; background: var(--ra-@(item.Color));" aria-valuenow="@item.ProbabilidadDesercion" aria-valuemin="0" aria-valuemax="1">
                                            @((item.ProbabilidadDesercion * 100).ToString("F0"))%
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Riesgo"><span class="ra-badge ra-badge-@item.Color">@item.Riesgo</span></td>
                                <td data-label="Acciones">
                                    <a asp-action="Detalle" asp-route-matricula="@item.Matricula" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver detalle del análisis" title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-brain"></i>
                <p>No hay predicciones disponibles.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaPredicciones').DataTable({
                language: window.RaDataTablesEs,
                pageLength: 25
            });
        });
    </script>
}
