@model IEnumerable<RescateAcademico.Models.Postulacion>
@{
    ViewData["Title"] = "Mis Postulaciones";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-send-check ra-text-accent me-2"></i>Mis Postulaciones</h1>
        <p class="text-secondary small mb-0">Consulta el estado de tus solicitudes a proyectos.</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="ra-alert ra-alert-success mb-4" role="alert">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="ra-alert ra-alert-danger mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@TempData["Error"]</div>
    </div>
}

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table" id="tablaPostulaciones">
                    <thead>
                        <tr>
                            <th>Proyecto</th>
                            <th>Fecha de Solicitud</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Proyecto?.Titulo</strong>
                                    <br />
                                    <span class="text-secondary small">@item.Proyecto?.Tipo</span>
                                </td>
                                <td>@item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.Estado == "Aceptado")
                                    {
                                        <span class="ra-badge ra-badge-success"><i class="bi bi-check-circle me-1"></i>Aceptado</span>
                                    }
                                    else if (item.Estado == "Rechazado")
                                    {
                                        <span class="ra-badge ra-badge-danger"><i class="bi bi-x-circle me-1"></i>Rechazado</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-warning"><i class="bi bi-clock me-1"></i>En Revisión</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Proyectos" asp-action="Details" asp-route-id="@item.ProyectoId" class="ra-btn ra-btn-sm ra-btn-outline">
                                        <i class="bi bi-eye"></i> Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-inbox"></i>
                <p>Aún no te has postulado a ningún proyecto.</p>
                <a asp-controller="Convocatorias" asp-action="Index" class="ra-btn ra-btn-primary mt-2">
                    <i class="bi bi-search"></i> Ver Convocatorias
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaPostulaciones').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
