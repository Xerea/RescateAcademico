@model IEnumerable<RescateAcademico.Models.Postulacion>
@{
    ViewData["Title"] = "Mis postulaciones";
    Layout = "_Layout";

    var postulaciones = Model.ToList();
    var pendientes = postulaciones.Count(p => p.Estado == "En Revisión");
    var aceptadas = postulaciones.Count(p => p.Estado == "Aceptado");
    var rechazadas = postulaciones.Count(p => p.Estado == "Rechazado");

    var header = new PageHeader
    {
        Title = "Mis postulaciones",
        Subtitle = "Seguimiento claro de tus solicitudes activas y resueltas.",
        Icon = "bi-send-check",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

@if (TempData["Success"] != null)
{
    <div class="ra-alert ra-alert-success mb-4" role="alert">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="ra-alert ra-alert-danger mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@TempData["Error"]</div>
    </div>
}

@if (postulaciones.Any())
{
    <section class="ra-application-summary mb-4" aria-label="Resumen de postulaciones">
        <div>
            <span class="ra-student-eyebrow">Tu seguimiento</span>
            <h2>@postulaciones.Count solicitudes registradas</h2>
            <p>Lo importante aquí es saber qué requiere atención y qué ya quedó resuelto.</p>
        </div>
        <div class="ra-opportunity-brief-metrics">
            <span><strong>@pendientes</strong><small>En revisión</small></span>
            <span><strong>@aceptadas</strong><small>Aceptadas</small></span>
            <span><strong>@rechazadas</strong><small>Rechazadas</small></span>
        </div>
    </section>

    <div class="ra-application-list">
        @foreach (var item in postulaciones)
        {
            var estadoClass = item.Estado == "Aceptado" ? "is-success" : item.Estado == "Rechazado" ? "is-danger" : "is-warning";
            var estadoBadge = item.Estado == "Aceptado" ? "ra-badge-success" : item.Estado == "Rechazado" ? "ra-badge-danger" : "ra-badge-warning";
            var estadoIcon = item.Estado == "Aceptado" ? "bi-check-circle" : item.Estado == "Rechazado" ? "bi-x-circle" : "bi-clock";

            <article class="ra-application-item @estadoClass">
                <div class="ra-application-status">
                    <i class="bi @estadoIcon"></i>
                </div>
                <div class="ra-application-content">
                    <div class="ra-application-title-row">
                        <div>
                            <h3>@item.Proyecto?.Titulo</h3>
                            <p>@item.Proyecto?.Tipo</p>
                        </div>
                        <span class="ra-badge @estadoBadge">@item.Estado</span>
                    </div>

                    <div class="ra-application-meta">
                        <span><i class="bi bi-calendar-event"></i> @item.FechaSolicitud.ToString("dd/MM/yyyy HH:mm")</span>
                        @if (!string.IsNullOrWhiteSpace(item.DocumentoNombre))
                        {
                            <span><i class="bi bi-paperclip"></i> Documento adjunto</span>
                        }
                        else
                        {
                            <span><i class="bi bi-file-earmark"></i> Sin documento adjunto</span>
                        }
                    </div>

                    <div class="ra-application-next">
                        @if (item.Estado == "Aceptado")
                        {
                            <span>Tu solicitud fue aceptada. Conserva esta postulación para seguimiento institucional.</span>
                        }
                        else if (item.Estado == "Rechazado")
                        {
                            <span>Esta solicitud no avanzó. Puedes revisar nuevas convocatorias disponibles.</span>
                        }
                        else
                        {
                            <span>Está en revisión. Te avisaremos cuando cambie el estado.</span>
                        }
                    </div>
                </div>
                <div class="ra-application-actions">
                    <a asp-controller="Proyectos" asp-action="Details" asp-route-id="@item.ProyectoId" class="ra-btn ra-btn-sm ra-btn-outline">
                        <i class="bi bi-eye"></i> Ver proyecto
                    </a>
                </div>
            </article>
        }
    </div>
}
else
{
    <div class="ra-empty">
        <i class="bi bi-inbox"></i>
        <p>Aún no te has postulado a ningún proyecto.</p>
        <a asp-controller="Convocatorias" asp-action="Index" class="ra-btn ra-btn-primary mt-2">
            <i class="bi bi-search"></i> Ver convocatorias
        </a>
    </div>
}
