@model RescateAcademico.Models.Convocatoria
@{
    ViewData["Title"] = "Postularme";
    Layout = "_Layout";
    var diasRestantes = (Model.FechaCierre - DateTime.Now).Days;
    var promedioAlumno = ViewBag.PromedioAlumno as decimal?;
    var cumpleRequisito = !Model.PromedioMinimo.HasValue
        || (promedioAlumno.HasValue && promedioAlumno.Value >= Model.PromedioMinimo.Value);
    var cupoDisponible = Model.PostulacionesActuales < Model.CupoMaximo;
    var puedePostular = cumpleRequisito && cupoDisponible && diasRestantes > 0;

    var header = new PageHeader
    {
        Title = "Postularme a convocatoria",
        Subtitle = Model.Titulo,
        Icon = "bi-send",
        IconVariant = "accent",
        BackUrl = Url.Action("Index", "Convocatorias"),
        BackLabel = "Convocatorias"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row g-3">
    <div class="col-lg-5">
        <div class="ra-card ra-card-primary h-100">
            <div class="ra-card-header">
                <i class="bi bi-info-circle"></i> Detalles
            </div>
            <div class="ra-card-body">
                <div class="mb-3">
                    <span class="ra-badge ra-badge-neutral">@Model.Tipo</span>
                    @if (diasRestantes > 0 && diasRestantes <= 7)
                    {
                        <span class="ra-badge ra-badge-warning">Cierra en @diasRestantes días</span>
                    }
                </div>
                <h5 class="fw-bold mb-2">@Model.Titulo</h5>
                <p class="text-secondary small">@Model.Descripcion</p>

                <div class="d-flex flex-column gap-1 text-secondary small mt-3 pt-3" style="border-top:1px solid var(--ra-border-subtle);">
                    <div><i class="bi bi-calendar-event me-1"></i> <strong>Cierre:</strong> @Model.FechaCierre.ToString("dd/MM/yyyy")</div>
                    <div><i class="bi bi-people me-1"></i> <strong>Cupo:</strong> @Model.PostulacionesActuales / @Model.CupoMaximo</div>
                    @if (Model.PromedioMinimo.HasValue)
                    {
                        <div><i class="bi bi-star me-1"></i> <strong>Promedio mínimo:</strong> @Model.PromedioMinimo.Value.ToString("F1")</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Requisitos))
                    {
                        <div class="mt-2"><strong>Requisitos:</strong><br><span>@Model.Requisitos</span></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="ra-card">
            <div class="ra-card-header">
                <i class="bi bi-check2-square"></i> Tu elegibilidad
            </div>
            <div class="ra-card-body">
                @* Eligibility checklist *@
                <ul class="list-unstyled mb-4">
                    <li class="d-flex align-items-start gap-2 mb-2">
                        @if (cumpleRequisito)
                        {
                            <i class="bi bi-check-circle-fill fs-5" style="color: var(--ra-success);"></i>
                            <div>
                                <div class="fw-medium">Promedio suficiente</div>
                                @if (Model.PromedioMinimo.HasValue)
                                {
                                    <div class="text-secondary small">Tu promedio @promedioAlumno?.ToString("F2") cumple el mínimo de @Model.PromedioMinimo.Value.ToString("F1").</div>
                                }
                                else
                                {
                                    <div class="text-secondary small">Esta convocatoria no exige promedio mínimo.</div>
                                }
                            </div>
                        }
                        else
                        {
                            <i class="bi bi-x-circle-fill fs-5" style="color: var(--ra-danger);"></i>
                            <div>
                                <div class="fw-medium">Promedio insuficiente</div>
                                <div class="text-secondary small">Tu promedio @promedioAlumno?.ToString("F2") está por debajo del mínimo de @Model.PromedioMinimo?.ToString("F1").</div>
                            </div>
                        }
                    </li>
                    <li class="d-flex align-items-start gap-2 mb-2">
                        @if (cupoDisponible)
                        {
                            <i class="bi bi-check-circle-fill fs-5" style="color: var(--ra-success);"></i>
                            <div>
                                <div class="fw-medium">Cupo disponible</div>
                                <div class="text-secondary small">Quedan @(Model.CupoMaximo - Model.PostulacionesActuales) lugares.</div>
                            </div>
                        }
                        else
                        {
                            <i class="bi bi-x-circle-fill fs-5" style="color: var(--ra-danger);"></i>
                            <div>
                                <div class="fw-medium">Sin cupo</div>
                                <div class="text-secondary small">Esta convocatoria ya está llena.</div>
                            </div>
                        }
                    </li>
                    <li class="d-flex align-items-start gap-2">
                        @if (diasRestantes > 0)
                        {
                            <i class="bi bi-check-circle-fill fs-5" style="color: var(--ra-success);"></i>
                            <div>
                                <div class="fw-medium">Dentro del plazo</div>
                                <div class="text-secondary small">Cierra el @Model.FechaCierre.ToString("dd/MM/yyyy") (@diasRestantes días).</div>
                            </div>
                        }
                        else
                        {
                            <i class="bi bi-x-circle-fill fs-5" style="color: var(--ra-danger);"></i>
                            <div>
                                <div class="fw-medium">Convocatoria cerrada</div>
                                <div class="text-secondary small">Se cerró el @Model.FechaCierre.ToString("dd/MM/yyyy").</div>
                            </div>
                        }
                    </li>
                </ul>

                @if (puedePostular)
                {
                    <form asp-controller="Postulaciones" asp-action="Postularse" method="post" enctype="multipart/form-data" id="postulacionForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="convocatoriaId" value="@Model.Id" />

                        <div class="mb-3">
                            <label for="documento" class="ra-label">Documento adjunto (opcional)</label>
                            <input type="file" name="documento" id="documento" class="ra-input" accept=".pdf,.doc,.docx" />
                            <div class="text-secondary small mt-1">
                                CV, carta de motivos u otro soporte. PDF/DOC/DOCX, máximo 5 MB.
                            </div>
                            <div id="fileInfo" class="small mt-2" style="display:none;"></div>
                        </div>

                        <div class="ra-alert ra-alert-info mb-3">
                            <i class="bi bi-info-circle-fill"></i>
                            <div>Tu solicitud será revisada por el profesor responsable. Recibirás una notificación cuando cambie su estado.</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="ra-btn ra-btn-primary flex-fill">
                                <i class="bi bi-send"></i> Enviar postulación
                            </button>
                            <a asp-controller="Convocatorias" asp-action="Index" class="ra-btn ra-btn-ghost">Cancelar</a>
                        </div>
                    </form>
                }
                else
                {
                    <div class="ra-alert ra-alert-warning">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <div>
                            No puedes postularte en este momento. Revisa los requisitos arriba.
                        </div>
                    </div>
                    <a asp-controller="Convocatorias" asp-action="Index" class="ra-btn ra-btn-outline mt-3">
                        <i class="bi bi-arrow-left"></i> Volver a convocatorias
                    </a>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var fileInput = document.getElementById('documento');
        var fileInfo = document.getElementById('fileInfo');
        if (fileInput && fileInfo) {
            fileInput.addEventListener('change', function () {
                var f = this.files && this.files[0];
                if (!f) { fileInfo.style.display = 'none'; return; }
                var sizeMb = (f.size / (1024 * 1024)).toFixed(2);
                var ok = f.size <= 5 * 1024 * 1024;
                fileInfo.style.display = 'block';
                fileInfo.textContent = (ok ? '✓ ' : '⚠ ') + f.name + ' · ' + sizeMb + ' MB' + (ok ? '' : ' (excede 5 MB)');
                fileInfo.style.color = ok ? 'var(--ra-success)' : 'var(--ra-danger)';
            });
        }
    </script>
}
