@model IEnumerable<RescateAcademico.Models.Postulacion>
@{
    ViewData["Title"] = "Gestión de Postulaciones";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-clipboard-check"></i> Gestión de Postulaciones</h1>
        <p class="text-secondary small mb-0">Revisión de solicitudes estudiantiles.</p>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        <form method="get" class="mb-3">
            <div class="row g-2">
                <div class="col-md-4">
                    <select name="estado" class="ra-select">
                        <option value="Todos">Todos los estados</option>
                        <option value="En Revisión">En Revisión</option>
                        <option value="Aceptado">Aceptado</option>
                        <option value="Rechazado">Rechazado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="ra-btn ra-btn-primary w-100">
                        <i class="bi bi-filter"></i> Filtrar
                    </button>
                </div>
            </div>
        </form>

        @if (TempData["Success"] != null)
        {
            <div class="ra-alert ra-alert-success mb-3" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
        }

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table" id="tablaPostulaciones">
                    <thead>
                        <tr>
                            <th>Alumno</th>
                            <th>Proyecto</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Alumno?.Nombre @item.Alumno?.Apellidos</strong>
                                    <br />
                                    <span class="text-secondary small">@item.AlumnoId</span>
                                </td>
                                <td>@item.Proyecto?.Titulo</td>
                                <td>@item.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.Estado == "Aceptado")
                                    {
                                        <span class="ra-badge ra-badge-success">Aceptado</span>
                                    }
                                    else if (item.Estado == "Rechazado")
                                    {
                                        <span class="ra-badge ra-badge-danger">Rechazado</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-warning">En Revisión</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Estado == "En Revisión")
                                    {
                                        <div class="d-flex gap-1">
                                            <form asp-action="CambiarEstado" method="post" class="m-0" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="estado" value="Aceptado" />
                                                <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" title="Aceptar">
                                                    <i class="bi bi-check ra-text-success"></i>
                                                </button>
                                            </form>
                                            <form asp-action="CambiarEstado" method="post" class="m-0" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="estado" value="Rechazado" />
                                                <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" title="Rechazar">
                                                    <i class="bi bi-x ra-text-danger"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-secondary small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-inbox"></i>
                <p>No hay postulaciones registradas.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaPostulaciones').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
