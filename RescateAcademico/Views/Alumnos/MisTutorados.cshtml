@model IEnumerable<RescateAcademico.Models.Alumno>
@{
    ViewData["Title"] = "Mis Estudiantes";
    Layout = "_Layout";

    var header = new PageHeader
    {
        Title = "Mis Estudiantes",
        Subtitle = "Alumnos asignados a tus grupos.",
        Icon = "bi-people",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card ra-filter-bar">
    <div class="ra-card-body">
        <form method="get" class="d-flex gap-2 align-items-end">
            <div style="flex:1;max-width:320px;">
                <label class="ra-label">Grupo</label>
                <select name="grupo" class="ra-select" onchange="this.form.submit()">
                    <option value="Todos">Todos los grupos</option>
                    @foreach (var g in ViewBag.Grupos as List<string> ?? new List<string>())
                    {
                        <option value="@g" selected="@(ViewBag.GrupoSeleccionado == g ? "selected" : null)">@g</option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards mb-0" id="tablaEstudiantes">
                    <thead>
                        <tr>
                            <th>Boleta</th>
                            <th>Nombre</th>
                            <th>Grupo</th>
                            <th>Carrera</th>
                            <th>Sem</th>
                            <th>Promedio</th>
                            <th>Riesgo</th>
                            <th style="width: 1px;" data-orderable="false">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var alumno in Model)
                        {
                            <tr>
                                <td data-label="Boleta" class="ra-mono"><strong>@alumno.Matricula</strong></td>
                                <td data-label="Nombre">@alumno.Nombre @alumno.Apellidos</td>
                                <td data-label="Grupo">@(alumno.Grupo?.Clave ?? "—")</td>
                                <td data-label="Carrera">@alumno.Carrera</td>
                                <td data-label="Semestre">@alumno.SemestreActual</td>
                                <td data-label="Promedio">
                                    <span class="ra-badge @(alumno.PromedioGlobal >= 8 ? "ra-badge-success" : alumno.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                        @alumno.PromedioGlobal.ToString("F2")
                                    </span>
                                </td>
                                <td data-label="Riesgo" data-order="@(alumno.RiesgoAcademico == "Rojo" ? 3 : alumno.RiesgoAcademico == "Amarillo" ? 2 : 1)">
                                    <ra-semaforo riesgo="@alumno.RiesgoAcademico" size="sm"></ra-semaforo>
                                </td>
                                <td data-label="Acciones">
                                    <div class="d-flex gap-1 flex-nowrap justify-content-end">
                                        <button type="button" class="ra-btn ra-btn-sm ra-btn-outline" onclick="RaQuickView.open('@alumno.Matricula')" aria-label="Vista rápida" title="Vista rápida">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <a asp-controller="Profesor" asp-action="HistorialAcademico" asp-route-boleta="@alumno.Matricula" class="ra-btn ra-btn-sm ra-btn-primary" aria-label="Perfil académico" title="Perfil">
                                            <i class="bi bi-graph-up"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty py-5">
                <i class="bi bi-people"></i>
                <p>No tienes estudiantes asignados actualmente.</p>
            </div>
        }
    </div>
</div>

<partial name="_AlumnoQuickView" />

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaEstudiantes').DataTable({
                language: window.RaDataTablesEs,
                pageLength: 25,
                columnDefs: [{ orderable: false, targets: [6, 7] }]
            });
        });

        RaQuickView.configure({
            profile:      '/Profesor/HistorialAcademico?boleta={matricula}',
            intervencion: '/Intervenciones/Crear?matricula={matricula}',
            plan:         '/PlanesMejora/Crear?matricula={matricula}',
            cosecovi:     '/Cosecovi/Alumno?matricula={matricula}'
        });
    </script>
}
