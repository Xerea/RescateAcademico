@model IEnumerable<RescateAcademico.Models.Alumno>
@{
    ViewData["Title"] = "Mis Estudiantes";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-people"></i> Mis Estudiantes</h1>
        <p class="text-secondary small mb-0">Lista de alumnos asignados a tus grupos.</p>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="get" class="d-flex gap-2">
            <select name="grupo" class="ra-select" onchange="this.form.submit()">
                <option value="Todos">Todos los grupos</option>
                @foreach (var g in ViewBag.Grupos as List<string> ?? new List<string>())
                {
                    <option value="@g" selected="@(ViewBag.GrupoSeleccionado == g ? "selected" : null)">@g</option>
                }
            </select>
        </form>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table" id="tablaEstudiantes">
                    <thead>
                        <tr>
                            <th>Boleta</th>
                            <th>Nombre</th>
                            <th>Grupo</th>
                            <th>Carrera</th>
                            <th>Semestre</th>
                            <th>Promedio</th>
                            <th>Riesgo</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var alumno in Model)
                        {
                            <tr>
                                <td><strong>@alumno.Matricula</strong></td>
                                <td>@alumno.Nombre @alumno.Apellidos</td>
                                <td>@(alumno.Grupo?.Clave ?? "—")</td>
                                <td>@alumno.Carrera</td>
                                <td>@alumno.SemestreActual</td>
                                <td>
                                    <span class="ra-badge @(alumno.PromedioGlobal >= 8 ? "ra-badge-success" : alumno.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                        @alumno.PromedioGlobal.ToString("F2")
                                    </span>
                                </td>
                                <td>
                                    <ra-semaforo riesgo="@alumno.RiesgoAcademico" size="sm"></ra-semaforo>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <button type="button" class="ra-btn ra-btn-sm ra-btn-outline" data-bs-toggle="modal" data-bs-target="#modalAlumno_@alumno.Matricula">
                                            <i class="bi bi-eye"></i> Rápido
                                        </button>
                                        <a asp-controller="Profesor" asp-action="HistorialAcademico" asp-route-boleta="@alumno.Matricula" class="ra-btn ra-btn-sm ra-btn-primary">
                                            <i class="bi bi-graph-up"></i> Perfil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-people"></i>
                <p>No tienes estudiantes asignados actualmente.</p>
            </div>
        }
    </div>
</div>

@foreach (var alumno in Model)
{
    <div class="modal fade" id="modalAlumno_@alumno.Matricula" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content ra-modal-content">
                <div class="modal-header border-bottom" style="border-color: var(--ra-border) !important;">
                    <h5 class="modal-title fw-semibold"><i class="bi bi-person-badge ra-text-accent me-2"></i>@alumno.Nombre @alumno.Apellidos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <p class="mb-2"><span class="text-secondary small">Boleta:</span> <strong>@alumno.Matricula</strong></p>
                            <p class="mb-2"><span class="text-secondary small">Grupo:</span> <strong>@(alumno.Grupo?.Clave ?? "—")</strong></p>
                            <p class="mb-2"><span class="text-secondary small">Carrera:</span> <strong>@alumno.Carrera</strong></p>
                            <p class="mb-0"><span class="text-secondary small">Semestre:</span> <strong>@alumno.SemestreActual</strong></p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2"><span class="text-secondary small">Promedio:</span> <span class="ra-badge @(alumno.PromedioGlobal >= 8 ? "ra-badge-success" : alumno.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">@alumno.PromedioGlobal.ToString("F2")</span></p>
                            <p class="mb-2"><span class="text-secondary small">Riesgo:</span>
                                <ra-semaforo riesgo="@alumno.RiesgoAcademico" size="sm"></ra-semaforo>
                            </p>
                            <p class="mb-2"><span class="text-secondary small">Materias Reprobadas:</span> <strong>@(alumno.MateriasReprobadas ?? 0)</strong></p>
                            <p class="mb-0"><span class="text-secondary small">Ausencias:</span> <strong>@(alumno.Ausencias ?? 0)</strong></p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top" style="border-color: var(--ra-border) !important;">
                    <a asp-controller="Intervenciones" asp-action="Crear" asp-route-matricula="@alumno.Matricula" class="ra-btn ra-btn-primary">
                        <i class="bi bi-plus-circle"></i> Agregar Intervención
                    </a>
                    <a asp-controller="Profesor" asp-action="HistorialAcademico" asp-route-boleta="@alumno.Matricula" class="ra-btn ra-btn-outline">
                        <i class="bi bi-graph-up"></i> Ver Historial
                    </a>
                    <button type="button" class="ra-btn ra-btn-ghost" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaEstudiantes').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
