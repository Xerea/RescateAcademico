@model IEnumerable<RescateAcademico.Models.AsignacionTutor>
@{
    ViewData["Title"] = "Mis Estudiantes";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col">
        <h2 style="color: #6c1d45;"><i class="bi bi-people"></i> Mis Estudiantes</h2>
        <p class="text-muted">Lista de alumnos asignados a tu Profesoría.</p>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Boleta</th>
                            <th>Nombre</th>
                            <th>Carrera</th>
                            <th>Semestre</th>
                            <th>Promedio</th>
                            <th>Riesgo</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var alumno = item.Alumno;
                            <tr>
                                <td><strong>@alumno?.Matricula</strong></td>
                                <td>@alumno?.Nombre @alumno?.Apellidos</td>
                                <td>@alumno?.Carrera</td>
                                <td>@alumno?.SemestreActual</td>
                                <td>
                                    <span class="badge @(alumno?.PromedioGlobal >= 8 ? "bg-success" : alumno?.PromedioGlobal >= 6 ? "bg-warning text-dark" : "bg-danger")">
                                        @(alumno?.PromedioGlobal.ToString("F2") ?? "N/A")
                                    </span>
                                </td>
                                <td>
                                    @if (alumno?.RiesgoAcademico == "Rojo")
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-exclamation-triangle"></i> Rojo
                                        </span>
                                    }
                                    else if (alumno?.RiesgoAcademico == "Amarillo")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-exclamation"></i> Amarillo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Verde
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="PerfilAcademico" asp-action="VerTutorado" asp-route-matricula="@alumno?.Matricula" class="btn btn-sm btn-primary">
                                        <i class="bi bi-eye"></i> Ver Perfil
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-people fs-1 text-muted"></i>
                <p class="text-muted mt-3">No tienes tutorados asignados actualmente.</p>
            </div>
        }
    </div>
</div>
