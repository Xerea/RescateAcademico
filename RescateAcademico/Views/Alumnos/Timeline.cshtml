@model RescateAcademico.Models.Alumno
@{
    ViewData["Title"] = "Línea de tiempo — " + Model.Nombre + " " + Model.Apellidos;
    Layout = "_Layout";
    var intervenciones = ViewBag.Intervenciones as List<RescateAcademico.Models.IntervencionTutoria> ?? new();
    var planes = ViewBag.Planes as List<RescateAcademico.Models.PlanMejora> ?? new();
    var dictamenes = Model.Dictamenes?.OrderByDescending(d => d.FechaEmision).ToList() ?? new();
    var reportes = Model.ReportesCosecovi?.OrderByDescending(r => r.FechaReporte).ToList() ?? new();
    var calificaciones = Model.Calificaciones?.Where(c => !c.Aprobada).OrderByDescending(c => c.Periodo).ToList() ?? new();

    var eventos = new List<(DateTime Fecha, string Titulo, string Descripcion, string Tipo, string Icono)>();

    foreach (var i in intervenciones)
        eventos.Add((i.Fecha, $"Intervención: {i.Tipo}", i.Descripcion, "intervencion", "bi-clipboard-pulse"));

    foreach (var p in planes)
        eventos.Add((p.FechaCreacion, "Plan de mejora", $"Estado: {p.Estado}", "plan", "bi-journal-check"));

    foreach (var d in dictamenes)
        eventos.Add((d.FechaEmision, $"Dictamen: {d.Tipo}", d.Observaciones ?? "Sin observaciones", "dictamen", "bi-file-text"));

    foreach (var r in reportes)
        eventos.Add((r.FechaReporte, "Reporte COSECOVI", r.SituacionObservada ?? "Sin observaciones", "cosecovi", "bi-exclamation-circle"));

    foreach (var c in calificaciones)
        eventos.Add((DateTime.Now.AddMonths(-1), $"Materia reprobada: {c.Materia?.Nombre}", $"Calificación: {c.Valor} · Periodo: {c.Periodo}", "reprobada", "bi-x-circle"));

    eventos = eventos.OrderByDescending(e => e.Fecha).ToList();

    var header = new PageHeader
    {
        Title = "Línea de tiempo académica",
        Subtitle = $"{Model.Nombre} {Model.Apellidos} — Boleta {Model.Matricula}",
        Icon = "bi-clock-history",
        IconVariant = "accent",
        BackUrl = Url.Action("Index", "Alumnos"),
        BackLabel = "Catálogo"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-info">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Intervenciones</div>
                    <div class="ra-stat-value">@intervenciones.Count</div>
                </div>
                <i class="bi bi-clipboard-pulse ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-success">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Planes de mejora</div>
                    <div class="ra-stat-value">@planes.Count</div>
                </div>
                <i class="bi bi-journal-check ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-warning">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">Dictámenes</div>
                    <div class="ra-stat-value">@dictamenes.Count</div>
                </div>
                <i class="bi bi-file-text ra-stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="ra-stat ra-stat-danger">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="ra-stat-label">COSECOVI</div>
                    <div class="ra-stat-value">@reportes.Count</div>
                </div>
                <i class="bi bi-exclamation-circle ra-stat-icon"></i>
            </div>
        </div>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (eventos.Any())
        {
            <div class="ra-timeline">
                @foreach (var evt in eventos)
                {
                    var (badgeColor, barColor) = evt.Tipo switch
                    {
                        "intervencion" => ("var(--ra-info)",    "var(--ra-info)"),
                        "plan"         => ("var(--ra-success)", "var(--ra-success)"),
                        "dictamen"     => ("var(--ra-warning)", "var(--ra-warning)"),
                        "cosecovi"     => ("var(--ra-danger)",  "var(--ra-danger)"),
                        "reprobada"    => ("var(--ra-danger)",  "var(--ra-danger)"),
                        _              => ("var(--ra-text-muted)", "var(--ra-border)")
                    };
                    <div class="ra-timeline-item">
                        <div class="ra-timeline-dot" style="background:@badgeColor;">
                            <i class="bi @evt.Icono"></i>
                        </div>
                        <div class="ra-timeline-body" style="border-left-color:@barColor;">
                            <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                <h6 class="fw-semibold mb-1">@evt.Titulo</h6>
                                <small class="text-secondary">@evt.Fecha.ToString("dd/MM/yyyy")</small>
                            </div>
                            <p class="small text-secondary mb-0">@evt.Descripcion</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-inbox"></i>
                <p>No hay eventos registrados.</p>
            </div>
        }
    </div>
</div>

<style>
    .ra-timeline { position: relative; }
    .ra-timeline-item {
        display: flex;
        gap: 1rem;
        padding-bottom: 1.25rem;
        position: relative;
    }
    .ra-timeline-item:not(:last-child)::before {
        content: '';
        position: absolute;
        top: 36px;
        left: 17px;
        bottom: 0;
        width: 2px;
        background: var(--ra-border);
    }
    .ra-timeline-dot {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 0 0 3px var(--ra-surface);
        z-index: 1;
    }
    .ra-timeline-body {
        flex: 1;
        background: var(--ra-surface);
        border: 1px solid var(--ra-border);
        border-left-width: 3px;
        border-radius: var(--ra-radius);
        padding: 0.6rem 0.9rem;
    }
</style>
