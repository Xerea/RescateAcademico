@model IEnumerable<RescateAcademico.Models.Alumno>
@{
    ViewData["Title"] = "Catálogo de Alumnos";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold h3 mb-1">Catálogo de Alumnos</h1>
        <p class="text-secondary small mb-0">Consulta y filtra el alumnado por riesgo, carrera y semestre.</p>
    </div>
</div>

<div class="ra-card mb-4">
    <div class="ra-card-body">
        <form method="get">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="ra-label">Buscar</label>
                    <input type="text" name="busqueda" class="ra-input" placeholder="Boleta, nombre o apellidos..." value="@ViewBag.Busqueda" />
                </div>
                <div class="col-md-2">
                    <label class="ra-label">Riesgo</label>
                    <select name="filtroRiesgo" class="ra-input">
                        <option value="">Todos</option>
                        <option value="Verde" selected="@(ViewBag.FiltroRiesgo == "Verde" ? "selected" : null)">Verde</option>
                        <option value="Amarillo" selected="@(ViewBag.FiltroRiesgo == "Amarillo" ? "selected" : null)">Amarillo</option>
                        <option value="Rojo" selected="@(ViewBag.FiltroRiesgo == "Rojo" ? "selected" : null)">Rojo</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="ra-label">Carrera</label>
                    <select name="carrera" class="ra-input">
                        <option value="">Todas</option>
                        @foreach (var c in (ViewBag.Carreras as List<string>)!)
                        {
                            <option value="@c" selected="@(ViewBag.FiltroCarrera == c ? "selected" : null)">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="ra-label">Semestre</label>
                    <select name="semestre" class="ra-input">
                        <option value="">Todos</option>
                        @foreach (var s in (ViewBag.Semestres as List<int>)!)
                        {
                            <option value="@s" selected="@(ViewBag.FiltroSemestre == s ? "selected" : null)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="ra-btn ra-btn-primary w-100">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="ra-card">
    <div class="table-responsive">
        <table class="ra-table mb-0" id="tablaAlumnos">
            <thead>
                <tr>
                    <th>Boleta</th>
                    <th>Nombre</th>
                    <th>Carrera</th>
                    <th>Sem</th>
                    <th>Promedio</th>
                    <th>Riesgo</th>
                    <th>Actualización</th>
                    <th style="width: 1px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Matricula</strong></td>
                        <td>@item.Nombre @item.Apellidos</td>
                        <td class="text-secondary">@item.Carrera</td>
                        <td>@item.SemestreActual</td>
                        <td>
                            <span class="ra-badge @(item.PromedioGlobal >= 8 ? "ra-badge-success" : item.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                @item.PromedioGlobal.ToString("F2")
                            </span>
                        </td>
                        <td>
                            @if (item.RiesgoAcademico == "Rojo")
                            {
                                <span class="ra-badge ra-badge-danger">Rojo</span>
                            }
                            else if (item.RiesgoAcademico == "Amarillo")
                            {
                                <span class="ra-badge ra-badge-warning">Amarillo</span>
                            }
                            else
                            {
                                <span class="ra-badge ra-badge-success">Verde</span>
                            }
                        </td>
                        <td class="text-secondary small">@(item.FechaUltimaActualizacion?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>
                            <div class="d-flex gap-1 flex-nowrap">
                                <button type="button" class="ra-btn ra-btn-ghost ra-btn-sm" onclick="loadQuickView('@item.Matricula')" title="Vista rápida">
                                    <i class="bi bi-lightning"></i>
                                </button>
                                <a asp-controller="Alumnos" asp-action="Detalles" asp-route-id="@item.Matricula" class="ra-btn ra-btn-outline ra-btn-sm" title="Detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-controller="Alumnos" asp-action="Timeline" asp-route-matricula="@item.Matricula" class="ra-btn ra-btn-outline ra-btn-sm" title="Línea de tiempo">
                                    <i class="bi bi-clock-history"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Quick View Modal -->
<div class="modal fade" id="quickViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border: 1px solid var(--ra-border); border-radius: var(--ra-radius-lg); background: var(--ra-surface);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="qvTitle"><i class="bi bi-person-badge me-2" style="color: var(--ra-primary);"></i>Cargando...</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div id="qvLoading" class="text-center py-5">
                    <div class="spinner-border" role="status" style="color: var(--ra-primary);"><span class="visually-hidden">Cargando...</span></div>
                    <p class="text-secondary mt-3">Cargando información del estudiante...</p>
                </div>
                <div id="qvContent" style="display:none;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="ra-card h-100">
                                <div class="ra-card-body">
                                    <div class="mb-3">
                                        <small class="text-secondary d-block">Boleta</small>
                                        <span class="fw-semibold" id="qvMatricula">—</span>
                                    </div>
                                    <div class="mb-3">
                                        <small class="text-secondary d-block">Carrera</small>
                                        <span id="qvCarrera">—</span>
                                    </div>
                                    <div class="mb-3">
                                        <small class="text-secondary d-block">Semestre</small>
                                        <span id="qvSemestre">—</span>
                                    </div>
                                    <div>
                                        <small class="text-secondary d-block">Grupo</small>
                                        <span id="qvGrupo">—</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="ra-card h-100">
                                <div class="ra-card-body">
                                    <div class="mb-3">
                                        <small class="text-secondary d-block">Promedio Global</small>
                                        <span class="fw-bold fs-5" id="qvPromedio">—</span>
                                    </div>
                                    <div class="mb-3">
                                        <small class="text-secondary d-block">Riesgo Académico</small>
                                        <span id="qvRiesgo">—</span>
                                    </div>
                                    <div class="mb-3">
                                        <small class="text-secondary d-block">Carga Académica</small>
                                        <span id="qvCarga">—</span>
                                    </div>
                                    <div>
                                        <small class="text-secondary d-block">Última Actualización</small>
                                        <span id="qvActualizacion">—</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="row g-2">
                                <div class="col-3">
                                    <div class="ra-card text-center py-2">
                                        <div class="fw-bold fs-5" style="color: var(--ra-danger);" id="qvReprobadas">0</div>
                                        <small class="text-secondary">Reprobadas</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="ra-card text-center py-2">
                                        <div class="fw-bold fs-5" style="color: var(--ra-warning);" id="qvAusencias">0</div>
                                        <small class="text-secondary">Ausencias</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="ra-card text-center py-2">
                                        <div class="fw-bold fs-5" style="color: var(--ra-info);" id="qvEts">0</div>
                                        <small class="text-secondary">ETS</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="ra-card text-center py-2">
                                        <div class="fw-bold fs-5 text-secondary" id="qvRecursadas">0</div>
                                        <small class="text-secondary">Recursadas</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <a id="qvLinkDetalle" href="#" class="ra-btn ra-btn-primary ra-btn-sm">
                    <i class="bi bi-eye"></i> Detalle Completo
                </a>
                <a id="qvLinkTimeline" href="#" class="ra-btn ra-btn-outline ra-btn-sm">
                    <i class="bi bi-clock-history"></i> Línea de Tiempo
                </a>
                <button type="button" class="ra-btn ra-btn-ghost ra-btn-sm" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaAlumnos').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25,
                columnDefs: [
                    { orderable: false, targets: 7 }
                ]
            });
        });

        async function loadQuickView(matricula) {
            const modal = new bootstrap.Modal(document.getElementById('quickViewModal'));
            modal.show();

            document.getElementById('qvLoading').style.display = 'block';
            document.getElementById('qvContent').style.display = 'none';
            document.getElementById('qvTitle').innerHTML = '<i class="bi bi-person-badge me-2" style="color: var(--ra-primary);"></i>Cargando...';

            try {
                const response = await fetch('/Alumnos/QuickView?matricula=' + encodeURIComponent(matricula));
                if (!response.ok) throw new Error('Error al cargar');
                const data = await response.json();

                const title = document.getElementById('qvTitle');
                title.innerHTML = '<i class="bi bi-person-badge me-2" style="color: var(--ra-primary);"></i>';
                title.appendChild(document.createTextNode(data.nombre + ' ' + data.apellidos));

                document.getElementById('qvMatricula').textContent = data.matricula;
                document.getElementById('qvCarrera').textContent = data.carrera || '—';
                document.getElementById('qvSemestre').textContent = data.semestreActual;
                document.getElementById('qvGrupo').textContent = data.grupo || '—';

                const promedioEl = document.getElementById('qvPromedio');
                promedioEl.textContent = data.promedioGlobal.toFixed(2);
                promedioEl.style.color = data.promedioGlobal >= 8 ? 'var(--ra-success)' : data.promedioGlobal >= 6 ? 'var(--ra-warning)' : 'var(--ra-danger)';

                const riesgoEl = document.getElementById('qvRiesgo');
                const riesgo = data.riesgoAcademico || 'Verde';
                let badgeClass = riesgo === 'Rojo' ? 'ra-badge-danger' : riesgo === 'Amarillo' ? 'ra-badge-warning' : 'ra-badge-success';
                riesgoEl.innerHTML = '<span class="ra-badge ' + badgeClass + '">' + riesgo + '</span>';

                document.getElementById('qvCarga').textContent = (data.cargaAcademicaActual || 0) + ' materias';
                document.getElementById('qvActualizacion').textContent = data.fechaUltimaActualizacion || '—';

                document.getElementById('qvReprobadas').textContent = data.materiasReprobadas || 0;
                document.getElementById('qvAusencias').textContent = data.ausencias || 0;
                document.getElementById('qvEts').textContent = data.etsPresentados || 0;
                document.getElementById('qvRecursadas').textContent = data.recursamientos || 0;

                document.getElementById('qvLinkDetalle').href = '/Alumnos/Detalles/' + data.matricula;
                document.getElementById('qvLinkTimeline').href = '/Alumnos/Timeline?matricula=' + data.matricula;

                document.getElementById('qvLoading').style.display = 'none';
                document.getElementById('qvContent').style.display = 'block';
            } catch (err) {
                document.getElementById('qvLoading').innerHTML = '<p class="text-danger">No se pudo cargar la información. Intenta de nuevo.</p>';
            }
        }
    </script>
}
