@model IEnumerable<RescateAcademico.Models.Alumno>
@{
    ViewData["Title"] = "Catálogo de Alumnos";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;"><i class="bi bi-people"></i> Catálogo de Alumnos</h2>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="get" class="mb-3">
            <div class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="busqueda" class="form-control" placeholder="Buscar por boleta, nombre o apellidos..." value="@ViewBag.Busqueda" />
                </div>
                <div class="col-md-2">
                    <select name="filtroRiesgo" class="form-select">
                        <option value="">Todos los riesgos</option>
                        <option value="Verde" selected="@(ViewBag.FiltroRiesgo == "Verde" ? "selected" : null)">Verde</option>
                        <option value="Amarillo" selected="@(ViewBag.FiltroRiesgo == "Amarillo" ? "selected" : null)">Amarillo</option>
                        <option value="Rojo" selected="@(ViewBag.FiltroRiesgo == "Rojo" ? "selected" : null)">Rojo</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="carrera" class="form-select">
                        <option value="">Todas las carreras</option>
                        @foreach (var c in (ViewBag.Carreras as List<string>)!)
                        {
                            <option value="@c" selected="@(ViewBag.FiltroCarrera == c ? "selected" : null)">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="semestre" class="form-select">
                        <option value="">Todos los semestres</option>
                        @foreach (var s in (ViewBag.Semestres as List<int>)!)
                        {
                            <option value="@s" selected="@(ViewBag.FiltroSemestre == s ? "selected" : null)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover" id="tablaAlumnos">
                <thead style="background-color: #6c1d45; color: white;">
                    <tr>
                        <th>Boleta</th>
                        <th>Nombre</th>
                        <th>Carrera</th>
                        <th>Semestre</th>
                        <th>Promedio</th>
                        <th>Riesgo</th>
                        <th>Última Actualización</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Matricula</strong></td>
                            <td>@item.Nombre @item.Apellidos</td>
                            <td>@item.Carrera</td>
                            <td>@item.SemestreActual</td>
                            <td>
                                <span class="badge @(item.PromedioGlobal >= 8 ? "bg-success" : item.PromedioGlobal >= 6 ? "bg-warning" : "bg-danger")">
                                    @item.PromedioGlobal.ToString("F2")
                                </span>
                            </td>
                            <td>
                                @if (item.RiesgoAcademico == "Rojo")
                                {
                                    <span class="badge bg-danger">Rojo</span>
                                }
                                else if (item.RiesgoAcademico == "Amarillo")
                                {
                                    <span class="badge bg-warning text-dark">Amarillo</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Verde</span>
                                }
                            </td>
                            <td>
                                @(item.FechaUltimaActualizacion?.ToString("dd/MM/yyyy") ?? "—")
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="loadQuickView('@item.Matricula')" title="Vista rápida">
                                    <i class="bi bi-lightning"></i> Rápido
                                </button>
                                <a asp-controller="Alumnos" asp-action="Detalles" asp-route-id="@item.Matricula" class="btn btn-sm btn-outline-info" title="Ver detalle">
                                    <i class="bi bi-eye"></i> Detalle
                                </a>
                                <a asp-controller="Profesor" asp-action="HistorialAcademico" asp-route-boleta="@item.Matricula" class="btn btn-sm btn-outline-primary" title="Historial académico">
                                    <i class="bi bi-journal-text"></i> Historial
                                </a>
                                <a asp-controller="Predicciones" asp-action="Detalle" asp-route-matricula="@item.Matricula" class="btn btn-sm btn-outline-dark" title="Predicción IA">
                                    <i class="bi bi-brain"></i> IA
                                </a>
                                <a asp-controller="Alumnos" asp-action="Timeline" asp-route-matricula="@item.Matricula" class="btn btn-sm btn-outline-warning" title="Línea de tiempo">
                                    <i class="bi bi-clock-history"></i> Línea de Tiempo
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Single reusable modal -->
<div class="modal fade" id="quickViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background-color: #6c1d45; color: white;">
                <h5 class="modal-title" id="qvTitle"><i class="bi bi-person-badge"></i> Cargando...</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div id="qvLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
                    <p class="text-muted mt-2">Cargando información del estudiante...</p>
                </div>
                <div id="qvContent" style="display:none;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body">
                                    <h6 class="text-muted">Boleta</h6>
                                    <p class="fw-bold" id="qvMatricula">—</p>
                                    <h6 class="text-muted">Carrera</h6>
                                    <p id="qvCarrera">—</p>
                                    <h6 class="text-muted">Semestre</h6>
                                    <p id="qvSemestre">—</p>
                                    <h6 class="text-muted">Grupo</h6>
                                    <p id="qvGrupo">—</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 bg-light h-100">
                                <div class="card-body">
                                    <h6 class="text-muted">Promedio Global</h6>
                                    <p class="fw-bold" id="qvPromedio">—</p>
                                    <h6 class="text-muted">Riesgo Académico</h6>
                                    <p id="qvRiesgo">—</p>
                                    <h6 class="text-muted">Carga Académica</h6>
                                    <p id="qvCarga">—</p>
                                    <h6 class="text-muted">Última Actualización</h6>
                                    <p id="qvActualizacion">—</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="row text-center">
                                <div class="col-3">
                                    <div class="p-2 bg-danger text-white rounded">
                                        <h5 class="mb-0" id="qvReprobadas">0</h5>
                                        <small>Reprobadas</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="p-2 bg-warning text-dark rounded">
                                        <h5 class="mb-0" id="qvAusencias">0</h5>
                                        <small>Ausencias</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="p-2 bg-info text-white rounded">
                                        <h5 class="mb-0" id="qvEts">0</h5>
                                        <small>ETS</small>
                                    </div>
                                </div>
                                <div class="col-3">
                                    <div class="p-2 bg-secondary text-white rounded">
                                        <h5 class="mb-0" id="qvRecursadas">0</h5>
                                        <small>Recursadas</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <a id="qvLinkDetalle" href="#" class="btn btn-info">
                    <i class="bi bi-eye"></i> Ver Detalle Completo
                </a>
                <a id="qvLinkTimeline" href="#" class="btn btn-warning">
                    <i class="bi bi-clock-history"></i> Línea de Tiempo
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaAlumnos').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25,
                columnDefs: [
                    { orderable: false, targets: 7 }
                ]
            });
        });

        async function loadQuickView(matricula) {
            const modal = new bootstrap.Modal(document.getElementById('quickViewModal'));
            modal.show();

            document.getElementById('qvLoading').style.display = 'block';
            document.getElementById('qvContent').style.display = 'none';
            document.getElementById('qvTitle').innerHTML = '<i class="bi bi-person-badge"></i> Cargando...';

            try {
                const response = await fetch('/Alumnos/QuickView?matricula=' + encodeURIComponent(matricula));
                if (!response.ok) throw new Error('Error al cargar');
                const data = await response.json();

                document.getElementById('qvTitle').innerHTML = '<i class="bi bi-person-badge"></i> ' + data.nombre + ' ' + data.apellidos;
                document.getElementById('qvMatricula').textContent = data.matricula;
                document.getElementById('qvCarrera').textContent = data.carrera || '—';
                document.getElementById('qvSemestre').textContent = data.semestreActual;
                document.getElementById('qvGrupo').textContent = data.grupo || '—';

                const promedioEl = document.getElementById('qvPromedio');
                promedioEl.textContent = data.promedioGlobal.toFixed(2);
                promedioEl.className = 'fw-bold ' + (data.promedioGlobal >= 8 ? 'text-success' : data.promedioGlobal >= 6 ? 'text-warning' : 'text-danger');

                const riesgoEl = document.getElementById('qvRiesgo');
                const riesgo = data.riesgoAcademico || 'Verde';
                let riesgoBadge = '';
                if (riesgo === 'Rojo') riesgoBadge = '<span class="badge bg-danger">Rojo</span>';
                else if (riesgo === 'Amarillo') riesgoBadge = '<span class="badge bg-warning text-dark">Amarillo</span>';
                else riesgoBadge = '<span class="badge bg-success">Verde</span>';
                riesgoEl.innerHTML = riesgoBadge;

                document.getElementById('qvCarga').textContent = (data.cargaAcademicaActual || 0) + ' materias';
                document.getElementById('qvActualizacion').textContent = data.fechaUltimaActualizacion || '—';

                document.getElementById('qvReprobadas').textContent = data.materiasReprobadas || 0;
                document.getElementById('qvAusencias').textContent = data.ausencias || 0;
                document.getElementById('qvEts').textContent = data.etsPresentados || 0;
                document.getElementById('qvRecursadas').textContent = data.recursamientos || 0;

                document.getElementById('qvLinkDetalle').href = '/Alumnos/Detalles/' + data.matricula;
                document.getElementById('qvLinkTimeline').href = '/Alumnos/Timeline?matricula=' + data.matricula;

                document.getElementById('qvLoading').style.display = 'none';
                document.getElementById('qvContent').style.display = 'block';
            } catch (err) {
                document.getElementById('qvLoading').innerHTML = '<p class="text-danger">No se pudo cargar la información. Intenta de nuevo.</p>';
            }
        }
    </script>
}