@model IEnumerable<RescateAcademico.Models.Alumno>
@{
    ViewData["Title"] = "Catálogo de Alumnos";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Catálogo de alumnos",
        Subtitle = "Consulta y filtra el alumnado por riesgo, carrera y semestre.",
        Icon = "bi-people",
        IconVariant = "accent"
    };

    var filterActive = !string.IsNullOrEmpty(ViewBag.Busqueda as string)
        || !string.IsNullOrEmpty(ViewBag.FiltroRiesgo as string)
        || !string.IsNullOrEmpty(ViewBag.FiltroCarrera as string)
        || !string.IsNullOrEmpty(ViewBag.FiltroGrupo as string)
        || ViewBag.FiltroSemestre != null;
}

<partial name="_PageHeader" model="header" />

<div class="ra-card ra-filter-bar">
    <div class="ra-card-body">
        <form method="get">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="ra-label">Buscar</label>
                    <input type="text" name="busqueda" class="ra-input" placeholder="Boleta, nombre o apellidos…" value="@ViewBag.Busqueda" />
                </div>
                <div class="col-md-2">
                    <label class="ra-label">Riesgo</label>
                    <select name="filtroRiesgo" class="ra-select">
                        <option value="">Todos</option>
                        <option value="Verde" selected="@(ViewBag.FiltroRiesgo == "Verde" ? "selected" : null)">Verde</option>
                        <option value="Amarillo" selected="@(ViewBag.FiltroRiesgo == "Amarillo" ? "selected" : null)">Amarillo</option>
                        <option value="Rojo" selected="@(ViewBag.FiltroRiesgo == "Rojo" ? "selected" : null)">Rojo</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="ra-label">Carrera</label>
                    <select name="carrera" class="ra-select">
                        <option value="">Todas</option>
                        @foreach (var c in (ViewBag.Carreras as List<string>)!)
                        {
                            <option value="@c" selected="@(ViewBag.FiltroCarrera == c ? "selected" : null)">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="ra-label">Semestre</label>
                    <select name="semestre" class="ra-select">
                        <option value="">Todos</option>
                        @foreach (var s in (ViewBag.Semestres as List<int>)!)
                        {
                            <option value="@s" selected="@(ViewBag.FiltroSemestre == s ? "selected" : null)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="ra-label">Grupo</label>
                    <select name="grupo" class="ra-select">
                        <option value="">Todos</option>
                        @foreach (var g in (ViewBag.Grupos as List<string>)!)
                        {
                            <option value="@g" selected="@(ViewBag.FiltroGrupo as string == g ? "selected" : null)">@g</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="ra-btn ra-btn-primary flex-fill">
                        <i class="bi bi-search"></i> Filtrar
                    </button>
                    @if (filterActive)
                    {
                        <a asp-action="Index" class="ra-btn ra-btn-ghost" title="Limpiar filtros">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="ra-card">
    <div class="table-responsive">
        <table class="ra-table ra-table-cards mb-0" id="tablaAlumnos">
            <thead>
                <tr>
                    <th>Boleta</th>
                    <th>Nombre</th>
                    <th>Carrera</th>
                    <th>Sem</th>
                    <th>Promedio</th>
                    <th>Riesgo</th>
                    <th>Actualización</th>
                    <th style="width: 1px;" data-orderable="false">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td data-label="Boleta"><strong class="ra-mono">@item.Matricula</strong></td>
                        <td data-label="Nombre">@item.Nombre @item.Apellidos</td>
                        <td data-label="Carrera" class="text-secondary">@item.Carrera</td>
                        <td data-label="Semestre">@item.SemestreActual</td>
                        <td data-label="Promedio">
                            <span class="ra-badge @(item.PromedioGlobal >= 8 ? "ra-badge-success" : item.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                @item.PromedioGlobal.ToString("F2")
                            </span>
                        </td>
                        <td data-label="Riesgo" data-order="@(item.RiesgoAcademico == "Rojo" ? 3 : item.RiesgoAcademico == "Amarillo" ? 2 : 1)">
                            <ra-semaforo riesgo="@item.RiesgoAcademico" size="sm"></ra-semaforo>
                        </td>
                        <td data-label="Actualizado" class="text-secondary small">@(item.FechaUltimaActualizacion?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td data-label="Acciones">
                            <div class="d-flex gap-1 flex-nowrap justify-content-end">
                                <button type="button" class="ra-btn ra-btn-ghost ra-btn-sm" onclick="RaQuickView.open('@item.Matricula')" aria-label="Vista rápida de @item.Nombre @item.Apellidos" title="Vista rápida">
                                    <i class="bi bi-lightning"></i>
                                </button>
                                <a asp-controller="Alumnos" asp-action="Detalles" asp-route-id="@item.Matricula" class="ra-btn ra-btn-outline ra-btn-sm" aria-label="Detalles completos" title="Detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-controller="Alumnos" asp-action="Timeline" asp-route-matricula="@item.Matricula" class="ra-btn ra-btn-outline ra-btn-sm" aria-label="Línea de tiempo" title="Línea de tiempo">
                                    <i class="bi bi-clock-history"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_AlumnoQuickView" />

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaAlumnos').DataTable({
                language: window.RaDataTablesEs,
                pageLength: 25,
                columnDefs: [{ orderable: false, targets: 7 }]
            });
        });

        // Configure shared quick view links for this page
        RaQuickView.configure({
            detalle:  '/Alumnos/Detalles/{matricula}',
            timeline: '/Alumnos/Timeline?matricula={matricula}',
            cosecovi: '/Cosecovi/Alumno?matricula={matricula}'
        });
    </script>
}
