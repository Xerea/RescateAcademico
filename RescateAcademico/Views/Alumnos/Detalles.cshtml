@model RescateAcademico.Models.Alumno
@{
    ViewData["Title"] = "Detalles del Alumno";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col">
        <h2 style="color: #6c1d45;">
            <i class="bi bi-person-badge"></i> @Model.Nombre @Model.Apellidos
        </h2>
        <p class="text-muted">Matrícula: @Model.Matricula</p>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <h4 class="mb-0 @(Model.PromedioGlobal >= 8 ? "text-success" : Model.PromedioGlobal >= 6 ? "text-warning" : "text-danger")">
                    @Model.PromedioGlobal.ToString("F2")
                </h4>
                <small class="text-muted">Promedio Global</small>
                <hr />
                <p><strong>Carrera:</strong> @Model.Carrera</p>
                <p><strong>Semestre:</strong> @Model.SemestreActual</p>
                <p>
                    <strong>Riesgo:</strong>
                    @if (Model.RiesgoAcademico == "Rojo")
                    {
                        <span class="badge bg-danger">Rojo</span>
                    }
                    else if (Model.RiesgoAcademico == "Amarillo")
                    {
                        <span class="badge bg-warning text-dark">Amarillo</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Verde</span>
                    }
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header" style="background-color: #6c1d45; color: white;">
                <h5 class="mb-0">Información Académica</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <h5 class="text-success">@Model.CargaAcademicaActual</h5>
                        <small>Materias Actuales</small>
                    </div>
                    <div class="col-4">
                        <h5 class="text-danger">@(Model.MateriasReprobadas ?? 0)</h5>
                        <small>Reprobadas</small>
                    </div>
                    <div class="col-4">
                        <h5 class="text-warning">@(Model.Recursamientos ?? 0)</h5>
                        <small>Recursadas</small>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Calificaciones?.Any() == true)
        {
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header" style="background-color: #6c1d45; color: white;">
                    <h5 class="mb-0">Historial de Calificaciones</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Materia</th>
                                    <th>Período</th>
                                    <th>Calificación</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var calif in Model.Calificaciones)
                                {
                                    <tr>
                                        <td>@calif.Materia?.Nombre</td>
                                        <td>@calif.Periodo</td>
                                        <td>@calif.Valor?.ToString("F1")</td>
                                        <td>
                                            @if (calif.Aprobada)
                                            {
                                                <span class="badge bg-success">Aprobada</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Reprobada</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Admin" asp-action="Alumnos" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver a la lista
    </a>
</div>
