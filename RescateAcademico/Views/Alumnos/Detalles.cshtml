@model RescateAcademico.Models.Alumno
@{
    ViewData["Title"] = "Detalles del Alumno";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1">
            <i class="bi bi-person-badge ra-text-accent me-2"></i>@Model.Nombre @Model.Apellidos
        </h1>
        <p class="text-secondary small mb-0">Boleta: @Model.Matricula</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="ra-card h-100">
            <div class="ra-card-body text-center">
                <h4 class="mb-0 @(Model.PromedioGlobal >= 8 ? "ra-text-success" : Model.PromedioGlobal >= 6 ? "ra-text-warning" : "ra-text-danger")">
                    @Model.PromedioGlobal.ToString("F2")
                </h4>
                <small class="text-secondary">Promedio Global</small>
                <hr style="border-color: var(--ra-border);" />
                <p class="mb-2"><strong>Carrera:</strong> @Model.Carrera</p>
                <p class="mb-2"><strong>Semestre:</strong> @Model.SemestreActual</p>
                <p class="mb-0">
                    <strong>Riesgo:</strong>
                    @if (Model.RiesgoAcademico == "Rojo")
                    {
                        <span class="ra-badge ra-badge-danger">Rojo</span>
                    }
                    else if (Model.RiesgoAcademico == "Amarillo")
                    {
                        <span class="ra-badge ra-badge-warning">Amarillo</span>
                    }
                    else
                    {
                        <span class="ra-badge ra-badge-success">Verde</span>
                    }
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="ra-card">
            <div class="ra-card-header">
                <i class="bi bi-journal-text"></i> Información Académica
            </div>
            <div class="ra-card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <h5 class="ra-text-success">@Model.CargaAcademicaActual</h5>
                        <small class="text-secondary">Materias Actuales</small>
                    </div>
                    <div class="col-4">
                        <h5 class="ra-text-danger">@(Model.MateriasReprobadas ?? 0)</h5>
                        <small class="text-secondary">Reprobadas</small>
                    </div>
                    <div class="col-4">
                        <h5 class="ra-text-warning">@(Model.Recursamientos ?? 0)</h5>
                        <small class="text-secondary">Recursadas</small>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Calificaciones?.Any() == true)
        {
            <div class="ra-card mt-3">
                <div class="ra-card-header">
                    <i class="bi bi-list-check"></i> Historial de Calificaciones
                </div>
                <div class="ra-card-body p-0">
                    <div class="table-responsive">
                        <table class="table ra-table mb-0">
                            <thead>
                                <tr>
                                    <th>Materia</th>
                                    <th>Período</th>
                                    <th>Calificación</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var calif in Model.Calificaciones)
                                {
                                    <tr>
                                        <td>@calif.Materia?.Nombre</td>
                                        <td>@calif.Periodo</td>
                                        <td>@calif.Valor?.ToString("F1")</td>
                                        <td>
                                            @if (calif.Aprobada)
                                            {
                                                <span class="ra-badge ra-badge-success">Aprobada</span>
                                            }
                                            else
                                            {
                                                <span class="ra-badge ra-badge-danger">Reprobada</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-4">
    <a asp-controller="Alumnos" asp-action="Index" class="ra-btn ra-btn-outline">
        <i class="bi bi-arrow-left"></i> Volver a la lista
    </a>
</div>
