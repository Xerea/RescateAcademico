@model RescateAcademico.Models.Alumno
@{
    ViewData["Title"] = "Detalle del alumno";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = Model.Nombre + " " + Model.Apellidos,
        Subtitle = $"Boleta {Model.Matricula}",
        Icon = "bi-person-badge",
        IconVariant = "accent",
        BackUrl = Url.Action("Index", "Alumnos"),
        BackLabel = "Catálogo"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row g-3">
    <div class="col-md-4">
        <div class="ra-card h-100">
            <div class="ra-card-body text-center">
                <div class="fw-bold" style="font-size:2.25rem; line-height:1;" class="@(Model.PromedioGlobal >= 8 ? "ra-text-success" : Model.PromedioGlobal >= 6 ? "ra-text-warning" : "ra-text-danger")">
                    @Model.PromedioGlobal.ToString("F2")
                </div>
                <small class="text-secondary">Promedio global</small>
                <hr style="border-color: var(--ra-border);" />
                <div class="text-start small">
                    <p class="mb-2"><span class="text-secondary">Carrera:</span> <strong>@Model.Carrera</strong></p>
                    <p class="mb-2"><span class="text-secondary">Semestre:</span> <strong>@Model.SemestreActual</strong></p>
                    <p class="mb-0 d-flex align-items-center gap-2">
                        <span class="text-secondary">Riesgo:</span>
                        <ra-semaforo riesgo="@Model.RiesgoAcademico" size="sm"></ra-semaforo>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="ra-card">
            <div class="ra-card-header">
                <i class="bi bi-journal-text"></i> Información académica
            </div>
            <div class="ra-card-body">
                <div class="row text-center g-3">
                    <div class="col-4">
                        <div class="p-2 rounded-3" style="background: var(--ra-success-bg);">
                            <div class="fw-bold fs-5 ra-text-success">@Model.CargaAcademicaActual</div>
                            <small class="text-secondary">Materias actuales</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded-3" style="background: var(--ra-danger-bg);">
                            <div class="fw-bold fs-5 ra-text-danger">@(Model.MateriasReprobadas ?? 0)</div>
                            <small class="text-secondary">Reprobadas</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-2 rounded-3" style="background: var(--ra-warning-bg);">
                            <div class="fw-bold fs-5 ra-text-warning">@(Model.Recursamientos ?? 0)</div>
                            <small class="text-secondary">Recursadas</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Calificaciones?.Any() == true)
        {
            <div class="ra-card mt-3">
                <div class="ra-card-header">
                    <i class="bi bi-list-check"></i> Historial de calificaciones
                </div>
                <div class="ra-card-body p-0">
                    <div class="table-responsive">
                        <table class="table ra-table ra-table-cards mb-0">
                            <thead>
                                <tr>
                                    <th>Materia</th>
                                    <th>Período</th>
                                    <th>Calificación</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var calif in Model.Calificaciones)
                                {
                                    <tr>
                                        <td data-label="Materia">@calif.Materia?.Nombre</td>
                                        <td data-label="Período">@calif.Periodo</td>
                                        <td data-label="Calificación">@calif.Valor?.ToString("F1")</td>
                                        <td data-label="Estado">
                                            @if (calif.Aprobada)
                                            {
                                                <span class="ra-badge ra-badge-success">Aprobada</span>
                                            }
                                            else
                                            {
                                                <span class="ra-badge ra-badge-danger">Reprobada</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
