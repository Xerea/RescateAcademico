@using RescateAcademico.Controllers
@model DashboardStats
@{
    var grupos = ViewBag.Grupos as List<string> ?? new List<string>();
    var grupoSeleccionado = ViewBag.GrupoSeleccionado as string;
    var scopeLabel = string.IsNullOrWhiteSpace(grupoSeleccionado) ? "Vista institucional" : $"Grupo {grupoSeleccionado}";
    var totalBase = Math.Max(Model.TotalAlumnos, 1);
    var riesgoAltoPct = Math.Round((double)Model.RiesgoRojo / totalBase * 100, 0);
    var riesgoSeguimientoPct = Math.Round((double)(Model.RiesgoRojo + Model.RiesgoAmarillo) / totalBase * 100, 0);
    var promedioCriticoPct = Math.Round((double)Model.AlumnosPromedioCritico / totalBase * 100, 0);
    var promedioObservacionPct = Math.Round((double)Model.AlumnosPromedioObservacion / totalBase * 100, 0);
    var promedioSolidoPct = Math.Round((double)Model.AlumnosPromedioSolido / totalBase * 100, 0);
    var reprobadasPct = Math.Round((double)Model.AlumnosConMateriasReprobadas / totalBase * 100, 0);
    var ausenciasPct = Math.Round((double)Model.AlumnosConAusencias / totalBase * 100, 0);
}

<section class="ra-hero mb-4" aria-label="Resumen institucional">
    <div class="ra-hero-canvas-wrap" aria-hidden="true"><canvas class="ra-hero-shader"></canvas></div>
    <div class="ra-hero-scrim" aria-hidden="true"></div>
    <div class="ra-hero-content">
        <div class="ra-hero-text">
            <span class="ra-hero-eyebrow"><i class="bi bi-building"></i> Autoridad académica</span>
            <h1 class="ra-hero-title">@scopeLabel</h1>
            <p class="ra-hero-lead">Una lectura clara del estado académico: riesgo, solicitudes por revisar y cierres próximos. Menos ruido, mejores decisiones.</p>
        </div>
        <div class="ra-hero-aside">
            <form method="get" class="ra-authority-scope" aria-label="Filtrar por grupo">
                <label class="ra-label" for="grupoDashboard">Grupo</label>
                <div class="d-flex gap-2">
                    <select id="grupoDashboard" name="grupo" class="ra-select" onchange="this.form.submit()">
                        <option value="">Todos los grupos</option>
                        @foreach (var grupo in grupos)
                        {
                            <option value="@grupo" selected="@(grupoSeleccionado == grupo ? "selected" : null)">@grupo</option>
                        }
                    </select>
                    @if (!string.IsNullOrWhiteSpace(grupoSeleccionado))
                    {
                        <a asp-action="Index" class="ra-btn ra-btn-ghost" title="Limpiar grupo" aria-label="Limpiar grupo">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>
</section>

<div class="ra-authority-priority-grid mb-4" aria-label="Prioridades">
    <a asp-controller="Alumnos" asp-action="Index" asp-route-filtroRiesgo="Rojo" asp-route-grupo="@grupoSeleccionado" class="ra-authority-priority is-danger">
        <span class="ra-priority-icon"><i class="bi bi-exclamation-triangle-fill"></i></span>
        <span>
            <strong>@Model.RiesgoRojo críticos</strong>
            <small>@riesgoAltoPct% del alumnado visible requiere atención inmediata.</small>
        </span>
        <i class="bi bi-arrow-right-short"></i>
    </a>
    <a asp-controller="Postulaciones" asp-action="Todas" asp-route-estado="En Revisión" asp-route-grupo="@grupoSeleccionado" class="ra-authority-priority is-warning">
        <span class="ra-priority-icon"><i class="bi bi-hourglass-split"></i></span>
        <span>
            <strong>@Model.PostulacionesPendientes pendientes</strong>
            <small>Solicitudes que esperan una decisión institucional.</small>
        </span>
        <i class="bi bi-arrow-right-short"></i>
    </a>
    <a asp-controller="Convocatorias" asp-action="Todas" class="ra-authority-priority is-info">
        <span class="ra-priority-icon"><i class="bi bi-calendar-event"></i></span>
        <span>
            <strong>@Model.ConvocatoriasProximasACerrar cierres próximos</strong>
            <small>Convocatorias activas que vencen en los siguientes 30 días.</small>
        </span>
        <i class="bi bi-arrow-right-short"></i>
    </a>
</div>

<div class="ra-authority-board mb-4">
    <div class="ra-authority-kpis">
        <a asp-controller="Alumnos" asp-action="Index" asp-route-grupo="@grupoSeleccionado" class="ra-authority-kpi is-link" aria-label="Ver alumnos visibles">
            <span class="ra-authority-kpi-icon"><i class="bi bi-people"></i></span>
            <strong>@Model.TotalAlumnos</strong>
            <small>Alumnos visibles</small>
            <em>Ver listado</em>
        </a>
        <button type="button" class="ra-authority-kpi is-link" data-bs-toggle="modal" data-bs-target="#promedioModal" aria-label="Ver detalle de promedio general">
            <span class="ra-authority-kpi-icon"><i class="bi bi-graph-up-arrow"></i></span>
            <strong>@Model.PromedioGeneral.ToString("F2")</strong>
            <small>Promedio general</small>
            <em>Analizar promedio</em>
        </button>
        <button type="button" class="ra-authority-kpi is-link" data-bs-toggle="modal" data-bs-target="#seguimientoModal" aria-label="Ver detalle de seguimiento académico">
            <span class="ra-authority-kpi-icon"><i class="bi bi-activity"></i></span>
            <strong>@riesgoSeguimientoPct%</strong>
            <small>Con seguimiento</small>
            <em>Ver señales</em>
        </button>
        <a asp-controller="Autoridad" asp-action="Profesores" asp-route-estado="activos" asp-route-grupo="@grupoSeleccionado" class="ra-authority-kpi is-link" aria-label="Ver profesores activos">
            <span class="ra-authority-kpi-icon"><i class="bi bi-person-badge"></i></span>
            <strong>@Model.TotalTutores</strong>
            <small>Profesores activos</small>
            <em>Ver plantilla</em>
        </a>
    </div>
    <div class="ra-authority-chart-card">
        <div class="ra-card-header">
            <span><i class="bi bi-pie-chart"></i> Riesgo académico</span>
            <button type="button" class="ra-btn ra-btn-sm ra-btn-outline" data-bs-toggle="modal" data-bs-target="#riesgoChartModal">
                <i class="bi bi-arrows-fullscreen"></i> Ver grande
            </button>
        </div>
        <div class="ra-card-body">
            <div class="ra-chart-frame">
                <canvas id="chartRiesgo" height="240"></canvas>
            </div>
            <div class="ra-risk-legend">
                <span><i class="is-success"></i> @Model.RiesgoVerde verde</span>
                <span><i class="is-warning"></i> @Model.RiesgoAmarillo amarillo</span>
                <span><i class="is-danger"></i> @Model.RiesgoRojo rojo</span>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="riesgoChartModal" tabindex="-1" aria-labelledby="riesgoChartModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ra-modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="riesgoChartModalLabel">Distribución de riesgo académico</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="ra-chart-modal-canvas">
                    <canvas id="chartRiesgoGrande"></canvas>
                </div>
                <div class="ra-risk-legend mt-3">
                    <span><i class="is-success"></i> Verde: seguimiento normal</span>
                    <span><i class="is-warning"></i> Amarillo: requiere observación</span>
                    <span><i class="is-danger"></i> Rojo: atención inmediata</span>
                </div>
            </div>
            <div class="modal-footer">
                <a asp-controller="Alumnos" asp-action="Index" asp-route-filtroRiesgo="Rojo" asp-route-grupo="@grupoSeleccionado" class="ra-btn ra-btn-primary">
                    <i class="bi bi-exclamation-triangle"></i> Ver críticos
                </a>
                <button type="button" class="ra-btn ra-btn-ghost" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="promedioModal" tabindex="-1" aria-labelledby="promedioModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ra-modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="promedioModalLabel">Lectura del promedio general</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="ra-authority-insight-hero">
                    <div>
                        <span class="ra-student-eyebrow">@scopeLabel</span>
                        <strong>@Model.PromedioGeneral.ToString("F2")</strong>
                        <small>Promedio general del alumnado visible</small>
                    </div>
                    <a asp-controller="Estadisticas" asp-action="Index" asp-route-grupo="@grupoSeleccionado" class="ra-btn ra-btn-outline">
                        <i class="bi bi-bar-chart"></i> Abrir tablero estadístico
                    </a>
                </div>
                <div class="ra-metric-bars mt-3">
                    <div class="ra-metric-bar">
                        <div><span>Promedio crítico</span><strong>@Model.AlumnosPromedioCritico alumnos</strong></div>
                        <div class="ra-metric-track"><span class="is-danger" style="width:@promedioCriticoPct%"></span></div>
                        <small>@promedioCriticoPct% con promedio menor a 6.0</small>
                    </div>
                    <div class="ra-metric-bar">
                        <div><span>En observación</span><strong>@Model.AlumnosPromedioObservacion alumnos</strong></div>
                        <div class="ra-metric-track"><span class="is-warning" style="width:@promedioObservacionPct%"></span></div>
                        <small>@promedioObservacionPct% entre 6.0 y 7.49</small>
                    </div>
                    <div class="ra-metric-bar">
                        <div><span>Rendimiento sólido</span><strong>@Model.AlumnosPromedioSolido alumnos</strong></div>
                        <div class="ra-metric-track"><span class="is-success" style="width:@promedioSolidoPct%"></span></div>
                        <small>@promedioSolidoPct% con 7.5 o más</small>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="ra-btn ra-btn-ghost" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="seguimientoModal" tabindex="-1" aria-labelledby="seguimientoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ra-modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="seguimientoModalLabel">Señales de seguimiento académico</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="ra-insight-grid">
                    <a asp-controller="Alumnos" asp-action="Index" asp-route-filtroRiesgo="Rojo" asp-route-grupo="@grupoSeleccionado" class="ra-insight-tile is-danger">
                        <strong>@Model.RiesgoRojo</strong>
                        <span>Críticos</span>
                        <small>Requieren atención inmediata</small>
                    </a>
                    <a asp-controller="Alumnos" asp-action="Index" asp-route-filtroRiesgo="Amarillo" asp-route-grupo="@grupoSeleccionado" class="ra-insight-tile is-warning">
                        <strong>@Model.RiesgoAmarillo</strong>
                        <span>En observación</span>
                        <small>Necesitan monitoreo cercano</small>
                    </a>
                    <div class="ra-insight-tile">
                        <strong>@Model.IntervencionesRecientes</strong>
                        <span>Intervenciones</span>
                        <small>Registradas en los últimos 30 días</small>
                    </div>
                </div>
                <div class="ra-metric-bars mt-3">
                    <div class="ra-metric-bar">
                        <div><span>Con materias reprobadas</span><strong>@Model.AlumnosConMateriasReprobadas alumnos</strong></div>
                        <div class="ra-metric-track"><span class="is-danger" style="width:@reprobadasPct%"></span></div>
                        <small>@reprobadasPct% del alumnado visible</small>
                    </div>
                    <div class="ra-metric-bar">
                        <div><span>Con ausencias registradas</span><strong>@Model.AlumnosConAusencias alumnos</strong></div>
                        <div class="ra-metric-track"><span class="is-warning" style="width:@ausenciasPct%"></span></div>
                        <small>@ausenciasPct% del alumnado visible</small>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <a asp-controller="Estadisticas" asp-action="Index" asp-route-grupo="@grupoSeleccionado" class="ra-btn ra-btn-outline">
                    <i class="bi bi-bar-chart"></i> Abrir tablero estadístico
                </a>
                <button type="button" class="ra-btn ra-btn-ghost" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(grupoSeleccionado))
{
    <div class="row g-3">
        <div class="col-lg-7">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-speedometer2"></i> Pulso académico del grupo
                </div>
                <div class="ra-card-body">
                    <div class="ra-metric-bars">
                        <div class="ra-metric-bar">
                            <div><span>Promedio crítico</span><strong>@Model.AlumnosPromedioCritico</strong></div>
                            <div class="ra-metric-track"><span class="is-danger" style="width:@promedioCriticoPct%"></span></div>
                            <small>@promedioCriticoPct% del grupo debajo de 6.0</small>
                        </div>
                        <div class="ra-metric-bar">
                            <div><span>En observación</span><strong>@Model.AlumnosPromedioObservacion</strong></div>
                            <div class="ra-metric-track"><span class="is-warning" style="width:@promedioObservacionPct%"></span></div>
                            <small>@promedioObservacionPct% entre 6.0 y 7.49</small>
                        </div>
                        <div class="ra-metric-bar">
                            <div><span>Rendimiento sólido</span><strong>@Model.AlumnosPromedioSolido</strong></div>
                            <div class="ra-metric-track"><span class="is-success" style="width:@promedioSolidoPct%"></span></div>
                            <small>@promedioSolidoPct% en 7.5 o más</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-clipboard-pulse"></i> Señales accionables
                </div>
                <div class="ra-card-body">
                    <div class="ra-signal-list">
                        <a asp-controller="Alumnos" asp-action="Index" asp-route-filtroRiesgo="Rojo" asp-route-grupo="@grupoSeleccionado">
                            <span class="is-danger">@Model.RiesgoRojo</span>
                            <div><strong>Alumnos críticos</strong><small>Atención prioritaria</small></div>
                        </a>
                        <a asp-controller="Alumnos" asp-action="Index" asp-route-filtroRiesgo="Amarillo" asp-route-grupo="@grupoSeleccionado">
                            <span class="is-warning">@Model.RiesgoAmarillo</span>
                            <div><strong>En observación</strong><small>Seguimiento preventivo</small></div>
                        </a>
                        <div>
                            <span>@Model.IntervencionesRecientes</span>
                            <div><strong>Intervenciones recientes</strong><small>Últimos 30 días</small></div>
                        </div>
                        <div>
                            <span>@Model.PostulacionesPendientes</span>
                            <div><strong>Postulaciones pendientes</strong><small>Solicitudes por revisar</small></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-bar-chart"></i> Alumnos por carrera
                </div>
                <div class="ra-card-body">
                    <canvas id="chartCarrera" height="230"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-bar-chart-line"></i> Alumnos por semestre
                </div>
                <div class="ra-card-body">
                    <canvas id="chartSemestre" height="230"></canvas>
                </div>
            </div>
        </div>
    </div>
}
