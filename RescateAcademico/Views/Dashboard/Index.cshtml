@using RescateAcademico.Controllers
@model DashboardStats
@{
    ViewData["Title"] = "Panel Principal";
    Layout = "_Layout";

    var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
    var today = DateTime.Now.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-MX"));

    var header = new PageHeader
    {
        Title = "Panel de control",
        SubtitleHtml = new Microsoft.AspNetCore.Html.HtmlString($"<i class=\"bi bi-person-circle me-1\"></i> {System.Net.WebUtility.HtmlEncode(userName ?? "")} <span class=\"mx-2 text-muted\">·</span> {today}"),
        Icon = "bi-grid-1x2",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

@if (TempData["Success"] != null)
{
    <div class="ra-alert ra-alert-success mb-4" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="ra-alert ra-alert-danger mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>@TempData["Error"]</div>
    </div>
}

@if (User.IsInRole("Administrador") || User.IsInRole("Autoridad"))
{
    var isAutoridad = User.IsInRole("Autoridad");

    <div class="ra-card ra-card-subtle mb-4">
        <div class="ra-card-body">
            <form method="get">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="ra-label">Grupo</label>
                        <select name="grupo" class="ra-select" onchange="this.form.submit()">
                            <option value="">— Todos los grupos —</option>
                            @foreach (var g in (ViewBag.Grupos as List<string>)!)
                            {
                                <option value="@g" selected="@(ViewBag.GrupoSeleccionado as string == g ? "selected" : null)">@g</option>
                            }
                        </select>
                    </div>
                    @if (!string.IsNullOrEmpty(ViewBag.GrupoSeleccionado as string))
                    {
                        <div class="col-md-4">
                            <a asp-action="Index" class="ra-btn ra-btn-ghost">Limpiar filtro</a>
                        </div>
                    }
                </div>
            </form>
        </div>
    </div>

    if (isAutoridad)
    {
        <div class="row g-2 mb-4">
            <div class="col-md-4">
                <a asp-controller="Alumnos" asp-action="Index" asp-route-filtroRiesgo="Rojo" class="text-decoration-none">
                    <div class="ra-alert ra-alert-danger mb-0" role="alert" style="cursor:pointer;">
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                        <div>
                            <strong>@Model.RiesgoRojo en riesgo crítico</strong>
                            <small class="d-block">Requieren intervención inmediata</small>
                        </div>
                        <i class="bi bi-arrow-right ms-auto"></i>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Postulaciones" asp-action="Todas" asp-route-estado="En Revisión" class="text-decoration-none">
                    <div class="ra-alert ra-alert-warning mb-0" role="alert" style="cursor:pointer;">
                        <i class="bi bi-hourglass-split fs-5"></i>
                        <div>
                            <strong>@Model.PostulacionesPendientes postulaciones pendientes</strong>
                            <small class="d-block">Esperan revisión de autoridad</small>
                        </div>
                        <i class="bi bi-arrow-right ms-auto"></i>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Convocatorias" asp-action="Todas" class="text-decoration-none">
                    <div class="ra-alert ra-alert-info mb-0" role="alert" style="cursor:pointer;">
                        <i class="bi bi-calendar-event fs-5"></i>
                        <div>
                            <strong>@Model.ConvocatoriasProximasACerrar convocatorias próximas</strong>
                            <small class="d-block">Cierran en los próximos 30 días</small>
                        </div>
                        <i class="bi bi-arrow-right ms-auto"></i>
                    </div>
                </a>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-md-3">
            <div class="ra-stat ra-stat-accent">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Total alumnos</div>
                        <div class="ra-stat-value" data-countup="@Model.TotalAlumnos">@Model.TotalAlumnos</div>
                    </div>
                    <i class="bi bi-people-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="ra-stat ra-stat-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">En riesgo</div>
                        <div class="ra-stat-value" data-countup="@Model.AlumnosEnRiesgo">@Model.AlumnosEnRiesgo</div>
                    </div>
                    <i class="bi bi-exclamation-triangle-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="ra-stat ra-stat-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Promedio general</div>
                        <div class="ra-stat-value">@Model.PromedioGeneral.ToString("F2")</div>
                    </div>
                    <i class="bi bi-graph-up ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-md-3">
            <div class="ra-stat ra-stat-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Profesores activos</div>
                        <div class="ra-stat-value" data-countup="@Model.TotalTutores">@Model.TotalTutores</div>
                    </div>
                    <i class="bi bi-person-badge-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-pie-chart"></i> Distribución por riesgo
                </div>
                <div class="ra-card-body">
                    <canvas id="chartRiesgo" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-bar-chart"></i> Alumnos por carrera
                </div>
                <div class="ra-card-body">
                    <canvas id="chartCarrera" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-bar-chart-line"></i> Alumnos por semestre
                </div>
                <div class="ra-card-body">
                    <canvas id="chartSemestre" height="220"></canvas>
                </div>
            </div>
        </div>
    </div>

    if (isAutoridad)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3 col-6">
                <div class="ra-stat ra-stat-success text-center">
                    <div class="ra-stat-label">Grupos activos</div>
                    <div class="ra-stat-value">@Model.TotalGrupos</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="ra-stat ra-stat-info text-center">
                    <div class="ra-stat-label">Convocatorias</div>
                    <div class="ra-stat-value">@Model.TotalConvocatorias</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="ra-stat ra-stat-primary text-center">
                    <div class="ra-stat-label">Proyectos activos</div>
                    <div class="ra-stat-value">@Model.TotalProyectos</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="ra-stat ra-stat-warning text-center">
                    <div class="ra-stat-label">Interv. 30 días</div>
                    <div class="ra-stat-value">@Model.IntervencionesRecientes</div>
                </div>
            </div>
        </div>
    }
}

@if (User.IsInRole("Alumno"))
{
    var riesgo = Model.AlumnoRiesgo ?? "Verde";
    var riesgoClass = riesgo == "Rojo" ? "is-danger" : riesgo == "Amarillo" ? "is-warning" : "is-success";
    var primerNombre = string.IsNullOrWhiteSpace(Model.AlumnoNombre) ? "Alumno" : Model.AlumnoNombre.Split(' ')[0];
    var promedioPct = Math.Clamp((double)Model.AlumnoPromedio * 10, 0, 100);
    var siguienteAccion = riesgo == "Rojo"
        ? "Prioriza una conversación con tu profesor y revisa tu simulador antes de postularte."
        : riesgo == "Amarillo"
            ? "Ajusta tus metas de calificación y elige convocatorias que no sobrecarguen tu semana."
            : "Tu perfil está estable. Busca una convocatoria que fortalezca tu trayectoria.";

    <section class="ra-student-hero @riesgoClass mb-4" aria-label="Resumen académico del alumno">
        <div class="ra-student-hero-main">
            <div class="ra-student-eyebrow">Tu estado académico</div>
            <h2 class="ra-student-hero-title">Hola, @primerNombre.</h2>
            <p class="ra-student-hero-copy">@siguienteAccion</p>
            <div class="ra-student-chip-row" aria-label="Datos del expediente">
                @if (!string.IsNullOrWhiteSpace(Model.AlumnoMatricula))
                {
                    <span class="ra-student-chip"><i class="bi bi-credit-card-2-front"></i>@Model.AlumnoMatricula</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.AlumnoCarrera))
                {
                    <span class="ra-student-chip"><i class="bi bi-mortarboard"></i>@Model.AlumnoCarrera</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.AlumnoGrupo))
                {
                    <span class="ra-student-chip"><i class="bi bi-people"></i>@Model.AlumnoGrupo</span>
                }
                <span class="ra-student-chip"><i class="bi bi-layers"></i>@(Model.AlumnoSemestre)° semestre</span>
            </div>
            <div class="ra-student-hero-actions">
                <a asp-controller="PerfilAcademico" asp-action="MiPerfil" class="ra-btn ra-btn-primary">
                    <i class="bi bi-person-badge"></i> Revisar perfil
                </a>
                <a asp-controller="Convocatorias" asp-action="Index" class="ra-btn ra-btn-outline">
                    <i class="bi bi-megaphone"></i> Ver convocatorias
                </a>
            </div>
        </div>
        <div class="ra-student-status-panel" aria-label="Indicadores principales">
            <div class="ra-status-ring @riesgoClass">
                <span>@riesgo</span>
                <small>riesgo</small>
            </div>
            <div class="ra-grade-meter">
                <div class="d-flex justify-content-between align-items-end gap-3">
                    <div>
                        <div class="ra-stat-label">Promedio global</div>
                        <div class="ra-stat-value">@Model.AlumnoPromedio.ToString("F2")</div>
                    </div>
                    <span class="ra-badge @(riesgo == "Rojo" ? "ra-badge-danger" : riesgo == "Amarillo" ? "ra-badge-warning" : "ra-badge-success")">
                        @Model.AlumnoMateriasReprobadas reprobadas
                    </span>
                </div>
                <div class="ra-meter-track" aria-hidden="true">
                    <div class="ra-meter-fill @riesgoClass" style="width: @promedioPct.ToString("F0")%;"></div>
                </div>
                <div class="ra-meter-caption">Meta recomendada: 7.50 o más</div>
            </div>
        </div>
    </section>

    <div class="ra-student-action-grid mb-4">
        <a asp-controller="PerfilAcademico" asp-action="MiPerfil" class="ra-action-tile">
            <span class="ra-action-icon"><i class="bi bi-calculator"></i></span>
            <span>
                <strong>Simular calificaciones</strong>
                <small>Calcula impacto en promedio y riesgo.</small>
            </span>
            <i class="bi bi-arrow-right-short"></i>
        </a>
        <a asp-controller="Convocatorias" asp-action="Index" class="ra-action-tile">
            <span class="ra-action-icon"><i class="bi bi-stars"></i></span>
            <span>
                <strong>@Model.AlumnoConvocatoriasDisponibles oportunidades listas</strong>
                <small>Filtradas por cupo, promedio y semestre.</small>
            </span>
            <i class="bi bi-arrow-right-short"></i>
        </a>
        <a asp-controller="Postulaciones" asp-action="MisPostulaciones" class="ra-action-tile">
            <span class="ra-action-icon"><i class="bi bi-send-check"></i></span>
            <span>
                <strong>@Model.AlumnoPostulacionesPendientes en revisión</strong>
                <small>@Model.AlumnoPostulacionesAceptadas aceptadas · @Model.AlumnoPostulaciones totales</small>
            </span>
            <i class="bi bi-arrow-right-short"></i>
        </a>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-compass"></i> Siguiente mejor paso
                </div>
                <div class="ra-card-body">
                    <div class="ra-path-list">
                        @if (riesgo == "Rojo")
                        {
                            <div class="ra-path-step is-current">
                                <span>1</span>
                                <div><strong>Estabiliza tu carga</strong><small>Revisa materias reprobadas, ausencias y prioridades con tu profesor.</small></div>
                            </div>
                            <div class="ra-path-step">
                                <span>2</span>
                                <div><strong>Simula un escenario realista</strong><small>Define qué calificaciones necesitas para salir de riesgo alto.</small></div>
                            </div>
                            <div class="ra-path-step">
                                <span>3</span>
                                <div><strong>Postúlate después</strong><small>Elige convocatorias que no agreguen presión innecesaria.</small></div>
                            </div>
                        }
                        else if (riesgo == "Amarillo")
                        {
                            <div class="ra-path-step is-current">
                                <span>1</span>
                                <div><strong>Ajusta tu promedio objetivo</strong><small>Usa el simulador para identificar una meta viable esta semana.</small></div>
                            </div>
                            <div class="ra-path-step">
                                <span>2</span>
                                <div><strong>Elige una oportunidad</strong><small>Prioriza convocatorias con requisitos que ya cumples.</small></div>
                            </div>
                            <div class="ra-path-step">
                                <span>3</span>
                                <div><strong>Da seguimiento</strong><small>Revisa el estado de tus postulaciones sin perder fechas clave.</small></div>
                            </div>
                        }
                        else
                        {
                            <div class="ra-path-step is-current">
                                <span>1</span>
                                <div><strong>Aprovecha tu estabilidad</strong><small>Busca proyectos que sumen experiencia, no solo créditos.</small></div>
                            </div>
                            <div class="ra-path-step">
                                <span>2</span>
                                <div><strong>Postúlate con intención</strong><small>Elige una convocatoria alineada con tu carrera.</small></div>
                            </div>
                            <div class="ra-path-step">
                                <span>3</span>
                                <div><strong>Mantén el ritmo</strong><small>Revisa tu perfil después de cada periodo de evaluación.</small></div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-activity"></i> Señales rápidas
                </div>
                <div class="ra-card-body">
                    <div class="ra-mini-metrics">
                        <div>
                            <span>@Model.AlumnoMateriasReprobadas</span>
                            <small>Materias reprobadas</small>
                        </div>
                        <div>
                            <span>@Model.AlumnoAusencias</span>
                            <small>Ausencias registradas</small>
                        </div>
                        <div>
                            <span>@Model.AlumnoConvocatoriasDisponibles</span>
                            <small>Convocatorias viables</small>
                        </div>
                    </div>
                    <p class="text-secondary small mb-0 mt-3">Estas señales no sustituyen la revisión con tu profesor, pero ayudan a decidir qué atender primero.</p>
                </div>
            </div>
        </div>
    </div>
}


@if (User.IsInRole("Autoridad"))
{
    <div class="ra-heading mb-3">Acciones rápidas</div>
    <div class="row g-3">
        <div class="col-md-3 col-6">
            <a asp-controller="Alumnos" asp-action="Index" class="ra-action-tile text-decoration-none">
                <span class="ra-action-icon"><i class="bi bi-people-fill"></i></span>
                <span>
                    <strong>Gestionar alumnos</strong>
                    <small>Filtrar por riesgo, carrera y grupo.</small>
                </span>
                <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
        <div class="col-md-3 col-6">
            <a asp-controller="Postulaciones" asp-action="Todas" class="ra-action-tile text-decoration-none">
                <span class="ra-action-icon"><i class="bi bi-send-check"></i></span>
                <span>
                    <strong>@Model.PostulacionesPendientes pendientes</strong>
                    <small>Revisar y decidir postulaciones.</small>
                </span>
                <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
        <div class="col-md-3 col-6">
            <a asp-controller="Estadisticas" asp-action="Index" class="ra-action-tile text-decoration-none">
                <span class="ra-action-icon"><i class="bi bi-bar-chart-line"></i></span>
                <span>
                    <strong>Estadísticas</strong>
                    <small>Métricas institucionales.</small>
                </span>
                <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
        <div class="col-md-3 col-6">
            <a asp-controller="Autoridad" asp-action="Profesores" class="ra-action-tile text-decoration-none">
                <span class="ra-action-icon"><i class="bi bi-person-badge"></i></span>
                <span>
                    <strong>@Model.TotalTutores profesores</strong>
                    <small>Plantilla docente y grupos.</small>
                </span>
                <i class="bi bi-arrow-right-short"></i>
            </a>
        </div>
    </div>
}
else if (User.IsInRole("Administrador"))
{
    <div class="row g-3">
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-bar-chart-line fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Tablero estadístico</h5>
                    <p class="text-secondary small">Métricas globales de desempeño.</p>
                    <a asp-controller="Estadisticas" asp-action="Index" class="ra-btn ra-btn-primary w-100">Ver</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-clipboard-data fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Reportes</h5>
                    <p class="text-secondary small">Estadísticas, predicciones y exportes.</p>
                    <a asp-controller="Reportes" asp-action="Index" class="ra-btn ra-btn-primary w-100">Ir a reportes</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-folder-check fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Postulaciones</h5>
                    <p class="text-secondary small">Revisa solicitudes pendientes.</p>
                    <a asp-controller="Postulaciones" asp-action="Todas" class="ra-btn ra-btn-primary w-100">Ver</a>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        @if (User.IsInRole("Administrador") || User.IsInRole("Autoridad"))
        {
            <text>
            (function () {
                var rootStyle = getComputedStyle(document.documentElement);
                var get = function (v) { return (rootStyle.getPropertyValue(v) || '').trim(); };
                var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                var textColor = isDark ? '#cbd5e1' : '#475569';
                var gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.04)';

                var palette = {
                    primary: get('--ra-primary') || '#0f766e',
                    accent: get('--ra-accent') || '#6c1d45',
                    success: get('--ra-success') || '#15803d',
                    warning: get('--ra-warning') || '#b45309',
                    danger: get('--ra-danger') || '#b91c1c',
                    info: get('--ra-info') || '#1d4ed8'
                };

                Chart.defaults.color = textColor;
                Chart.defaults.borderColor = gridColor;
                Chart.defaults.font.family = "'Inter', sans-serif";

                new Chart(document.getElementById('chartRiesgo'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Verde', 'Amarillo', 'Rojo'],
                        datasets: [{
                            data: [@Model.RiesgoVerde, @Model.RiesgoAmarillo, @Model.RiesgoRojo],
                            backgroundColor: [palette.success, palette.warning, palette.danger],
                            borderWidth: 0,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '65%',
                        plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 16 } } }
                    }
                });

                new Chart(document.getElementById('chartCarrera'), {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlumnosPorCarrera.Select(c => c.Carrera))),
                        datasets: [{
                            label: 'Alumnos',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlumnosPorCarrera.Select(c => c.Count))),
                            backgroundColor: palette.primary,
                            borderRadius: 6,
                            barThickness: 24
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: gridColor } },
                            x: { grid: { display: false } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });

                new Chart(document.getElementById('chartSemestre'), {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlumnosPorSemestre.Select(s => "Sem " + s.Semestre))),
                        datasets: [{
                            label: 'Alumnos',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlumnosPorSemestre.Select(s => s.Count))),
                            backgroundColor: palette.accent,
                            borderRadius: 6,
                            barThickness: 24
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: gridColor } },
                            x: { grid: { display: false } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });
            })();
            </text>
        }
    </script>
