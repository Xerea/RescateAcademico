@using RescateAcademico.Controllers
@model DashboardStats
@{
    ViewData["Title"] = "Panel Principal";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold mb-1" style="letter-spacing: -0.02em;">Panel de Control</h1>
        <p class="text-secondary mb-0">
            <i class="bi bi-person-circle me-1"></i>
            @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
            <span class="mx-2 text-muted">|</span>
            @(DateTime.Now.ToString("dddd, dd 'de' MMMM", new System.Globalization.CultureInfo("es-MX")))
        </p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="ra-alert ra-alert-success mb-4" role="alert">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="ra-alert ra-alert-danger mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@TempData["Error"]</div>
    </div>
}

@if (User.IsInRole("Administrador") || User.IsInRole("Autoridad"))
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="ra-stat ra-stat-accent">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Total Alumnos</div>
                        <div class="ra-stat-value">@Model.TotalAlumnos</div>
                    </div>
                    <i class="bi bi-people-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="ra-stat ra-stat-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Proyectos Activos</div>
                        <div class="ra-stat-value">@Model.TotalProyectos</div>
                    </div>
                    <i class="bi bi-folder-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="ra-stat ra-stat-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Convocatorias</div>
                        <div class="ra-stat-value">@Model.TotalConvocatorias</div>
                    </div>
                    <i class="bi bi-megaphone-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="ra-stat ra-stat-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">En Riesgo</div>
                        <div class="ra-stat-value">@Model.AlumnosEnRiesgo</div>
                    </div>
                    <i class="bi bi-exclamation-triangle-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-pie-chart"></i> Distribución por Riesgo
                </div>
                <div class="ra-card-body">
                    <canvas id="chartRiesgo" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-bar-chart"></i> Alumnos por Carrera
                </div>
                <div class="ra-card-body">
                    <canvas id="chartCarrera" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-bar-chart-line"></i> Alumnos por Semestre
                </div>
                <div class="ra-card-body">
                    <canvas id="chartSemestre" height="220"></canvas>
                </div>
            </div>
        </div>
    </div>
}

@if (User.IsInRole("Alumno"))
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="ra-stat ra-stat-accent">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Promedio</div>
                        <div class="ra-stat-value">@Model.AlumnoPromedio.ToString("F2")</div>
                    </div>
                    <i class="bi bi-award ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="ra-stat @(Model.AlumnoRiesgo == "Rojo" ? "ra-stat-danger" : Model.AlumnoRiesgo == "Amarillo" ? "ra-stat-warning" : "ra-stat-success")">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Riesgo</div>
                        <div class="ra-stat-value">@Model.AlumnoRiesgo</div>
                    </div>
                    <i class="bi bi-shield-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="ra-stat ra-stat-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Semestre</div>
                        <div class="ra-stat-value">@Model.AlumnoSemestre</div>
                    </div>
                    <i class="bi bi-layers ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="ra-stat ra-stat-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Postulaciones</div>
                        <div class="ra-stat-value">@Model.AlumnoPostulaciones</div>
                    </div>
                    <i class="bi bi-send-check ra-stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-person-badge fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Mi Perfil Académico</h5>
                    <p class="text-secondary small">Consulta tu situación académica, promedio, materias y carga actual.</p>
                    <a asp-controller="PerfilAcademico" asp-action="MiPerfil" class="ra-btn ra-btn-primary w-100">Ver Perfil</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-journal-text fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Convocatorias</h5>
                    <p class="text-secondary small">Explora y postúlate a proyectos de servicio social o investigación.</p>
                    <a asp-controller="Convocatorias" asp-action="Index" class="ra-btn ra-btn-primary w-100">Explorar</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-send-check fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Mis Postulaciones</h5>
                    <p class="text-secondary small">Consulta el estado de tus solicitudes a proyectos.</p>
                    <a asp-controller="Postulaciones" asp-action="MisPostulaciones" class="ra-btn ra-btn-primary w-100">Ver Postulaciones</a>
                </div>
            </div>
        </div>
    </div>
}

@if (User.IsInRole("Tutor"))
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="ra-stat ra-stat-accent">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Mis Estudiantes</div>
                        <div class="ra-stat-value">@Model.TutorAssignedStudents</div>
                    </div>
                    <i class="bi bi-people-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-stat ra-stat-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">En Riesgo</div>
                        <div class="ra-stat-value">@Model.TutorStudentsAtRisk</div>
                    </div>
                    <i class="bi bi-exclamation-triangle-fill ra-stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-stat ra-stat-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="ra-stat-label">Intervenciones (30 días)</div>
                        <div class="ra-stat-value">@Model.TutorRecentInterventions</div>
                    </div>
                    <i class="bi bi-clipboard-pulse ra-stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="ra-card ra-card-accent h-100">
                <div class="ra-card-body text-center">
                    <i class="bi bi-people fs-1 mb-3" style="color: var(--ra-accent);"></i>
                    <h5 class="fw-semibold">Mis Estudiantes</h5>
                    <p class="text-secondary small">Visualiza la radiografía académica y riesgo de tus alumnos asignados.</p>
                    <a asp-controller="Alumnos" asp-action="MisTutorados" class="ra-btn ra-btn-accent w-100">Ir a Profesoría</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="ra-card ra-card-primary h-100">
                <div class="ra-card-body text-center">
                    <i class="bi bi-graph-up fs-1 mb-3" style="color: var(--ra-primary);"></i>
                    <h5 class="fw-semibold">Radiografía Académica</h5>
                    <p class="text-secondary small">Consulta el desempeño integral de un tutorado específico.</p>
                    <a asp-controller="Alumnos" asp-action="MisTutorados" class="ra-btn ra-btn-primary w-100">Seleccionar Estudiante</a>
                </div>
            </div>
        </div>
    </div>
}

@if (User.IsInRole("Autoridad"))
{
    <div class="row g-3">
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-bar-chart-line fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Tablero Estadístico</h5>
                    <p class="text-secondary small">Reportes globales de desempeño y situación estudiantil.</p>
                    <a asp-controller="Estadisticas" asp-action="Index" class="ra-btn ra-btn-primary w-100">Ver Estadísticas</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-clipboard-data fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Reportes</h5>
                    <p class="text-secondary small">Genera reportes oficiales en PDF o Excel.</p>
                    <a asp-controller="Estadisticas" asp-action="Reporte" class="ra-btn ra-btn-primary w-100">Generar Reporte</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <div class="mb-3">
                        <i class="bi bi-folder-check fs-1" style="color: var(--ra-accent);"></i>
                    </div>
                    <h5 class="fw-semibold">Postulaciones</h5>
                    <p class="text-secondary small">Revisa y gestiona las postulaciones pendientes.</p>
                    <a asp-controller="Postulaciones" asp-action="Todas" class="ra-btn ra-btn-primary w-100">Ver Postulaciones</a>
                </div>
            </div>
        </div>
    </div>
}

@if (User.IsInRole("Administrador"))
{
    <div class="row g-3">
        <div class="col-6 col-md-4 col-lg-3">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <i class="bi bi-shield-lock fs-1 mb-2" style="color: var(--ra-primary);"></i>
                    <h6 class="fw-semibold">Usuarios</h6>
                    <p class="text-secondary small mb-3">Roles, alumnos y tutores.</p>
                    <a asp-controller="Admin" asp-action="Usuarios" class="ra-btn ra-btn-outline ra-btn-sm w-100">Administrar</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <i class="bi bi-person-lines-fill fs-1 mb-2" style="color: var(--ra-primary);"></i>
                    <h6 class="fw-semibold">Alumnos</h6>
                    <p class="text-secondary small mb-3">Gestión integral del alumnado.</p>
                    <a asp-controller="Admin" asp-action="Alumnos" class="ra-btn ra-btn-outline ra-btn-sm w-100">Ver Alumnos</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <i class="bi bi-calendar-event fs-1 mb-2" style="color: var(--ra-primary);"></i>
                    <h6 class="fw-semibold">Ciclos</h6>
                    <p class="text-secondary small mb-3">Períodos académicos.</p>
                    <a asp-controller="Admin" asp-action="CiclosEscolares" class="ra-btn ra-btn-outline ra-btn-sm w-100">Gestionar</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <i class="bi bi-clock-history fs-1 mb-2" style="color: var(--ra-primary);"></i>
                    <h6 class="fw-semibold">Bitácora</h6>
                    <p class="text-secondary small mb-3">Registro de acciones.</p>
                    <a asp-controller="Bitacora" asp-action="Index" class="ra-btn ra-btn-outline ra-btn-sm w-100">Ver Logs</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <i class="bi bi-folder-plus fs-1 mb-2" style="color: var(--ra-primary);"></i>
                    <h6 class="fw-semibold">Proyectos</h6>
                    <p class="text-secondary small mb-3">Crear y gestionar proyectos.</p>
                    <a asp-controller="Proyectos" asp-action="Index" class="ra-btn ra-btn-outline ra-btn-sm w-100">Proyectos</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <i class="bi bi-megaphone fs-1 mb-2" style="color: var(--ra-primary);"></i>
                    <h6 class="fw-semibold">Convocatorias</h6>
                    <p class="text-secondary small mb-3">Publicar y gestionar.</p>
                    <a asp-controller="Convocatorias" asp-action="Todas" class="ra-btn ra-btn-outline ra-btn-sm w-100">Convocatorias</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <i class="bi bi-mortarboard fs-1 mb-2" style="color: var(--ra-primary);"></i>
                    <h6 class="fw-semibold">Carreras</h6>
                    <p class="text-secondary small mb-3">Gestión de carreras.</p>
                    <a asp-controller="Admin" asp-action="Carreras" class="ra-btn ra-btn-outline ra-btn-sm w-100">Carreras</a>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <div class="ra-card h-100 text-center">
                <div class="ra-card-body">
                    <i class="bi bi-shield-check fs-1 mb-2" style="color: var(--ra-primary);"></i>
                    <h6 class="fw-semibold">Integridad</h6>
                    <p class="text-secondary small mb-3">Checks de datos.</p>
                    <a asp-controller="Admin" asp-action="IntegridadDatos" class="ra-btn ra-btn-outline ra-btn-sm w-100">Verificar</a>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        @if (User.IsInRole("Administrador") || User.IsInRole("Autoridad"))
        {
            <text>
            (function() {
                const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                const textColor = isDark ? '#cbd5e1' : '#475569';
                const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.04)';

                Chart.defaults.color = textColor;
                Chart.defaults.borderColor = gridColor;
                Chart.defaults.font.family = "'Inter', sans-serif";

                new Chart(document.getElementById('chartRiesgo'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Verde', 'Amarillo', 'Rojo'],
                        datasets: [{
                            data: [@Model.RiesgoVerde, @Model.RiesgoAmarillo, @Model.RiesgoRojo],
                            backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                            borderWidth: 0,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '65%',
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { usePointStyle: true, padding: 16 }
                            }
                        }
                    }
                });

                new Chart(document.getElementById('chartCarrera'), {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlumnosPorCarrera.Select(c => c.Carrera))),
                        datasets: [{
                            label: 'Alumnos',
                            data: [@string.Join(", ", Model.AlumnosPorCarrera.Select(c => c.Count))],
                            backgroundColor: '#4f46e5',
                            borderRadius: 6,
                            barThickness: 24
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: gridColor } },
                            x: { grid: { display: false } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });

                new Chart(document.getElementById('chartSemestre'), {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlumnosPorSemestre.Select(s => $"Sem {s.Semestre}"))),
                        datasets: [{
                            label: 'Alumnos',
                            data: [@string.Join(", ", Model.AlumnosPorSemestre.Select(s => s.Count))],
                            backgroundColor: '#3b82f6',
                            borderRadius: 6,
                            barThickness: 24
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: gridColor } },
                            x: { grid: { display: false } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });
            })();
            </text>
        }
    </script>
}
