@model RescateAcademico.Controllers.CrearCuentaViewModel
@{
    ViewData["Title"] = "Crear Cuenta Institucional";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="ra-card">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-person-plus"></i> Crear Cuenta Institucional</h5>
            </div>
            <div class="ra-card-body">
                <form asp-action="CrearCuenta" method="post">
                    <div asp-validation-summary="ModelOnly" class="ra-alert ra-alert-danger mb-3" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="ra-label">Correo *</label>
                            <input asp-for="Email" class="ra-input" type="email" autocomplete="username" placeholder="usuario@ipn.mx" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="ra-label">Contraseña temporal *</label>
                            <div class="input-group">
                                <input asp-for="Password" type="password" class="ra-input" autocomplete="new-password" minlength="6" required />
                                <button class="ra-btn ra-btn-outline" type="button" id="togglePassword" aria-label="Mostrar contraseña">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <div class="text-secondary small mt-1">Debe incluir mayúscula, minúscula, número y símbolo.</div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Rol" class="ra-label">Rol *</label>
                            <select asp-for="Rol" class="ra-select" id="rolSelect" required>
                                <option value="Alumno">Alumno</option>
                                <option value="Tutor">Profesor</option>
                                <option value="Autoridad">Autoridad</option>
                                <option value="Administrador">Administrador</option>
                            </select>
                            <span asp-validation-for="Rol" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3" id="matriculaField">
                            <label asp-for="Matricula" class="ra-label">Boleta</label>
                            <input asp-for="Matricula" class="ra-input" placeholder="2023600000" inputmode="numeric" pattern="[0-9]{10}" />
                            <span asp-validation-for="Matricula" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="ra-label">Nombre</label>
                            <input asp-for="Nombre" class="ra-input" autocomplete="given-name" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Apellidos" class="ra-label">Apellidos</label>
                            <input asp-for="Apellidos" class="ra-input" autocomplete="family-name" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3" id="carreraField">
                            <label asp-for="Carrera" class="ra-label">Carrera</label>
                            <select asp-for="Carrera" class="ra-select">
                                <option value="">Pendiente de asignar</option>
                                <option value="Tronco común">Tronco común</option>
                                <option value="Técnico en Administración">Técnico en Administración</option>
                                <option value="Técnico en Administración de Empresas Turísticas">Técnico en Administración de Empresas Turísticas</option>
                                <option value="Técnico en Contaduría">Técnico en Contaduría</option>
                                <option value="Técnico en Gastronomía">Técnico en Gastronomía</option>
                                <option value="Técnico en Gestión de la Ciberseguridad">Técnico en Gestión de la Ciberseguridad</option>
                                <option value="Técnico en Informática">Técnico en Informática</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3" id="semestreField">
                            <label asp-for="SemestreActual" class="ra-label">Semestre</label>
                            <input asp-for="SemestreActual" type="number" class="ra-input" min="1" max="6" value="1" />
                        </div>
                        <div class="col-md-6 mb-3 d-none" id="especialidadField">
                            <label asp-for="Especialidad" class="ra-label">Especialidad</label>
                            <input asp-for="Especialidad" class="ra-input" placeholder="Asesoría Académica" />
                        </div>
                    </div>

                    <div class="ra-alert ra-alert-info mb-3">
                        <i class="bi bi-info-circle"></i>
                        <div>Si la boleta ya existe, la cuenta se vinculará al expediente académico existente. Si no existe, se creará un expediente mínimo para completar después.</div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-save"></i> Crear Cuenta
                        </button>
                        <a asp-action="Usuarios" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var rolSelect = document.getElementById('rolSelect');
            var matriculaField = document.getElementById('matriculaField');
            var carreraField = document.getElementById('carreraField');
            var semestreField = document.getElementById('semestreField');
            var especialidadField = document.getElementById('especialidadField');
            var matriculaInput = document.getElementById('Matricula');
            var passwordInput = document.getElementById('Password');
            var togglePassword = document.getElementById('togglePassword');

            function syncRoleFields() {
                var rol = rolSelect.value;
                var isAlumno = rol === 'Alumno';
                var isTutor = rol === 'Tutor';

                matriculaField.classList.toggle('d-none', !isAlumno);
                carreraField.classList.toggle('d-none', !isAlumno);
                semestreField.classList.toggle('d-none', !isAlumno);
                especialidadField.classList.toggle('d-none', !isTutor);

                if (matriculaInput) {
                    matriculaInput.required = isAlumno;
                }
            }

            rolSelect.addEventListener('change', syncRoleFields);
            if (togglePassword && passwordInput) {
                togglePassword.addEventListener('click', function () {
                    var showing = passwordInput.type === 'text';
                    passwordInput.type = showing ? 'password' : 'text';
                    togglePassword.setAttribute('aria-label', showing ? 'Mostrar contraseña' : 'Ocultar contraseña');
                    togglePassword.innerHTML = showing ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
                });
            }
            syncRoleFields();
        })();
    </script>
}
