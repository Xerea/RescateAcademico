@using Microsoft.AspNetCore.Identity
@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-shield-lock"></i> Gestión de Usuarios</h1>
        <p class="text-secondary small mb-0">Cuentas, roles y estado de acceso al sistema.</p>
    </div>
    <div class="col-auto">
        <a asp-action="CrearCuenta" class="ra-btn ra-btn-primary">
            <i class="bi bi-person-plus"></i> Crear Cuenta
        </a>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table" id="tablaUsuarios">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Estado</th>
                            <th>Email Confirmado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Email</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="ra-badge ra-badge-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    @if (item.EmailConfirmed)
                                    {
                                        <i class="bi bi-check-circle ra-text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle ra-text-danger"></i>
                                    }
                                </td>
                                <td>
                                    @{
                                        var lockoutEnd = item.LockoutEnd;
                                        var isLocked = lockoutEnd.HasValue && lockoutEnd.Value > DateTimeOffset.Now;
                                    }
                                    @if (isLocked)
                                    {
                                        <form asp-action="DesbloquearUsuario" method="post" class="m-0" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" title="Desbloquear">
                                                <i class="bi bi-unlock ra-text-success"></i> Desbloquear
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="BloquearUsuario" method="post" class="m-0" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" title="Bloquear" onclick="return confirm('¿Bloquear a este usuario por 20 minutos?')">
                                                <i class="bi bi-lock ra-text-danger"></i> Bloquear
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-people"></i>
                <p>No hay usuarios registrados.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaUsuarios').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
