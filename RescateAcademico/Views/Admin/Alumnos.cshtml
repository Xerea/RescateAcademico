@model IEnumerable<RescateAcademico.Models.Alumno>
@{
    ViewData["Title"] = "Alumnos";
    Layout = "_Layout";
    var actionsHtml = $"<a href=\"{Url.Action("CrearAlumno")}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-plus-circle\"></i> Nuevo alumno</a>";
    var header = new PageHeader
    {
        Title = "Gestión de alumnos",
        Subtitle = "Catálogo completo del alumnado del CECyT 13.",
        Icon = "bi-people",
        IconVariant = "accent",
        BackUrl = Url.Action("Gestion"),
        BackLabel = "Gestión",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        <form method="get" class="mb-3">
            <div class="row g-2">
                <div class="col-md-6">
                    <input type="text" name="busqueda" class="ra-input" placeholder="Buscar por matrícula, nombre o apellidos..." />
                </div>
                <div class="col-md-4">
                    <select name="filtroRiesgo" class="ra-select">
                        <option value="">Todos los riesgos</option>
                        <option value="Verde" selected="@(ViewBag.FiltroRiesgo == "Verde")">Verde</option>
                        <option value="Amarillo" selected="@(ViewBag.FiltroRiesgo == "Amarillo")">Amarillo</option>
                        <option value="Rojo" selected="@(ViewBag.FiltroRiesgo == "Rojo")">Rojo</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="ra-btn ra-btn-outline w-100">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table ra-table ra-table-cards" id="tablaAlumnos">
                <thead>
                    <tr>
                        <th>Boleta</th>
                        <th>Nombre</th>
                        <th>Carrera</th>
                        <th>Sem</th>
                        <th>Promedio</th>
                        <th>Riesgo</th>
                        <th data-orderable="false">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Boleta"><strong class="ra-mono">@item.Matricula</strong></td>
                            <td data-label="Nombre">@item.Nombre @item.Apellidos</td>
                            <td data-label="Carrera">@item.Carrera</td>
                            <td data-label="Semestre">@item.SemestreActual</td>
                            <td data-label="Promedio">
                                <span class="ra-badge @(item.PromedioGlobal >= 8 ? "ra-badge-success" : item.PromedioGlobal >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                    @item.PromedioGlobal.ToString("F2")
                                </span>
                            </td>
                            <td data-label="Riesgo">
                                <ra-semaforo riesgo="@item.RiesgoAcademico" size="sm"></ra-semaforo>
                            </td>
                            <td data-label="Acciones">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="EditarAlumno" asp-route-id="@item.Matricula" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Editar @item.Nombre @item.Apellidos" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Alumnos" asp-action="Detalles" asp-route-id="@item.Matricula" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver detalles de @item.Nombre @item.Apellidos" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form asp-action="EliminarAlumno" method="post" class="m-0" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Matricula" />
                                        <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Eliminar @item.Nombre @item.Apellidos" title="Eliminar" onclick="return confirm('¿Eliminar este alumno?')">
                                            <i class="bi bi-trash text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaAlumnos').DataTable({
                language: window.RaDataTablesEs,
                pageLength: 25
            });
        });
    </script>
}
