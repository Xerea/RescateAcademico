@model IEnumerable<RescateAcademico.Models.Tutor>
@{
    ViewData["Title"] = "Gestión de Profesores";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;"><i class="bi bi-person-badge"></i> Gestión de Profesores</h2>
    <a asp-action="CrearTutor" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Profesor
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Especialidad</th>
                            <th>Usuario Vinculado</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Nombre @item.Apellidos</td>
                                <td>@item.Email</td>
                                <td>@item.Especialidad</td>
                                <td>
                                    @if (item.Usuario != null)
                                    {
                                        <span class="badge bg-success">Vinculado</span>
                                        <span class="text-muted small">@item.Usuario.Email</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Sin vincular</span>
                                    }
                                </td>
                                <td>
                                    @if (item.EstaActivo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted">-</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-person-badge fs-1 text-muted"></i>
                <p class="text-muted mt-2">No hay tutores registrados</p>
            </div>
        }
    </div>
</div>
