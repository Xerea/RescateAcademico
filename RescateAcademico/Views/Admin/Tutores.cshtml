@model IEnumerable<RescateAcademico.Models.Tutor>
@{
    ViewData["Title"] = "Gestión de Profesores";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-person-badge"></i> Gestión de Profesores</h1>
        <p class="text-secondary small mb-0">Plantilla docente del CECyT 13.</p>
    </div>
    <div class="col-auto">
        <a asp-action="CrearTutor" class="ra-btn ra-btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Profesor
        </a>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table" id="tablaTutores">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>No. Empleado</th>
                            <th>Email</th>
                            <th>Especialidad</th>
                            <th>Usuario Vinculado</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Nombre @item.Apellidos</td>
                                <td><span class="ra-badge ra-badge-neutral">@item.NumeroEmpleado</span></td>
                                <td>@item.Email</td>
                                <td>@item.Especialidad</td>
                                <td>
                                    @if (item.Usuario != null)
                                    {
                                        <span class="ra-badge ra-badge-success">Vinculado</span>
                                        <span class="text-secondary small d-block">@item.Usuario.Email</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-neutral">Sin vincular</span>
                                    }
                                </td>
                                <td>
                                    @if (item.EstaActivo)
                                    {
                                        <span class="ra-badge ra-badge-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-danger">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-secondary small">—</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-person-badge"></i>
                <p>No hay profesores registrados.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaTutores').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
