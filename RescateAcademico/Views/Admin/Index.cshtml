@model RescateAcademico.Controllers.DashboardStats
@{
    ViewData["Title"] = "Panel de Administración";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1">
            <i class="bi bi-gear"></i> Panel de Administración
        </h1>
        <p class="text-secondary small mb-0">Gestión integral del sistema académico.</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="ra-alert ra-alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="ra-card h-100 text-center">
            <div class="ra-card-body">
                <i class="bi bi-people-fill fs-1 mb-2" style="color: var(--ra-accent);"></i>
                <h4>@Model.TotalAlumnos</h4>
                <p class="text-secondary mb-0">Alumnos Registrados</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ra-card h-100 text-center">
            <div class="ra-card-body">
                <i class="bi bi-folder-fill fs-1 mb-2" style="color: #198754;"></i>
                <h4>@Model.TotalProyectos</h4>
                <p class="text-secondary mb-0">Proyectos Activos</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ra-card h-100 text-center">
            <div class="ra-card-body">
                <i class="bi bi-exclamation-triangle-fill fs-1 mb-2 text-warning"></i>
                <h4>@Model.AlumnosEnRiesgo</h4>
                <p class="text-secondary mb-0">Alumnos en Riesgo</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ra-card h-100 text-center">
            <div class="ra-card-body">
                <i class="bi bi-send fs-1 mb-2" style="color: #0dcaf0;"></i>
                <h4>@Model.PostulacionesPendientes</h4>
                <p class="text-secondary mb-0">Postulaciones Pendientes</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="ra-card">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-people"></i> Gestión de Usuarios</h5>
            </div>
            <div class="ra-card-body">
                <a asp-action="Usuarios" class="ra-btn ra-btn-outline w-100 mb-2">
                    <i class="bi bi-people"></i> Ver Todos los Usuarios
                </a>
                <a asp-action="Alumnos" class="ra-btn ra-btn-outline w-100 mb-2">
                    <i class="bi bi-student"></i> Gestión de Alumnos
                </a>
                <a asp-action="Tutores" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-person-badge"></i> Gestión de Profesores
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="ra-card">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-gear"></i> Configuración</h5>
            </div>
            <div class="ra-card-body">
                <a asp-action="CiclosEscolares" class="ra-btn ra-btn-outline w-100 mb-2">
                    <i class="bi bi-calendar-event"></i> Ciclos Escolares
                </a>
                <a asp-action="Carreras" class="ra-btn ra-btn-outline w-100 mb-2">
                    <i class="bi bi-mortarboard"></i> Carreras y Planes
                </a>
                <a asp-action="Bitacora" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-clock-history"></i> Bitácora de Auditoría
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="ra-card">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-megaphone"></i> Proyectos y Convocatorias</h5>
            </div>
            <div class="ra-card-body">
                <a asp-controller="Proyectos" asp-action="Index" class="ra-btn ra-btn-outline w-100 mb-2">
                    <i class="bi bi-folder-plus"></i> Gestión de Proyectos
                </a>
                <a asp-controller="Convocatorias" asp-action="Todas" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-megaphone"></i> Todas las Convocatorias
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="ra-card">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-bar-chart"></i> Reportes</h5>
            </div>
            <div class="ra-card-body">
                <a asp-controller="Estadisticas" asp-action="Index" class="ra-btn ra-btn-outline w-100 mb-2">
                    <i class="bi bi-pie-chart"></i> Tablero Estadístico
                </a>
                <a asp-controller="Postulaciones" asp-action="Todas" class="ra-btn ra-btn-outline w-100">
                    <i class="bi bi-clipboard-data"></i> Revisar Postulaciones
                </a>
            </div>
        </div>
    </div>
</div>
