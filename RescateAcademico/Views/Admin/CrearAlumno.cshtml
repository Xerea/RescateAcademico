@model RescateAcademico.Models.Alumno
@{
    ViewData["Title"] = "Crear Alumno";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="ra-card">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-person-plus"></i> Nuevo Alumno</h5>
            </div>
            <div class="ra-card-body">
                <form asp-action="CrearAlumno">
                    <div class="mb-3">
                        <label class="ra-label">Boleta *</label>
                        <input asp-for="Matricula" class="ra-input" required />
                        <span asp-validation-for="Matricula" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Nombre *</label>
                        <input asp-for="Nombre" class="ra-input" required />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Apellidos *</label>
                        <input asp-for="Apellidos" class="ra-input" required />
                        <span asp-validation-for="Apellidos" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Carrera</label>
                        <input asp-for="Carrera" class="ra-input" />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Semestre</label>
                        <input asp-for="SemestreActual" class="ra-input" type="number" min="1" max="12" />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Promedio Global</label>
                        <input asp-for="PromedioGlobal" class="ra-input" type="number" step="0.01" min="0" max="10" />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Riesgo Académico</label>
                        <select asp-for="RiesgoAcademico" class="ra-select">
                            <option value="">Sin evaluar</option>
                            <option value="Verde">Verde</option>
                            <option value="Amarillo">Amarillo</option>
                            <option value="Rojo">Rojo</option>
                        </select>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-save"></i> Guardar Alumno
                        </button>
                        <a asp-action="Alumnos" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
