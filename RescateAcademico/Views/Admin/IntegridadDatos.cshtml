@{
    ViewData["Title"] = "Integridad de Datos";
    Layout = "_Layout";
    var problemas = ViewBag.Problemas as List<(string Mensaje, string Severidad)> ?? new List<(string, string)>();
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-shield-check"></i> Integridad de Datos</h1>
        <p class="text-secondary small mb-0">Verificación de consistencia en la base de datos institucional.</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="ra-alert ra-alert-success mb-4" role="alert">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <div>@TempData["Success"]</div>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="ra-stat ra-stat-accent text-center">
            <div class="ra-stat-label">Alumnos</div>
            <div class="ra-stat-value">@ViewBag.TotalAlumnos</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="ra-stat ra-stat-success text-center">
            <div class="ra-stat-label">Profesores</div>
            <div class="ra-stat-value">@ViewBag.TotalTutores</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="ra-stat ra-stat-info text-center">
            <div class="ra-stat-label">Proyectos</div>
            <div class="ra-stat-value">@ViewBag.TotalProyectos</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="ra-stat ra-stat-warning text-center">
            <div class="ra-stat-label">Convocatorias</div>
            <div class="ra-stat-value">@ViewBag.TotalConvocatorias</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="ra-stat ra-stat-primary text-center">
            <div class="ra-stat-label">Calificaciones</div>
            <div class="ra-stat-value">@ViewBag.TotalCalificaciones</div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="ra-stat ra-stat-accent text-center">
            <div class="ra-stat-label">Intervenciones</div>
            <div class="ra-stat-value">@ViewBag.TotalIntervenciones</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="ra-card ra-card-warning">
            <div class="ra-card-body">
                <div class="ra-stat-label">Sin Profesor</div>
                <div class="ra-stat-value h5">@ViewBag.AlumnosSinTutor</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ra-card ra-card-danger">
            <div class="ra-card-body">
                <div class="ra-stat-label">Riesgo Crítico sin Plan</div>
                <div class="ra-stat-value h5">@ViewBag.AlumnosRojoSinPlan</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ra-card ra-card-info">
            <div class="ra-card-body">
                <div class="ra-stat-label">Sin Evaluación</div>
                <div class="ra-stat-value h5">@ViewBag.AlumnosSinRiesgo</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="ra-card ra-card-primary">
            <div class="ra-card-body">
                <div class="ra-stat-label">Planes de Mejora</div>
                <div class="ra-stat-value h5">@ViewBag.TotalPlanes</div>
            </div>
        </div>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-header">
        <i class="bi bi-exclamation-triangle"></i> Problemas Detectados (@problemas.Count)
    </div>
    <div class="ra-card-body">
        @if (problemas.Count > 0)
        {
            <ul class="list-group list-group-flush">
                @foreach (var (mensaje, severidad) in problemas)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0" style="background: transparent; border-color: var(--ra-border);">
                        <span class="d-flex align-items-center gap-2">
                            <i class="bi @(severidad == "danger" ? "bi-x-circle ra-text-danger" : severidad == "warning" ? "bi-exclamation-circle ra-text-warning" : "bi-info-circle ra-text-info")"></i>
                            <span>@mensaje</span>
                        </span>
                        <span class="ra-badge @(severidad == "danger" ? "ra-badge-danger" : severidad == "warning" ? "ra-badge-warning" : "ra-badge-info")">@severidad.ToUpper()</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-check-circle-fill ra-text-success"></i>
                <p>No se detectaron problemas. La base de datos está consistente.</p>
            </div>
        }
    </div>
</div>

<div class="mt-4 d-flex flex-wrap gap-2">
    <form asp-action="EvaluarRiesgos" method="post" class="m-0">
        @Html.AntiForgeryToken()
        <button type="submit" class="ra-btn ra-btn-primary" onclick="return confirm('¿Ejecutar evaluación masiva de riesgo?')">
            <i class="bi bi-exclamation-triangle"></i> Evaluar Riesgos Ahora
        </button>
    </form>
    <a asp-controller="Predicciones" asp-action="Index" class="ra-btn ra-btn-accent">
        <i class="bi bi-brain"></i> Predicciones IA
    </a>
    <a asp-controller="Dashboard" asp-action="Index" class="ra-btn ra-btn-ghost">
        <i class="bi bi-arrow-left"></i> Volver al Panel
    </a>
</div>
