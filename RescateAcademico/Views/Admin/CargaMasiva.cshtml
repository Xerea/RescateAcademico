@{
    ViewData["Title"] = "Carga Masiva de Alumnos";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card border-0 shadow-sm">
            <div class="card-header" style="background-color: #6c1d45; color: white;">
                <h5 class="mb-0"><i class="bi bi-upload"></i> Carga Masiva de Alumnos</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Sube un archivo CSV con el siguiente formato:</p>
                <code>Boleta,Nombre,Apellidos,Correo,Carrera</code>
                <p class="text-muted mt-2">Ejemplo:</p>
                <pre class="bg-light p-2 rounded"><code>2023600009,Pedro,García López,pedro@alumno.ipn.mx,Informática
2023600010,Ana,Martínez Ruiz,ana@alumno.ipn.mx,Electrónica</code></pre>

                <form asp-action="CargaMasiva" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label">Archivo CSV</label>
                        <input type="file" name="archivo" class="form-control" accept=".csv" required />
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload"></i> Cargar Alumnos
                        </button>
                        <a asp-action="Alumnos" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
