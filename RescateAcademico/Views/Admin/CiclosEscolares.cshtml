@model IEnumerable<RescateAcademico.Models.CicloEscolar>
@{
    ViewData["Title"] = "Ciclos Escolares";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-calendar-event"></i> Ciclos Escolares</h1>
        <p class="text-secondary small mb-0">Períodos académicos activos e históricos.</p>
    </div>
    <div class="col-auto">
        <a asp-action="CrearCiclo" class="ra-btn ra-btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Ciclo
        </a>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (TempData["Success"] != null)
        {
            <div class="ra-alert ra-alert-success mb-3" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
        }

        <div class="table-responsive">
            <table class="table ra-table" id="tablaCiclos">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Período</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Fin</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Nombre</strong>
                                @if (item.EsActual)
                                {
                                    <span class="ra-badge ra-badge-success ms-2">Actual</span>
                                }
                            </td>
                            <td>@item.Periodo</td>
                            <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.EstaActivo)
                                {
                                    <span class="ra-badge ra-badge-success">Activo</span>
                                }
                                else
                                {
                                    <span class="ra-badge ra-badge-neutral">Inactivo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaCiclos').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
