@model IEnumerable<RescateAcademico.Models.CicloEscolar>
@{
    ViewData["Title"] = "Ciclos escolares";
    Layout = "_Layout";
    var actionsHtml = $"<a href=\"{Url.Action("CrearCiclo")}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-plus-circle\"></i> Nuevo ciclo</a>";
    var header = new PageHeader
    {
        Title = "Ciclos escolares",
        Subtitle = "Períodos académicos activos e históricos.",
        Icon = "bi-calendar-event",
        IconVariant = "accent",
        BackUrl = Url.Action("Gestion"),
        BackLabel = "Gestión",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        @if (TempData["Success"] != null)
        {
            <div class="ra-alert ra-alert-success mb-3" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
        }

        <div class="table-responsive">
            <table class="table ra-table" id="tablaCiclos">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Período</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Fin</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Nombre</strong>
                                @if (item.EsActual)
                                {
                                    <span class="ra-badge ra-badge-success ms-2">Actual</span>
                                }
                            </td>
                            <td>@item.Periodo</td>
                            <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.EstaActivo)
                                {
                                    <span class="ra-badge ra-badge-success">Activo</span>
                                }
                                else
                                {
                                    <span class="ra-badge ra-badge-neutral">Inactivo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaCiclos').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
