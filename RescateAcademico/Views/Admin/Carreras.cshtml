@model IEnumerable<RescateAcademico.Models.Carrera>
@{
    ViewData["Title"] = "Carreras";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;"><i class="bi bi-mortarboard"></i> Gestión de Carreras</h2>
    <a asp-action="CrearCarrera" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nueva Carrera
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead style="background-color: #6c1d45; color: white;">
                    <tr>
                        <th>Clave</th>
                        <th>Nombre</th>
                        <th>Semestres</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Clave</strong></td>
                            <td>@item.Nombre</td>
                            <td>@item.Semestres</td>
                            <td>
                                @if (item.EstaActiva)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactiva</span>
                                }
                            </td>
                            <td>
                                <a asp-action="ToggleActivoCarrera" asp-route-id="@item.Id" class="btn btn-sm @(item.EstaActiva ? "btn-outline-warning" : "btn-outline-success")">
                                    @(item.EstaActiva ? "Desactivar" : "Activar")
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
