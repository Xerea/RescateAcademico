@model IEnumerable<RescateAcademico.Models.Carrera>
@{
    ViewData["Title"] = "Carreras";
    Layout = "_Layout";
    var actionsHtml = $"<a href=\"{Url.Action("CrearCarrera")}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-plus-circle\"></i> Nueva carrera</a>";
    var header = new PageHeader
    {
        Title = "Carreras",
        Subtitle = "Programas académicos del CECyT 13.",
        Icon = "bi-mortarboard",
        IconVariant = "accent",
        BackUrl = Url.Action("Gestion"),
        BackLabel = "Gestión",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        <div class="table-responsive">
            <table class="table ra-table ra-table-cards" id="tablaCarreras">
                <thead>
                    <tr>
                        <th>Clave</th>
                        <th>Nombre</th>
                        <th>Semestres</th>
                        <th>Estado</th>
                        <th data-orderable="false">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Clave"><strong class="ra-mono">@item.Clave</strong></td>
                            <td data-label="Nombre">@item.Nombre</td>
                            <td data-label="Semestres">@item.Semestres</td>
                            <td data-label="Estado">
                                @if (item.EstaActiva)
                                {
                                    <span class="ra-badge ra-badge-success">Activa</span>
                                }
                                else
                                {
                                    <span class="ra-badge ra-badge-neutral">Inactiva</span>
                                }
                            </td>
                            <td data-label="Acciones">
                                <form asp-action="ToggleActivoCarrera" method="post" class="m-0" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="ra-btn ra-btn-sm @(item.EstaActiva ? "ra-btn-outline" : "ra-btn-primary")">
                                        @(item.EstaActiva ? "Desactivar" : "Activar")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaCarreras').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
