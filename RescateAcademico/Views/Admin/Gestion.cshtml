@{
    ViewData["Title"] = "Gestión";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1">Gestión</h1>
        <p class="text-secondary small mb-0">Administración de usuarios, académico y operaciones.</p>
    </div>
</div>

<div class="ra-tabs" role="tablist">
    <button class="ra-tab active" data-bs-toggle="tab" data-bs-target="#tab-usuarios" role="tab" aria-selected="true">
        <i class="bi bi-people"></i> Usuarios
    </button>
    <button class="ra-tab" data-bs-toggle="tab" data-bs-target="#tab-academico" role="tab" aria-selected="false">
        <i class="bi bi-mortarboard"></i> Académico
    </button>
    <button class="ra-tab" data-bs-toggle="tab" data-bs-target="#tab-operaciones" role="tab" aria-selected="false">
        <i class="bi bi-folder"></i> Operaciones
    </button>
    <button class="ra-tab" data-bs-toggle="tab" data-bs-target="#tab-sistema" role="tab" aria-selected="false">
        <i class="bi bi-shield-check"></i> Sistema
    </button>
</div>

<div class="tab-content">
    <!-- Usuarios -->
    <div class="tab-pane fade show active" id="tab-usuarios" role="tabpanel">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-shield-lock fs-1 mb-3" style="color: var(--ra-primary);"></i>
                        <h5 class="fw-semibold">Usuarios</h5>
                        <p class="text-secondary small">Cuentas, roles y estado de acceso.</p>
                        <a asp-action="Usuarios" class="ra-btn ra-btn-primary w-100">Administrar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-person-lines-fill fs-1 mb-3" style="color: var(--ra-accent);"></i>
                        <h5 class="fw-semibold">Alumnos</h5>
                        <p class="text-secondary small">Registro completo del alumnado.</p>
                        <a asp-action="Alumnos" class="ra-btn ra-btn-outline w-100">Ver Alumnos</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-person-badge fs-1 mb-3" style="color: var(--ra-info);"></i>
                        <h5 class="fw-semibold">Profesores</h5>
                        <p class="text-secondary small">Plantilla docente y especialidades.</p>
                        <a asp-action="Tutores" class="ra-btn ra-btn-outline w-100">Ver Profesores</a>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <div class="ra-card">
                    <div class="ra-card-body d-flex flex-wrap gap-2 align-items-center justify-content-between">
                        <span class="text-secondary small"><i class="bi bi-plus-circle me-1"></i> ¿Necesitas crear una nueva cuenta?</span>
                        <a asp-action="CrearCuenta" class="ra-btn ra-btn-primary ra-btn-sm"><i class="bi bi-person-plus"></i> Crear Cuenta</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Académico -->
    <div class="tab-pane fade" id="tab-academico" role="tabpanel">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-mortarboard fs-1 mb-3" style="color: var(--ra-primary);"></i>
                        <h5 class="fw-semibold">Carreras</h5>
                        <p class="text-secondary small">Programas académicos del CECyT 13.</p>
                        <a asp-action="Carreras" class="ra-btn ra-btn-primary w-100">Gestionar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-calendar-event fs-1 mb-3" style="color: var(--ra-accent);"></i>
                        <h5 class="fw-semibold">Ciclos Escolares</h5>
                        <p class="text-secondary small">Períodos académicos activos.</p>
                        <a asp-action="CiclosEscolares" class="ra-btn ra-btn-outline w-100">Gestionar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-journal-check fs-1 mb-3" style="color: var(--ra-info);"></i>
                        <h5 class="fw-semibold">Planes de Mejora</h5>
                        <p class="text-secondary small">Seguimiento académico personalizado.</p>
                        <a asp-controller="PlanesMejora" asp-action="Index" class="ra-btn ra-btn-outline w-100">Ver Planes</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Operaciones -->
    <div class="tab-pane fade" id="tab-operaciones" role="tabpanel">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-folder-plus fs-1 mb-3" style="color: var(--ra-primary);"></i>
                        <h5 class="fw-semibold">Proyectos</h5>
                        <p class="text-secondary small">Catálogo de proyectos académicos.</p>
                        <a asp-controller="Proyectos" asp-action="Index" class="ra-btn ra-btn-primary w-100">Gestionar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-megaphone fs-1 mb-3" style="color: var(--ra-accent);"></i>
                        <h5 class="fw-semibold">Convocatorias</h5>
                        <p class="text-secondary small">Publicación y cierre de convocatorias.</p>
                        <a asp-controller="Convocatorias" asp-action="Todas" class="ra-btn ra-btn-outline w-100">Gestionar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-send-check fs-1 mb-3" style="color: var(--ra-info);"></i>
                        <h5 class="fw-semibold">Postulaciones</h5>
                        <p class="text-secondary small">Revisión de solicitudes estudiantiles.</p>
                        <a asp-controller="Postulaciones" asp-action="Todas" class="ra-btn ra-btn-outline w-100">Revisar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sistema -->
    <div class="tab-pane fade" id="tab-sistema" role="tabpanel">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-clock-history fs-1 mb-3" style="color: var(--ra-primary);"></i>
                        <h5 class="fw-semibold">Bitácora</h5>
                        <p class="text-secondary small">Historial de acciones del sistema.</p>
                        <a asp-controller="Bitacora" asp-action="Index" class="ra-btn ra-btn-primary w-100">Ver Bitácora</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-shield-check fs-1 mb-3" style="color: var(--ra-accent);"></i>
                        <h5 class="fw-semibold">Integridad</h5>
                        <p class="text-secondary small">Diagnóstico de consistencia de datos.</p>
                        <a asp-action="IntegridadDatos" class="ra-btn ra-btn-outline w-100">Verificar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100 text-center">
                    <div class="ra-card-body">
                        <i class="bi bi-exclamation-triangle fs-1 mb-3" style="color: var(--ra-warning);"></i>
                        <h5 class="fw-semibold">Evaluar Riesgos</h5>
                        <p class="text-secondary small">Ejecutar evaluación masiva del alumnado.</p>
                        <form asp-action="EvaluarRiesgos" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="ra-btn ra-btn-accent w-100" onclick="return confirm('¿Ejecutar evaluación masiva de riesgo?')">
                                <i class="bi bi-lightning"></i> Ejecutar Ahora
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="ra-card h-100">
                    <div class="ra-card-body text-center">
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                            <span class="d-inline-block rounded-circle" style="width:10px;height:10px;background:var(--ra-success);box-shadow:0 0 8px var(--ra-success);"></span>
                            <span class="fw-semibold">Sincronización Activa</span>
                        </div>
                        <p class="text-secondary small mb-2">Datos académicos sincronizados con sistemas institucionales.</p>
                        <div class="ra-mono text-secondary" style="font-size:0.75rem;">
                            Última actualización: hace 2h<br>
                            Próxima sincronización: en 4h
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
