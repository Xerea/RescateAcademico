@model RescateAcademico.Models.Carrera
@{
    ViewData["Title"] = "Crear carrera";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Nueva carrera",
        Subtitle = "Registra un programa académico.",
        Icon = "bi-mortarboard",
        IconVariant = "accent",
        BackUrl = Url.Action("Carreras"),
        BackLabel = "Carreras"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row">
    <div class="col-md-8 col-lg-6 mx-auto">
        <div class="ra-card">
            <div class="ra-card-body">
                <form asp-action="CrearCarrera">
                    <div class="mb-3">
                        <label class="ra-label">Clave * (ej: INFO)</label>
                        <input asp-for="Clave" class="ra-input" required maxlength="10" />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Nombre *</label>
                        <input asp-for="Nombre" class="ra-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Descripción</label>
                        <textarea asp-for="Descripcion" class="ra-input" rows="2"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Número de Semestres</label>
                        <input asp-for="Semestres" class="ra-input" type="number" min="1" max="12" value="6" />
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-save"></i> Crear Carrera
                        </button>
                        <a asp-action="Carreras" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
