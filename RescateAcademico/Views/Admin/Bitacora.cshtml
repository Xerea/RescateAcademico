@model IEnumerable<RescateAcademico.Models.BitacoraLog>
@{
    ViewData["Title"] = "Bitácora de Auditoría";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;"><i class="bi bi-clock-history"></i> Bitácora de Auditoría</h2>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Fecha</th>
                            <th>Usuario</th>
                            <th>Acción</th>
                            <th>Tabla</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FechaHora.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@item.UsuarioEmail</td>
                                <td>
                                    <span class="badge @(item.Accion == "Crear" ? "bg-success" : item.Accion == "Editar" ? "bg-primary" : item.Accion == "Eliminar" ? "bg-danger" : "bg-secondary")">
                                        @item.Accion
                                    </span>
                                </td>
                                <td>@item.TablaAfectada</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <p class="text-muted mt-3">No hay registros en la bitácora</p>
            </div>
        }
    </div>
</div>
