@model RescateAcademico.Models.Tutor
@{
    ViewData["Title"] = "Crear Profesor";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="ra-card">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-person-badge"></i> Nuevo Profesor</h5>
            </div>
            <div class="ra-card-body">
                <form asp-action="CrearTutor">
                    <div class="mb-3">
                        <label class="ra-label">Nombre *</label>
                        <input asp-for="Nombre" class="ra-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Apellidos *</label>
                        <input asp-for="Apellidos" class="ra-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Email *</label>
                        <input asp-for="Email" class="ra-input" type="email" required />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">No. de Empleado</label>
                        <input asp-for="NumeroEmpleado" class="ra-input" placeholder="Ej. 1234567" />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Teléfono</label>
                        <input asp-for="Telefono" class="ra-input" />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Especialidad</label>
                        <input asp-for="Especialidad" class="ra-input" />
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-save"></i> Guardar Profesor
                        </button>
                        <a asp-action="Tutores" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
