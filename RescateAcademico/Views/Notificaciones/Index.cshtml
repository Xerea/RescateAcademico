@model IEnumerable<RescateAcademico.Models.Notificacion>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf
@{
    ViewData["Title"] = "Notificaciones";
    Layout = "_Layout";
    string? actionsHtml = null;
    if (Model.Any(n => !n.Leida))
    {
        var token = Xsrf.GetAndStoreTokens(Context).RequestToken;
        var action = Url.Action("MarcarTodasLeidas");
        actionsHtml =
            $"<form action=\"{action}\" method=\"post\" class=\"m-0\">" +
            $"<input type=\"hidden\" name=\"__RequestVerificationToken\" value=\"{token}\" />" +
            "<button type=\"submit\" class=\"ra-btn ra-btn-outline ra-btn-sm\"><i class=\"bi bi-check-all\"></i> Marcar todas como leídas</button></form>";
    }
    var header = new PageHeader
    {
        Title = "Notificaciones",
        Subtitle = "Centro de notificaciones del sistema.",
        Icon = "bi-bell",
        IconVariant = "accent",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="d-flex align-items-start p-3 mb-2 rounded-3 @(item.Leida ? "" : "ra-bg-primary")" style="border: 1px solid var(--ra-border);">
                    <div class="me-3 flex-shrink-0">
                        @if (item.Tipo == "Exito")
                        {
                            <i class="bi bi-check-circle-fill ra-text-success fs-4"></i>
                        }
                        else if (item.Tipo == "Error")
                        {
                            <i class="bi bi-x-circle-fill ra-text-danger fs-4"></i>
                        }
                        else if (item.Tipo == "Informacion")
                        {
                            <i class="bi bi-info-circle-fill ra-text-info fs-4"></i>
                        }
                        else
                        {
                            <i class="bi bi-bell-fill ra-text-secondary fs-4"></i>
                        }
                    </div>
                    <div class="flex-grow-1 min-width-0">
                        <h6 class="mb-1 @(item.Leida ? "text-secondary" : "fw-semibold")">
                            @item.Titulo
                            @if (!item.Leida)
                            {
                                <span class="ra-badge ra-badge-primary ms-2">Nuevo</span>
                            }
                        </h6>
                        <p class="mb-1 @(!item.Leida ? "" : "text-secondary")">@item.Mensaje</p>
                        <small class="text-secondary">@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    <div class="flex-shrink-0 ms-2">
                        @if (!string.IsNullOrEmpty(item.Enlace))
                        {
                            <form asp-action="MarcarLeida" method="post" class="m-0" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline">
                                    <i class="bi bi-eye"></i> Ver
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="MarcarLeida" method="post" class="m-0" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline @(item.Leida ? "disabled" : "")">
                                    <i class="bi bi-check"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-bell-slash"></i>
                <p>No tienes notificaciones</p>
            </div>
        }
    </div>
</div>
