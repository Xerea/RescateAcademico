@model RescateAcademico.Controllers.ReporteViewModel
@{
    ViewData["Title"] = "Reporte general";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Reporte general",
        Subtitle = "Generado el " + Model.FechaReporte.ToString("dd/MM/yyyy HH:mm"),
        Icon = "bi-file-earmark-text",
        IconVariant = "accent",
        BackUrl = Url.Action("Index"),
        BackLabel = "Estadísticas"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card mb-4">
    <div class="ra-card-header">
        <h5 class="mb-0">Resumen Institucional</h5>
    </div>
    <div class="ra-card-body">
        <div class="row">
            <div class="col-md-3 text-center">
                <h3>@Model.TotalAlumnos</h3>
                <p class="text-secondary mb-0">Total Alumnos</p>
            </div>
            <div class="col-md-3 text-center">
                <h3>@Model.PromedioInstitucional.ToString("F2")</h3>
                <p class="text-secondary mb-0">Promedio Institucional</p>
            </div>
            <div class="col-md-3 text-center">
                <h3>@Model.TotalProyectos</h3>
                <p class="text-secondary mb-0">Proyectos Activos</p>
            </div>
            <div class="col-md-3 text-center">
                <h3>@Model.TotalConvocatorias</h3>
                <p class="text-secondary mb-0">Convocatorias Activas</p>
            </div>
        </div>
    </div>
</div>

<div class="ra-card mb-4">
    <div class="ra-card-header">
        <h5 class="mb-0">Distribución por Nivel de Riesgo</h5>
    </div>
    <div class="ra-card-body">
        <div class="row text-center">
            <div class="col-4">
                <div class="p-3 rounded bg-success bg-opacity-10">
                    <h3 class="text-success">@Model.AlumnosPorRiesgo.GetValueOrDefault("Verde", 0)</h3>
                    <small class="text-secondary">Sin Riesgo (Verde)</small>
                </div>
            </div>
            <div class="col-4">
                <div class="p-3 rounded bg-warning bg-opacity-10">
                    <h3 class="text-warning">@Model.AlumnosPorRiesgo.GetValueOrDefault("Amarillo", 0)</h3>
                    <small class="text-secondary">En Atención (Amarillo)</small>
                </div>
            </div>
            <div class="col-4">
                <div class="p-3 rounded bg-danger bg-opacity-10">
                    <h3 class="text-danger">@Model.AlumnosPorRiesgo.GetValueOrDefault("Rojo", 0)</h3>
                    <small class="text-secondary">Crítico (Rojo)</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-header">
        <h5 class="mb-0">Postulaciones</h5>
    </div>
    <div class="ra-card-body">
        <div class="row text-center">
            <div class="col-4">
                <h3>@Model.TotalPostulaciones</h3>
                <p class="text-secondary mb-0">Total</p>
            </div>
            <div class="col-4">
                <h3 class="text-success">@Model.PostulacionesAceptadas</h3>
                <p class="text-secondary mb-0">Aceptadas</p>
            </div>
            <div class="col-4">
                <h3>@((Model.TotalPostulaciones - Model.PostulacionesAceptadas))</h3>
                <p class="text-secondary mb-0">Pendientes/No aceptadas</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <button onclick="window.print()" class="ra-btn ra-btn-primary">
        <i class="bi bi-printer"></i> Imprimir Reporte
    </button>
    <a asp-action="Index" class="ra-btn ra-btn-ghost">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>
