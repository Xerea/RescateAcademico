@model IEnumerable<RescateAcademico.Controllers.EstadisticaCarrera>
@{
    ViewData["Title"] = "Estadísticas por carrera";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Estadísticas por carrera",
        Subtitle = "Análisis desagregado por programa académico.",
        Icon = "bi-bar-chart",
        IconVariant = "accent",
        BackUrl = Url.Action("Index"),
        BackLabel = "Estadísticas"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards">
                    <thead>
                        <tr>
                            <th>Carrera</th>
                            <th>Total</th>
                            <th>Promedio</th>
                            <th>En riesgo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="Carrera"><strong>@item.Carrera</strong></td>
                                <td data-label="Total">@item.TotalAlumnos</td>
                                <td data-label="Promedio">
                                    <span class="ra-badge @(item.PromedioGeneral >= 8 ? "ra-badge-success" : item.PromedioGeneral >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                        @item.PromedioGeneral.ToString("F2")
                                    </span>
                                </td>
                                <td data-label="En riesgo">
                                    @if (item.AlumnosEnRiesgo > 0)
                                    {
                                        <span class="ra-badge ra-badge-warning">@item.AlumnosEnRiesgo</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-success">0</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-bar-chart"></i>
                <p>No hay datos disponibles</p>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="ra-btn ra-btn-ghost">
        <i class="bi bi-arrow-left"></i> Volver al Tablero
    </a>
</div>
