@model IEnumerable<RescateAcademico.Controllers.EstadisticaCarrera>
@{
    ViewData["Title"] = "Estadísticas por Carrera";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col">
        <h2 style="color: #6c1d45;"><i class="bi bi-bar-chart"></i> Estadísticas por Carrera</h2>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Carrera</th>
                            <th>Total Alumnos</th>
                            <th>Promedio General</th>
                            <th>Alumnos en Riesgo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Carrera</strong></td>
                                <td>@item.TotalAlumnos</td>
                                <td>
                                    <span class="badge @(item.PromedioGeneral >= 8 ? "bg-success" : item.PromedioGeneral >= 6 ? "bg-warning" : "bg-danger")">
                                        @item.PromedioGeneral.ToString("F2")
                                    </span>
                                </td>
                                <td>
                                    @if (item.AlumnosEnRiesgo > 0)
                                    {
                                        <span class="badge bg-warning text-dark">@item.AlumnosEnRiesgo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">0</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-bar-chart fs-1 text-muted"></i>
                <p class="text-muted mt-3">No hay datos disponibles</p>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver al Tablero
    </a>
</div>
