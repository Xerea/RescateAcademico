@model IEnumerable<RescateAcademico.Models.BitacoraLog>
@{
    ViewData["Title"] = "Bitácora de auditoría";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Bitácora de auditoría",
        Subtitle = "Registro histórico de acciones del sistema.",
        Icon = "bi-clock-history",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        <form method="get" class="mb-3">
            <div class="row g-2">
                <div class="col-md-3">
                    <input type="text" name="usuario" class="ra-input" placeholder="Buscar por usuario..." />
                </div>
                <div class="col-md-2">
                    <select name="accion" class="ra-select">
                        <option value="">Todas las acciones</option>
                        <option value="Crear">Crear</option>
                        <option value="Editar">Editar</option>
                        <option value="Eliminar">Eliminar</option>
                        <option value="Login">Login</option>
                        <option value="Logout">Logout</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="date" name="desde" class="ra-input" />
                </div>
                <div class="col-md-2">
                    <input type="date" name="hasta" class="ra-input" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="ra-btn ra-btn-primary">
                        <i class="bi bi-search"></i> Filtrar
                    </button>
                    <a asp-action="Index" class="ra-btn ra-btn-outline">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </a>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table ra-table ra-table-cards" id="tablaBitacora">
                <thead>
                    <tr>
                        <th>Fecha y Hora</th>
                        <th>Usuario</th>
                        <th>Acción</th>
                        <th>Tabla</th>
                        <th>IP</th>
                        <th data-orderable="false">Detalles</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Fecha">
                                <span class="text-secondary small">@item.FechaHora.ToString("dd/MM/yyyy HH:mm:ss")</span>
                            </td>
                            <td data-label="Usuario">@item.UsuarioEmail</td>
                            <td data-label="Acción">
                                <span class="ra-badge @(item.Accion == "Crear" ? "ra-badge-success" : item.Accion == "Editar" ? "ra-badge-primary" : item.Accion == "Eliminar" ? "ra-badge-danger" : item.Accion == "Login" ? "ra-badge-info" : "ra-badge-neutral")">
                                    @item.Accion
                                </span>
                            </td>
                            <td data-label="Tabla"><span class="text-secondary small">@item.TablaAfectada</span></td>
                            <td data-label="IP"><span class="text-secondary small">@item.IpAddress</span></td>
                            <td data-label="Detalles">
                                @if (!string.IsNullOrEmpty(item.RegistroAnterior) || !string.IsNullOrEmpty(item.RegistroNuevo))
                                {
                                    <a asp-action="Detalles" asp-route-id="@item.Id" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver detalles del registro" title="Ver detalles">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaBitacora').DataTable({
                language: window.RaDataTablesEs,
                pageLength: 25,
                order: [[0, 'desc']]
            });
        });
    </script>
}
