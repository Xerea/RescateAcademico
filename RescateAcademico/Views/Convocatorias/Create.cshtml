@model RescateAcademico.Models.Convocatoria
@{
    ViewData["Title"] = "Crear convocatoria";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Nueva convocatoria",
        Subtitle = "Publica una nueva oportunidad para los estudiantes.",
        Icon = "bi-megaphone",
        IconVariant = "accent",
        BackUrl = Url.Action("Todas"),
        BackLabel = "Convocatorias"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row">
    <div class="col-md-8 col-lg-6 mx-auto">
        <div class="ra-card">
            <div class="ra-card-body">
                <form asp-action="Create">
                    <div class="mb-3">
                        <label class="ra-label">Título *</label>
                        <input asp-for="Titulo" class="ra-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Descripción</label>
                        <textarea asp-for="Descripcion" class="ra-input" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Tipo</label>
                        <select asp-for="Tipo" class="ra-select">
                            <option value="ServicioSocial">Servicio Social</option>
                            <option value="Investigacion">Investigación</option>
                            <option value="Laboratorio">Laboratorio</option>
                            <option value="ApoyoAcademico">Apoyo Académico</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Proyecto Asociado</label>
                        <select asp-for="ProyectoId" class="ra-select" asp-items="ViewBag.Proyectos">
                            <option value="">-- Seleccionar --</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="ra-label">Cupo Máximo</label>
                            <input asp-for="CupoMaximo" class="ra-input" type="number" min="1" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="ra-label">Fecha de Cierre</label>
                            <input asp-for="FechaCierre" class="ra-input" type="date" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="ra-label">Promedio Mínimo</label>
                            <input asp-for="PromedioMinimo" class="ra-input" type="number" step="0.1" min="0" max="10" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="ra-label">Semestre Mínimo</label>
                            <input asp-for="SemestreMinimo" class="ra-input" type="number" min="1" max="12" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Área</label>
                        <input asp-for="Area" class="ra-input" />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Requisitos</label>
                        <textarea asp-for="Requisitos" class="ra-input" rows="2"></textarea>
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="ValidadaPorAcademia" class="form-check-input" />
                        <label class="form-check-label">Validada por Academia</label>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-save"></i> Crear Convocatoria
                        </button>
                        <a asp-action="Index" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
