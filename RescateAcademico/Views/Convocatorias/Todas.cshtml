@model IEnumerable<RescateAcademico.Models.Convocatoria>
@{
    ViewData["Title"] = "Todas las Convocatorias";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;"><i class="bi bi-megaphone"></i> Gestión de Convocatorias</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nueva Convocatoria
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="table-responsive">
            <table class="table table-hover">
                <thead style="background-color: #6c1d45; color: white;">
                    <tr>
                        <th>Título</th>
                        <th>Tipo</th>
                        <th>Cupo</th>
                        <th>Fecha Cierre</th>
                        <th>Validada</th>
                        <th>Activa</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Titulo</strong></td>
                            <td>@item.Tipo</td>
                            <td>@item.PostulacionesActuales / @item.CupoMaximo</td>
                            <td>@item.FechaCierre.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.ValidadaPorAcademia)
                                {
                                    <i class="bi bi-check-circle text-success"></i>
                                }
                                else
                                {
                                    <a asp-action="Validar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-check"></i> Validar
                                    </a>
                                }
                            </td>
                            <td>
                                @if (item.EstaActiva)
                                {
                                    <span class="badge bg-success">Activa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactiva</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Cerrar esta convocatoria?')">
                                    <i class="bi bi-x-circle"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('table').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
