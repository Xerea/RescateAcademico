@model IEnumerable<RescateAcademico.Models.Convocatoria>
@{
    ViewData["Title"] = "Gestión de convocatorias";
    Layout = "_Layout";
    var actionsHtml = $"<a href=\"{Url.Action("Create")}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-plus-circle\"></i> Nueva convocatoria</a>";
    var header = new PageHeader
    {
        Title = "Gestión de convocatorias",
        Subtitle = "Publicación, validación y cierre.",
        Icon = "bi-megaphone",
        IconVariant = "accent",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        @if (TempData["Success"] != null)
        {
            <div class="ra-alert ra-alert-success mb-3" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
        }

        <div class="table-responsive">
            <table class="table ra-table" id="tablaConvocatorias">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Tipo</th>
                        <th>Cupo</th>
                        <th>Fecha Cierre</th>
                        <th>Validada</th>
                        <th>Activa</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Titulo</strong></td>
                            <td>@item.Tipo</td>
                            <td>@item.PostulacionesActuales / @item.CupoMaximo</td>
                            <td>@item.FechaCierre.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.ValidadaPorAcademia)
                                {
                                    <i class="bi bi-check-circle ra-text-success"></i>
                                }
                                else
                                {
                                    <form asp-action="Validar" method="post" class="m-0" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" title="Validar">
                                            <i class="bi bi-check ra-text-success"></i> Validar
                                        </button>
                                    </form>
                                }
                            </td>
                            <td>
                                @if (item.EstaActiva)
                                {
                                    <span class="ra-badge ra-badge-success">Activa</span>
                                }
                                else
                                {
                                    <span class="ra-badge ra-badge-neutral">Inactiva</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="ra-btn ra-btn-sm ra-btn-outline" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" class="m-0" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" title="Cerrar" onclick="return confirm('¿Cerrar esta convocatoria?')">
                                            <i class="bi bi-x-circle ra-text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaConvocatorias').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
