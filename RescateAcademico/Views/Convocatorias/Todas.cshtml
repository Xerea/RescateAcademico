@model IEnumerable<RescateAcademico.Models.Convocatoria>
@{
    ViewData["Title"] = "Gestión de convocatorias";
    Layout = "_Layout";
    var isAdmin = User.IsInRole("Administrador");
    var actionsHtml = isAdmin
        ? $"<a href=\"{Url.Action("Create")}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-plus-circle\"></i> Nueva convocatoria</a>"
        : null;
    var header = new PageHeader
    {
        Title = "Gestión de convocatorias",
        Subtitle = isAdmin ? "Publicación, validación y cierre." : "Consulta de convocatorias activas.",
        Icon = "bi-megaphone",
        IconVariant = "accent",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        @if (TempData["Success"] != null)
        {
            <div class="ra-alert ra-alert-success mb-3" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
        }

        <div class="table-responsive">
            <table class="table ra-table ra-table-cards" id="tablaConvocatorias">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Tipo</th>
                        <th>Cupo</th>
                        <th>Cierre</th>
                        <th>Validada</th>
                        <th>Activa</th>
                        @if (isAdmin)
                        {
                        <th data-orderable="false">Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Título"><strong>@item.Titulo</strong></td>
                            <td data-label="Tipo">@item.Tipo</td>
                            <td data-label="Cupo">@item.PostulacionesActuales / @item.CupoMaximo</td>
                            <td data-label="Cierre">@item.FechaCierre.ToString("dd/MM/yyyy")</td>
                            <td data-label="Validada">
                                @if (item.ValidadaPorAcademia)
                                {
                                    <span class="ra-badge ra-badge-success"><i class="bi bi-check-circle"></i> Validada</span>
                                }
                                else if (isAdmin)
                                {
                                    <form asp-action="Validar" method="post" class="m-0" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Validar @item.Titulo">
                                            <i class="bi bi-check ra-text-success"></i> Validar
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="ra-badge ra-badge-warning">Pendiente</span>
                                }
                            </td>
                            <td data-label="Activa">
                                @if (item.EstaActiva)
                                {
                                    <span class="ra-badge ra-badge-success">Activa</span>
                                }
                                else
                                {
                                    <span class="ra-badge ra-badge-neutral">Inactiva</span>
                                }
                            </td>
                            @if (isAdmin)
                            {
                            <td data-label="Acciones">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Editar @item.Titulo" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" class="m-0" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Cerrar @item.Titulo" title="Cerrar" onclick="return confirm('¿Cerrar esta convocatoria?')">
                                            <i class="bi bi-x-circle ra-text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                            }
                            else
                            {
                            <td></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaConvocatorias').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
                @if (isAdmin)
                {
                <text>, columnDefs: [{ orderable: false, targets: 7 }]</text>
                }
            });
        });
    </script>
}
