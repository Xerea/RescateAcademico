@model IEnumerable<RescateAcademico.Models.Convocatoria>
@{
    ViewData["Title"] = "Convocatorias";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Convocatorias disponibles",
        Subtitle = "Explora y postúlate a proyectos de servicio social, investigación o apoyo académico.",
        Icon = "bi-megaphone",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card ra-filter-bar">
    <div class="ra-card-body">
        <form method="get">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <input type="text" name="busqueda" class="ra-input" placeholder="Buscar por título…" />
                </div>
                <div class="col-md-3">
                    <select name="tipo" class="ra-select">
                        <option value="">Todos los tipos</option>
                        <option value="ServicioSocial">Servicio Social</option>
                        <option value="Investigacion">Investigación</option>
                        <option value="Laboratorio">Laboratorio</option>
                        <option value="ApoyoAcademico">Apoyo Académico</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="text" name="area" class="ra-input" placeholder="Área…" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="ra-btn ra-btn-primary w-100">
                        <i class="bi bi-search"></i> Filtrar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="ra-alert ra-alert-success mb-4" role="alert">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="ra-alert ra-alert-danger mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@TempData["Error"]</div>
    </div>
}

<div class="row g-3">
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            var diasRestantes = (item.FechaCierre - DateTime.Now).Days;
            <div class="col-md-6 col-lg-4">
                <div class="ra-card h-100 @(diasRestantes <= 7 && diasRestantes > 0 ? "ra-card-warning" : "")">
                    <div class="ra-card-header d-flex justify-content-between align-items-center flex-wrap gap-1">
                        <span class="ra-badge ra-badge-neutral">@item.Tipo</span>
                        @if (diasRestantes <= 7 && diasRestantes > 0)
                        {
                            <span class="ra-badge ra-badge-warning">Cierra pronto</span>
                        }
                        else if (diasRestantes <= 0)
                        {
                            <span class="ra-badge ra-badge-danger">Cerrada</span>
                        }
                    </div>
                    <div class="ra-card-body">
                        <h5 class="fw-bold mb-2">@item.Titulo</h5>
                        <p class="text-secondary small mb-3">@item.Descripcion</p>
                        <div class="d-flex flex-column gap-1 text-secondary small">
                            <div><i class="bi bi-calendar-event me-1"></i><strong>Cierre:</strong> @item.FechaCierre.ToString("dd/MM/yyyy") @(diasRestantes > 0 ? $"({diasRestantes} días)" : "")</div>
                            <div><i class="bi bi-people me-1"></i><strong>Cupo:</strong> @item.PostulacionesActuales / @item.CupoMaximo</div>
                            @if (item.PromedioMinimo.HasValue)
                            {
                                <div><i class="bi bi-star me-1"></i><strong>Promedio mínimo:</strong> @item.PromedioMinimo.Value.ToString("F1")</div>
                            }
                        </div>
                    </div>
                    <div class="ra-card-footer">
                        @if (diasRestantes > 0 && item.PostulacionesActuales < item.CupoMaximo)
                        {
                            <a asp-controller="Postulaciones" asp-action="Postularse" asp-route-convocatoriaId="@item.Id" class="ra-btn ra-btn-primary w-100">
                                <i class="bi bi-send"></i> Postularme
                            </a>
                        }
                        else if (diasRestantes <= 0)
                        {
                            <button class="ra-btn ra-btn-outline w-100" disabled>
                                <i class="bi bi-x-circle"></i> Convocatoria Cerrada
                            </button>
                        }
                        else if (item.PostulacionesActuales >= item.CupoMaximo)
                        {
                            <button class="ra-btn ra-btn-outline w-100" disabled>
                                <i class="bi bi-x-circle"></i> Sin Cupo
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="ra-empty">
                <i class="bi bi-inbox"></i>
                <p>No hay convocatorias disponibles en este momento.</p>
            </div>
        </div>
    }
</div>
