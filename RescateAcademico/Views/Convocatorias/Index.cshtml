@model IEnumerable<RescateAcademico.Models.Convocatoria>
@{
    ViewData["Title"] = "Catálogo de Convocatorias";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col">
        <h2 style="color: #6c1d45;"><i class="bi bi-megaphone"></i> Convocatorias Disponibles</h2>
        <p class="text-muted">Explora y postúlate a proyectos de servicio social, investigación o apoyo académico.</p>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="busqueda" class="form-control" placeholder="Buscar por título..." />
                </div>
                <div class="col-md-3">
                    <select name="tipo" class="form-select">
                        <option value="">Todos los tipos</option>
                        <option value="ServicioSocial">Servicio Social</option>
                        <option value="Investigacion">Investigación</option>
                        <option value="Laboratorio">Laboratorio</option>
                        <option value="ApoyoAcademico">Apoyo Académico</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="text" name="area" class="form-control" placeholder="Área..." />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filtrar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            var diasRestantes = (item.FechaCierre - DateTime.Now).Days;
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow-sm h-100 @(diasRestantes <= 7 ? "border-warning" : "")">
                    <div class="card-header" style="background-color: #6c1d45; color: white;">
                        <span class="badge bg-light text-dark">@item.Tipo</span>
                        @if (diasRestantes <= 7 && diasRestantes > 0)
                        {
                            <span class="badge bg-warning text-dark ms-2">¡Cierra pronto!</span>
                        }
                        else if (diasRestantes <= 0)
                        {
                            <span class="badge bg-danger ms-2">Cerrada</span>
                        }
                        <h5 class="mt-2 mb-0">@item.Titulo</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">@item.Descripcion</p>
                        <hr />
                        <p class="mb-1">
                            <i class="bi bi-calendar-event"></i>
                            <strong>Cierre:</strong> @item.FechaCierre.ToString("dd/MM/yyyy")
                            @if (diasRestantes > 0)
                            {
                                <span class="text-muted">(@diasRestantes días)</span>
                            }
                        </p>
                        <p class="mb-1">
                            <i class="bi bi-people"></i>
                            <strong>Cupo:</strong> @item.PostulacionesActuales / @item.CupoMaximo
                        </p>
                        @if (item.PromedioMinimo.HasValue)
                        {
                            <p class="mb-1">
                                <i class="bi bi-star"></i>
                                <strong>Promedio mínimo:</strong> @item.PromedioMinimo.Value.ToString("F1")
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(item.Requisitos))
                        {
                            <p class="mb-1">
                                <i class="bi bi-card-checklist"></i>
                                <small>@item.Requisitos</small>
                            </p>
                        }
                    </div>
                    <div class="card-footer bg-white">
                        @if (diasRestantes > 0 && item.PostulacionesActuales < item.CupoMaximo)
                        {
                            <a asp-controller="Postulaciones" asp-action="Postularse" asp-route-convocatoriaId="@item.Id" class="btn btn-primary w-100">
                                <i class="bi bi-send"></i> Postularme
                            </a>
                        }
                        else if (diasRestantes <= 0)
                        {
                            <button class="btn btn-secondary w-100" disabled>
                                <i class="bi bi-x-circle"></i> Convocatoria Cerrada
                            </button>
                        }
                        else if (item.PostulacionesActuales >= item.CupoMaximo)
                        {
                            <button class="btn btn-secondary w-100" disabled>
                                <i class="bi bi-x-circle"></i> Sin Cupo Disponible
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <p class="text-muted mt-3">No hay convocatorias disponibles en este momento.</p>
            </div>
        </div>
    }
</div>
