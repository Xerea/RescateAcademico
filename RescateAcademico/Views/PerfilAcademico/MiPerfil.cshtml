@model RescateAcademico.Controllers.PerfilAcademicoViewModel
@{
    ViewData["Title"] = "Mi Perfil Académico";
    Layout = "_Layout";
}

@if (TempData["Error"] != null)
{
    <div class="ra-alert ra-alert-danger mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@TempData["Error"]</div>
    </div>
    return;
}

@if (Model?.Alumno != null)
{
    <div class="row mb-4 align-items-end">
        <div class="col">
            <h1 class="fw-bold h3 mb-1"><i class="bi bi-person-badge ra-text-accent me-2"></i>Mi Perfil Académico</h1>
            <p class="text-secondary small mb-0">@Model.Alumno.Nombre @Model.Alumno.Apellidos — Boleta @Model.Alumno.Matricula</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="ra-stat ra-stat-accent text-center">
                <div class="ra-stat-label">Promedio</div>
                <div class="ra-stat-value @(Model.Alumno.PromedioGlobal >= 8 ? "ra-text-success" : Model.Alumno.PromedioGlobal >= 6 ? "ra-text-warning" : "ra-text-danger")">
                    @Model.Alumno.PromedioGlobal.ToString("F2")
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ra-stat ra-stat-info text-center">
                <div class="ra-stat-label">Semestre</div>
                <div class="ra-stat-value">@Model.Alumno.SemestreActual</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ra-stat ra-stat-primary text-center">
                <div class="ra-stat-label">Materias</div>
                <div class="ra-stat-value">@(Model.Alumno.CargaAcademicaActual ?? 0)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ra-stat @(Model.NivelRiesgo == "Rojo" ? "ra-stat-danger" : Model.NivelRiesgo == "Amarillo" ? "ra-stat-warning" : "ra-stat-success") text-center">
                <div class="ra-stat-label">Riesgo</div>
                <div class="ra-stat-value" style="font-size:1.4rem;"><ra-semaforo riesgo="@Model.NivelRiesgo" size="lg"></ra-semaforo></div>
            </div>
        </div>
    </div>

    <!-- What-If Calculator Trigger -->
    <div class="mb-4">
        <button type="button" class="ra-btn ra-btn-outline w-100 py-3" data-bs-toggle="modal" data-bs-target="#calculadoraModal">
            <i class="bi bi-calculator fs-4 me-2"></i>
            <span class="fw-semibold">¿Cómo me va? — Simulador de Calificaciones</span>
            <span class="d-block text-secondary small mt-1">Calcula tu promedio, riesgo y elegibilidad para convocatorias</span>
        </button>
    </div>

    @if (Model.Sugerencias.Any())
    {
        <div class="ra-card ra-card-primary mb-4">
            <div class="ra-card-body">
                <h5 class="fw-semibold mb-3"><i class="bi bi-lightbulb ra-text-primary me-2"></i>Sugerencias para Ti</h5>
                <ul class="mb-0">
                    @foreach (var sugerencia in Model.Sugerencias)
                    {
                        <li class="mb-2">@sugerencia</li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-cpu"></i> IA Predictiva de Deserción
                </div>
                <div class="ra-card-body">
                    <div class="text-center mb-3">
                        <div class="ra-stat-value">@((Model.ProbabilidadDesercion * 100).ToString("F1"))%</div>
                        <div class="ra-stat-label">Probabilidad Estimada</div>
                    </div>
                    <p class="mb-0">
                        <span class="text-secondary small">Nivel predictivo:</span>
                        <span class="ra-badge @(Model.NivelRiesgoPredictivo == "Critico" ? "ra-badge-danger" : Model.NivelRiesgoPredictivo == "Alto" ? "ra-badge-warning" : Model.NivelRiesgoPredictivo == "Medio" ? "ra-badge-info" : "ra-badge-success")">
                            @Model.NivelRiesgoPredictivo
                        </span>
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-stars"></i> IA: Proyectos Compatibles
                </div>
                <div class="ra-card-body">
                    @if (Model.CompatibilidadConvocatorias.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var recomendacion in Model.CompatibilidadConvocatorias)
                            {
                                <li class="mb-3 pb-2" style="border-bottom: 1px solid var(--ra-border-subtle);">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <strong class="small">@recomendacion.Titulo</strong>
                                        <span class="ra-badge ra-badge-primary">@recomendacion.Puntaje.ToString("F1")%</span>
                                    </div>
                                    <small class="text-secondary">@recomendacion.Explicacion</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="ra-empty py-4">
                            <i class="bi bi-stars"></i>
                            <p>No hay convocatorias activas para recomendar.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="ra-card">
                <div class="ra-card-header">
                    <i class="bi bi-journal-text"></i> Historial por Período
                </div>
                <div class="ra-card-body p-0">
                    @if (Model.PromedioPorSemestre.Any())
                    {
                        <div class="table-responsive">
                            <table class="table ra-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Período</th>
                                        <th>Promedio</th>
                                        <th>Materias</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var semestre in Model.PromedioPorSemestre)
                                    {
                                        <tr>
                                            <td>@semestre.Periodo</td>
                                            <td>
                                                <span class="ra-badge @(semestre.Promedio >= 8 ? "ra-badge-success" : semestre.Promedio >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                                    @semestre.Promedio.ToString("F2")
                                                </span>
                                            </td>
                                            <td>@semestre.Materias</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="ra-empty py-4">
                            <i class="bi bi-journal-text"></i>
                            <p>Sin datos de períodos</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="ra-card">
                <div class="ra-card-header">
                    <i class="bi bi-people"></i> Mis Profesores
                </div>
                <div class="ra-card-body">
                    @if (Model.Alumno.TutoresAsignados?.Any() == true)
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var asignacion in Model.Alumno.TutoresAsignados.Where(a => a.EstaActiva))
                            {
                                <li class="mb-3 pb-2 d-flex align-items-start gap-2" style="border-bottom: 1px solid var(--ra-border-subtle);">
                                    <div class="ra-avatar flex-shrink-0">
                                        <i class="bi bi-person-badge"></i>
                                    </div>
                                    <div>
                                        <div class="fw-medium">@asignacion.Tutor?.Nombre @asignacion.Tutor?.Apellidos</div>
                                        <div class="text-secondary small">@asignacion.Tutor?.Especialidad</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="ra-empty py-4">
                            <i class="bi bi-people"></i>
                            <p>Sin profesores asignados</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="ra-card @(Model.NivelRiesgo == "Rojo" ? "ra-card-danger" : Model.NivelRiesgo == "Amarillo" ? "ra-card-warning" : "ra-card-success")">
        <div class="ra-card-body">
            <h5 class="fw-semibold mb-3">
                <i class="bi bi-traffic-light me-2"></i>Nivel de Riesgo Académico: @Model.NivelRiesgo
            </h5>
            <div class="row text-center g-3">
                <div class="col-4">
                    <div class="p-3 rounded-3" style="background: var(--ra-success-bg);">
                        <h3 class="ra-text-success mb-0">@Model.MateriasAprobadas</h3>
                        <small class="text-secondary">Aprobadas</small>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded-3" style="background: var(--ra-danger-bg);">
                        <h3 class="ra-text-danger mb-0">@Model.MateriasReprobadas</h3>
                        <small class="text-secondary">Reprobadas</small>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded-3" style="background: var(--ra-warning-bg);">
                        <h3 class="ra-text-warning mb-0">@Model.Recursamientos</h3>
                        <small class="text-secondary">Recursadas</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Integration Footer -->
    <div class="text-center mt-4 mb-2">
        <p class="text-secondary" style="font-size:0.75rem;opacity:0.7;">
            <i class="bi bi-cloud-check me-1"></i> Información académica sincronizada con sistemas institucionales
        </p>
    </div>

    <!-- Calculadora Modal -->
    <div class="modal fade" id="calculadoraModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="ra-modal-content">
                <div class="ra-card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-calculator"></i> Simulador de Calificaciones</span>
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="ra-card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="ra-heading mb-3">Tus materias actuales</div>
                            <div id="materiasInputs">
                                @for (int i = 0; i < (Model.Alumno.CargaAcademicaActual ?? 5); i++)
                                {
                                    <div class="mb-2 d-flex align-items-center gap-2">
                                        <span class="ra-mono text-secondary small" style="width:24px;">@(i+1)</span>
                                        <input type="number" class="ra-input calif-input" min="0" max="10" step="0.1" value="7.0" placeholder="0-10" oninput="calcularSimulacion()" />
                                    </div>
                                }
                            </div>
                            <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost mt-2" onclick="agregarMateria()">
                                <i class="bi bi-plus"></i> Agregar materia
                            </button>
                        </div>
                        <div class="col-md-6">
                            <div class="ra-card h-100 text-center">
                                <div class="ra-card-body d-flex flex-column justify-content-center">
                                    <div class="ra-heading mb-2">Promedio proyectado</div>
                                    <div class="ra-stat-value" id="simPromedio" style="font-size:3rem;">7.00</div>
                                    <div class="mb-3">
                                        <ra-semaforo id="simSemaforo" riesgo="Amarillo" size="lg"></ra-semaforo>
                                    </div>
                                    <div class="ra-heading mb-2">Riesgo estimado</div>
                                    <div class="fw-semibold mb-3" id="simRiesgoTexto">Amarillo</div>

                                    <div style="height:8px;background:var(--ra-border);border-radius:4px;overflow:hidden;margin-bottom:1rem;">
                                        <div id="simBarra" style="height:100%;width:70%;background:var(--ra-warning);transition:width 0.3s ease,background 0.3s ease;"></div>
                                    </div>

                                    <div class="ra-heading mb-2">Elegibilidad convocatorias</div>
                                    <p class="small text-secondary mb-0" id="simElegibilidad">Promedio mínimo requerido: 7.5</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="ra-card-footer d-flex justify-content-between">
                    <button type="button" class="ra-btn ra-btn-ghost" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" class="ra-btn ra-btn-primary" onclick="resetSimulacion()">
                        <i class="bi bi-arrow-counterclockwise"></i> Reiniciar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            function calcularSimulacion() {
                var inputs = document.querySelectorAll('.calif-input');
                var sum = 0, count = 0;
                inputs.forEach(function(inp) {
                    var v = parseFloat(inp.value);
                    if (!isNaN(v)) { sum += v; count++; }
                });
                var promedio = count > 0 ? sum / count : 0;
                var promedioFixed = promedio.toFixed(2);
                document.getElementById('simPromedio').textContent = promedioFixed;

                var riesgo = 'Verde', color = 'var(--ra-success)';
                if (promedio < 6) { riesgo = 'Rojo'; color = 'var(--ra-danger)'; }
                else if (promedio < 7.5) { riesgo = 'Amarillo'; color = 'var(--ra-warning)'; }

                document.getElementById('simRiesgoTexto').textContent = riesgo;
                document.getElementById('simBarra').style.width = Math.min(promedio * 10, 100) + '%';
                document.getElementById('simBarra').style.background = color;

                var sem = document.getElementById('simSemaforo');
                sem.setAttribute('riesgo', riesgo);

                var eleg = document.getElementById('simElegibilidad');
                if (promedio >= 8.5) eleg.textContent = 'Elegible para todas las convocatorias';
                else if (promedio >= 7.5) eleg.textContent = 'Elegible para la mayoría de convocatorias';
                else if (promedio >= 6) eleg.textContent = 'Elegibilidad limitada — algunas convocatorias requieren 7.5+';
                else eleg.textContent = 'No elegible para convocatorias con promedio mínimo';
            }
            function agregarMateria() {
                var container = document.getElementById('materiasInputs');
                var idx = container.children.length + 1;
                var div = document.createElement('div');
                div.className = 'mb-2 d-flex align-items-center gap-2';
                div.innerHTML = '<span class="ra-mono text-secondary small" style="width:24px;">' + idx + '</span><input type="number" class="ra-input calif-input" min="0" max="10" step="0.1" value="7.0" placeholder="0-10" oninput="calcularSimulacion()" />';
                container.appendChild(div);
                calcularSimulacion();
            }
            function resetSimulacion() {
                document.querySelectorAll('.calif-input').forEach(function(inp) { inp.value = '7.0'; });
                calcularSimulacion();
            }
            calcularSimulacion();
        </script>
    }
}
