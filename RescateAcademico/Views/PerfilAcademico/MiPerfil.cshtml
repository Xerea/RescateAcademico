@model RescateAcademico.Controllers.PerfilAcademicoViewModel
@{
    ViewData["Title"] = "Mi Perfil Académico";
    Layout = "_Layout";
    var header = Model?.Alumno == null ? null : new PageHeader
    {
        Title = "Mi Perfil Académico",
        Subtitle = $"{Model.Alumno.Nombre} {Model.Alumno.Apellidos} · Boleta {Model.Alumno.Matricula}",
        Icon = "bi-person-badge",
        IconVariant = "accent"
    };
}

@if (TempData["Error"] != null)
{
    <div class="ra-alert ra-alert-danger mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@TempData["Error"]</div>
    </div>
    return;
}

@if (Model?.Alumno != null)
{
    <partial name="_PageHeader" model="header" />

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="ra-stat ra-stat-accent text-center">
                <div class="ra-stat-label">Promedio</div>
                <div class="ra-stat-value @(Model.Alumno.PromedioGlobal >= 8 ? "ra-text-success" : Model.Alumno.PromedioGlobal >= 6 ? "ra-text-warning" : "ra-text-danger")">
                    @Model.Alumno.PromedioGlobal.ToString("F2")
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ra-stat ra-stat-info text-center">
                <div class="ra-stat-label">Semestre</div>
                <div class="ra-stat-value">@Model.Alumno.SemestreActual</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ra-stat ra-stat-primary text-center">
                <div class="ra-stat-label">Materias</div>
                <div class="ra-stat-value">@(Model.Alumno.CargaAcademicaActual ?? 0)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ra-stat @(Model.NivelRiesgo == "Rojo" ? "ra-stat-danger" : Model.NivelRiesgo == "Amarillo" ? "ra-stat-warning" : "ra-stat-success") text-center">
                <div class="ra-stat-label">Riesgo</div>
                <div class="ra-stat-value" style="font-size:1.4rem;"><ra-semaforo riesgo="@Model.NivelRiesgo" size="lg"></ra-semaforo></div>
            </div>
        </div>
    </div>

    <!-- Simulador Trigger -->
    <div class="mb-4">
        <button type="button" class="ra-btn ra-btn-accent w-100 py-3" data-bs-toggle="modal" data-bs-target="#calculadoraModal">
            <i class="bi bi-calculator fs-4 me-2"></i>
            <span class="fw-semibold">Simulador de Impacto Académico</span>
            <span class="d-block text-white-50 small mt-1">Simula cómo tu promedio, riesgo y elegibilidad cambian al modificar tus calificaciones</span>
        </button>
    </div>

    @if (Model.Sugerencias.Any())
    {
        <div class="ra-card ra-card-primary mb-4">
            <div class="ra-card-body">
                <h5 class="fw-semibold mb-3"><i class="bi bi-lightbulb ra-text-primary me-2"></i>Sugerencias para Ti</h5>
                <ul class="mb-0">
                    @foreach (var sugerencia in Model.Sugerencias)
                    {
                        <li class="mb-2">@sugerencia</li>
                    }
                </ul>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-cpu"></i> IA Predictiva de Deserción
                </div>
                <div class="ra-card-body">
                    <div class="text-center mb-3">
                        <div class="ra-stat-value">@((Model.ProbabilidadDesercion * 100).ToString("F1"))%</div>
                        <div class="ra-stat-label">Probabilidad Estimada</div>
                    </div>
                    <p class="mb-0">
                        <span class="text-secondary small">Nivel predictivo:</span>
                        <span class="ra-badge @(Model.NivelRiesgoPredictivo == "Critico" ? "ra-badge-danger" : Model.NivelRiesgoPredictivo == "Alto" ? "ra-badge-warning" : Model.NivelRiesgoPredictivo == "Medio" ? "ra-badge-info" : "ra-badge-success")">
                            @Model.NivelRiesgoPredictivo
                        </span>
                    </p>
                    @if (Model.EsTutor || User.IsInRole("Administrador") || User.IsInRole("Autoridad"))
                    {
                        <form asp-action="GuardarAnalisisInteligente" method="post" class="mt-3">
                            <input type="hidden" name="matricula" value="@Model.Alumno.Matricula" />
                            <button type="submit" class="ra-btn ra-btn-outline w-100">
                                <i class="bi bi-save"></i> Guardar análisis
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="ra-card h-100">
                <div class="ra-card-header">
                    <i class="bi bi-stars"></i> IA: Proyectos Compatibles
                </div>
                <div class="ra-card-body">
                    @if (Model.CompatibilidadConvocatorias.Any())
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var recomendacion in Model.CompatibilidadConvocatorias)
                            {
                                <li class="mb-3 pb-2" style="border-bottom: 1px solid var(--ra-border-subtle);">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <strong class="small">@recomendacion.Titulo</strong>
                                        <span class="ra-badge ra-badge-primary">@recomendacion.Puntaje.ToString("F1")%</span>
                                    </div>
                                    <small class="text-secondary">@recomendacion.Explicacion</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="ra-empty py-4">
                            <i class="bi bi-stars"></i>
                            <p>No hay convocatorias activas para recomendar.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="ra-card">
                <div class="ra-card-header">
                    <i class="bi bi-journal-text"></i> Historial por Período
                </div>
                <div class="ra-card-body p-0">
                    @if (Model.PromedioPorSemestre.Any())
                    {
                        <div class="table-responsive">
                            <table class="table ra-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Período</th>
                                        <th>Promedio</th>
                                        <th>Materias</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var semestre in Model.PromedioPorSemestre)
                                    {
                                        <tr>
                                            <td>@semestre.Periodo</td>
                                            <td>
                                                <span class="ra-badge @(semestre.Promedio >= 8 ? "ra-badge-success" : semestre.Promedio >= 6 ? "ra-badge-warning" : "ra-badge-danger")">
                                                    @semestre.Promedio.ToString("F2")
                                                </span>
                                            </td>
                                            <td>@semestre.Materias</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="ra-empty py-4">
                            <i class="bi bi-journal-text"></i>
                            <p>Sin datos de períodos</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="ra-card">
                <div class="ra-card-header">
                    <i class="bi bi-people"></i> Mis Profesores
                </div>
                <div class="ra-card-body">
                    @if (Model.Alumno.TutoresAsignados?.Any() == true)
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var asignacion in Model.Alumno.TutoresAsignados.Where(a => a.EstaActiva))
                            {
                                <li class="mb-3 pb-2 d-flex align-items-start gap-2" style="border-bottom: 1px solid var(--ra-border-subtle);">
                                    <div class="ra-avatar flex-shrink-0">
                                        <i class="bi bi-person-badge"></i>
                                    </div>
                                    <div>
                                        <div class="fw-medium">@asignacion.Tutor?.Nombre @asignacion.Tutor?.Apellidos</div>
                                        <div class="text-secondary small">@asignacion.Tutor?.Especialidad</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="ra-empty py-4">
                            <i class="bi bi-people"></i>
                            <p>Sin profesores asignados</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="ra-card @(Model.NivelRiesgo == "Rojo" ? "ra-card-danger" : Model.NivelRiesgo == "Amarillo" ? "ra-card-warning" : "ra-card-success")">
        <div class="ra-card-body">
            <h5 class="fw-semibold mb-3">
                <i class="bi bi-traffic-light me-2"></i>Nivel de Riesgo Académico: @Model.NivelRiesgo
            </h5>
            <div class="row text-center g-3">
                <div class="col-4">
                    <div class="p-3 rounded-3" style="background: var(--ra-success-bg);">
                        <h3 class="ra-text-success mb-0">@Model.MateriasAprobadas</h3>
                        <small class="text-secondary">Aprobadas</small>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded-3" style="background: var(--ra-danger-bg);">
                        <h3 class="ra-text-danger mb-0">@Model.MateriasReprobadas</h3>
                        <small class="text-secondary">Reprobadas</small>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded-3" style="background: var(--ra-warning-bg);">
                        <h3 class="ra-text-warning mb-0">@Model.Recursamientos</h3>
                        <small class="text-secondary">Recursadas</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="simContext" hidden
         data-suma-previa="@Model.SumaPrevia.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
         data-total-previas="@Model.TotalMateriasPrevias"
         data-promedio-actual="@Model.Alumno.PromedioGlobal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
         data-riesgo-actual="@Model.NivelRiesgo"
         data-elegibles-ahora="@Model.ConvocatoriasElegiblesAhora"
         data-total-convocatorias="@Model.UmbralesPromedio.Count"
         data-umbrales='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UmbralesPromedio))'>
    </div>

    <div class="modal fade" id="calculadoraModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content ra-modal-content">
                <div class="ra-card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-calculator"></i> Simulador de Impacto Académico</span>
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="ra-card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="ra-heading mb-2">Tus materias</div>
                            <p class="small text-secondary mb-3">Modifica las calificaciones para ver el impacto en tu promedio acumulado.</p>
                            <div id="materiasInputs">
                                @foreach (var m in Model.MateriasSimulacion)
                                {
                                    <div class="mb-2">
                                        <label class="small text-secondary d-block text-truncate mb-1">@m.Nombre</label>
                                        <input type="number" class="ra-input calif-input" min="0" max="10" step="0.1"
                                               value="@m.CalificacionActual.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                               data-inicial="@m.CalificacionActual.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                               oninput="window.calcularSimulacion()" />
                                    </div>
                                }
                            </div>
                            <div class="d-flex gap-2 mt-2">
                                <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost flex-fill" onclick="window.restaurarReales()">
                                    <i class="bi bi-arrow-counterclockwise"></i> Restaurar reales
                                </button>
                                <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="window.agregarMateria()">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="ra-card ra-card-subtle mb-3">
                                <div class="ra-card-body text-center">
                                    <div class="row g-2 align-items-center">
                                        <div class="col-5">
                                            <div class="ra-stat-label mb-1">Promedio Actual</div>
                                            <div class="fw-bold" style="font-size:1.5rem;" id="simPromActual">@Model.Alumno.PromedioGlobal.ToString("F2")</div>
                                            <ra-semaforo id="simSemaforoActual" riesgo="@Model.NivelRiesgo" size="sm"></ra-semaforo>
                                        </div>
                                        <div class="col-2 text-center">
                                            <i class="bi bi-arrow-right text-secondary fs-5"></i>
                                        </div>
                                        <div class="col-5">
                                            <div class="ra-stat-label mb-1">Promedio Simulado</div>
                                            <div class="fw-bold" style="font-size:1.5rem;" id="simPromNuevo">@Model.Alumno.PromedioGlobal.ToString("F2")</div>
                                            <div class="small" id="simDelta"></div>
                                            <ra-semaforo id="simSemaforoNuevo" riesgo="@Model.NivelRiesgo" size="sm"></ra-semaforo>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="ra-card ra-card-subtle mb-3">
                                <div class="ra-card-body">
                                    <div class="ra-heading mb-2">Convocatorias elegibles</div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="small text-secondary">Con promedio actual:</span>
                                        <span class="fw-semibold" id="simElegiblesAhora">@Model.ConvocatoriasElegiblesAhora / @Model.UmbralesPromedio.Count</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="small text-secondary">Con promedio simulado:</span>
                                        <span class="fw-semibold" id="simElegiblesNuevo">@Model.ConvocatoriasElegiblesAhora / @Model.UmbralesPromedio.Count</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ra-card ra-card-subtle">
                                <div class="ra-card-body">
                                    <div class="ra-heading mb-2">Calculadora de objetivo</div>
                                    <p class="small text-secondary mb-2">¿Qué promedio necesitas este semestre para alcanzar tu meta?</p>
                                    <div class="input-group input-group-sm mb-2">
                                        <span class="input-group-text small">Quiero alcanzar</span>
                                        <input type="number" id="simObjetivo" class="ra-input" min="0" max="10" step="0.1" value="8.0"
                                               oninput="window.calcularObjetivo()" onkeydown="if(event.key==='Enter')window.calcularObjetivo()" />
                                    </div>
                                    <div class="small" id="simObjetivoResultado"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="ra-card-footer d-flex gap-2 flex-wrap">
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="window.aplicarPreset(7.0)">7.0</button>
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="window.aplicarPreset(7.5)">7.5</button>
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="window.aplicarPreset(8.0)">8.0</button>
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="window.aplicarPreset(8.5)">8.5</button>
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" onclick="window.aplicarPreset(9.0)">9.0</button>
                    <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost ms-auto" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            (function() {
                var simContext = document.getElementById('simContext');
                if (!simContext) { console.warn('[Simulador] simContext not found'); return; }

                var sumaPrevia = parseFloat(simContext.dataset.sumaPrevia) || 0;
                var totalPrevias = parseInt(simContext.dataset.totalPrevias) || 0;
                var promedioActual = parseFloat(simContext.dataset.promedioActual) || 0;
                var riesgoActual = simContext.dataset.riesgoActual || 'Verde';
                var elegiblesAhora = parseInt(simContext.dataset.elegiblesAhora) || 0;
                var totalConvocatorias = parseInt(simContext.dataset.totalConvocatorias) || 0;
                var umbrales = [];
                try { umbrales = JSON.parse(simContext.dataset.umbrales || '[]'); } catch(e) { console.warn('[Simulador] Failed to parse umbrales'); }

                function calcularSimulacion() {
                    try {
                        var inputs = document.querySelectorAll('.calif-input');
                        var sum = 0, count = 0;
                        inputs.forEach(function(inp) {
                            var v = parseFloat(inp.value);
                            if (!isNaN(v)) { sum += v; count++; }
                        });
                        if (count === 0) return;

                        var nuevaSuma = sumaPrevia + sum;
                        var nuevasMaterias = totalPrevias + count;
                        var cumulativoNuevo = nuevasMaterias > 0 ? nuevaSuma / nuevasMaterias : 0;
                        var delta = cumulativoNuevo - promedioActual;

                        var promNuevoEl = document.getElementById('simPromNuevo');
                        if (promNuevoEl) promNuevoEl.textContent = cumulativoNuevo.toFixed(2);

                        var deltaEl = document.getElementById('simDelta');
                        if (deltaEl) {
                            if (delta >= 0.01) {
                                deltaEl.innerHTML = '<span class="ra-text-success">+' + delta.toFixed(2) + ' <i class="bi bi-arrow-up-short"></i></span>';
                            } else if (delta <= -0.01) {
                                deltaEl.innerHTML = '<span class="ra-text-danger">' + delta.toFixed(2) + ' <i class="bi bi-arrow-down-short"></i></span>';
                            } else {
                                deltaEl.innerHTML = '<span class="text-secondary">0.00</span>';
                            }
                        }

                        var riesgoNuevo = cumulativoNuevo < 6.0 ? 'Rojo' : cumulativoNuevo < 7.5 ? 'Amarillo' : 'Verde';
                        var semEl = document.getElementById('simSemaforoNuevo');
                        if (semEl) semEl.setAttribute('riesgo', riesgoNuevo);

                        var elegiblesNuevo = 0;
                        umbrales.forEach(function(u) {
                            if (u == null || cumulativoNuevo >= u) elegiblesNuevo++;
                        });
                        var eligEl = document.getElementById('simElegiblesNuevo');
                        if (eligEl) eligEl.textContent = elegiblesNuevo + ' / ' + totalConvocatorias;

                        if (document.getElementById('simObjetivo').value) {
                            calcularObjetivo();
                        }
                    } catch(e) {
                        console.error('[Simulador] Error in calcularSimulacion:', e);
                    }
                }

                function calcularObjetivo() {
                    try {
                        var objetivo = parseFloat(document.getElementById('simObjetivo').value);
                        if (isNaN(objetivo) || objetivo < 0 || objetivo > 10) {
                            document.getElementById('simObjetivoResultado').innerHTML = '';
                            return;
                        }
                        var inputs = document.querySelectorAll('.calif-input');
                        var count = inputs.length;
                        if (count === 0) return;

                        var targetTotal = objetivo * (totalPrevias + count);
                        var needed = targetTotal - sumaPrevia;
                        var neededAvg = needed / count;
                        var res = document.getElementById('simObjetivoResultado');
                        if (!res) return;

                        if (promedioActual >= objetivo) {
                            res.innerHTML = '<span class="ra-text-success"><i class="bi bi-check-circle"></i> Ya tienes un promedio acumulado de ' + promedioActual.toFixed(2) + '.</span>';
                        } else if (neededAvg > 10) {
                            res.innerHTML = '<span class="ra-text-danger"><i class="bi bi-x-circle"></i> No es posible este semestre. Necesitar&iacute;as ' + neededAvg.toFixed(1) + ' de promedio y el m&aacute;ximo es 10.</span>';
                        } else {
                            res.innerHTML = '<span class="ra-text-primary"><i class="bi bi-bullseye"></i> Necesitas <strong>' + neededAvg.toFixed(1) + '</strong> de promedio semestral en tus ' + count + ' materias.</span>';
                        }
                    } catch(e) {
                        console.error('[Simulador] Error in calcularObjetivo:', e);
                    }
                }

                window.restaurarReales = function() {
                    document.querySelectorAll('.calif-input').forEach(function(inp) {
                        var inicial = inp.getAttribute('data-inicial');
                        if (inicial) inp.value = inicial;
                    });
                    calcularSimulacion();
                };

                window.agregarMateria = function() {
                    var container = document.getElementById('materiasInputs');
                    if (!container) return;
                    var idx = container.querySelectorAll('.calif-input').length + 1;
                    var div = document.createElement('div');
                    div.className = 'mb-2';
                    div.innerHTML = '<label class="small text-secondary d-block text-truncate mb-1">Materia ' + idx + '</label>'
                        + '<input type="number" class="ra-input calif-input" min="0" max="10" step="0.1" value="7.0" data-inicial="7.0" oninput="window.calcularSimulacion()" />';
                    container.appendChild(div);
                    calcularSimulacion();
                };

                window.aplicarPreset = function(valor) {
                    document.querySelectorAll('.calif-input').forEach(function(inp) {
                        inp.value = valor.toFixed(1);
                    });
                    calcularSimulacion();
                };

                window.calcularSimulacion = calcularSimulacion;
                window.calcularObjetivo = calcularObjetivo;

                calcularSimulacion();
                calcularObjetivo();
            })();
        </script>
    }
}
