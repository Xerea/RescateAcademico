@model RescateAcademico.Models.Proyecto
@{
    ViewData["Title"] = "Editar proyecto";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = $"Editar: {Model.Titulo}",
        Subtitle = "Actualiza los datos del proyecto.",
        Icon = "bi-pencil",
        IconVariant = "accent",
        BackUrl = Url.Action("Index"),
        BackLabel = "Proyectos"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row">
    <div class="col-md-8 col-lg-6 mx-auto">
        <div class="ra-card">
            <div class="ra-card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label class="ra-label">Título *</label>
                        <input asp-for="Titulo" class="ra-input" required />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Descripción</label>
                        <textarea asp-for="Descripcion" class="ra-input" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Tipo</label>
                        <select asp-for="Tipo" class="ra-select">
                            <option value="Servicio Social">Servicio Social</option>
                            <option value="Investigacion">Investigación</option>
                            <option value="Laboratorio">Laboratorio</option>
                            <option value="Apoyo Academico">Apoyo Académico</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Cupo Máximo</label>
                        <input asp-for="CupoMaximo" class="ra-input" type="number" min="1" />
                    </div>
                    <div class="mb-3">
                        <label class="ra-label">Fecha de Cierre</label>
                        <input asp-for="FechaCierre" class="ra-input" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-save"></i> Guardar Cambios
                        </button>
                        <a asp-action="Index" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
