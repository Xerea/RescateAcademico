@model RescateAcademico.Models.Proyecto
@{
    ViewData["Title"] = Model.Titulo;
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = Model.Titulo,
        Subtitle = "Detalles del proyecto",
        Icon = "bi-folder",
        IconVariant = "accent",
        BackUrl = User.IsInRole("Alumno")
            ? Url.Action("MisPostulaciones", "Postulaciones")
            : Url.Action("Index"),
        BackLabel = User.IsInRole("Alumno") ? "Mis postulaciones" : "Proyectos"
    };
}

<partial name="_PageHeader" model="header" />

<div class="row">
    <div class="col-md-8">
        <div class="ra-card">
            <div class="ra-card-body">
                <h5>Descripción</h5>
                <p>@Model.Descripcion</p>
                <hr />
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Tipo:</strong> @Model.Tipo</p>
                        <p><strong>Cupo Máximo:</strong> @Model.CupoMaximo</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Fecha de Cierre:</strong> @Model.FechaCierre.ToString("dd/MM/yyyy")</p>
                        <p>
                            <strong>Estado:</strong>
                            @if (Model.EstaActivo)
                            {
                                <span class="ra-badge ra-badge-success">Activo</span>
                            }
                            else
                            {
                                <span class="ra-badge ra-badge-neutral">Inactivo</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="@(User.IsInRole("Alumno") ? Url.Action("MisPostulaciones", "Postulaciones") : Url.Action("Index"))" class="ra-btn ra-btn-ghost">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>
