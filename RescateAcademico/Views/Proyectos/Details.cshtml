@model RescateAcademico.Models.Proyecto
@{
    ViewData["Title"] = "Detalles del Proyecto";
    Layout = "_Layout";
}

<div class="row mb-4">
    <div class="col">
        <h2 class="ra-text-accent"><i class="bi bi-folder"></i> @Model.Titulo</h2>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="ra-card">
            <div class="ra-card-body">
                <h5>Descripción</h5>
                <p>@Model.Descripcion</p>
                <hr />
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Tipo:</strong> @Model.Tipo</p>
                        <p><strong>Cupo Máximo:</strong> @Model.CupoMaximo</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Fecha de Cierre:</strong> @Model.FechaCierre.ToString("dd/MM/yyyy")</p>
                        <p>
                            <strong>Estado:</strong>
                            @if (Model.EstaActivo)
                            {
                                <span class="ra-badge ra-badge-success">Activo</span>
                            }
                            else
                            {
                                <span class="ra-badge ra-badge-neutral">Inactivo</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="ra-btn ra-btn-ghost">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>
