@model IEnumerable<RescateAcademico.Models.Proyecto>
@{
    ViewData["Title"] = "Gestión de proyectos";
    Layout = "_Layout";
    var actionsHtml = $"<a href=\"{Url.Action("Create")}\" class=\"ra-btn ra-btn-primary\"><i class=\"bi bi-plus-circle\"></i> Nuevo proyecto</a>";
    var header = new PageHeader
    {
        Title = "Gestión de proyectos",
        Subtitle = "Catálogo de proyectos académicos y de servicio social.",
        Icon = "bi-folder",
        IconVariant = "accent",
        ActionsHtml = actionsHtml
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        @if (TempData["Success"] != null)
        {
            <div class="ra-alert ra-alert-success mb-3" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
        }

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards" id="tablaProyectos">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Tipo</th>
                            <th>Cupo</th>
                            <th>Cierre</th>
                            <th>Estado</th>
                            <th data-orderable="false">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="Título">
                                    <strong>@item.Titulo</strong>
                                    <br />
                                    <span class="text-secondary small">@item.Descripcion</span>
                                </td>
                                <td data-label="Tipo">@item.Tipo</td>
                                <td data-label="Cupo">@item.CupoMaximo</td>
                                <td data-label="Cierre">@item.FechaCierre.ToString("dd/MM/yyyy")</td>
                                <td data-label="Estado">
                                    @if (item.EstaActivo)
                                    {
                                        <span class="ra-badge ra-badge-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-neutral">Inactivo</span>
                                    }
                                </td>
                                <td data-label="Acciones">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Editar @item.Titulo" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver detalles de @item.Titulo" title="Ver">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="m-0" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Desactivar @item.Titulo" title="Eliminar" onclick="return confirm('¿Desactivar este proyecto?')">
                                                <i class="bi bi-trash ra-text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-folder-x"></i>
                <p>No hay proyectos registrados.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaProyectos').DataTable({
                language: window.RaDataTablesEs,
                pageLength: 25
            });
        });
    </script>
}
