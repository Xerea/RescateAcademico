@model IEnumerable<RescateAcademico.Models.Proyecto>
@{
    ViewData["Title"] = "Gestión de Proyectos";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;"><i class="bi bi-folder"></i> Gestión de Proyectos</h2>
    <a asp-action="Create" class="btn btn-primary" style="background-color: #6c1d45; border-color: #6c1d45;">
        <i class="bi bi-plus-circle"></i> Nuevo Proyecto
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover" id="tablaProyectos">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Título</th>
                            <th>Tipo</th>
                            <th>Cupo</th>
                            <th>Fecha Cierre</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Titulo</strong>
                                    <br />
                                    <small class="text-muted">@item.Descripcion</small>
                                </td>
                                <td>@item.Tipo</td>
                                <td>@item.CupoMaximo</td>
                                <td>@item.FechaCierre.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.EstaActivo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Eliminar" onclick="return confirm('¿Desactivar este proyecto?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-folder-x fs-1 text-muted"></i>
                <p class="text-muted mt-3">No hay proyectos registrados.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaProyectos').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}