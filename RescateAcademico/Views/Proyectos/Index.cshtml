@model IEnumerable<RescateAcademico.Models.Proyecto>
@{
    ViewData["Title"] = "Gestión de Proyectos";
    Layout = "_Layout";
}

<div class="row mb-4 align-items-end">
    <div class="col">
        <h1 class="fw-bold h3 mb-1"><i class="bi bi-folder"></i> Gestión de Proyectos</h1>
        <p class="text-secondary small mb-0">Catálogo de proyectos académicos y de servicio social.</p>
    </div>
    <div class="col-auto">
        <a asp-action="Create" class="ra-btn ra-btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Proyecto
        </a>
    </div>
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (TempData["Success"] != null)
        {
            <div class="ra-alert ra-alert-success mb-3" role="alert">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>@TempData["Success"]</div>
            </div>
        }

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table" id="tablaProyectos">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Tipo</th>
                            <th>Cupo</th>
                            <th>Fecha Cierre</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Titulo</strong>
                                    <br />
                                    <span class="text-secondary small">@item.Descripcion</span>
                                </td>
                                <td>@item.Tipo</td>
                                <td>@item.CupoMaximo</td>
                                <td>@item.FechaCierre.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.EstaActivo)
                                    {
                                        <span class="ra-badge ra-badge-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-neutral">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="ra-btn ra-btn-sm ra-btn-outline" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="ra-btn ra-btn-sm ra-btn-outline" title="Ver">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="m-0" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="ra-btn ra-btn-sm ra-btn-outline" title="Eliminar" onclick="return confirm('¿Desactivar este proyecto?')">
                                                <i class="bi bi-trash ra-text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-folder-x"></i>
                <p>No hay proyectos registrados.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaProyectos').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 25
            });
        });
    </script>
}
