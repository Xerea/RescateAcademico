@model List<RescateAcademico.Models.Alumno>
@{
    ViewData["Title"] = "Reporte de Alumnos en Riesgo";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Reporte de Riesgo Académico - IPN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 20px; }
        .institutional-header {
            border-bottom: 3px solid #6A1B3D;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }
        .institutional-header h1 {
            color: #6A1B3D;
            font-size: 1.5rem;
            margin-bottom: 0;
        }
        .institutional-header h2 {
            color: #333;
            font-size: 1.1rem;
            margin-top: 5px;
        }
        .logo-placeholder {
            width: 80px;
            height: 80px;
            background: #6A1B3D;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 0.8rem;
            text-align: center;
            float: left;
            margin-right: 15px;
        }
        .summary-box {
            background: #f8f9fa;
            border-left: 4px solid #6A1B3D;
            padding: 15px;
            margin-bottom: 20px;
        }
        @@media print {
            .no-print { display: none; }
            body { padding: 0; }
        }
    </style>
</head>
<body>
    <div class="no-print mb-3">
        <button onclick="window.print()" class="btn btn-primary">Imprimir / Guardar como PDF</button>
        <a href="/Admin" class="btn btn-secondary">Volver al Dashboard</a>
    </div>

    <div class="institutional-header clearfix">
        <div class="logo-placeholder">IPN<br/>Logo</div>
        <h1>Instituto Politécnico Nacional</h1>
        <h2>Sistema de Monitoreo Académico - Rescate Académico</h2>
        <p class="mb-0 text-muted">Reporte de Alumnos en Riesgo Académico</p>
        <p class="mb-0 text-muted">Generado: @ViewBag.FechaReporte.ToString("yyyy-MM-dd HH:mm")</p>
    </div>

    <div class="summary-box">
        <div class="row">
            <div class="col-md-3"><strong>Total Alumnos:</strong> @ViewBag.TotalAlumnos</div>
            <div class="col-md-3"><strong>En Riesgo Rojo:</strong> <span class="text-danger">@ViewBag.EnRojo</span></div>
            <div class="col-md-3"><strong>En Riesgo Amarillo:</strong> <span class="text-warning">@ViewBag.EnAmarillo</span></div>
            <div class="col-md-3"><strong>% en Riesgo:</strong> @(((ViewBag.EnRojo + ViewBag.EnAmarillo) * 100.0 / Math.Max(ViewBag.TotalAlumnos, 1)).ToString("F1"))%</div>
        </div>
    </div>

    <table class="table table-bordered table-sm">
        <thead class="table-dark">
            <tr>
                <th>Boleta</th>
                <th>Nombre</th>
                <th>Carrera</th>
                <th>Semestre</th>
                <th>Promedio</th>
                <th>Riesgo</th>
                <th>Reprobadas</th>
                <th>Ausencias</th>
                <th>Parciales Bajos</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr class="@(a.RiesgoAcademico == "Rojo" ? "table-danger" : a.RiesgoAcademico == "Amarillo" ? "table-warning" : "")">
                    <td>@a.Matricula</td>
                    <td>@a.Nombre @a.Apellidos</td>
                    <td>@a.Carrera</td>
                    <td>@a.SemestreActual</td>
                    <td>@a.PromedioGlobal.ToString("F2")</td>
                    <td><strong>@a.RiesgoAcademico</strong></td>
                    <td>@(a.MateriasReprobadas ?? 0)</td>
                    <td>@(a.Ausencias ?? 0)</td>
                    <td>@(a.ParcialesBajos ?? 0)</td>
                </tr>
            }
        </tbody>
    </table>

    <footer class="mt-4 text-muted small">
        <p>Documento generado automáticamente por el Sistema Rescate Académico. Este reporte es confidencial y de uso institucional.</p>
    </footer>
</body>
</html>
