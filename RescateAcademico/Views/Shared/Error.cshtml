@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="row justify-content-center text-center" style="min-height: 60vh; align-items: center;">
    <div class="col-md-6">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px; background: var(--ra-danger-soft);">
            <i class="bi bi-exclamation-triangle-fill fs-2" style="color: var(--ra-danger);"></i>
        </div>
        <h1 class="fw-bold mb-2" style="font-size:1.75rem; letter-spacing:-0.02em;">Algo salió mal</h1>
        <p class="text-secondary">No pudimos procesar tu solicitud en este momento.</p>

        @if (Model.ShowRequestId)
        {
            <p class="text-secondary small ra-mono">
                ID de solicitud: <code>@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index" class="ra-btn ra-btn-primary mt-3">
            <i class="bi bi-house"></i> Volver al inicio
        </a>
    </div>
</div>
