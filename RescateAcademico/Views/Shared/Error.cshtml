@model ErrorViewModel
@{
    ViewData["Title"] = "Error del Sistema";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <i class="bi bi-exclamation-triangle-fill fs-1 text-danger mb-3"></i>
        <h1 class="text-danger">Ha ocurrido un error</h1>
        <p class="text-muted">Lo sentimos, no pudimos procesar tu solicitud en este momento.</p>

        @if (Model.ShowRequestId)
        {
            <p class="text-muted small">
                <strong>ID de solicitud:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary mt-3">
            <i class="bi bi-house"></i> Volver al inicio
        </a>
    </div>
</div>