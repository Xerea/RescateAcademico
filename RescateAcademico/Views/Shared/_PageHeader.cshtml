@*
    Shared page header for consistent title / subtitle / primary actions across all views.
    Usage:
        <partial name="_PageHeader" model="new RescateAcademico.ViewModels.PageHeader {
            Title = "Mis Grupos",
            Subtitle = "Bienvenido, Juan Pérez",
            Icon = "bi-person-workspace",
            IconVariant = "accent",     // accent | primary | muted
            BackUrl = Url.Action("Index"),
            BackLabel = "Mis Grupos"
        }" />

    Primary action buttons can be appended via the Actions HTML (ViewData) or composed
    inline by placing them in a wrapping <div class="ra-page-header-actions">...</div>
    after the partial.
*@
@model RescateAcademico.ViewModels.PageHeader
@{
    var iconColor = Model?.IconVariant switch
    {
        "primary" => "var(--ra-primary)",
        "muted"   => "var(--ra-text-muted)",
        _          => "var(--ra-accent)"
    };
}
@if (Model != null)
{
    <div class="ra-page-header mb-4">
        @if (!string.IsNullOrEmpty(Model.BackUrl))
        {
            <div class="ra-page-header-back">
                <a href="@Model.BackUrl" class="ra-btn ra-btn-sm ra-btn-ghost">
                    <i class="bi bi-arrow-left"></i> @(Model.BackLabel ?? "Volver")
                </a>
            </div>
        }
        <div class="ra-page-header-row">
            <div class="ra-page-header-text">
                <h1 class="ra-page-title">
                    @if (!string.IsNullOrEmpty(Model.Icon))
                    {
                        <i class="bi @Model.Icon" style="color:@iconColor"></i>
                    }
                    <span>@Model.Title</span>
                </h1>
                @if (!string.IsNullOrEmpty(Model.Subtitle))
                {
                    <p class="ra-page-subtitle">@Html.Raw(Model.Subtitle)</p>
                }
            </div>
            @if (Model.ActionsHtml != null)
            {
                <div class="ra-page-header-actions">
                    @Html.Raw(Model.ActionsHtml)
                </div>
            }
        </div>
    </div>
}
