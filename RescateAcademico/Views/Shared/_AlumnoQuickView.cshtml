@*
    Shared compact student radiography modal. Include once per page and open with:
        <button onclick="RaQuickView.open('@matricula')">...</button>
*@
<div class="modal fade" id="raQuickViewModal" tabindex="-1" aria-hidden="true" aria-labelledby="raQvTitle">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content ra-modal-content ra-qv-modal">
            <div class="modal-header border-0 pb-0">
                <div class="min-w-0">
                    <h5 class="modal-title fw-bold text-truncate" id="raQvTitle">
                        <i class="bi bi-person-badge me-2" style="color: var(--ra-primary);"></i>
                        <span>Cargando...</span>
                    </h5>
                    <div class="text-secondary small mt-1" data-qv="identityLine">Radiografía académica</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body">
                <div id="raQvLoading" class="text-center py-5">
                    <div class="spinner-border" role="status" style="color: var(--ra-primary);">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="text-secondary mt-3 mb-0">Cargando radiografía del estudiante...</p>
                </div>

                <div id="raQvError" class="ra-alert ra-alert-danger" style="display:none;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>No se pudo cargar la información. Intenta de nuevo.</div>
                </div>

                <div id="raQvContent" style="display:none;">
                    <section class="ra-qv-summary" aria-label="Resumen académico">
                        <div>
                            <span class="ra-student-eyebrow">Lectura rápida</span>
                            <h3 data-qv="diagnostico">Sin diagnóstico disponible</h3>
                            <p data-qv="nextStep">Revisa el perfil completo para más contexto.</p>
                            <div class="ra-qv-chip-row">
                                <span><i class="bi bi-upc-scan"></i> <strong data-qv="matricula">—</strong></span>
                                <span><i class="bi bi-people"></i> <strong data-qv="grupo">—</strong></span>
                                <span><i class="bi bi-mortarboard"></i> <strong data-qv="semestre">—</strong> semestre</span>
                            </div>
                        </div>
                        <div class="ra-qv-score-card">
                            <small>Promedio global</small>
                            <strong data-qv="promedio">—</strong>
                            <div data-qv="riesgo" aria-label="Riesgo académico">—</div>
                        </div>
                    </section>

                    <section class="ra-qv-metrics" aria-label="Señales académicas">
                        <div class="ra-qv-metric">
                            <span data-qv="reprobadas">0</span>
                            <small>Reprobadas</small>
                        </div>
                        <div class="ra-qv-metric">
                            <span data-qv="ausencias">0</span>
                            <small>Ausencias</small>
                        </div>
                        <div class="ra-qv-metric">
                            <span data-qv="ets">0</span>
                            <small>ETS</small>
                        </div>
                        <div class="ra-qv-metric">
                            <span data-qv="recursadas">0</span>
                            <small>Recursadas</small>
                        </div>
                        <div class="ra-qv-metric">
                            <span data-qv="carga">—</span>
                            <small>Carga</small>
                        </div>
                    </section>

                    <section class="ra-qv-detail-grid" aria-label="Contexto">
                        <div class="ra-qv-panel">
                            <small>Trayectoria</small>
                            <strong data-qv="carrera">—</strong>
                            <span>Actualizado: <span data-qv="actualizacion">—</span></span>
                        </div>
                        <div class="ra-qv-panel">
                            <div class="d-flex justify-content-between gap-2 align-items-start">
                                <div>
                                    <small>COSECOVI</small>
                                    <strong data-qv="cosecoviResumen">Sin reportes disciplinarios</strong>
                                    <span data-qv="cosecoviDetalle"></span>
                                </div>
                                <span class="ra-badge ra-badge-neutral" data-qv="cosecoviBadge">0</span>
                            </div>
                        </div>
                    </section>
                </div>
            </div>

            <div class="modal-footer border-0 pt-0 ra-qv-actions">
                <a data-qv-link="profile" href="#" class="ra-btn ra-btn-primary ra-btn-sm" style="display:none;">
                    <i class="bi bi-graph-up"></i> <span data-qv-label="profile">Ver perfil</span>
                </a>
                <a data-qv-link="detalle" href="#" class="ra-btn ra-btn-outline ra-btn-sm" style="display:none;">
                    <i class="bi bi-eye"></i> Detalle
                </a>
                <a data-qv-link="timeline" href="#" class="ra-btn ra-btn-outline ra-btn-sm" style="display:none;">
                    <i class="bi bi-clock-history"></i> Línea de tiempo
                </a>
                <a data-qv-link="intervencion" href="#" class="ra-btn ra-btn-accent ra-btn-sm" style="display:none;">
                    <i class="bi bi-plus-circle"></i> Intervención
                </a>
                <a data-qv-link="plan" href="#" class="ra-btn ra-btn-outline ra-btn-sm" style="display:none;">
                    <i class="bi bi-journal-plus"></i> Crear plan
                </a>
                <a data-qv-link="cosecovi" href="#" class="ra-btn ra-btn-outline ra-btn-sm" style="display:none;">
                    <i class="bi bi-shield-exclamation"></i> COSECOVI
                </a>
                <button type="button" class="ra-btn ra-btn-ghost ra-btn-sm" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
