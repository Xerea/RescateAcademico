@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center gap-1">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item dropdown">
        <a class="nav-link position-relative px-2" href="#" role="button" data-bs-toggle="dropdown" title="Notificaciones" aria-label="Notificaciones">
            <i class="bi bi-bell fs-5"></i>
            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-2 rounded-circle" style="display: none; border-color: var(--ra-surface) !important;" id="notifBadge">
                <span class="visually-hidden">Notificaciones nuevas</span>
            </span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" asp-controller="Notificaciones" asp-action="Index"><i class="bi bi-bell"></i> Ver Notificaciones</a></li>
        </ul>
    </li>

    <li class="nav-item dropdown ms-1">
        <a class="nav-link d-flex align-items-center gap-2 ps-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <div class="ra-avatar">
                <i class="bi bi-person-fill"></i>
            </div>
            <span class="d-none d-lg-inline fw-medium">@User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
            <li><span class="dropdown-item-text text-secondary small">@User.Identity?.Name</span></li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="dropdown-item text-danger">
                        <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="ra-btn ra-btn-primary ra-btn-sm" asp-controller="Account" asp-action="Login">
            <i class="bi bi-box-arrow-in-right"></i> Acceder
        </a>
    </li>
}
</ul>
