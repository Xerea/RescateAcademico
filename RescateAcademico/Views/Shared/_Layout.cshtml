<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rescate Académico</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm ra-navbar">
            <div class="container-fluid px-4 px-lg-5">
                <a class="navbar-brand ra-navbar-brand" asp-area="" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-mortarboard-fill"></i>
                    <span>Rescate Académico</span>
                </a>
                <button class="navbar-toggler ra-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav flex-grow-1">
                        @{
                            var cc = ViewContext.RouteData.Values["controller"]?.ToString();
                            var ca = ViewContext.RouteData.Values["action"]?.ToString();
                            bool isDash = cc == "Dashboard" && ca == "Index";
                        }

                        @* ALL authenticated users see Dashboard *@
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(isDash ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-grid-1x2"></i> Panel
                                </a>
                            </li>
                        }

                        @* Alumno: only Convocatorias in nav *@
                        @if (User.IsInRole("Alumno"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(cc == "Convocatorias" ? "active" : "")" asp-controller="Convocatorias" asp-action="Index">
                                    <i class="bi bi-megaphone"></i> Convocatorias
                                </a>
                            </li>
                        }

                        @* Tutor: no extra nav items — everything is in Panel *@

                        @* Autoridad: Alumnos + Reportes *@
                        @if (User.IsInRole("Autoridad"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(cc == "Alumnos" ? "active" : "")" asp-controller="Alumnos" asp-action="Index">
                                    <i class="bi bi-people"></i> Alumnos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(cc == "Reportes" ? "active" : "")" asp-controller="Reportes" asp-action="Index">
                                    <i class="bi bi-bar-chart-line"></i> Reportes
                                </a>
                            </li>
                        }

                        @* Admin: Gestión + Reportes *@
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(cc == "Admin" && ca != "Index" ? "active" : "")" asp-controller="Admin" asp-action="Gestion">
                                    <i class="bi bi-sliders"></i> Gestión
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(cc == "Reportes" ? "active" : "")" asp-controller="Reportes" asp-action="Index">
                                    <i class="bi bi-bar-chart-line"></i> Reportes
                                </a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <button type="button" class="ra-theme-toggle" id="themeToggle" title="Cambiar tema" aria-label="Cambiar tema">
                            <i class="bi bi-sun-fill" id="themeIcon"></i>
                        </button>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-4">
        <div class="container-fluid px-4 px-lg-5">
            @{
                var isHome = cc == "Home" && ca == "Index";
                var isPanel = cc == "Dashboard" && ca == "Index";
            }
            @if (!isHome && !isPanel)
            {
                <nav aria-label="breadcrumb" class="ra-breadcrumb mt-3">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index"><i class="bi bi-grid-1x2"></i> Panel</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                    </ol>
                </nav>
            }
            <div class="ra-fade-in">
                @RenderBody()
            </div>
        </div>
    </main>

    <footer class="ra-footer">
        <div class="container-fluid px-4 px-lg-5 d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>Rescate Académico IPN — CECyT No. 13</span>
            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Política de Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
