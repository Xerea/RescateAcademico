@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var routeController = ViewContext.RouteData.Values["controller"]?.ToString();
    var routeAction = ViewContext.RouteData.Values["action"]?.ToString();
    bool isTutor = User.IsInRole("Tutor");
    bool isAlumno = User.IsInRole("Alumno");
    bool isAutoridad = User.IsInRole("Autoridad");
    bool isAdmin = User.IsInRole("Administrador");
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
    var antiforgeryToken = isAuthenticated ? Antiforgery.GetAndStoreTokens(Context).RequestToken : null;

    // Home ("brand click") routes to the role's main entry
    string homeController = isTutor ? "Profesor" : "Dashboard";

    // Pages with their own bespoke hero skip the breadcrumb
    bool suppressBreadcrumb = (routeController == "Home" && routeAction == "Index")
        || (routeController == "Dashboard" && routeAction == "Index")
        || (routeController == "Profesor" && routeAction == "Index")
        || (routeController == "Account");

    // Allow a view to override the breadcrumb trail.
    // Trail format: list of tuples "Label|url" (empty url for non-link crumb).
    var breadcrumbTrail = ViewData["BreadcrumbTrail"] as List<(string Label, string Url)>;
}
<!DOCTYPE html>
<html lang="es" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @if (!string.IsNullOrEmpty(antiforgeryToken))
    {
        <meta name="request-verification-token" content="@antiforgeryToken" />
    }
    <title>@ViewData["Title"] · Rescate Académico</title>
    <script>
        (function () {
            var theme = null;
            try { theme = localStorage.getItem('ra-theme'); } catch (e) { }
            if (!theme) {
                theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600;6..72,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
</head>
<body>
    <a href="#mainContent" class="visually-hidden-focusable ra-btn ra-btn-primary ra-btn-sm" style="position:fixed;top:0.5rem;left:0.5rem;z-index:2100;">Saltar al contenido</a>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm ra-navbar">
            <div class="container-fluid px-4 px-lg-5">
                <a class="navbar-brand ra-navbar-brand" asp-area="" asp-controller="@homeController" asp-action="Index">
                    <i class="bi bi-mortarboard-fill"></i>
                    <span>Rescate Académico</span>
                </a>
                <button class="navbar-toggler ra-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Abrir menú">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav flex-grow-1">
                        @{
                            bool isActiveDashboard = routeController == "Dashboard" && routeAction == "Index";
                        }

                        @* Alumno · Mi Perfil · Convocatorias *@
                        @if (isAlumno)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(routeController == "PerfilAcademico" ? "active" : "")" asp-controller="PerfilAcademico" asp-action="MiPerfil">
                                    <i class="bi bi-person-badge"></i> Mi Perfil
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(routeController == "Convocatorias" || routeController == "Postulaciones" ? "active" : "")" asp-controller="Convocatorias" asp-action="Index">
                                    <i class="bi bi-megaphone"></i> Convocatorias
                                </a>
                            </li>
                        }

                        @* Tutor navigation is intentionally hub-first: brand + breadcrumbs return to Mis Grupos. *@

                        @* Autoridad · Panel · Alumnos · Reportes *@
                        @if (isAutoridad)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(isActiveDashboard ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-grid-1x2"></i> Panel
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(routeController == "Alumnos" ? "active" : "")" asp-controller="Alumnos" asp-action="Index">
                                    <i class="bi bi-people"></i> Alumnos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(routeController == "Cosecovi" ? "active" : "")" asp-controller="Cosecovi" asp-action="Dashboard">
                                    <i class="bi bi-heart-pulse"></i> COSECOVI
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(routeController == "Reportes" || routeController == "Estadisticas" || routeController == "Predicciones" ? "active" : "")" asp-controller="Reportes" asp-action="Index">
                                    <i class="bi bi-bar-chart-line"></i> Reportes
                                </a>
                            </li>
                        }

                        @* Admin · Panel · Gestión · Reportes *@
                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(isActiveDashboard ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-grid-1x2"></i> Panel
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(routeController == "Admin" || routeController == "Proyectos" || routeController == "Convocatorias" || routeController == "Bitacora" ? "active" : "")" asp-controller="Admin" asp-action="Gestion">
                                    <i class="bi bi-sliders"></i> Gestión
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(routeController == "Cosecovi" ? "active" : "")" asp-controller="Cosecovi" asp-action="Dashboard">
                                    <i class="bi bi-heart-pulse"></i> COSECOVI
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(routeController == "Reportes" || routeController == "Estadisticas" || routeController == "Predicciones" ? "active" : "")" asp-controller="Reportes" asp-action="Index">
                                    <i class="bi bi-bar-chart-line"></i> Reportes
                                </a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        @if (isAuthenticated && (isAdmin || isAutoridad || isTutor))
                        {
                            <button type="button" id="raSearchTrigger" class="ra-search-trigger" aria-label="Buscar">
                                <i class="bi bi-search"></i>
                                <span>Buscar alumnos, secciones…</span>
                                <kbd>Ctrl K</kbd>
                            </button>
                        }
                        <button type="button" class="ra-theme-toggle" id="themeToggle" title="Cambiar tema" aria-label="Cambiar tema">
                            <i class="bi bi-sun-fill" id="themeIcon"></i>
                        </button>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main id="mainContent" role="main" class="pb-4">
        <div class="container-fluid px-4 px-lg-5">
            @if (!suppressBreadcrumb)
            {
                <nav aria-label="breadcrumb" class="ra-breadcrumb mt-3">
                    <ol class="breadcrumb mb-0">
                        @if (breadcrumbTrail != null && breadcrumbTrail.Count > 0)
                        {
                            for (int i = 0; i < breadcrumbTrail.Count; i++)
                            {
                                var crumb = breadcrumbTrail[i];
                                var isLast = i == breadcrumbTrail.Count - 1;
                                if (isLast || string.IsNullOrEmpty(crumb.Url))
                                {
                                    <li class="breadcrumb-item active" aria-current="page">@crumb.Label</li>
                                }
                                else
                                {
                                    <li class="breadcrumb-item"><a href="@crumb.Url">@crumb.Label</a></li>
                                }
                            }
                        }
                        else
                        {
                            @if (isTutor)
                            {
                                <li class="breadcrumb-item"><a asp-controller="Profesor" asp-action="Index"><i class="bi bi-person-workspace"></i> Mis Grupos</a></li>
                            }
                            else
                            {
                                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index"><i class="bi bi-grid-1x2"></i> Inicio</a></li>
                            }
                            <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                        }
                    </ol>
                </nav>
            }
            <div class="ra-page-content">
                @RenderBody()
            </div>
        </div>
    </main>

    <footer class="ra-footer">
        <div class="container-fluid px-4 px-lg-5 d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>Rescate Académico IPN — CECyT No. 13</span>
            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Política de Privacidad</a>
        </div>
    </footer>

    <!-- Toast container -->
    <div id="raToastContainer" class="position-fixed top-0 end-0 p-3" style="z-index: 9999;"></div>

    @if (isAuthenticated)
    {
        <!-- Lightweight notification center -->
        <div class="ra-notif-scrim" id="raNotifScrim" hidden></div>
        <aside class="ra-notif-panel" id="raNotifPanel" aria-label="Centro de notificaciones" aria-hidden="true">
            <div class="ra-notif-header">
                <div>
                    <div class="ra-heading mb-1">Notificaciones</div>
                    <p class="text-secondary small mb-0">Avisos recientes del sistema.</p>
                </div>
                <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" id="raNotifClose" aria-label="Cerrar notificaciones">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="ra-notif-actions">
                <button type="button" class="ra-btn ra-btn-sm ra-btn-outline" id="raNotifEnableBrowser">
                    <i class="bi bi-phone-vibrate"></i> Activar avisos
                </button>
                <button type="button" class="ra-btn ra-btn-sm ra-btn-ghost" id="raNotifMarkAll">
                    <i class="bi bi-check2-all"></i> Marcar leídas
                </button>
            </div>
            <div class="ra-notif-list" id="raNotifList">
                <div class="ra-notif-loading">Cargando notificaciones...</div>
            </div>
            <div class="ra-notif-empty" id="raNotifEmpty" hidden>
                <i class="bi bi-bell"></i>
                <p>No tienes notificaciones recientes.</p>
            </div>
            <a asp-controller="Notificaciones" asp-action="Index" class="ra-notif-fallback">
                Ver historial completo
            </a>
        </aside>
    }

    @if (isAuthenticated && (isAdmin || isAutoridad || isTutor))
    {
        <!-- Global search overlay -->
        <div class="ra-search-backdrop" id="raSearchBackdrop" role="dialog" aria-label="Búsqueda rápida">
            <div class="ra-search-panel">
                <div class="ra-search-input-row">
                    <i class="bi bi-search"></i>
                    <input type="text" class="ra-search-input" placeholder="Buscar alumnos, secciones…" autocomplete="off" spellcheck="false" />
                    <span class="ra-kbd-hint">ESC</span>
                </div>
                <div class="ra-search-results"></div>
                <div class="ra-search-footer">
                    <span><kbd>↑</kbd> <kbd>↓</kbd> navegar</span>
                    <span><kbd>↵</kbd> abrir</span>
                    <span><kbd>ESC</kbd> cerrar</span>
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/countup.js/2.8.0/countUp.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/ra-hero-shader.js" asp-append-version="true"></script>
    @if (isAuthenticated && (isAdmin || isAutoridad || isTutor))
    {
        <script>
            // Register static nav items in the global search
            (function () {
                if (!window.RaSearch) return;
                var items = [
                    @if (isAdmin || isAutoridad)
                    {
                        <text>
                        { label: 'Panel', icon: 'bi-grid-1x2', url: '@Url.Action("Index", "Dashboard")' , group: 'Navegación' },
                        { label: 'Alumnos', icon: 'bi-people', url: '@Url.Action("Index", "Alumnos")', group: 'Navegación' },
                        { label: 'Reportes', icon: 'bi-bar-chart-line', url: '@Url.Action("Index", "Reportes")', group: 'Navegación' },
                        { label: 'Estadísticas', icon: 'bi-pie-chart', url: '@Url.Action("Index", "Estadisticas")', group: 'Navegación' },
                        { label: 'Predicciones', icon: 'bi-brain', url: '@Url.Action("Index", "Predicciones")', group: 'Navegación' },
                        { label: 'COSECOVI', icon: 'bi-heart-pulse', url: '@Url.Action("Dashboard", "Cosecovi")', group: 'Navegación' },
                        { label: 'Reportes COSECOVI', icon: 'bi-clipboard2-pulse', url: '@Url.Action("Index", "Cosecovi")', group: 'Navegación' },
                        </text>
                    }
                    @if (isAdmin)
                    {
                        <text>
                        { label: 'Gestión', icon: 'bi-sliders', url: '@Url.Action("Gestion", "Admin")', group: 'Navegación' },
                        { label: 'Usuarios', icon: 'bi-shield-lock', url: '@Url.Action("Usuarios", "Admin")', group: 'Admin' },
                        { label: 'Carreras', icon: 'bi-mortarboard', url: '@Url.Action("Carreras", "Admin")', group: 'Admin' },
                        { label: 'Ciclos escolares', icon: 'bi-calendar-event', url: '@Url.Action("CiclosEscolares", "Admin")', group: 'Admin' },
                        { label: 'Bitácora', icon: 'bi-clock-history', url: '@Url.Action("Index", "Bitacora")', group: 'Admin' },
                        { label: 'Integridad de datos', icon: 'bi-shield-check', url: '@Url.Action("IntegridadDatos", "Admin")', group: 'Admin' },
                        { label: 'Proyectos', icon: 'bi-folder', url: '@Url.Action("Index", "Proyectos")', group: 'Admin' },
                        { label: 'Convocatorias (todas)', icon: 'bi-megaphone', url: '@Url.Action("Todas", "Convocatorias")', group: 'Admin' },
                        </text>
                    }
                    @if (isTutor)
                    {
                        <text>
                        { label: 'Mis Grupos', icon: 'bi-person-workspace', url: '@Url.Action("Index", "Profesor")', group: 'Navegación' },
                        { label: 'Intervenciones', icon: 'bi-clipboard-pulse', url: '@Url.Action("Index", "Intervenciones")', group: 'Navegación' },
                        { label: 'Planes de mejora', icon: 'bi-journal-check', url: '@Url.Action("Index", "PlanesMejora")', group: 'Navegación' },
                        { label: 'Predicciones', icon: 'bi-brain', url: '@Url.Action("Index", "Predicciones")', group: 'Navegación' },
                        { label: 'Materias reprobadas', icon: 'bi-x-circle', url: '@Url.Action("MateriasReprobadas", "Profesor")', group: 'Navegación' },
                        </text>
                    }
                    { label: 'Notificaciones', icon: 'bi-bell', url: '@Url.Action("Index", "Notificaciones")', group: 'Cuenta' },
                    { label: 'Cambiar contraseña', icon: 'bi-shield-lock', url: '@Url.Action("CambiarContrasena", "Account")', group: 'Cuenta' }
                ];
                RaSearch.register(items);
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
