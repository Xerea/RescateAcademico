<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rescate Académico IPN</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" /
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RescateAcademico.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3" style="border-left: 4px solid #6c1d45 !important;">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index" style="color: #6c1d45;">
                    <i class="bi bi-mortarboard-fill"></i> Rescate Académico
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house"></i> Inicio
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Dashboard" asp-action="Index" style="color: #6c1d45;">
                                    <i class="bi bi-grid-1x2"></i> Dashboard
                                </a>
                            </li>
                            
                            @if (User.IsInRole("Alumno"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="PerfilAcademico" asp-action="MiPerfil">
                                        <i class="bi bi-person-badge"></i> Mi Perfil
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Convocatorias" asp-action="Index">
                                        <i class="bi bi-megaphone"></i> Convocatorias
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Postulaciones" asp-action="MisPostulaciones">
                                        <i class="bi bi-send-check"></i> Mis Postulaciones
                                    </a>
                                </li>
                            }
                            
                            @if (User.IsInRole("Tutor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-bold" asp-controller="Profesor" asp-action="Index">
                                        <i class="bi bi-person-workspace"></i> Panel Profesor
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Profesor" asp-action="MisEstudiantes">
                                        <i class="bi bi-people"></i> Mis Estudiantes
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Intervenciones" asp-action="Index">
                                        <i class="bi bi-clipboard-pulse"></i> Intervenciones
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="PlanesMejora" asp-action="Index">
                                        <i class="bi bi-journal-check"></i> Planes de Mejora
                                    </a>
                                </li>
                            }
                            
                            @if (User.IsInRole("Autoridad"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Estadisticas" asp-action="Index">
                                        <i class="bi bi-bar-chart-line"></i> Estadísticas
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Postulaciones" asp-action="Todas">
                                        <i class="bi bi-clipboard-check"></i> Postulaciones
                                    </a>
                                </li>
                            }
                            
                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-gear"></i> Administración
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2"></i> Panel Admin</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Usuarios"><i class="bi bi-people"></i> Usuarios</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="CrearCuenta"><i class="bi bi-person-plus"></i> Crear Cuenta</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Alumnos"><i class="bi bi-student"></i> Alumnos</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Tutores"><i class="bi bi-person-badge"></i> Profesores</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="EvaluarRiesgos"><i class="bi bi-exclamation-triangle"></i> Evaluar Riesgos</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Proyectos" asp-action="Index"><i class="bi bi-folder"></i> Proyectos</a></li>
                                        <li><a class="dropdown-item" asp-controller="Convocatorias" asp-action="Todas"><i class="bi bi-megaphone"></i> Convocatorias</a></li>
                                        <li><a class="dropdown-item" asp-controller="PlanesMejora" asp-action="Index"><i class="bi bi-journal-check"></i> Planes de Mejora</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Export" asp-action="ReporteImprimible" target="_blank"><i class="bi bi-printer"></i> Reporte en Riesgo (PDF)</a></li>
                                        <li><a class="dropdown-item" asp-controller="Export" asp-action="AlumnosCSV"><i class="bi bi-file-earmark-excel"></i> Exportar Alumnos (CSV)</a></li>
                                        <li><a class="dropdown-item" asp-controller="Predicciones" asp-action="Index"><i class="bi bi-brain"></i> Predicción ML.NET</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="CiclosEscolares"><i class="bi bi-calendar"></i> Ciclos</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Carreras"><i class="bi bi-mortarboard"></i> Carreras</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Bitacora" asp-action="Index"><i class="bi bi-clock-history"></i> Bitácora</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="IntegridadDatos"><i class="bi bi-shield-check"></i> Integridad de Datos</a></li>
                                    </ul>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Estadisticas" asp-action="Index">
                                        <i class="bi bi-bar-chart"></i> Estadísticas
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container d-flex justify-content-between align-items-center">
            <span>&copy; 2026 - Rescate Académico IPN - CECyT No. 13</span>
            <a asp-controller="Home" asp-action="Privacy">Política de Privacidad</a>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
