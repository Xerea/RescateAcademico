@model IEnumerable<RescateAcademico.Models.IntervencionTutoria>
@{
    ViewData["Title"] = "Intervenciones por Alumno";
    Layout = "_Layout";
    var alumno = ViewBag.Alumno as RescateAcademico.Models.Alumno;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="ra-text-accent">
        <i class="bi bi-clipboard-pulse"></i> Intervenciones: @alumno?.Nombre @alumno?.Apellidos
    </h2>
    @if (!User.IsInRole("Autoridad"))
    {
        <a asp-action="Crear" asp-route-matricula="@alumno?.Matricula" class="ra-btn ra-btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Intervención
        </a>
    }
</div>

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Descripción</th>
                            <th>Resultado</th>
                            <th>Seguimiento</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="ra-badge ra-badge-info">@item.Tipo</span></td>
                                <td>@item.Descripcion</td>
                                <td>@item.Resultado</td>
                                <td>
                                    @if (item.RequiereSeguimiento)
                                    {
                                        <span class="ra-badge ra-badge-warning">Pendiente</span>
                                    }
                                    else if (item.FechaSeguimiento.HasValue)
                                    {
                                        <span class="ra-badge ra-badge-success">Completado @item.FechaSeguimiento.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-secondary">No requiere</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-clipboard-x"></i>
                <p>No hay intervenciones registradas para este alumno.</p>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Alumnos" asp-action="MisTutorados" class="ra-btn ra-btn-ghost">
        <i class="bi bi-arrow-left"></i> Volver a Estudiantes
    </a>
</div>
