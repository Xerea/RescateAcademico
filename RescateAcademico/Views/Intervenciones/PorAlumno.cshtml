@model IEnumerable<RescateAcademico.Models.IntervencionTutoria>
@{
    ViewData["Title"] = "Intervenciones por Alumno";
    Layout = "_Layout";
    var alumno = ViewBag.Alumno as RescateAcademico.Models.Alumno;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;">
        <i class="bi bi-clipboard-pulse"></i> Intervenciones: @alumno?.Nombre @alumno?.Apellidos
    </h2>
    @if (!User.IsInRole("Autoridad"))
    {
        <a asp-action="Crear" asp-route-matricula="@alumno?.Matricula" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nueva Intervención
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Descripción</th>
                            <th>Resultado</th>
                            <th>Seguimiento</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge bg-info">@item.Tipo</span></td>
                                <td>@item.Descripcion</td>
                                <td>@item.Resultado</td>
                                <td>
                                    @if (item.RequiereSeguimiento)
                                    {
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                    }
                                    else if (item.FechaSeguimiento.HasValue)
                                    {
                                        <span class="badge bg-success">Completado @item.FechaSeguimiento.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No requiere</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-clipboard-x fs-1 text-muted"></i>
                <p class="text-muted mt-3">No hay intervenciones registradas para este alumno.</p>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Alumnos" asp-action="MisTutorados" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver a Estudiantes
    </a>
</div>
