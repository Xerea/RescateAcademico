@model RescateAcademico.Models.IntervencionTutoria
@{
    ViewData["Title"] = "Nueva Intervención";
    Layout = "_Layout";
    var alumno = ViewBag.Alumno as RescateAcademico.Models.Alumno;
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="ra-card">
            <div class="ra-card-header">
                <i class="bi bi-plus-circle"></i> Nueva Intervención: @alumno?.Nombre @alumno?.Apellidos
            </div>
            <div class="ra-card-body">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="AlumnoMatricula" value="@ViewBag.Matricula" />

                    <div class="mb-3">
                        <label class="ra-label">Tipo de Intervención *</label>
                        <select asp-for="Tipo" class="ra-select" required>
                            <option value="Acercamiento">Acercamiento</option>
                            <option value="Tutoria">Profesoría</option>
                            <option value="Canalizacion">Canalización</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="ra-label">Descripción *</label>
                        <textarea asp-for="Descripcion" class="ra-input" rows="4" placeholder="Describe la intervención realizada..." required></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="ra-label">Resultado / Observaciones</label>
                        <textarea asp-for="Resultado" class="ra-input" rows="3" placeholder="Resultados obtenidos..."></textarea>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="RequiereSeguimiento" class="form-check-input" />
                        <label class="form-check-label" style="color: var(--ra-text-secondary);">Requiere seguimiento</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary flex-fill">
                            <i class="bi bi-save"></i> Guardar Intervención
                        </button>
                        <a asp-action="PorAlumno" asp-route-matricula="@ViewBag.Matricula" class="ra-btn ra-btn-ghost">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
