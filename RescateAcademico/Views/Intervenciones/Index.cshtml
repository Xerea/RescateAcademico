@model IEnumerable<RescateAcademico.Models.IntervencionTutoria>
@{
    ViewData["Title"] = "Intervenciones";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #6c1d45;"><i class="bi bi-clipboard-pulse"></i> Intervenciones</h2>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead style="background-color: #6c1d45; color: white;">
                        <tr>
                            <th>Fecha</th>
                            <th>Alumno</th>
                            <th>Tipo</th>
                            <th>Descripción</th>
                            <th>Seguimiento</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td>@item.Alumno?.Nombre @item.Alumno?.Apellidos</td>
                                <td><span class="badge bg-info">@item.Tipo</span></td>
                                <td>@item.Descripcion</td>
                                <td>
                                    @if (item.RequiereSeguimiento)
                                    {
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                    }
                                    else if (item.FechaSeguimiento.HasValue)
                                    {
                                        <span class="badge bg-success">Completado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No requiere</span>
                                    }
                                </td>
                                <td>
                                    @if (item.RequiereSeguimiento && !User.IsInRole("Autoridad"))
                                    {
                                        <a asp-action="Seguimiento" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-check"></i> Seguimiento
                                        </a>
                                    }
                                    <a asp-action="PorAlumno" asp-route-matricula="@item.AlumnoMatricula" class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-eye"></i> Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-clipboard-x fs-1 text-muted"></i>
                <p class="text-muted mt-3">No has registrado intervenciones aún.</p>
            </div>
        }
    </div>
</div>
