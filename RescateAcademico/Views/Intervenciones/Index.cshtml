@model IEnumerable<RescateAcademico.Models.IntervencionTutoria>
@{
    ViewData["Title"] = "Intervenciones";
    Layout = "_Layout";
    var header = new PageHeader
    {
        Title = "Intervenciones",
        Subtitle = "Registro de intervenciones y seguimientos.",
        Icon = "bi-clipboard-pulse",
        IconVariant = "accent"
    };
}

<partial name="_PageHeader" model="header" />

<div class="ra-card">
    <div class="ra-card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table ra-table ra-table-cards" id="tablaIntervenciones">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Alumno</th>
                            <th>Tipo</th>
                            <th>Descripción</th>
                            <th>Seguimiento</th>
                            <th data-orderable="false">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="Fecha">@item.Fecha.ToString("dd/MM/yyyy")</td>
                                <td data-label="Alumno">@item.Alumno?.Nombre @item.Alumno?.Apellidos</td>
                                <td data-label="Tipo"><span class="ra-badge ra-badge-info">@item.Tipo</span></td>
                                <td data-label="Descripción">@item.Descripcion</td>
                                <td data-label="Seguimiento">
                                    @if (item.RequiereSeguimiento)
                                    {
                                        <span class="ra-badge ra-badge-warning">Pendiente</span>
                                    }
                                    else if (item.FechaSeguimiento.HasValue)
                                    {
                                        <span class="ra-badge ra-badge-success">Completado</span>
                                    }
                                    else
                                    {
                                        <span class="ra-badge ra-badge-neutral">No requiere</span>
                                    }
                                </td>
                                <td data-label="Acciones">
                                    <div class="d-flex gap-1 justify-content-end">
                                        @if (item.RequiereSeguimiento && !User.IsInRole("Autoridad"))
                                        {
                                            <a asp-action="Seguimiento" asp-route-id="@item.Id" class="ra-btn ra-btn-sm ra-btn-primary" aria-label="Registrar seguimiento" title="Seguimiento">
                                                <i class="bi bi-check"></i>
                                            </a>
                                        }
                                        <a asp-action="PorAlumno" asp-route-matricula="@item.AlumnoMatricula" class="ra-btn ra-btn-sm ra-btn-outline" aria-label="Ver intervenciones del alumno" title="Ver">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="ra-empty">
                <i class="bi bi-clipboard-x"></i>
                <p>No has registrado intervenciones aún.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaIntervenciones').DataTable({
                language: window.RaDataTablesEs,
                pageLength: 25
            });
        });
    </script>
}
