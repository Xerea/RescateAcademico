@model RescateAcademico.Models.IntervencionTutoria
@{
    ViewData["Title"] = "Seguimiento de Intervención";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-8 col-lg-6 mx-auto">
        <div class="ra-card">
            <div class="ra-card-header">
                <h5 class="mb-0"><i class="bi bi-check-circle"></i> Registrar Seguimiento</h5>
            </div>
            <div class="ra-card-body">
                <div class="mb-3">
                    <label class="ra-label fw-bold">Intervención original:</label>
                    <p>@Model.Descripcion</p>
                </div>

                <form asp-action="Seguimiento" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="ra-label">Fecha de Seguimiento *</label>
                        <input type="date" name="fechaSeguimiento" class="ra-input" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="mb-3">
                        <label class="ra-label">Notas de Seguimiento *</label>
                        <textarea name="notas" class="ra-input" rows="4" placeholder="Describe el resultado del seguimiento..." required></textarea>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="ra-btn ra-btn-primary">
                            <i class="bi bi-save"></i> Guardar Seguimiento
                        </button>
                        <a asp-action="Index" class="ra-btn ra-btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
